<%
  const size = (typeof locals?.size === 'string' ? locals.size : 'header');
  const classes =
    size === 'login'
      ? 'h-16 w-auto sm:h-20'
      : 'h-7 w-auto sm:h-9';
%>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 920 260" role="img" aria-label="CredFácil logo" class="<%= classes %> select-none">
  <!-- No background: header/login already have their own background -->
  <g transform="translate(60,50)">
    <rect x="0" y="0" width="160" height="160" rx="28" fill="none" stroke="#FFFFFF" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M110 52 C95 40, 72 40, 56 56 C40 72, 40 95, 56 110 C72 126, 95 126, 110 114"
          stroke="#FFFFFF" fill="none" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M78 44 L78 120" stroke="#C9A227" fill="none" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M78 54 L120 54" stroke="#C9A227" fill="none" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M78 84 L112 84" stroke="#C9A227" fill="none" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M112 84 L126 70" stroke="#C9A227" fill="none" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/>
  </g>

  <g transform="translate(260,105)">
    <text x="0" y="0" font-size="56" fill="#FFFFFF"
          font-family="Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, &quot;Helvetica Neue&quot;, sans-serif"
          font-weight="600" letter-spacing="0.5px">Cred</text>
    <text x="140" y="0" font-size="56" fill="#C9A227"
          font-family="Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, &quot;Helvetica Neue&quot;, sans-serif"
          font-weight="600" letter-spacing="0.5px">Fácil</text>
  </g>
</svg>
