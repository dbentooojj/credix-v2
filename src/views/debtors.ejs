    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            document.getElementById('userName').textContent = currentUser.name || currentUser.full_name || 'Administrador';
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const sidebarLinks = document.querySelectorAll('#sidebar .sidebar-item');
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');

        const tableCache = {};
        function getDemoTable(tableName) {
            return Array.isArray(tableCache[tableName]) ? tableCache[tableName] : [];
        }

        async function fetchTableData(tableName) {
            try {
                const response = await fetch(`/api/tables/${tableName}`, { credentials: 'include' });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const payload = await response.json();
                if (Array.isArray(payload?.data)) {
                    tableCache[tableName] = payload.data;
                    return payload.data;
                }
            } catch (error) {
                console.warn(`Fallback para dados demo: ${tableName}`, error);
            }
            return getDemoTable(tableName);
        }

        function saveTableData(tableName, rows) {
            const safeRows = Array.isArray(rows) ? rows : [];
            tableCache[tableName] = safeRows;

            fetch(`/api/tables/${tableName}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ rows: safeRows })
            }).catch(error => {
                console.error(`Erro ao salvar tabela ${tableName}:`, error);
            });
        }

        function getNextTableId(tableName, fallbackStart) {
            const table = getDemoTable(tableName);
            const maxId = table.reduce((max, row) => {
                const parsed = Number(row?.id);
                if (!Number.isFinite(parsed)) return max;
                return parsed > max ? parsed : max;
            }, Number(fallbackStart || 1) - 1);
            return maxId + 1;
        }

        function setActiveSidebarItem(targetHref) {
            sidebarLinks.forEach(link => {
                const isActive = link.getAttribute('href') === targetHref;
                link.classList.toggle('active', isActive);
                if (isActive) link.setAttribute('aria-current', 'page');
                else link.removeAttribute('aria-current');
            });
        }

        function syncActiveSidebarWithRoute() {
            const currentPage = window.location.pathname.split('/').pop() || 'debtors.html';
            setActiveSidebarItem(currentPage);
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                return;
            }
            sidebar.classList.remove('mobile-open');
            main.style.marginLeft = document.body.classList.contains('sidebar-collapsed') ? '0' : '16rem';
        }

        sidebarToggle.addEventListener('click', function() {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();
        syncActiveSidebarWithRoute();

        document.getElementById('themeToggle').addEventListener('click', function() {
            document.body.classList.toggle('dark');
            const icon = this.querySelector('i');
            if (document.body.classList.contains('dark')) {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            } else {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
            }
            localStorage.setItem('theme', document.body.classList.contains('dark') ? 'dark' : 'light');
        });

        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark');
            document.getElementById('themeToggle').querySelector('i').classList.remove('fa-sun');
            document.getElementById('themeToggle').querySelector('i').classList.add('fa-moon');
        }

        function closeUserMenu() {
            if (!userMenuDropdown) return;
            userMenuDropdown.classList.add('hidden');
        }

        function showUserMenuNotice(message) {
            if (typeof showMessage === 'function') {
                showMessage(message, 'success');
                return;
            }
            window.alert(message);
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        async function handleUserMenuAction(action) {
            if (action === 'logout') {
                await performLogout();
                return;
            }

            if (action === 'profile') {
                showUserMenuNotice('Meu perfil: em breve.');
                return;
            }

            if (action === 'security') {
                showUserMenuNotice('Segurança: em breve.');
                return;
            }

            if (action === 'preferences') {
                showUserMenuNotice('Preferências: em breve.');
                return;
            }

            if (action === 'help') {
                showUserMenuNotice('Ajuda: em breve.');
            }
        }

        if (userMenuBtn && userMenuDropdown) {
            userMenuBtn.addEventListener('click', (event) => {
                event.stopPropagation();
                userMenuDropdown.classList.toggle('hidden');
            });

            userMenuDropdown.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Element)) return;
                const actionBtn = target.closest('[data-user-menu-action]');
                if (!actionBtn) return;
                const action = actionBtn.getAttribute('data-user-menu-action');
                closeUserMenu();
                void handleUserMenuAction(action);
            });

            document.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Node)) return;
                if (userMenuDropdown.classList.contains('hidden')) return;
                if (userMenuDropdown.contains(target) || userMenuBtn.contains(target)) return;
                closeUserMenu();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeUserMenu();
            });
        }

        const debtorsState = {
            debtors: [],
            loans: [],
            installments: [],
            filtered: [],
            currentPage: 1,
            pageSize: 8,
            editingDebtorId: null
        };
        const focusDebtorId = String(new URLSearchParams(window.location.search).get('debtorId') || '').trim();
        let hasAppliedDebtorFocus = false;

        const debtorModal = document.getElementById('debtorModal');
        const debtorModalTitle = document.getElementById('debtorModalTitle');
        const newDebtorBtn = document.getElementById('newDebtorBtn');
        const closeDebtorModalBtn = document.getElementById('closeDebtorModalBtn');
        const cancelDebtorModalBtn = document.getElementById('cancelDebtorModalBtn');
        const newDebtorForm = document.getElementById('newDebtorForm');
        const refreshBtn = document.getElementById('refreshBtn');
        const sortBy = document.getElementById('sortBy');
        const prevPageBtn = document.getElementById('prevPageBtn');
        const nextPageBtn = document.getElementById('nextPageBtn');

        function sameId(a, b) {
            return String(a ?? '') === String(b ?? '');
        }

        function highlightFocusedDebtorRow(debtorId) {
            const rows = document.querySelectorAll('#debtorsTableBody tr[data-debtor-id]');
            const targetRow = Array.from(rows).find(row => sameId(row.getAttribute('data-debtor-id'), debtorId));
            if (!targetRow) return;

            targetRow.classList.add('debtor-focus-row');
            targetRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(() => targetRow.classList.remove('debtor-focus-row'), 3500);
        }

        function toDigits(value) {
            return String(value || '').replace(/\D/g, '');
        }

        function formatDocument(value) {
            const digits = toDigits(value);
            if (digits.length === 11) {
                return digits.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
            }
            if (digits.length === 14) {
                return digits.replace(/(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})/, '$1.$2.$3/$4-$5');
            }
            return value || '-';
        }

        function formatPhone(value) {
            const digits = toDigits(value);
            if (digits.length === 11) {
                return digits.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
            }
            if (digits.length === 10) {
                return digits.replace(/(\d{2})(\d{4})(\d{4})/, '($1) $2-$3');
            }
            return value || '-';
        }

        function normalizeStatus(status) {
            const s = String(status || '').trim().toLowerCase();
            if (s === 'ativo') return 'Ativo';
            if (s === 'inativo') return 'Inativo';
            if (s === 'quitado') return 'Quitado';
            if (s === 'atrasado') return 'Atrasado';
            return status || 'Inativo';
        }

        function normalizeDebtorRow(row) {
            return {
                ...row,
                id: row.id,
                name: row.name || '',
                cpf: row.cpf || row.document || '',
                document: row.document || row.cpf || '',
                phone: row.phone || '',
                email: row.email || '',
                address: row.address || '',
                notes: row.notes || '',
                status: normalizeStatus(row.status),
                created_at: row.created_at || row.createdAt || new Date().toISOString().slice(0, 10)
            };
        }

        function getDebtorOverdueCount(debtorId) {
            const today = new Date();
            return debtorsState.installments.filter(installment => {
                if (!sameId(installment.debtor_id, debtorId)) return false;
                const status = String(installment.status || '').toLowerCase();
                if (status === 'atrasado') return true;
                if (status === 'pago') return false;
                const dueDate = installment.due_date ? new Date(installment.due_date) : null;
                return dueDate && dueDate < today;
            }).length;
        }

        function getDebtorLoansCount(debtorId) {
            return debtorsState.loans.filter(loan => sameId(loan.debtor_id, debtorId)).length;
        }

        function updateDebtorMetrics() {
            const total = debtorsState.debtors.length;
            const active = debtorsState.debtors.filter(d => normalizeStatus(d.status) === 'Ativo').length;
            const inactive = debtorsState.debtors.filter(d => ['Inativo', 'Quitado'].includes(normalizeStatus(d.status))).length;
            const withOverdue = debtorsState.debtors.filter(d => normalizeStatus(d.status) === 'Atrasado' || getDebtorOverdueCount(d.id) > 0).length;

            document.getElementById('totalDebtors').textContent = String(total);
            document.getElementById('activeDebtors').textContent = String(active);
            document.getElementById('inactiveDebtors').textContent = String(inactive);
            document.getElementById('overdueDebtors').textContent = String(withOverdue);
        }

        function badgeForStatus(status) {
            if (status === 'Ativo') return 'badge badge-success';
            if (status === 'Atrasado') return 'badge badge-danger';
            if (status === 'Quitado') return 'badge badge-success';
            if (status === 'Inativo') return 'badge badge-neutral';
            return 'badge badge-warn';
        }

        function compareDebtors(a, b, sortField) {
            if (sortField === 'created_at') {
                return new Date(b.created_at || 0) - new Date(a.created_at || 0);
            }
            if (sortField === 'status') {
                return normalizeStatus(a.status).localeCompare(normalizeStatus(b.status), 'pt-BR');
            }
            return String(a.name || '').localeCompare(String(b.name || ''), 'pt-BR');
        }

        function getFilteredDebtors() {
            const searchValue = document.getElementById('debtorSearch').value.trim().toLowerCase();
            const statusValue = document.getElementById('statusFilter').value;
            const sortField = sortBy.value;

            const filtered = debtorsState.debtors.filter(debtor => {
                const normalizedStatus = normalizeStatus(debtor.status);
                if (statusValue !== 'Todos' && normalizedStatus !== statusValue) return false;

                if (!searchValue) return true;
                const haystack = `${debtor.name || ''} ${debtor.phone || ''} ${debtor.document || debtor.cpf || ''} ${debtor.email || ''}`.toLowerCase();
                return haystack.includes(searchValue);
            });

            return filtered.sort((a, b) => compareDebtors(a, b, sortField));
        }

        function updatePaginationInfo(total) {
            const totalPages = Math.max(1, Math.ceil(total / debtorsState.pageSize));
            if (debtorsState.currentPage > totalPages) {
                debtorsState.currentPage = totalPages;
            }

            const start = total === 0 ? 0 : (debtorsState.currentPage - 1) * debtorsState.pageSize + 1;
            const end = total === 0 ? 0 : Math.min(start + debtorsState.pageSize - 1, total);

            document.getElementById('showingStart').textContent = String(start);
            document.getElementById('showingEnd').textContent = String(end);
            document.getElementById('totalResults').textContent = String(total);
            document.getElementById('pageIndicator').textContent = `PÃ¡gina ${debtorsState.currentPage} de ${totalPages}`;

            prevPageBtn.disabled = debtorsState.currentPage <= 1;
            nextPageBtn.disabled = debtorsState.currentPage >= totalPages;
            prevPageBtn.classList.toggle('opacity-50', prevPageBtn.disabled);
            nextPageBtn.classList.toggle('opacity-50', nextPageBtn.disabled);
        }

        function renderDebtorsTable() {
            const tbody = document.getElementById('debtorsTableBody');
            const total = debtorsState.filtered.length;
            updatePaginationInfo(total);

            if (!total) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center py-8 text-gray-500">Nenhum devedor encontrado.</td></tr>';
                return;
            }

            const startIndex = (debtorsState.currentPage - 1) * debtorsState.pageSize;
            const pageRows = debtorsState.filtered.slice(startIndex, startIndex + debtorsState.pageSize);

            tbody.innerHTML = pageRows.map(debtor => {
                const status = normalizeStatus(debtor.status);
                const loansCount = getDebtorLoansCount(debtor.id);
                const overdueCount = getDebtorOverdueCount(debtor.id);
                const rawDocument = debtor.document || debtor.cpf || debtor.cnpj || '';
                const documentValue = formatDocument(rawDocument);
                const rawPhone = debtor.phone || '';
                const phoneValue = formatPhone(rawPhone);
                const phoneDigits = toDigits(rawPhone);
                const phoneHtml = phoneDigits ? `<a href="https://wa.me/55${phoneDigits}" target="_blank" class="text-blue-600 hover:text-blue-500">${phoneValue}</a>` : '-';

                return `
                    <tr data-debtor-id="${debtor.id}">
                        <td>
                            <div class="font-semibold">${debtor.name || '-'}</div>
                            <div class="text-xs text-gray-500">${debtor.email || 'Sem e-mail'}</div>
                        </td>
                        <td>${documentValue}</td>
                        <td>${phoneHtml}</td>
                        <td><span class="${badgeForStatus(status)}">${status}</span></td>
                        <td>${loansCount}</td>
                        <td>${overdueCount > 0 ? `<span class="badge badge-danger">${overdueCount}</span>` : '<span class="badge badge-success">0</span>'}</td>
                        <td>
                            <button type="button" class="mr-2 text-blue-600" data-action="edit-debtor" data-id="${debtor.id}" title="Editar">
                                <i class="fas fa-pen-to-square"></i>
                            </button>
                            <button type="button" class="text-red-600" data-action="delete-debtor" data-id="${debtor.id}" title="Excluir">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function applyDebtorsFilters(resetPage) {
            if (resetPage) {
                debtorsState.currentPage = 1;
            }
            debtorsState.filtered = getFilteredDebtors();
            renderDebtorsTable();
        }

        function applyDebtorFocusFromQuery() {
            if (!focusDebtorId || hasAppliedDebtorFocus) return;

            const debtorExists = debtorsState.debtors.some(debtor => sameId(debtor.id, focusDebtorId));
            if (!debtorExists) return;

            hasAppliedDebtorFocus = true;

            document.getElementById('debtorSearch').value = '';
            document.getElementById('statusFilter').value = 'Todos';
            sortBy.value = 'name';

            debtorsState.filtered = getFilteredDebtors();
            const debtorIndex = debtorsState.filtered.findIndex(debtor => sameId(debtor.id, focusDebtorId));

            if (debtorIndex < 0) {
                renderDebtorsTable();
                return;
            }

            debtorsState.currentPage = Math.floor(debtorIndex / debtorsState.pageSize) + 1;
            renderDebtorsTable();
            highlightFocusedDebtorRow(focusDebtorId);
        }

        function openDebtorModal(mode, debtor) {
            debtorsState.editingDebtorId = mode === 'edit' ? debtor.id : null;
            debtorModalTitle.textContent = mode === 'edit' ? 'Editar devedor' : 'Novo devedor';

            document.getElementById('newDebtorName').value = debtor?.name || '';
            document.getElementById('newDebtorPhone').value = debtor?.phone || '';
            document.getElementById('newDebtorDocument').value = debtor?.document || debtor?.cpf || '';
            document.getElementById('newDebtorEmail').value = debtor?.email || '';
            document.getElementById('newDebtorAddress').value = debtor?.address || '';
            document.getElementById('newDebtorNotes').value = debtor?.notes || '';
            document.getElementById('newDebtorStatus').value = normalizeStatus(debtor?.status || 'Ativo');
            document.getElementById('newDebtorCreatedAt').value = debtor?.created_at || new Date().toISOString().slice(0, 10);

            debtorModal.classList.remove('hidden');
            debtorModal.classList.add('flex');
            document.getElementById('newDebtorName').focus();
        }

        function closeDebtorModal() {
            debtorsState.editingDebtorId = null;
            debtorModal.classList.add('hidden');
            debtorModal.classList.remove('flex');
            newDebtorForm.reset();
        }

        function deleteDebtor(debtorId) {
            if (!confirm('Tem certeza que deseja excluir este devedor?')) return;

            debtorsState.debtors = debtorsState.debtors.filter(debtor => !sameId(debtor.id, debtorId));
            debtorsState.loans = debtorsState.loans.filter(loan => !sameId(loan.debtor_id, debtorId));
            debtorsState.installments = debtorsState.installments.filter(installment => !sameId(installment.debtor_id, debtorId));

            saveTableData('debtors', debtorsState.debtors);
            saveTableData('loans', debtorsState.loans);
            saveTableData('installments', debtorsState.installments);

            updateDebtorMetrics();
            applyDebtorsFilters(false);
        }

        async function loadDebtorsData() {
            try {
                const [debtors, loans, installments] = await Promise.all([
                    fetchTableData('debtors'),
                    fetchTableData('loans'),
                    fetchTableData('installments')
                ]);

                debtorsState.debtors = debtors.map(normalizeDebtorRow);
                debtorsState.loans = loans;
                debtorsState.installments = installments;

                updateDebtorMetrics();
                applyDebtorsFilters(true);
                applyDebtorFocusFromQuery();
            } catch (error) {
                console.error('Erro ao carregar devedores:', error);
                document.getElementById('debtorsTableBody').innerHTML = '<tr><td colspan="7" class="text-center py-8 text-red-600">Erro ao carregar dados.</td></tr>';
            }
        }

        document.getElementById('debtorSearch').addEventListener('input', function () {
            applyDebtorsFilters(true);
        });
        document.getElementById('statusFilter').addEventListener('change', function () {
            applyDebtorsFilters(true);
        });
        sortBy.addEventListener('change', function () {
            applyDebtorsFilters(true);
        });
        refreshBtn.addEventListener('click', function () {
            loadDebtorsData();
        });

        prevPageBtn.addEventListener('click', function () {
            if (debtorsState.currentPage <= 1) return;
            debtorsState.currentPage -= 1;
            renderDebtorsTable();
        });
        nextPageBtn.addEventListener('click', function () {
            const totalPages = Math.max(1, Math.ceil(debtorsState.filtered.length / debtorsState.pageSize));
            if (debtorsState.currentPage >= totalPages) return;
            debtorsState.currentPage += 1;
            renderDebtorsTable();
        });

        newDebtorBtn.addEventListener('click', function () {
            openDebtorModal('create');
        });
        closeDebtorModalBtn.addEventListener('click', closeDebtorModal);
        cancelDebtorModalBtn.addEventListener('click', closeDebtorModal);
        debtorModal.addEventListener('click', function (event) {
            if (event.target === debtorModal) {
                closeDebtorModal();
            }
        });

        document.getElementById('debtorsTableBody').addEventListener('click', function (event) {
            const editBtn = event.target.closest('button[data-action="edit-debtor"]');
            if (editBtn) {
                const debtor = debtorsState.debtors.find(item => sameId(item.id, editBtn.getAttribute('data-id')));
                if (debtor) openDebtorModal('edit', debtor);
                return;
            }

            const deleteBtn = event.target.closest('button[data-action="delete-debtor"]');
            if (deleteBtn) {
                deleteDebtor(deleteBtn.getAttribute('data-id'));
            }
        });

        newDebtorForm.addEventListener('submit', function (event) {
            event.preventDefault();

            const name = document.getElementById('newDebtorName').value.trim();
            if (!name) return;

            const phone = document.getElementById('newDebtorPhone').value.trim();
            const documentValue = document.getElementById('newDebtorDocument').value.trim();
            const email = document.getElementById('newDebtorEmail').value.trim();
            const address = document.getElementById('newDebtorAddress').value.trim();
            const notes = document.getElementById('newDebtorNotes').value.trim();
            const status = document.getElementById('newDebtorStatus').value;
            const createdAt = document.getElementById('newDebtorCreatedAt').value || new Date().toISOString().slice(0, 10);

            const payload = {
                name,
                phone,
                cpf: documentValue,
                document: documentValue,
                email,
                address,
                notes,
                status,
                created_at: createdAt
            };

            if (debtorsState.editingDebtorId) {
                debtorsState.debtors = debtorsState.debtors.map(debtor =>
                    sameId(debtor.id, debtorsState.editingDebtorId) ? normalizeDebtorRow({ ...debtor, ...payload }) : debtor
                );
            } else {
                const newDebtor = normalizeDebtorRow({
                    id: getNextTableId('debtors', 1),
                    ...payload
                });
                debtorsState.debtors = [newDebtor, ...debtorsState.debtors];
            }

            saveTableData('debtors', debtorsState.debtors);
            updateDebtorMetrics();
            applyDebtorsFilters(true);
            closeDebtorModal();
        });

        document.addEventListener('DOMContentLoaded', function() {
            loadDebtorsData();
        });
    </script>
</body>
</html>




