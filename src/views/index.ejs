<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CredFácil - Login</title>

<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
html { font-size: 16px; }
body { font-family: 'Inter', sans-serif; }

.primary-gradient {
    background: linear-gradient(135deg, #000000 0%, #0f172a 50%, #111827 100%);
}

.glass-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 40px rgba(0,0,0,0.25);
}

.modern-input {
    background: rgba(255,255,255,0.9);
    border: 2px solid transparent;
    transition: 0.2s;
}

.modern-input:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
}

.modern-button {
    background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
    transition:
        transform 160ms cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 170ms ease-out,
        filter 140ms ease-out;
    will-change: transform;
    transform: translateZ(0);
}

.modern-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(59,130,246,0.34);
    filter: brightness(1.03);
}
</style>
</head>

<body class="primary-gradient min-h-screen flex items-center justify-center p-4">

<div class="w-full max-w-md">

    <!-- Título -->
    <div class="text-center mb-7">
        <div class="flex flex-col items-center gap-2">
            <%- include('partials/brand-wordmark', { size: 'login' }) %>
            <p class="text-slate-200/80 text-sm tracking-widest uppercase">Gerenciamento inteligente</p>
        </div>
    </div>

    <!-- Card -->
    <div class="glass-card rounded-2xl p-7">

        <div class="text-center mb-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-1">Bem-vindo</h2>
            <p class="text-gray-600">Entre com suas credenciais</p>
            <p class="text-xs text-gray-500 mt-2">Teste: admin@credfacil.com | 123456</p>
        </div>

        <form id="loginForm" class="space-y-4">

            <!-- Email -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    <i class="fas fa-envelope mr-1 text-blue-600"></i>Email
                </label>
                <input type="email" id="email" required autocomplete="email"
                class="modern-input w-full px-4 py-3 rounded-lg focus:outline-none"
                placeholder="seu@email.com">
            </div>

            <!-- Senha -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    <i class="fas fa-lock mr-1 text-blue-600"></i>Senha
                </label>
                <div class="relative">
                    <input type="password" id="password" required autocomplete="current-password"
                    class="modern-input w-full px-4 py-3 pr-11 rounded-lg focus:outline-none"
                    placeholder="••••••••">
                    <button type="button" id="togglePassword"
                    class="absolute right-3 top-3 text-gray-500"
                    aria-label="Mostrar senha" aria-pressed="false">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>

            <!-- Opções -->
            <div class="flex items-center justify-between text-sm">
                <label class="flex items-center">
                    <input type="checkbox" id="rememberMe" class="mr-2">
                    Lembrar-me
                </label>
                <a href="#" class="text-blue-600 hover:underline">
                    Esqueceu?
                </a>
            </div>

            <div id="loginMessage" class="hidden text-sm rounded-lg px-3 py-2"></div>

            <!-- Botão -->
            <button type="submit"
            class="modern-button w-full text-white py-3.5 rounded-lg font-medium text-base">
                <i class="fas fa-sign-in-alt mr-2"></i>Entrar
            </button>

        </form>

    </div>

    <!-- Footer -->
    <div class="text-center mt-4">
        <p class="text-xs text-blue-200 opacity-70">
            © 2026 CredFácil
        </p>
    </div>

</div>

<script>
async function checkSession() {
    try {
        const response = await fetch('/auth/me', { credentials: 'include' });
        if (response.ok) {
            window.location.href = '/admin/dashboard.html';
        }
    } catch (error) {
        // Ignora erro de rede aqui e mantém tela de login
    }
}

checkSession();

document.getElementById('togglePassword').addEventListener('click', function() {
    const input = document.getElementById('password');
    const icon = this.querySelector('i');

    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye','fa-eye-slash');
        this.setAttribute('aria-label', 'Ocultar senha');
        this.setAttribute('aria-pressed', 'true');
    } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash','fa-eye');
        this.setAttribute('aria-label', 'Mostrar senha');
        this.setAttribute('aria-pressed', 'false');
    }
});

document.getElementById('loginForm').addEventListener('submit', async function(event) {
    event.preventDefault();

    const email = document.getElementById('email').value.trim().toLowerCase();
    const password = document.getElementById('password').value;
    const rememberMe = document.getElementById('rememberMe').checked;
    const message = document.getElementById('loginMessage');

    try {
        const response = await fetch('/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ email, password })
        });

        const payload = await response.json();

        if (!response.ok) {
            throw new Error(payload?.message || 'E-mail ou senha inválidos.');
        }

        localStorage.setItem('isLoggedIn', 'true');
        localStorage.setItem('currentUser', JSON.stringify(payload.user || {}));
        localStorage.setItem('rememberMe', rememberMe ? 'true' : 'false');

        message.className = 'text-sm rounded-lg px-3 py-2 bg-green-100 text-green-700';
        message.textContent = 'Login realizado com sucesso. Redirecionando...';
        message.classList.remove('hidden');

        setTimeout(() => {
            window.location.href = '/admin/dashboard.html';
        }, 600);
    } catch (error) {
        message.className = 'text-sm rounded-lg px-3 py-2 bg-red-100 text-red-700';
        message.textContent = error.message || 'Falha ao realizar login.';
        message.classList.remove('hidden');
    }
});
</script>
</body>
</html>


