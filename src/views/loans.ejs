
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credix - Empréstimos</title>
    <style>
        html, body { background-color: #020617; }
    </style>
    <script>
        (function () {
            const root = document.documentElement;
            try {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark') root.classList.add('dark');
                if (savedTheme === 'light') root.classList.remove('dark');
            } catch (error) {}
        })();

        window.tailwind = window.tailwind || {};
        window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        html { font-size: 16px; }
        body { font-family: 'Inter', sans-serif; }
        .primary-gradient { background: linear-gradient(135deg, #000000 0%, #0f172a 50%, #111827 100%); }
        .premium-header { background: rgba(2, 6, 23, 0.75); border-bottom: 1px solid rgba(148, 163, 184, 0.2); }

        .icon-btn {
            color: #cbd5e1;
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background-color 120ms ease-out, color 120ms ease-out, box-shadow 120ms ease-out;
        }
        .icon-btn:hover {
            color: #ffffff;
            background: rgba(59, 130, 246, 0.2);
            box-shadow: 0 0 0 1px rgba(96, 165, 250, 0.35) inset;
        }

        .modern-sidebar {
            background: linear-gradient(180deg, rgba(2, 6, 23, 0.9) 0%, rgba(15, 23, 42, 0.85) 100%);
            border-right: 1px solid rgba(148, 163, 184, 0.18);
            transform: translateX(0);
            transition: transform 120ms ease-out;
        }
        .sidebar-item {
            transition: background-color 120ms ease-out, color 120ms ease-out, box-shadow 120ms ease-out;
            border-radius: 12px;
            margin: 4px 0;
        }
        .sidebar-item:hover {
            background: rgba(148, 163, 184, 0.12);
            box-shadow: 0 0 0 1px rgba(148, 163, 184, 0.2) inset;
        }
        .sidebar-item.active {
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
            box-shadow: 0 0 0 1px rgba(147, 197, 253, 0.5) inset, 0 2px 8px rgba(59, 130, 246, 0.25);
        }

        .glass-card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
        }
        .page-title { color: #ffffff; }
        .muted-on-dark { color: #cbd5e1; }

        .kpi-value {
            font-size: 2rem;
            font-weight: 700;
            line-height: 1;
            color: #0f172a;
        }
        .filter-control {
            background: #f8fafc;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 10px 12px;
            color: #111827;
            width: 100%;
        }
        #loanModal .filter-control:focus,
        #loanModal button:focus,
        #loanSearch:focus,
        #loanStatusFilter:focus {
            outline: none !important;
            box-shadow: none !important;
        }
        .filter-control.field-invalid {
            border-color: #ef4444;
            box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.2);
        }
        .field-error {
            margin-top: 6px;
            font-size: 12px;
            color: #dc2626;
            display: none;
        }
        .field-error:not(:empty) { display: block; }

        .table-shell {
            overflow: auto;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
        }
        .table-shell table { width: 100%; border-collapse: collapse; }
        .table-shell th {
            text-align: left;
            background: #f8fafc;
            color: #64748b;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 12px 14px;
            border-bottom: 1px solid #e2e8f0;
        }
        .table-shell td { padding: 16px 14px; border-top: 1px solid #f1f5f9; color: #1f2937; }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 10px;
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
        }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-danger { background: #fee2e2; color: #991b1b; }
        .badge-warn { background: #fef3c7; color: #92400e; }
        .badge-neutral { background: #e2e8f0; color: #334155; }

        .action-btn {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid transparent;
            transition: background-color 120ms ease-out, border-color 120ms ease-out;
        }
        .action-btn-view { color: #2563eb; }
        .action-btn-edit { color: #059669; }
        .action-btn-delete { color: #dc2626; }
        .action-btn-view:hover,
        .action-btn-edit:hover,
        .action-btn-delete:hover {
            background: #f1f5f9;
            border-color: #e2e8f0;
        }

        .calc-card {
            border-radius: 12px;
            border: 1px solid rgba(59, 130, 246, 0.25);
            background: linear-gradient(135deg, rgba(30, 64, 175, 0.08) 0%, rgba(59, 130, 246, 0.12) 100%);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
        }
        .installment-preview {
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #f8fafc;
        }
        .installment-preview.overdue { background: #fee2e2; border-color: #fecaca; }
        .installment-preview.pending { background: #fef3c7; border-color: #fde68a; }
        .installment-preview.overdue:hover { background: #fecaca; }
        .installment-preview.pending:hover { background: #fde68a; }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }
        .details-item {
            border-radius: 10px;
            border: 1px solid #e5e7eb;
            padding: 10px 12px;
            background: #f8fafc;
        }

        main { transition: none; }
        body.sidebar-collapsed .modern-sidebar { transform: translateX(-100%); }
        body.sidebar-collapsed main { margin-left: 0 !important; }

        @media (max-width: 1024px) {
            .modern-sidebar { transform: translateX(-100%); }
            .modern-sidebar.mobile-open { transform: translateX(0) !important; }
            main { margin-left: 0 !important; }
        }
        @media (max-width: 640px) {
            .kpi-value { font-size: 1.6rem; }
            .details-grid { grid-template-columns: repeat(1, minmax(0, 1fr)); }

            .icon-btn {
                width: 36px;
                height: 36px;
                border-radius: 10px;
            }

            .icon-btn i {
                font-size: 1rem !important;
            }

            .header-user-chevron { display: none; }
        }

        .dark .glass-card {
            background: rgba(15, 23, 42, 0.82);
            border: 1px solid rgba(148, 163, 184, 0.2);
            color: #e2e8f0;
            box-shadow: 0 1px 2px rgba(2, 6, 23, 0.35);
        }
        .dark .kpi-value { color: #f8fafc; }
        .dark .filter-control,
        .dark .table-shell,
        .dark .table-shell th,
        .dark .table-shell td,
        .dark .details-item,
        .dark .installment-preview {
            background: rgba(15, 23, 42, 0.7);
            color: #e2e8f0;
            border-color: rgba(148, 163, 184, 0.22);
        }
        .dark .field-error { color: #fca5a5; }
        .dark .table-shell th { background: rgba(30, 41, 59, 0.95); color: #cbd5e1; }
        .dark .calc-card {
            background: linear-gradient(135deg, rgba(30, 64, 175, 0.2) 0%, rgba(59, 130, 246, 0.22) 100%);
            border-color: rgba(96, 165, 250, 0.35);
            box-shadow: 0 1px 2px rgba(2, 6, 23, 0.35);
        }
    </style>
</head>
<body class="primary-gradient min-h-screen">
    <header class="premium-header fixed w-full top-0 z-50">
        <div class="flex items-center justify-between px-3 py-3 sm:px-6 sm:py-4">
            <div class="flex items-center">
                <button id="sidebarToggle" class="icon-btn focus:outline-none"><i class="fas fa-bars text-xl"></i></button>
                <h1 class="ml-3 sm:ml-6">
                    <a href="dashboard.html" class="flex items-center" aria-label="Credix">
                        <%- include('partials/brand-wordmark', { size: 'header' }) %>
                    </a>
                </h1>
            </div>
            <div class="flex flex-1 items-center justify-end gap-1 sm:gap-4 lg:gap-6 min-w-0">
                <div class="relative min-w-0">
                    <button id="userMenuBtn" class="flex items-center gap-2 text-slate-200 hover:text-white focus:outline-none min-w-0 max-w-full">
                        <span id="userName" class="header-user-name font-semibold min-w-0 max-w-[16rem] truncate">Olá, <%= currentUser?.name || currentUser?.full_name || 'Administrador' %></span>
                        <i class="header-user-chevron fas fa-chevron-down text-sm"></i>
                    </button>
                    <div id="userMenuDropdown" class="absolute right-0 top-full z-50 mt-2 hidden w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-xl dark:border-slate-700 dark:bg-slate-900">
                        <button type="button" data-user-menu-action="profile" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                            <i class="fas fa-id-card text-slate-500 dark:text-slate-300"></i>
                            <span>Meu perfil</span>
                        </button>
                        <button type="button" data-user-menu-action="security" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                            <i class="fas fa-shield-halved text-slate-500 dark:text-slate-300"></i>
                            <span>Segurança</span>
                        </button>
                        <button type="button" data-user-menu-action="help" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                            <i class="fas fa-circle-question text-slate-500 dark:text-slate-300"></i>
                            <span>Ajuda</span>
                        </button>
                        <div class="my-1 h-px bg-slate-200 dark:bg-slate-700"></div>
                        <button type="button" data-user-menu-action="logout" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-950/40">
                            <i class="fas fa-right-from-bracket"></i>
                            <span>Sair</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="flex pt-16 sm:pt-20">
        <aside id="sidebar" class="modern-sidebar fixed left-0 top-16 h-[calc(100%-4rem)] w-64 z-40 sm:top-20 sm:h-[calc(100%-5rem)]">
            <nav class="mt-8 px-4">
                <ul class="space-y-2">
                    <li><a href="dashboard.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-tachometer-alt mr-4 text-lg"></i><span>Painel financeiro</span></a></li>
                    <li><a href="debtors.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-users mr-4 text-lg"></i><span>Clientes</span></a></li>
                    <li><a href="loans.html" class="sidebar-item active flex items-center px-4 py-3 text-white rounded-lg"><i class="fas fa-hand-holding-usd mr-4 text-lg"></i><span class="font-medium">Empréstimos</span></a></li>
                    <li><a href="installments.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-calendar-check mr-4 text-lg"></i><span>Parcelas</span></a></li>
                    <li><a href="reports.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-chart-bar mr-4 text-lg"></i><span>Relatórios</span></a></li>
                </ul>
            </nav>
        </aside>

        <main class="flex-1 ml-64 p-4 sm:p-6 lg:p-8">
            <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                <div>
                    <h2 class="page-title text-3xl font-bold">Empréstimos</h2>
                    <p class="muted-on-dark mt-1 text-sm">Acompanhe contratos, valores e status da carteira ativa.</p>
                </div>
                <button id="newLoanBtn" class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition-colors duration-150 hover:bg-blue-500">
                    <i class="fas fa-file-invoice-dollar mr-2"></i>Novo empréstimo
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5 mb-6">
                <div class="relative rounded-2xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
                    <span class="pointer-events-none absolute right-4 top-4 text-slate-400/80"><i class="fas fa-hashtag"></i></span>
                    <p class="text-xs tracking-wide text-slate-600">Qtd. empréstimos</p>
                    <p id="totalLoans" class="mt-2 text-xl font-semibold text-slate-900">0</p>
                </div>
                <div class="relative rounded-2xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
                    <span class="pointer-events-none absolute right-4 top-4 text-slate-400/80"><i class="fas fa-hand-holding-usd"></i></span>
                    <p class="text-xs tracking-wide text-slate-600">Principal total</p>
                    <p id="totalPrincipal" class="mt-2 text-xl font-semibold text-slate-900">R$ 0,00</p>
                </div>
                <div class="relative rounded-2xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
                    <span class="pointer-events-none absolute right-4 top-4 text-slate-400/80"><i class="fas fa-chart-line"></i></span>
                    <p class="text-xs tracking-wide text-slate-600">Total contratado</p>
                    <p id="totalContracted" class="mt-2 text-xl font-semibold text-slate-900">R$ 0,00</p>
                </div>
                <div class="relative rounded-2xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
                    <span class="pointer-events-none absolute right-4 top-4 text-slate-400/80"><i class="fas fa-circle-check"></i></span>
                    <p class="text-xs tracking-wide text-slate-600">Empréstimos ativos</p>
                    <p id="activeLoans" class="mt-2 text-xl font-semibold text-slate-900">0</p>
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-5">
                    <div class="md:col-span-2">
                        <label class="block text-sm text-gray-600 mb-1">Buscar</label>
                        <input id="loanSearch" type="text" class="filter-control focus:ring-2 focus:ring-blue-500/40" placeholder="Cliente ou ID do empréstimo">
                    </div>
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">Status</label>
                        <select id="loanStatusFilter" class="filter-control focus:ring-2 focus:ring-blue-500/40">
                            <option value="Todos">Todos</option>
                            <option value="Ativo">Ativo</option>
                            <option value="Inativo">Inativo</option>
                        </select>
                    </div>
                </div>

                <div class="table-shell">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Cliente</th>
                                <th>Principal</th>
                                <th>Total</th>
                                <th>Parcelas</th>
                                <th>Juros</th>
                                <th>Data de início</th>
                                <th>Status</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody id="loansTableBody">
                            <tr><td colspan="9" class="text-center py-8 text-gray-500">Carregando empréstimos...</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 flex items-center justify-between">
                    <p class="text-sm text-gray-600">
                        Mostrando <span id="showingStart">0</span> até <span id="showingEnd">0</span> de <span id="totalResults">0</span> resultados
                    </p>
                    <div class="flex items-center gap-2">
                        <button id="prevPageBtn" type="button" class="rounded-lg border border-slate-200 px-3 py-1 text-sm text-slate-700 transition-colors duration-150 hover:bg-slate-50">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <span id="pageIndicator" class="text-sm text-gray-600">Página 1</span>
                        <button id="nextPageBtn" type="button" class="rounded-lg border border-slate-200 px-3 py-1 text-sm text-slate-700 transition-colors duration-150 hover:bg-slate-50">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div id="loanModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4">
                <div class="w-full max-w-2xl rounded-2xl border border-gray-200 bg-slate-50 p-6 shadow-sm max-h-[92vh] overflow-y-auto">
                    <div class="mb-5 flex items-center justify-between">
                        <h3 id="loanModalTitle" class="text-xl font-bold text-gray-800">Novo empréstimo</h3>
                        <button id="closeLoanModalBtn" class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700 focus:outline-none" type="button"><i class="fas fa-times"></i></button>
                    </div>

                    <form id="loanForm" class="space-y-4">
                        <input type="hidden" id="loanEditingId">

                        <div class="rounded-xl border border-gray-200 p-4">
                            <h4 class="mb-3 text-sm font-semibold text-gray-700 uppercase tracking-wide">Informações básicas</h4>
                            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                                <div class="md:col-span-2">
                                    <label class="mb-1 block text-sm text-gray-600">Cliente</label>
                                    <select id="loanDebtor" class="filter-control focus:ring-2 focus:ring-blue-500/40" required></select>
                                    <p id="loanDebtorError" class="field-error" aria-live="polite"></p>
                                </div>
                                <div>
                                    <label class="mb-1 block text-sm text-gray-600">Valor principal (R$)</label>
                                    <input id="loanPrincipal" class="filter-control focus:ring-2 focus:ring-blue-500/40" type="number" min="0.01" step="0.01" required>
                                    <p id="loanPrincipalError" class="field-error" aria-live="polite"></p>
                                </div>
                            </div>
                        </div>

                        <div class="rounded-xl border border-gray-200 p-4">
                            <h4 class="mb-3 text-sm font-semibold text-gray-700 uppercase tracking-wide">Condições</h4>
                            <div class="grid grid-cols-1 gap-4 md:[grid-template-columns:minmax(0,1.45fr)_minmax(0,1fr)_minmax(0,1fr)]">
                                <div>
                                    <label class="mb-1 block text-sm text-gray-600">Tipo de juros</label>
                                    <select id="loanInterestType" class="filter-control focus:ring-2 focus:ring-blue-500/40">
                                        <option value="simples">Simples %</option>
                                        <option value="composto" selected>Composto %</option>
                                        <option value="fixo">Fixo (valor total)</option>
                                    </select>
                                    <p id="loanInterestTypeError" class="field-error" aria-live="polite"></p>
                                </div>
                                <div id="loanInterestRateWrap">
                                    <label class="mb-1 block text-sm text-gray-600">Taxa mensal (%)</label>
                                    <input id="loanInterestRate" class="filter-control focus:ring-2 focus:ring-blue-500/40" type="number" min="0" step="0.01" value="20" required placeholder="Ex: 8">
                                    <p id="loanInterestRateError" class="field-error" aria-live="polite"></p>
                                </div>
                                <div id="loanFixedAdditionWrap" class="hidden">
                                    <label class="mb-1 block text-sm text-gray-600">Acréscimo fixo total (R$)</label>
                                    <input id="loanFixedAddition" class="filter-control focus:ring-2 focus:ring-blue-500/40" type="number" min="0" step="0.01" value="0">
                                    <p id="loanFixedAdditionError" class="field-error" aria-live="polite"></p>
                                </div>
                                <div>
                                    <label class="mb-1 block text-sm text-gray-600">Parcelas</label>
                                    <input id="loanInstallments" class="filter-control focus:ring-2 focus:ring-blue-500/40" type="number" min="1" max="96" step="1" value="6" required>
                                    <p id="loanInstallmentsError" class="field-error" aria-live="polite"></p>
                                </div>
                            </div>
                            <input id="loanPaymentMethod" type="hidden" value="Pix">
                        </div>

                        <div class="rounded-xl border border-gray-200 p-4">
                            <h4 class="mb-3 text-sm font-semibold text-gray-700 uppercase tracking-wide">Datas</h4>
                            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                                <div>
                                    <label class="mb-1 block text-sm text-gray-600">Data de início</label>
                                    <input id="loanStartDate" class="filter-control focus:ring-2 focus:ring-blue-500/40" type="date" required>
                                    <p id="loanStartDateError" class="field-error" aria-live="polite"></p>
                                </div>
                                <div>
                                    <label class="mb-1 block text-sm text-gray-600">1º vencimento</label>
                                    <input id="loanFirstDueDate" class="filter-control focus:ring-2 focus:ring-blue-500/40" type="date" required>
                                    <p id="loanFirstDueDateError" class="field-error" aria-live="polite"></p>
                                </div>
                            </div>
                            <input id="loanFrequency" type="hidden" value="mensal">
                        </div>

                        <div id="loanCalculationCard" class="calc-card p-4 hidden">
                            <h4 class="text-sm font-semibold uppercase tracking-wide text-blue-900">Simulação</h4>
                            <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
                                <div class="rounded-lg border border-blue-200/70 bg-white/55 px-3 py-2">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-blue-800">Total do contrato</p>
                                    <p id="loanCalculatedTotal" class="mt-1 text-lg font-semibold tracking-tight leading-tight text-blue-950">R$ 0,00</p>
                                </div>
                                <div class="rounded-lg border border-blue-200/70 bg-white/55 px-3 py-2">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-blue-800">Valor da parcela</p>
