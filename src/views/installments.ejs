        document.getElementById('refreshBtn').addEventListener('click', loadInstallmentsData);

        document.getElementById('messageTemplate').addEventListener('change', handleTemplateChange);
        document.getElementById('sendNotificationBtn').addEventListener('click', sendBatchNotifications);
        document.getElementById('closeNotificationModalBtn').addEventListener('click', () => closeModal(notificationModal));
        document.getElementById('cancelNotificationBtn').addEventListener('click', () => closeModal(notificationModal));

        document.getElementById('paymentForm').addEventListener('submit', registerInstallmentPayment);
        document.getElementById('closePaymentModalBtn').addEventListener('click', () => closeModal(paymentModal));
        document.getElementById('cancelPaymentBtn').addEventListener('click', () => closeModal(paymentModal));

        document.getElementById('installmentsTableBody').addEventListener('click', function(event) {
            const actionBtn = event.target.closest('button[data-action]');
            if (!actionBtn) return;

            const action = actionBtn.getAttribute('data-action');
            const installmentId = actionBtn.getAttribute('data-id');

            if (action === 'pay-installment') {
                openPaymentModal(installmentId);
                return;
            }

            if (action === 'whatsapp') {
                sendInstallmentWhatsApp(installmentId);
                return;
            }

            if (action === 'undo-payment') {
                undoInstallmentPayment(installmentId);
            }
        });

        [paymentModal, notificationModal].forEach(modal => {
            modal.addEventListener('click', function(event) {
                if (event.target === modal) closeModal(modal);
            });
        });

        document.addEventListener('DOMContentLoaded', function() {
            handleTemplateChange();
            applyQueryFiltersToControls();
            loadInstallmentsData();
        });
    </script>
</body>
</html>







