generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum ClientStatus {
  ATIVO
  INATIVO
}

enum LoanStatus {
  PENDENTE
  EM_DIA
  ATRASADO
  QUITADO
}

enum InterestType {
  SIMPLES
  COMPOSTO
}

enum LoanSimulationInterestType {
  SIMPLES
  COMPOSTO
  FIXO
}

enum LoanSimulationStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  CANCELED
}

enum PaymentMethod {
  PIX
  DINHEIRO
  TRANSFERENCIA
  CARTAO
}

enum InstallmentStatus {
  PENDENTE
  PAGO
  ATRASADO
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clients      Client[]
  loans        Loan[]
  loanSimulations LoanSimulation[]
  installments Installment[]
  payments     Payment[]
}

model Client {
  id           Int          @id @default(autoincrement())
  ownerUserId  Int
  ownerUser    User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  name         String
  cpf          String?
  phone        String
  email        String?
  status       ClientStatus @default(ATIVO)
  address      String?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  loans        Loan[]
  loanSimulations LoanSimulation[]
  installments Installment[]

  @@index([ownerUserId])
  @@index([cpf])
  @@unique([ownerUserId, cpf])
}

model Loan {
  id                Int            @id @default(autoincrement())
  ownerUserId       Int
  ownerUser         User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clientId          Int
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  principalAmount   Decimal        @db.Decimal(14, 2)
  interestRate      Decimal        @db.Decimal(7, 4)
  interestType      InterestType   @default(SIMPLES)
  installmentsCount Int
  installmentAmount Decimal?       @db.Decimal(14, 2)
  totalAmount       Decimal        @db.Decimal(14, 2)
  paymentMethod     PaymentMethod  @default(PIX)
  startDate         DateTime       @db.Date
  firstDueDate      DateTime       @db.Date
  dueDate           DateTime       @db.Date
  status            LoanStatus     @default(PENDENTE)
  observations      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  installments      Installment[]
  approvedFromSimulation LoanSimulation? @relation("LoanApprovedBySimulation")
  payments          Payment[]

  @@index([ownerUserId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model LoanSimulation {
  id                String                     @id @default(uuid()) @db.Uuid
  ownerUserId       Int
  ownerUser         User                       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clientId          Int
  client            Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  principalAmount   Decimal                    @db.Decimal(14, 2)
  interestType      LoanSimulationInterestType @default(COMPOSTO)
  interestRate      Decimal                    @db.Decimal(7, 4)
  fixedFeeAmount    Decimal?                   @db.Decimal(14, 2)
  installmentsCount Int
  firstDueDate      DateTime                   @db.Date
  scheduleJson      Json
  totalsJson        Json
  status            LoanSimulationStatus       @default(DRAFT)
  expiresAt         DateTime
  approvedLoanId    Int?                       @unique
  approvedLoan      Loan?                      @relation("LoanApprovedBySimulation", fields: [approvedLoanId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([ownerUserId])
  @@index([clientId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
}

model Installment {
  id               Int               @id @default(autoincrement())
  ownerUserId      Int
  ownerUser        User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  loanId           Int
  loan             Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clientId         Int
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  installmentNumber Int
  dueDate          DateTime          @db.Date
  paymentDate      DateTime?         @db.Date
  amount           Decimal           @db.Decimal(14, 2)
  principalAmount  Decimal?          @db.Decimal(14, 2)
  interestAmount   Decimal?          @db.Decimal(14, 2)
  status           InstallmentStatus @default(PENDENTE)
  paymentMethod    PaymentMethod?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  payments         Payment[]

  @@index([ownerUserId])
  @@unique([loanId, installmentNumber])
  @@index([loanId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id            Int           @id @default(autoincrement())
  ownerUserId   Int
  ownerUser     User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  loanId        Int
  loan          Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  installmentId Int?          @unique
  installment   Installment?  @relation(fields: [installmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  amount        Decimal       @db.Decimal(14, 2)
  paymentDate   DateTime      @db.Date
  method        PaymentMethod
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([ownerUserId])
  @@index([loanId])
  @@index([installmentId])
  @@index([paymentDate])
}
