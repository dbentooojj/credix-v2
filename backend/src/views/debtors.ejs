        function toDigits(value) {
            return String(value || '').replace(/\D/g, '');
        }

        function setInlineError(element, message) {
            if (!element) return;
            const text = String(message || '').trim();
            if (!text) {
                element.textContent = '';
                element.classList.add('hidden');
                return;
            }
            element.textContent = text;
            element.classList.remove('hidden');
        }

        function clearDebtorFormErrors() {
            setInlineError(newDebtorNameError, '');
            setInlineError(newDebtorPhoneError, '');
            setInlineError(newDebtorCpfError, '');
            setInlineError(newDebtorEmailError, '');
        }

        function normalizeBrazilPhoneDigits(value) {
            const digits = toDigits(value);
            if (!digits) return '';

            let normalized = digits;
            if (normalized.startsWith('55') && normalized.length > 11) {
                normalized = normalized.slice(2);
            }
            if (normalized.startsWith('0') && normalized.length > 11) {
                // Aceita colagem tipo 0XX...: mantém apenas os últimos 11 dígitos.
                normalized = normalized.slice(-11);
            }
            return normalized;
        }

        function formatPhonePartial(value) {
            const digits = normalizeBrazilPhoneDigits(value).slice(0, 11);
            if (!digits) return '';
            if (digits.length <= 2) return digits;

            const ddd = digits.slice(0, 2);
            const rest = digits.slice(2);
            const isMobile = digits.length === 11;
            const firstLen = isMobile ? 5 : 4;
            const first = rest.slice(0, firstLen);
            const second = rest.slice(firstLen);

            return `(${ddd}) ${first}${second ? `-${second}` : ''}`;
        }

        function formatCpfPartial(value) {
            const digits = toDigits(value).slice(0, 11);
            if (!digits) return '';

            const p1 = digits.slice(0, 3);
            const p2 = digits.slice(3, 6);
            const p3 = digits.slice(6, 9);
            const p4 = digits.slice(9, 11);

            if (digits.length <= 3) return p1;
            if (digits.length <= 6) return `${p1}.${p2}`;
            if (digits.length <= 9) return `${p1}.${p2}.${p3}`;
            return `${p1}.${p2}.${p3}-${p4}`;
        }

        function isValidCpfDigits(cpfDigits) {
            const cpf = String(cpfDigits || '');
            if (!/^\d{11}$/.test(cpf)) return false;
            if (/^(\d)\1{10}$/.test(cpf)) return false;

            let sum = 0;
            for (let i = 0; i < 9; i++) {
                sum += Number(cpf[i]) * (10 - i);
            }
            let first = (sum * 10) % 11;
            if (first === 10) first = 0;
            if (first !== Number(cpf[9])) return false;

            sum = 0;
            for (let i = 0; i < 10; i++) {
                sum += Number(cpf[i]) * (11 - i);
            }
            let second = (sum * 10) % 11;
            if (second === 10) second = 0;
            return second === Number(cpf[10]);
        }

        function isValidEmail(value) {
            const email = String(value || '').trim();
            if (!email) return true;
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        }

        function formatDocument(value) {
            const digits = toDigits(value);
            if (digits.length === 11) {
                return digits.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
            }
            if (digits.length === 14) {
                return digits.replace(/(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})/, '$1.$2.$3/$4-$5');
            }
            return value || '-';
        }

        function formatPhone(value) {
            const digits = toDigits(value);
            if (digits.length === 11) {
                return digits.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
            }
            if (digits.length === 10) {
                return digits.replace(/(\d{2})(\d{4})(\d{4})/, '($1) $2-$3');
            }
            return value || '-';
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('pt-BR', {
                style: 'currency',
                currency: 'BRL',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            }).format(Number(value || 0));
        }

        function parseCurrencyInput(value) {
            const raw = String(value ?? '').trim();
            if (!raw) return 0;

            const sanitized = raw
                .replace(/\s+/g, '')
                .replace(/R\$/gi, '')
                .replace(/[^\d,.-]/g, '');

            const commaIndex = sanitized.lastIndexOf(',');
            const dotIndex = sanitized.lastIndexOf('.');
            let normalized = sanitized;

            if (commaIndex >= 0 && dotIndex >= 0) {
                if (commaIndex > dotIndex) {
                    normalized = sanitized.replace(/\./g, '').replace(',', '.');
                } else {
                    normalized = sanitized.replace(/,/g, '');
                }
            } else if (commaIndex >= 0) {
                normalized = sanitized.replace(/\./g, '').replace(',', '.');
            } else {
                normalized = sanitized.replace(/,/g, '');
            }

            const parsed = Number(normalized);
            return Number.isFinite(parsed) ? parsed : 0;
        }

        function formatCurrencyInput(value) {
            const parsed = parseCurrencyInput(value);
            if (parsed <= 0) return '';
            return parsed.toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            });
        }

        function formatPercent(value, fractionDigits = 1) {
            const safeDigits = Number.isInteger(fractionDigits) ? Math.max(0, fractionDigits) : 1;
            const safeValue = Number(value);
            const normalized = Number.isFinite(safeValue) ? safeValue : 0;
            return `${normalized.toLocaleString('pt-BR', {
                minimumFractionDigits: safeDigits,
                maximumFractionDigits: safeDigits,
            })}%`;
        }

        function parseDateValue(value) {
            if (!value) return null;
            if (value instanceof Date) return new Date(value.getTime());

            const raw = String(value).trim();
            const dateOnlyMatch = raw.match(/^(\d{4})-(\d{2})-(\d{2})$/);
            if (dateOnlyMatch) {
                const year = Number(dateOnlyMatch[1]);
                const month = Number(dateOnlyMatch[2]) - 1;
                const day = Number(dateOnlyMatch[3]);
                return new Date(year, month, day);
            }

            const parsed = new Date(raw);
            if (Number.isNaN(parsed.getTime())) return null;
            return parsed;
        }

        function startOfDay(value) {
            const date = parseDateValue(value);
            if (!date) return null;
            date.setHours(0, 0, 0, 0);
            return date;
        }

        function formatDate(value) {
            const date = parseDateValue(value);
            if (!date) return '-';
            return date.toLocaleDateString('pt-BR');
        }

        function daysBetween(fromDate, toDate) {
            if (!(fromDate instanceof Date) || !(toDate instanceof Date)) return 0;
            return Math.floor((toDate.getTime() - fromDate.getTime()) / (1000 * 60 * 60 * 24));
        }

        function normalizeStatus(status) {
            const s = String(status || '').trim().toLowerCase();
            if (s === 'ativo') return 'Ativo';
            if (s === 'inativo') return 'Inativo';
            if (s === 'quitado') return 'Quitado';
            if (s === 'atrasado') return 'Atrasado';
            return status || 'Inativo';
        }

        function isOverdueStatus(status) {
            const normalized = String(status || '').trim().toLowerCase();
            return ['atrasado', 'overdue', 'em atraso', 'vencido', 'late'].includes(normalized);
        }

        function normalizeEditableClientStatus(value) {
            const s = normalizeStatus(value);
            if (s === 'Inativo' || s === 'Quitado') return 'Inativo';
            return 'Ativo';
        }

        function normalizeDebtorRow(row) {
            return {
                ...row,
                id: row.id,
                name: row.name || '',
                cpf: row.cpf || row.document || '',
                document: row.document || row.cpf || '',
                phone: row.phone || '',
                email: row.email || '',
                address: row.address || '',
                notes: row.notes || '',
                status: normalizeStatus(row.status),
                created_at: row.created_at || row.createdAt || new Date().toISOString().slice(0, 10)
            };
        }

        function getDebtorOverdueCount(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return 0;
            return debtorsState.installments.filter(installment => {
                if (!sameId(installment.debtor_id, debtorId)) return false;
                const status = String(installment.status || '').toLowerCase();
                if (status === 'atrasado') return true;
                if (status === 'pago') return false;
                const dueDate = startOfDay(installment.due_date);
                return dueDate && dueDate < today;
            }).length;
        }

        function getDebtorUiStatus(debtor) {
            const base = normalizeStatus(debtor?.status);
            const overdueCount = getDebtorOverdueCount(debtor?.id);
            if (overdueCount > 0) return 'Atrasado';
            return base;
        }

        function getDebtorRegistrationStatus(debtor) {
            const base = normalizeEditableClientStatus(debtor?.status);
            return base === 'Inativo' ? 'Inativo' : 'Ativo';
        }

        function getDebtorFinancialSituation(debtor) {
            const loansCount = getDebtorLoansCount(debtor?.id);
            if (loansCount <= 0) return 'Sem empréstimo';

            const overdueCount = getDebtorOverdueCount(debtor?.id);
            if (overdueCount > 0) return 'Atrasado';
            return 'Em dia';
        }

        function badgeForFinancialSituation(situation) {
            if (situation === 'Atrasado') return 'badge badge-danger';
            if (situation === 'Em dia') return 'badge badge-success';
            return 'badge badge-neutral';
        }

        function getDebtorMaxOverdueDays(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return null;

            let maxDays = null;
            debtorsState.installments.forEach((installment) => {
                if (!sameId(installment.debtor_id, debtorId)) return;

                const status = String(installment.status || '').trim().toLowerCase();
                if (status === 'pago') return;

                const dueDate = startOfDay(installment.due_date);
                if (!dueDate) return;

                const isOverdue = status === 'atrasado' || dueDate < today;
                if (!isOverdue) return;

                const diffMs = today.getTime() - dueDate.getTime();
                const days = Math.max(0, Math.floor(diffMs / (1000 * 60 * 60 * 24)));
                if (maxDays === null || days > maxDays) maxDays = days;
            });

            return maxDays;
        }

        function getDebtorOpenTotal(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return 0;
            return debtorsState.installments.reduce((sum, installment) => {
                if (!sameId(installment.debtor_id, debtorId)) return sum;
                const status = String(installment.status || '').toLowerCase();
                if (status === 'pago') return sum;
                if (status === 'atrasado') return sum;

                const dueDate = startOfDay(installment.due_date);
                if (dueDate && dueDate < today) return sum;

                return sum + Number(installment.amount ?? installment.value ?? 0);
            }, 0);
        }

        function getDebtorOverdueTotal(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return 0;

            return debtorsState.installments.reduce((sum, installment) => {
                if (!sameId(installment.debtor_id, debtorId)) return sum;

                const status = String(installment.status || '').trim().toLowerCase();
                if (status === 'pago') return sum;

                const dueDate = startOfDay(installment.due_date);
                if (!dueDate) return sum;

                const isOverdue = status === 'atrasado' || dueDate < today;
                if (!isOverdue) return sum;

                return sum + Number(installment.amount ?? installment.value ?? 0);
            }, 0);
        }

        function getDebtorDueInstallmentsHistory(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return [];

            return debtorsState.installments
                .filter((installment) => sameId(installment.debtor_id, debtorId))
                .map((installment) => {
                    const dueDate = startOfDay(installment.due_date);
                    const paymentDate = startOfDay(installment.payment_date);
                    if (!dueDate) return null;
                    const status = String(installment.status || '').trim().toLowerCase();
                    const amount = Number(installment.amount ?? installment.value ?? 0);
                    return {
                        dueDate,
                        paymentDate,
                        status,
                        amount: Number.isFinite(amount) ? amount : 0,
                    };
                })
                .filter((item) => item && item.dueDate <= today)
                .sort((a, b) => a.dueDate - b.dueDate);
        }

        function getDebtorClosedLoansCount(debtorId) {
            return debtorsState.loans.filter((loan) => {
                if (!sameId(loan.debtor_id, debtorId)) return false;
                const status = String(loan.status || '').trim().toLowerCase();
                return status === 'finalizado' || status === 'quitado';
            }).length;
        }

        function getDebtorCreditScore(debtorId) {
            const today = startOfDay(new Date());
            if (!today) {
                return {
                    score: 700,
                    totalDueCount: 0,
                    paidOnTimeCount: 0,
                    paidLateCount: 0,
                    unpaidOverdueCount: 0,
                    avgLateDays: 0,
                    onTimeRatio: null,
                    onTimeStreak: 0,
                    closedLoansCount: 0,
                    scoreTrend: 'stable',
                };
            }

            const history = getDebtorDueInstallmentsHistory(debtorId);
            const closedLoansCount = getDebtorClosedLoansCount(debtorId);

            if (!history.length) {
                return {
                    score: 700,
                    totalDueCount: 0,
                    paidOnTimeCount: 0,
                    paidLateCount: 0,
                    unpaidOverdueCount: 0,
                    avgLateDays: 0,
                    onTimeRatio: null,
                    onTimeStreak: 0,
                    closedLoansCount,
                    scoreTrend: 'stable',
                };
            }

            let scoreRaw = 700;
            let paidOnTimeCount = 0;
            let paidLateCount = 0;
            let unpaidOverdueCount = 0;
            let totalLateDays = 0;
            let totalOverdueOpenDays = 0;

            const outcomeSeries = [];

            history.forEach((item) => {
                const isPaid = item.status === 'pago' || Boolean(item.paymentDate);
                const paymentDate = item.paymentDate;

                if (isPaid) {
                    const lateDays = paymentDate ? Math.max(daysBetween(item.dueDate, paymentDate), 0) : 0;
                    if (lateDays === 0) {
                        scoreRaw += 12;
                        paidOnTimeCount += 1;
                        outcomeSeries.push(1);
                    } else if (lateDays <= 3) {
                        scoreRaw -= 8;
                        paidLateCount += 1;
                        totalLateDays += lateDays;
                        outcomeSeries.push(0);
                    } else if (lateDays <= 7) {
                        scoreRaw -= 20;
                        paidLateCount += 1;
                        totalLateDays += lateDays;
                        outcomeSeries.push(0);
                    } else if (lateDays <= 15) {
                        scoreRaw -= 38;
                        paidLateCount += 1;
                        totalLateDays += lateDays;
                        outcomeSeries.push(0);
                    } else {
                        scoreRaw -= 60;
                        paidLateCount += 1;
                        totalLateDays += lateDays;
                        outcomeSeries.push(0);
                    }
                    return;
                }

                const overdueDays = Math.max(daysBetween(item.dueDate, today), 0);
                if (overdueDays > 0) {
                    unpaidOverdueCount += 1;
                    totalOverdueOpenDays += overdueDays;
                    if (overdueDays <= 7) scoreRaw -= 48;
                    else if (overdueDays <= 15) scoreRaw -= 78;
                    else if (overdueDays <= 30) scoreRaw -= 118;
                    else scoreRaw -= 165;
                    outcomeSeries.push(-1);
                } else {
                    outcomeSeries.push(0);
                }
            });

            let onTimeStreak = 0;
            for (let index = history.length - 1; index >= 0; index -= 1) {
                const item = history[index];
                const isPaid = item.status === 'pago' || Boolean(item.paymentDate);
                if (!isPaid) break;
                const lateDays = item.paymentDate ? Math.max(daysBetween(item.dueDate, item.paymentDate), 0) : 0;
                if (lateDays === 0) {
                    onTimeStreak += 1;
                } else {
                    break;
                }
            }

            scoreRaw += Math.min(onTimeStreak * 6, 30);
            scoreRaw += Math.min(closedLoansCount * 10, 40);

            const totalDueCount = history.length;
            const onTimeRatio = totalDueCount > 0 ? (paidOnTimeCount / totalDueCount) : null;
            if (onTimeRatio !== null) {
                if (totalDueCount >= 6 && onTimeRatio >= 0.9) scoreRaw += 24;
                else if (totalDueCount >= 6 && onTimeRatio >= 0.75) scoreRaw += 10;
                else if (totalDueCount >= 6 && onTimeRatio < 0.5) scoreRaw -= 22;
            }

            let scoreTrend = 'stable';
            if (outcomeSeries.length >= 8) {
                const recent = outcomeSeries.slice(-4);
                const previous = outcomeSeries.slice(-8, -4);
                const avgRecent = recent.reduce((sum, value) => sum + value, 0) / recent.length;
                const avgPrevious = previous.reduce((sum, value) => sum + value, 0) / previous.length;
                const delta = avgRecent - avgPrevious;
                if (delta >= 0.25) {
                    scoreRaw += 12;
                    scoreTrend = 'up';
                } else if (delta <= -0.25) {
                    scoreRaw -= 12;
                    scoreTrend = 'down';
                }
            }

            const avgLateDays = paidLateCount > 0 ? (totalLateDays / paidLateCount) : 0;
            const score = Math.max(0, Math.min(1000, Math.round(scoreRaw)));

            return {
                score,
                totalDueCount,
                paidOnTimeCount,
                paidLateCount,
                unpaidOverdueCount,
                avgLateDays,
                onTimeRatio,
                onTimeStreak,
                closedLoansCount,
                scoreTrend,
                totalOverdueOpenDays,
            };
        }

        function getScoreIndicator(scoreValue) {
            const score = Number.isFinite(Number(scoreValue)) ? Number(scoreValue) : 0;

            if (score >= 850) {
                return {
                    badgeClass: 'border-emerald-300 bg-emerald-50 text-emerald-700',
                    dotClass: 'bg-emerald-500',
                    textClass: 'text-emerald-700',
                };
            }

            if (score >= 700) {
                return {
                    badgeClass: 'border-yellow-300 bg-yellow-50 text-yellow-700',
                    dotClass: 'bg-yellow-500',
                    textClass: 'text-yellow-700',
                };
            }

            if (score >= 550) {
                return {
                    badgeClass: 'border-orange-300 bg-orange-50 text-orange-700',
                    dotClass: 'bg-orange-500',
                    textClass: 'text-orange-700',
                };
            }

            return {
                badgeClass: 'border-red-300 bg-red-50 text-red-700',
                dotClass: 'bg-red-500',
                textClass: 'text-red-700',
            };
        }

        function getDebtorPunctuality90d(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return { dueCount: 0, onTimeCount: 0, percent: null };

            const windowStart = new Date(today.getTime());
            windowStart.setDate(windowStart.getDate() - 90);

            let dueCount = 0;
            let onTimeCount = 0;

            debtorsState.installments.forEach((installment) => {
                if (!sameId(installment.debtor_id, debtorId)) return;

                const dueDate = startOfDay(installment.due_date);
                if (!dueDate) return;
                if (dueDate < windowStart || dueDate > today) return;

                dueCount += 1;

                const status = String(installment.status || '').trim().toLowerCase();
                const paymentDate = startOfDay(installment.payment_date);

                if (status === 'pago') {
                    if (!paymentDate || paymentDate <= dueDate) {
                        onTimeCount += 1;
                    }
                }
            });

            if (dueCount === 0) {
                return { dueCount, onTimeCount, percent: null };
            }

            return {
                dueCount,
                onTimeCount,
                percent: (onTimeCount / dueCount) * 100,
            };
        }

        function getDebtorLastPaymentInfo(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return { date: null, daysSince: null };

            let lastPaymentDate = null;

            debtorsState.installments.forEach((installment) => {
                if (!sameId(installment.debtor_id, debtorId)) return;

                const paymentDate = startOfDay(installment.payment_date);
                if (!paymentDate) return;
                if (!lastPaymentDate || paymentDate > lastPaymentDate) {
                    lastPaymentDate = paymentDate;
                }
            });

            if (!lastPaymentDate) return { date: null, daysSince: null };

            const diffMs = today.getTime() - lastPaymentDate.getTime();
            const daysSince = Math.max(0, Math.floor(diffMs / (1000 * 60 * 60 * 24)));
            return { date: lastPaymentDate, daysSince };
        }

        function getDebtorTrend3m(debtorId) {
            const today = startOfDay(new Date());
            if (!today) {
                return { tone: 'neutral', text: 'Sem dados para tendência 3M' };
            }

            const recentStart = new Date(today.getTime());
            recentStart.setDate(recentStart.getDate() - 90);
            const previousEnd = new Date(recentStart.getTime());
            previousEnd.setDate(previousEnd.getDate() - 1);
            const previousStart = new Date(previousEnd.getTime());
            previousStart.setDate(previousStart.getDate() - 90);

            let recentTotal = 0;
            let previousTotal = 0;

            debtorsState.installments.forEach((installment) => {
                if (!sameId(installment.debtor_id, debtorId)) return;
                const paymentDate = startOfDay(installment.payment_date);
                if (!paymentDate) return;

                const amount = Number(installment.amount ?? installment.value ?? 0);
                const safeAmount = Number.isFinite(amount) ? amount : 0;

                if (paymentDate >= recentStart && paymentDate <= today) {
                    recentTotal += safeAmount;
                    return;
                }

                if (paymentDate >= previousStart && paymentDate <= previousEnd) {
                    previousTotal += safeAmount;
                }
            });

            if (recentTotal <= 0 && previousTotal <= 0) {
                return { tone: 'neutral', text: 'Tendência 3M: estável (sem recebimentos)' };
            }

            if (previousTotal <= 0 && recentTotal > 0) {
                return { tone: 'positive', text: 'Tendência 3M: ↑ sem base comparativa' };
            }

            const pct = ((recentTotal - previousTotal) / Math.abs(previousTotal)) * 100;
            if (Math.abs(pct) < 0.05) {
                return { tone: 'neutral', text: 'Tendência 3M: estável' };
            }

            return {
                tone: pct > 0 ? 'positive' : 'negative',
                text: `Tendência 3M: ${pct > 0 ? '↑' : '↓'} ${formatPercent(Math.abs(pct), 1)}`,
            };
        }

        function getDebtorInsightSnapshot(debtorId, scoreData = null) {
            const score = scoreData || getDebtorCreditScore(debtorId);
            const punctuality = getDebtorPunctuality90d(debtorId);
            const lastPayment = getDebtorLastPaymentInfo(debtorId);
            const trend3m = getDebtorTrend3m(debtorId);

            let punctualityText = 'Pontualidade 90d: sem vencimentos';
            let punctualityClass = 'text-gray-600';

            if (punctuality.percent !== null) {
                punctualityText = `Pontualidade 90d: ${formatPercent(punctuality.percent, 1)} (${punctuality.onTimeCount}/${punctuality.dueCount})`;
                if (punctuality.percent >= 90) punctualityClass = 'text-emerald-700';
                else if (punctuality.percent >= 70) punctualityClass = 'text-amber-700';
                else punctualityClass = 'text-red-700';
            }

            let lastPaymentText = 'Último pagamento: sem registro';
            let lastPaymentClass = 'text-gray-600';

            if (lastPayment.date) {
                if (lastPayment.daysSince === 0) {
                    lastPaymentText = `Último pagamento: hoje (${formatDate(lastPayment.date)})`;
                    lastPaymentClass = 'text-emerald-700';
                } else {
                    lastPaymentText = `Último pagamento: há ${lastPayment.daysSince} dia(s) (${formatDate(lastPayment.date)})`;
                    lastPaymentClass = lastPayment.daysSince >= 30 ? 'text-amber-700' : 'text-gray-700';
                }
            }

            const trendClass = trend3m.tone === 'positive'
                ? 'text-emerald-700'
                : trend3m.tone === 'negative'
                    ? 'text-red-700'
                    : 'text-gray-600';

            const scoreIndicator = getScoreIndicator(score.score);
            const scoreClass = scoreIndicator.textClass;

            const scoreTrendText = score.scoreTrend === 'up'
                ? 'subindo'
                : score.scoreTrend === 'down'
                    ? 'caindo'
                    : 'estável';

            const scoreText = `${score.score}/1000`;
            const behaviorText = score.totalDueCount > 0
                ? `Atrasos pagos: ${score.paidLateCount} | atraso médio: ${score.avgLateDays.toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 })} dia(s) | índice ${scoreTrendText}`
                : 'Sem histórico suficiente para cálculo do Índice Credix';
            const behaviorClass = score.scoreTrend === 'up'
                ? 'text-emerald-700'
                : score.scoreTrend === 'down'
                    ? 'text-red-700'
                    : 'text-gray-600';

            return {
                punctualityText,
                punctualityClass,
                lastPaymentText,
                lastPaymentClass,
                trendText: trend3m.text,
                trendClass,
                scoreText,
                scoreClass,
                behaviorText,
                behaviorClass,
            };
        }

        function getDebtorNextDueInstallment(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return null;

            let next = null;
            debtorsState.installments.forEach((installment) => {
                if (!sameId(installment.debtor_id, debtorId)) return;

                const status = String(installment.status || '').trim().toLowerCase();
                if (status === 'pago') return;
                if (status === 'atrasado') return;

                const dueDate = startOfDay(installment.due_date);
                if (!dueDate) return;
                if (dueDate < today) return;

                const amount = Number(installment.amount ?? installment.value ?? 0);
                if (!next || dueDate < next.dueDate) {
                    next = { dueDate, amount };
                }
            });

            return next;
        }

        function getDebtorPaymentTargetInstallment(debtorId) {
            const today = startOfDay(new Date());
            if (!today) return null;

            const candidates = debtorsState.installments
                .filter((installment) => sameId(installment.debtor_id, debtorId))
                .map((installment) => {
                    const status = String(installment.status || '').trim().toLowerCase();
                    const dueDate = startOfDay(installment.due_date);
                    const isPaid = status === 'pago';
                    const isOverdue = !isPaid && dueDate && (status === 'atrasado' || dueDate < today);
                    const isOpen = !isPaid && dueDate && dueDate >= today;
                    return {
                        installment,
                        status,
                        dueDate,
                        isPaid,
                        isOverdue,
                        isOpen,
                    };
                })
                .filter((item) => item.dueDate && !item.isPaid);

            if (!candidates.length) return null;

            const overdue = candidates
                .filter((item) => item.isOverdue)
                .sort((a, b) => a.dueDate - b.dueDate);

            const open = candidates
                .filter((item) => item.isOpen)
                .sort((a, b) => a.dueDate - b.dueDate);

            const target = overdue[0] || open[0] || candidates.sort((a, b) => a.dueDate - b.dueDate)[0];
            if (!target) return null;

            const amount = Number(target.installment.amount ?? target.installment.value ?? 0);
            return {
                loanId: target.installment.loan_id ?? target.installment.loanId,
                installmentId: target.installment.id,
                amount: Number.isFinite(amount) ? amount : 0,
            };
        }

        function getDebtorLoansCount(debtorId) {
            return debtorsState.loans.filter(loan => sameId(loan.debtor_id, debtorId)).length;
        }

        function updateDebtorMetrics() {
            const total = debtorsState.debtors.length;
            const active = debtorsState.debtors.filter(d => getDebtorUiStatus(d) === 'Ativo').length;
            const inactive = debtorsState.debtors.filter(d => ['Inativo', 'Quitado'].includes(getDebtorUiStatus(d))).length;
            const withOverdue = debtorsState.debtors.filter(d => getDebtorUiStatus(d) === 'Atrasado').length;

            const today = startOfDay(new Date());
            const createdLast30Days = debtorsState.debtors.filter((debtor) => {
                if (!today) return false;
                const createdAt = startOfDay(debtor.created_at);
                if (!createdAt) return false;
                const days = Math.floor((today.getTime() - createdAt.getTime()) / (1000 * 60 * 60 * 24));
                return days >= 0 && days <= 30;
            }).length;

            const activeRatio = total > 0 ? (active / total) * 100 : 0;
            const overdueRatio = total > 0 ? (withOverdue / total) * 100 : 0;
            const inactiveNoPayment60 = debtorsState.debtors.filter((debtor) => {
                if (getDebtorUiStatus(debtor) === 'Ativo') return false;
                const lastPayment = getDebtorLastPaymentInfo(debtor.id);
                return lastPayment.daysSince !== null && lastPayment.daysSince >= 60;
            }).length;

            const overdueTicketAverage = withOverdue > 0
                ? debtorsState.debtors.reduce((sum, debtor) => {
                    if (getDebtorUiStatus(debtor) !== 'Atrasado') return sum;
                    return sum + getDebtorOverdueTotal(debtor.id);
                }, 0) / withOverdue
                : 0;

            const snapshot = {
                total,
                active,
                inactive,
                withOverdue,
                totalInsight: `${createdLast30Days} novo(s) nos últimos 30 dias`,
                activeInsight: `${formatPercent(activeRatio, 1)} da base ativa`,
                inactiveInsight: `${inactiveNoPayment60} sem pagamento há 60+ dias`,
                overdueInsight: withOverdue > 0
                    ? `${formatPercent(overdueRatio, 1)} da base | ticket médio ${formatCurrency(overdueTicketAverage)}`
                    : 'Sem clientes em atraso no momento',
            };

            applyDebtorMetricsSnapshot(snapshot);
            cacheDebtorMetricsSnapshot(snapshot);
        }

        function badgeForStatus(status) {
            if (status === 'Ativo') return 'badge badge-success';
            if (status === 'Atrasado') return 'badge badge-danger';
            if (status === 'Quitado') return 'badge badge-success';
            if (status === 'Inativo') return 'badge badge-neutral';
            return 'badge badge-warn';
        }

        function getDebtorScoreBadgeModel(scoreData) {
            const score = Number.isFinite(Number(scoreData?.score)) ? Number(scoreData.score) : 0;
            const totalDueCount = Number.isFinite(Number(scoreData?.totalDueCount)) ? Number(scoreData.totalDueCount) : 0;
            const indicator = getScoreIndicator(score);
            return {
                score,
                badgeClass: indicator.badgeClass,
                dotClass: indicator.dotClass,
                noHistory: totalDueCount <= 0,
            };
        }

