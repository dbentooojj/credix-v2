        function clearDebtorsFilters() {
            const searchInput = document.getElementById('debtorSearch');
            const statusInput = document.getElementById('statusFilter');
            if (searchInput) searchInput.value = '';
            if (statusInput) statusInput.value = 'Todos';
            if (sortBy) sortBy.value = 'name';
            debtorsState.sortField = 'name';
            debtorsState.sortDir = getDefaultSortDir('name');
            updateDebtorsSortHeaderUi();
            applyDebtorsFilters(true);
        }

        function getDefaultSortDir(sortField) {
            if (sortField === 'open_total') return 'desc';
            if (sortField === 'max_overdue_days') return 'desc';
            if (sortField === 'created_at') return 'desc';
            if (sortField === 'loans_count') return 'desc';
            if (sortField === 'overdue_count') return 'desc';
            if (sortField === 'next_due_date') return 'asc';
            return 'asc';
        }

        function compareDebtors(a, b, sortField, sortDir) {
            const dir = sortDir === 'desc' ? -1 : 1;
            const nameCmp = String(a.name || '').localeCompare(String(b.name || ''), 'pt-BR');

            if (sortField === 'open_total') {
                const aTotal = Number(getDebtorOpenTotal(a.id) || 0);
                const bTotal = Number(getDebtorOpenTotal(b.id) || 0);
                const delta = aTotal - bTotal;
                if (delta !== 0) return delta * dir;
                return nameCmp;
            }

            if (sortField === 'max_overdue_days') {
                const aDays = Number(getDebtorMaxOverdueDays(a.id) ?? -1);
                const bDays = Number(getDebtorMaxOverdueDays(b.id) ?? -1);
                const delta = aDays - bDays;
                if (delta !== 0) return delta * dir;
                return nameCmp;
            }

            if (sortField === 'created_at') {
                const aTime = Date.parse(a.created_at || '') || 0;
                const bTime = Date.parse(b.created_at || '') || 0;
                const delta = aTime - bTime;
                if (delta !== 0) return delta * dir;
                return nameCmp;
            }

            if (sortField === 'status') {
                const aStatus = getDebtorRegistrationStatus(a);
                const bStatus = getDebtorRegistrationStatus(b);
                const cmp = String(aStatus).localeCompare(String(bStatus), 'pt-BR');
                if (cmp !== 0) return cmp * dir;
                return nameCmp;
            }

            if (sortField === 'document') {
                const aDoc = toDigits(a.document || a.cpf || '');
                const bDoc = toDigits(b.document || b.cpf || '');
                if (!aDoc && !bDoc) return nameCmp;
                if (!aDoc) return 1;
                if (!bDoc) return -1;
                const cmp = aDoc.localeCompare(bDoc, 'pt-BR');
                if (cmp !== 0) return cmp * dir;
                return nameCmp;
            }

            if (sortField === 'phone') {
                const aPhone = toDigits(a.phone || '');
                const bPhone = toDigits(b.phone || '');
                if (!aPhone && !bPhone) return nameCmp;
                if (!aPhone) return 1;
                if (!bPhone) return -1;
                const cmp = aPhone.localeCompare(bPhone, 'pt-BR');
                if (cmp !== 0) return cmp * dir;
                return nameCmp;
            }

            if (sortField === 'loans_count') {
                const aCount = getDebtorLoansCount(a.id);
                const bCount = getDebtorLoansCount(b.id);
                const delta = aCount - bCount;
                if (delta !== 0) return delta * dir;
                return nameCmp;
            }

            if (sortField === 'overdue_count') {
                const aCount = getDebtorOverdueCount(a.id);
                const bCount = getDebtorOverdueCount(b.id);
                const delta = aCount - bCount;
                if (delta !== 0) return delta * dir;
                return nameCmp;
            }

            if (sortField === 'next_due_date') {
                const aNext = getDebtorNextDueInstallment(a.id);
                const bNext = getDebtorNextDueInstallment(b.id);
                if (!aNext && !bNext) return nameCmp;
                if (!aNext) return 1;
                if (!bNext) return -1;
                const delta = aNext.dueDate.getTime() - bNext.dueDate.getTime();
                if (delta !== 0) return delta * dir;
                return nameCmp;
            }

            const cmp = String(a.name || '').localeCompare(String(b.name || ''), 'pt-BR');
            if (cmp !== 0) return cmp * dir;
            return 0;
        }

        function updateDebtorsSortHeaderUi() {
            const headers = document.querySelectorAll('.table-shell th[data-sort]');
            headers.forEach((th) => {
                const field = String(th.getAttribute('data-sort') || '');
                const active = field && field === debtorsState.sortField;
                th.setAttribute('data-sort-active', active ? 'true' : 'false');

                const icon = th.querySelector('.sort-icon');
                if (!icon) return;

                icon.classList.remove('fa-sort', 'fa-caret-up', 'fa-caret-down');
                if (!active) {
                    icon.classList.add('fa-sort');
                    return;
                }

                if (debtorsState.sortDir === 'desc') {
                    icon.classList.add('fa-caret-down');
                } else {
                    icon.classList.add('fa-caret-up');
                }
            });
        }

        function getFilteredDebtors() {
            const searchValue = document.getElementById('debtorSearch').value.trim().toLowerCase();
            const statusValue = document.getElementById('statusFilter').value;
            const sortField = debtorsState.sortField || sortBy.value || 'name';
            const sortDir = debtorsState.sortDir || getDefaultSortDir(sortField);

            const filtered = debtorsState.debtors.filter(debtor => {
                const normalizedStatus = getDebtorUiStatus(debtor);
                if (statusValue !== 'Todos' && normalizedStatus !== statusValue) return false;

                if (!searchValue) return true;
                const haystack = `${debtor.name || ''} ${debtor.phone || ''} ${debtor.document || debtor.cpf || ''} ${debtor.email || ''}`.toLowerCase();
                return haystack.includes(searchValue);
            });

            return filtered.sort((a, b) => compareDebtors(a, b, sortField, sortDir));
        }

        function updatePaginationInfo(total) {
            const totalPages = Math.max(1, Math.ceil(total / debtorsState.pageSize));
            if (debtorsState.currentPage > totalPages) {
                debtorsState.currentPage = totalPages;
            }

            const start = total === 0 ? 0 : (debtorsState.currentPage - 1) * debtorsState.pageSize + 1;
            const end = total === 0 ? 0 : Math.min(start + debtorsState.pageSize - 1, total);

            document.getElementById('showingStart').textContent = String(start);
            document.getElementById('showingEnd').textContent = String(end);
            document.getElementById('totalResults').textContent = String(total);
            document.getElementById('pageIndicator').textContent = `Página ${debtorsState.currentPage} de ${totalPages}`;

            prevPageBtn.disabled = debtorsState.currentPage <= 1;
            nextPageBtn.disabled = debtorsState.currentPage >= totalPages;
            prevPageBtn.classList.toggle('opacity-50', prevPageBtn.disabled);
            nextPageBtn.classList.toggle('opacity-50', nextPageBtn.disabled);
        }

        function isDebtorDetailExpanded(debtorId) {
            return debtorsState.expandedDebtorIds.has(String(debtorId));
        }

        function setDebtorDetailExpanded(debtorId, expanded) {
            const key = String(debtorId || '');
            if (!key) return;

            if (expanded) {
                debtorsState.expandedDebtorIds.add(key);
            } else {
                debtorsState.expandedDebtorIds.delete(key);
            }

            const detailNodes = document.querySelectorAll(`[data-debtor-detail-for="${key}"]`);
            const mainNodes = document.querySelectorAll(`[data-expandable-row="true"][data-debtor-id="${key}"]`);
            const toggleButtons = document.querySelectorAll(`button[data-action="toggle-debtor-details"][data-id="${key}"]`);

            detailNodes.forEach((node) => {
                node.classList.toggle('hidden', !expanded);
            });

            mainNodes.forEach((node) => {
                node.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            });

            toggleButtons.forEach((button) => {
                button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
                button.setAttribute('title', expanded ? 'Fechar detalhes' : 'Ver detalhes');
                button.setAttribute('aria-label', expanded ? 'Fechar detalhes do cliente' : 'Ver detalhes do cliente');
                const icon = button.querySelector('i');
                if (icon) {
                    icon.classList.toggle('fa-eye', !expanded);
                    icon.classList.toggle('fa-eye-slash', expanded);
                }
            });
        }

        function toggleDebtorDetail(debtorId) {
            const expanded = isDebtorDetailExpanded(debtorId);
            setDebtorDetailExpanded(debtorId, !expanded);
        }

