                                    <span class="text-[11px] uppercase tracking-wide text-gray-500">Índice Credix:</span> <span class="font-semibold ${insightSnapshot.scoreClass}">${insightSnapshot.scoreText}</span>
                                    <div class="mt-1 text-[11px] text-gray-500">Índice calculado com base no histórico de pagamentos</div>
                                </div>
                                <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Comportamento:</span> <span class="font-semibold ${insightSnapshot.behaviorClass}">${insightSnapshot.behaviorText}</span></div>
                                <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Pontualidade:</span> <span class="font-semibold ${insightSnapshot.punctualityClass}">${insightSnapshot.punctualityText.replace('Pontualidade 90d: ', '')}</span></div>
                                <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Último pagamento:</span> <span class="font-semibold ${insightSnapshot.lastPaymentClass}">${insightSnapshot.lastPaymentText.replace('Último pagamento: ', '')}</span></div>
                                <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Tendência:</span> <span class="font-semibold ${insightSnapshot.trendClass}">${insightSnapshot.trendText.replace('Tendência 3M: ', '')}</span></div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function renderDebtorsTable() {
            const tbody = document.getElementById('debtorsTableBody');
            const total = debtorsState.filtered.length;
            updatePaginationInfo(total);

            if (!total) {
                if (tbody) {
                    tbody.innerHTML = '<tr class="hidden sm:table-row"><td colspan="7" class="py-8 text-center text-gray-500">Nenhum cliente encontrado.</td></tr>';
                }
                if (debtorsMobileList) {
                    debtorsMobileList.innerHTML = `
                        <div class="rounded-2xl border border-gray-200 bg-slate-50 p-4 text-center text-sm text-gray-500">
                            Nenhum cliente encontrado.
                        </div>
                    `;
                }
                return;
            }

            const startIndex = (debtorsState.currentPage - 1) * debtorsState.pageSize;
            const pageRows = debtorsState.filtered.slice(startIndex, startIndex + debtorsState.pageSize);

            if (tbody) {
                tbody.innerHTML = pageRows.map((debtor, index) => {
                const statusLabel = getDebtorRegistrationStatus(debtor);
                const financialSituation = getDebtorFinancialSituation(debtor);
                const financialSituationBadge = badgeForFinancialSituation(financialSituation);
                const loansCount = getDebtorLoansCount(debtor.id);
                const overdueCount = getDebtorOverdueCount(debtor.id);
                const maxOverdueDays = getDebtorMaxOverdueDays(debtor.id);
                const nextDue = getDebtorNextDueInstallment(debtor.id);
                const openTotal = getDebtorOpenTotal(debtor.id);
                const scoreData = getDebtorCreditScore(debtor.id);
                const scoreBadge = getDebtorScoreBadgeModel(scoreData);
                const insightSnapshot = getDebtorInsightSnapshot(debtor.id, scoreData);
                const hasOverdue = overdueCount > 0;
                const isExpanded = isDebtorDetailExpanded(debtor.id);
                const rawDocument = debtor.document || debtor.cpf || debtor.cnpj || '';
                const documentValue = formatDocument(rawDocument);
                const rawPhone = debtor.phone || '';
                const phoneValue = formatPhone(rawPhone);
                const phoneDigits = toDigits(rawPhone);
                const phoneHtml = phoneDigits ? `<a href="https://wa.me/55${phoneDigits}" target="_blank" class="text-blue-600 hover:text-blue-500">${phoneValue}</a>` : '<span class="text-gray-500">-</span>';
                const detailNextDue = nextDue ? `${formatDate(nextDue.dueDate)} | ${formatCurrency(nextDue.amount)}` : '&mdash;';
                const scoreBadgeText = `${scoreBadge.score}/1000`;
                const scoreBadgeTitle = scoreBadge.noHistory
                    ? `Sem histórico de crédito (índice base ${scoreBadge.score} de 1000)`
                    : `Índice Credix ${scoreBadge.score} de 1000`;

                return `
                    <tr class="debtor-table-row debtor-row-enter ${hasOverdue ? 'debtor-overdue-row' : ''} ${isExpanded ? 'debtor-expanded-row' : ''}" data-debtor-id="${debtor.id}" data-expandable-row="true" aria-expanded="${isExpanded ? 'true' : 'false'}" style="animation-delay:${Math.min(index * 35, 180)}ms">
                        <td>
                            <div class="text-base font-semibold tracking-tight text-gray-900">${debtor.name || '-'}</div>
                                <div class="mt-1 text-sm font-medium text-gray-600" aria-label="Telefone: ${phoneDigits ? phoneValue : 'não informado'}">${phoneHtml}</div>
                        </td>
                        <td>
                            <span class="${badgeForStatus(statusLabel)}" aria-label="Status cadastral: ${statusLabel}">${statusLabel}</span>
                        </td>
                        <td>
                            <span class="${financialSituationBadge}" aria-label="Situação financeira: ${financialSituation}">${financialSituation}</span>
                        </td>
                        <td class="whitespace-nowrap text-center">
                            <span class="inline-flex items-center gap-1 rounded-full border px-2 py-1 text-xs font-semibold ${scoreBadge.badgeClass}" title="${scoreBadgeTitle}" aria-label="${scoreBadgeTitle}">
                                <span class="h-1.5 w-1.5 rounded-full ${scoreBadge.dotClass}"></span>
                                ${scoreBadgeText}
                            </span>
                        </td>
                        <td class="whitespace-nowrap text-right">
                            <span class="inline-flex min-w-[1.5rem] justify-end text-base ${overdueCount > 0 ? 'font-semibold text-amber-700' : 'font-medium text-gray-600'}" title="Parcelas em atraso" aria-label="Parcelas em atraso: ${overdueCount}">${overdueCount}</span>
                        </td>
                        <td class="whitespace-nowrap text-right text-base font-semibold ${hasOverdue ? 'text-amber-700' : 'text-gray-900'}" aria-label="Total em aberto: ${formatCurrency(openTotal)}">${formatCurrency(openTotal)}</td>
                        <td class="whitespace-nowrap w-[1%]">
                            <div class="flex items-center justify-end gap-2">
                                <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-700 transition-colors hover:bg-slate-100" data-action="toggle-debtor-details" data-id="${debtor.id}" aria-expanded="${isExpanded ? 'true' : 'false'}" title="${isExpanded ? 'Fechar detalhes' : 'Ver detalhes'}" aria-label="${isExpanded ? 'Fechar detalhes do cliente' : 'Ver detalhes do cliente'} ${debtor.name || ''}">
                                    <i class="fas ${isExpanded ? 'fa-eye-slash' : 'fa-eye'}"></i>
                                </button>
                                <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-300 bg-white text-blue-700 transition-colors hover:bg-blue-50" data-action="edit-debtor" data-id="${debtor.id}" title="Editar cliente" aria-label="Editar cliente ${debtor.name || ''}">
                                    <i class="fas fa-pen-to-square"></i>
                                </button>
                                <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-300 bg-white text-red-700 transition-colors hover:bg-red-50" data-action="delete-debtor" data-id="${debtor.id}" title="Excluir cliente" aria-label="Excluir cliente ${debtor.name || ''}">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr class="debtor-detail-row ${isExpanded ? '' : 'hidden'}" data-debtor-detail-for="${debtor.id}">
                        <td colspan="7" class="bg-slate-50 px-4 pb-3 pt-0">
                            <div class="debtor-detail-card px-4 py-4">
                                <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
                                    <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Detalhes do cliente</div>
                                    <div class="text-[11px] text-slate-500">Visualização expandida</div>
                                </div>
                                <div class="grid grid-cols-1 gap-3 text-sm text-gray-700 md:grid-cols-2 xl:grid-cols-4">
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Documento</div>
                                    <div class="mt-1 font-semibold text-gray-800">${documentValue}</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">E-mail</div>
                                    <div class="mt-1 font-semibold text-gray-800">${debtor.email || '&mdash;'}</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Dias em atraso (máx.)</div>
                                    <div class="mt-1 font-semibold ${Number(maxOverdueDays || 0) > 0 ? 'text-amber-700' : 'text-gray-600'}">${Number(maxOverdueDays || 0) > 0 ? maxOverdueDays : '&mdash;'}</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Próx. venc. | Parcela</div>
                                    <div class="mt-1 font-semibold text-gray-800">${detailNextDue}</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Empréstimos</div>
                                    <div class="mt-1 font-semibold text-gray-800">${loansCount}</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Índice Credix</div>
                                    <div class="mt-1 font-semibold ${insightSnapshot.scoreClass}">${insightSnapshot.scoreText}</div>
                                    <div class="mt-1 text-[11px] text-gray-500">Índice calculado com base no histórico de pagamentos</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Comportamento</div>
                                    <div class="mt-1 font-semibold ${insightSnapshot.behaviorClass}">${insightSnapshot.behaviorText}</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Pontualidade 90d</div>
                                    <div class="mt-1 font-semibold ${insightSnapshot.punctualityClass}">${insightSnapshot.punctualityText.replace('Pontualidade 90d: ', '')}</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Último pagamento</div>
                                    <div class="mt-1 font-semibold ${insightSnapshot.lastPaymentClass}">${insightSnapshot.lastPaymentText.replace('Último pagamento: ', '')}</div>
                                </div>
                                <div>
                                    <div class="text-[11px] uppercase tracking-wide text-gray-500">Tendência 3M</div>
                                    <div class="mt-1 font-semibold ${insightSnapshot.trendClass}">${insightSnapshot.trendText.replace('Tendência 3M: ', '')}</div>
                                </div>
                            </div>
                            </div>
                        </td>
                    </tr>
                `;
                }).join('');
            }

            renderDebtorsMobileList(pageRows);
        }

        function applyDebtorsFilters(resetPage) {
            if (resetPage) {
                debtorsState.currentPage = 1;
            }
            debtorsState.filtered = getFilteredDebtors();
            renderDebtorsTable();
        }

        function syncDebtorsPageSizeForViewport() {
            const nextSize = window.matchMedia('(max-width: 639px)').matches ? 6 : 8;
            if (debtorsState.pageSize === nextSize) return;

            debtorsState.pageSize = nextSize;
            if (debtorsState.debtors.length > 0) {
                applyDebtorsFilters(true);
            }
        }

        function applyDebtorFocusFromQuery() {
            if (!focusDebtorId || hasAppliedDebtorFocus) return;

            const debtorExists = debtorsState.debtors.some(debtor => sameId(debtor.id, focusDebtorId));
            if (!debtorExists) return;

            hasAppliedDebtorFocus = true;

            document.getElementById('debtorSearch').value = '';
            document.getElementById('statusFilter').value = 'Todos';
            sortBy.value = 'name';
            debtorsState.sortField = 'name';
            debtorsState.sortDir = getDefaultSortDir('name');
            updateDebtorsSortHeaderUi();

            debtorsState.filtered = getFilteredDebtors();
            const debtorIndex = debtorsState.filtered.findIndex(debtor => sameId(debtor.id, focusDebtorId));

            if (debtorIndex < 0) {
                renderDebtorsTable();
                return;
            }

            debtorsState.currentPage = Math.floor(debtorIndex / debtorsState.pageSize) + 1;
            renderDebtorsTable();
            highlightFocusedDebtorRow(focusDebtorId);
        }

        function openDebtorModal(mode, debtor) {
            debtorsState.editingDebtorId = mode === 'edit' ? debtor.id : null;
            debtorModalTitle.textContent = mode === 'edit' ? 'Editar cliente' : 'Novo cliente';

            clearDebtorFormErrors();

            if (newDebtorNameInput) newDebtorNameInput.value = debtor?.name || '';
            if (newDebtorPhoneInput) newDebtorPhoneInput.value = formatPhonePartial(debtor?.phone || '');
            if (newDebtorCpfInput) newDebtorCpfInput.value = formatCpfPartial(debtor?.document || debtor?.cpf || '');
            if (newDebtorEmailInput) newDebtorEmailInput.value = debtor?.email || '';
            if (newDebtorStatusInput) newDebtorStatusInput.value = normalizeEditableClientStatus(debtor?.status || 'Ativo');
            if (newDebtorAddressInput) newDebtorAddressInput.value = debtor?.address || '';

            debtorModal.classList.remove('hidden');
            debtorModal.classList.add('flex');
            lockBodyScrollForDebtorsModal(debtorModal);
            if (newDebtorNameInput) newDebtorNameInput.focus();
        }

        function closeDebtorModal() {
            debtorsState.editingDebtorId = null;
            debtorModal.classList.add('hidden');
            debtorModal.classList.remove('flex');
            unlockBodyScrollForDebtorsModal(debtorModal);
            newDebtorForm.reset();
            clearDebtorFormErrors();
        }

        function openDeleteDebtorConfirmModal(debtorId) {
            if (!deleteDebtorConfirmModal) {
                void performDebtorDeletion(debtorId);
                return;
            }
            pendingDeleteDebtorId = debtorId;
            deleteDebtorConfirmModal.classList.remove('hidden');
            deleteDebtorConfirmModal.classList.add('flex');
            lockBodyScrollForDebtorsModal(deleteDebtorConfirmModal);
            if (confirmDeleteDebtorBtn) confirmDeleteDebtorBtn.focus();
        }

        function closeDeleteDebtorConfirmModal() {
            pendingDeleteDebtorId = null;
            if (!deleteDebtorConfirmModal) return;
            deleteDebtorConfirmModal.classList.add('hidden');
            deleteDebtorConfirmModal.classList.remove('flex');
            unlockBodyScrollForDebtorsModal(deleteDebtorConfirmModal);
        }

        function showDeleteDebtorSuccessToast() {
            showMessage('Cliente excluído com sucesso.', 'success');
        }

        async function performDebtorDeletion(debtorId) {
            if (debtorId === null || debtorId === undefined || debtorId === '') return;

            const previousDebtors = [...debtorsState.debtors];
            const previousLoans = [...debtorsState.loans];
            const previousInstallments = [...debtorsState.installments];

            debtorsState.debtors = debtorsState.debtors.filter(debtor => !sameId(debtor.id, debtorId));
            debtorsState.loans = debtorsState.loans.filter(loan => !sameId(loan.debtor_id, debtorId));
            debtorsState.installments = debtorsState.installments.filter(installment => !sameId(installment.debtor_id, debtorId));

            try {
                await saveTableData('debtors', debtorsState.debtors);
                await saveTableData('loans', debtorsState.loans);
                await saveTableData('installments', debtorsState.installments);

                updateDebtorMetrics();
                applyDebtorsFilters(false);
                showDeleteDebtorSuccessToast();
            } catch (error) {
                debtorsState.debtors = previousDebtors;
                debtorsState.loans = previousLoans;
                debtorsState.installments = previousInstallments;
                updateDebtorMetrics();
                applyDebtorsFilters(false);
                showMessage(error instanceof Error ? error.message : 'Erro ao excluir cliente.', 'error');
            }
        }

        async function confirmDeleteDebtor() {
            if (pendingDeleteDebtorId === null || pendingDeleteDebtorId === undefined || pendingDeleteDebtorId === '') {
                closeDeleteDebtorConfirmModal();
                return;
            }

            const debtorId = pendingDeleteDebtorId;
            closeDeleteDebtorConfirmModal();
            await performDebtorDeletion(debtorId);
        }

        function deleteDebtor(debtorId) {
            openDeleteDebtorConfirmModal(debtorId);
        }

        async function loadDebtorsData(options = {}) {
            const showSkeleton = options.showSkeleton !== false;
            const showRefreshState = options.showRefreshState === true;
            const feedbackOnSuccess = options.feedbackOnSuccess === true;
            if (isDebtorsLoading) return;

            isDebtorsLoading = true;
            if (showRefreshState) setRefreshLoadingState(true);
            if (showSkeleton) renderDebtorsLoadingSkeleton();

            try {
                const [debtors, loans, installments] = await Promise.all([
                    fetchTableData('debtors'),
                    fetchTableData('loans'),
                    fetchTableData('installments')
                ]);

                debtorsState.debtors = debtors.map(normalizeDebtorRow);
                debtorsState.loans = loans;
                debtorsState.installments = installments;

                updateDebtorMetrics();
                applyDebtorsFilters(true);
                applyDebtorFocusFromQuery();
                if (feedbackOnSuccess) flashRefreshSuccess();
            } catch (error) {
                console.error('Erro ao carregar clientes:', error);
                const tbody = document.getElementById('debtorsTableBody');
                if (tbody) {
                    tbody.innerHTML = '<tr class="hidden sm:table-row"><td colspan="7" class="py-8 text-center text-red-600">Erro ao carregar dados.</td></tr>';
                }
                if (debtorsMobileList) {
                    debtorsMobileList.innerHTML = `
                        <div class="rounded-2xl border border-red-200 bg-red-50 p-4 text-center text-sm font-semibold text-red-700">
                            Erro ao carregar dados.
                        </div>
                    `;
                }
            } finally {
                isDebtorsLoading = false;
                if (showRefreshState) setRefreshLoadingState(false);
            }
        }

        function openRegisterPaymentModal(debtor) {
            if (!registerPaymentModal || !registerPaymentForm) return;

            const target = getDebtorPaymentTargetInstallment(debtor?.id);
            if (!target?.loanId || !target?.installmentId) {
                showMessage('Este cliente não possui parcelas em aberto.', 'error');
                return;
            }

            debtorsState.registeringPaymentTarget = {
                debtorId: debtor.id,
                loanId: target.loanId,
                installmentId: target.installmentId,
            };

            if (registerPaymentDebtorName) registerPaymentDebtorName.textContent = debtor?.name || '-';
            if (registerPaymentAmount) registerPaymentAmount.value = formatCurrencyInput(target.amount || 0);
            if (registerPaymentDate) registerPaymentDate.value = getLocalTodayDateInputValue();
            if (registerPaymentMethod) registerPaymentMethod.value = 'PIX';

            registerPaymentModal.classList.remove('hidden');
            registerPaymentModal.classList.add('flex');
            lockBodyScrollForDebtorsModal(registerPaymentModal);
            if (registerPaymentAmount) registerPaymentAmount.focus();
        }

        function closeRegisterPaymentModal() {
            debtorsState.registeringPaymentTarget = null;
            if (!registerPaymentModal) return;
            registerPaymentModal.classList.add('hidden');
            registerPaymentModal.classList.remove('flex');
            unlockBodyScrollForDebtorsModal(registerPaymentModal);
            if (registerPaymentForm) registerPaymentForm.reset();
        }

        function setRegisterPaymentSaving(isSaving) {
            if (!saveRegisterPaymentBtn) return;
            saveRegisterPaymentBtn.disabled = Boolean(isSaving);
            saveRegisterPaymentBtn.classList.toggle('opacity-60', Boolean(isSaving));
            saveRegisterPaymentBtn.classList.toggle('cursor-not-allowed', Boolean(isSaving));
        }

        window.addEventListener('resize', syncDebtorsPageSizeForViewport);
        syncDebtorsPageSizeForViewport();

        if (newDebtorNameInput) {
            newDebtorNameInput.addEventListener('input', function () {
                setInlineError(newDebtorNameError, '');
            });
        }

        if (newDebtorPhoneInput) {
            newDebtorPhoneInput.addEventListener('input', function () {
                newDebtorPhoneInput.value = formatPhonePartial(newDebtorPhoneInput.value);
                setInlineError(newDebtorPhoneError, '');
            });

            newDebtorPhoneInput.addEventListener('blur', function () {
                const digits = normalizeBrazilPhoneDigits(newDebtorPhoneInput.value);
                if (!digits || (digits.length !== 10 && digits.length !== 11)) {
                    setInlineError(newDebtorPhoneError, 'Informe um telefone válido (10 ou 11 dígitos).');
                    return;
                }
                newDebtorPhoneInput.value = formatPhonePartial(digits);
            });
        }

        if (newDebtorCpfInput) {
            newDebtorCpfInput.addEventListener('input', function () {
                newDebtorCpfInput.value = formatCpfPartial(newDebtorCpfInput.value);
                setInlineError(newDebtorCpfError, '');
            });

            newDebtorCpfInput.addEventListener('blur', function () {
                const digits = toDigits(newDebtorCpfInput.value);
                if (!digits) {
                    setInlineError(newDebtorCpfError, '');
                    newDebtorCpfInput.value = '';
                    return;
                }
                if (!isValidCpfDigits(digits)) {
                    setInlineError(newDebtorCpfError, 'CPF inválido.');
                    return;
                }
                newDebtorCpfInput.value = formatCpfPartial(digits);
            });
        }

        if (newDebtorEmailInput) {
            newDebtorEmailInput.addEventListener('input', function () {
                setInlineError(newDebtorEmailError, '');
            });

            newDebtorEmailInput.addEventListener('blur', function () {
                if (!isValidEmail(newDebtorEmailInput.value)) {
                    setInlineError(newDebtorEmailError, 'E-mail inválido.');
                }
            });
        }

        document.getElementById('debtorSearch').addEventListener('input', function () {
            applyDebtorsFilters(true);
        });
        document.getElementById('statusFilter').addEventListener('change', function () {
            applyDebtorsFilters(true);
        });
        if (clearFiltersBtn) {
            clearFiltersBtn.addEventListener('click', function () {
                clearDebtorsFilters();
                clearFiltersBtn.classList.add('ring-2', 'ring-blue-200');
                setTimeout(() => clearFiltersBtn.classList.remove('ring-2', 'ring-blue-200'), 450);
            });
        }
        sortBy.addEventListener('change', function () {
            debtorsState.sortField = sortBy.value;
            debtorsState.sortDir = getDefaultSortDir(debtorsState.sortField);
            updateDebtorsSortHeaderUi();
            applyDebtorsFilters(true);
        });

        if (debtorsTableHead) {
            debtorsTableHead.addEventListener('click', function (event) {
                const target = event.target;
                if (!(target instanceof Element)) return;

                const th = target.closest('th[data-sort]');
                if (!th) return;

                const field = String(th.getAttribute('data-sort') || '').trim();
                if (!field) return;

                if (debtorsState.sortField === field) {
                    debtorsState.sortDir = debtorsState.sortDir === 'asc' ? 'desc' : 'asc';
                } else {
                    debtorsState.sortField = field;
                    debtorsState.sortDir = getDefaultSortDir(field);
                }

                if (sortBy) {
                    const hasOption = Array.from(sortBy.options || []).some(opt => opt.value === field);
                    if (hasOption) sortBy.value = field;
                }

                updateDebtorsSortHeaderUi();
                applyDebtorsFilters(true);
            });
        }

        // Garantir que o estado inicial de ordenação esteja refletido no cabeçalho.
        debtorsState.sortField = sortBy.value || debtorsState.sortField;
        debtorsState.sortDir = getDefaultSortDir(debtorsState.sortField);
        updateDebtorsSortHeaderUi();
        if (refreshBtn) {
            refreshBtn.addEventListener('click', function () {
                loadDebtorsData({ showSkeleton: true, showRefreshState: true, feedbackOnSuccess: true });
            });
        }

        prevPageBtn.addEventListener('click', function () {
            if (debtorsState.currentPage <= 1) return;
            debtorsState.currentPage -= 1;
            renderDebtorsTable();
        });
        nextPageBtn.addEventListener('click', function () {
            const totalPages = Math.max(1, Math.ceil(debtorsState.filtered.length / debtorsState.pageSize));
            if (debtorsState.currentPage >= totalPages) return;
            debtorsState.currentPage += 1;
            renderDebtorsTable();
        });

        newDebtorBtn.addEventListener('click', function () {
            openDebtorModal('create');
        });
        closeDebtorModalBtn.addEventListener('click', closeDebtorModal);
        cancelDebtorModalBtn.addEventListener('click', closeDebtorModal);
        debtorModal.addEventListener('click', function (event) {
            if (event.target === debtorModal) {
                closeDebtorModal();
            }
        });

        if (closeRegisterPaymentModalBtn) closeRegisterPaymentModalBtn.addEventListener('click', closeRegisterPaymentModal);
        if (cancelRegisterPaymentModalBtn) cancelRegisterPaymentModalBtn.addEventListener('click', closeRegisterPaymentModal);
        if (registerPaymentModal) {
            registerPaymentModal.addEventListener('click', function (event) {
                if (event.target === registerPaymentModal) {
                    closeRegisterPaymentModal();
                }
            });
        }

        if (cancelDeleteDebtorBtn) cancelDeleteDebtorBtn.addEventListener('click', closeDeleteDebtorConfirmModal);
        if (confirmDeleteDebtorBtn) confirmDeleteDebtorBtn.addEventListener('click', confirmDeleteDebtor);
        if (deleteDebtorConfirmModal) {
            deleteDebtorConfirmModal.addEventListener('click', function (event) {
                if (event.target === deleteDebtorConfirmModal) {
                    closeDeleteDebtorConfirmModal();
                }
            });
        }

        document.addEventListener('keydown', function (event) {
            if (event.key !== 'Escape') return;
            if (deleteDebtorConfirmModal && !deleteDebtorConfirmModal.classList.contains('hidden')) {
                closeDeleteDebtorConfirmModal();
                return;
            }
            if (debtorModal && !debtorModal.classList.contains('hidden')) {
                closeDebtorModal();
                return;
            }
            closeRegisterPaymentModal();
        });

        function handleDebtorsListClick(event) {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const detailsBtn = target.closest('button[data-action="toggle-debtor-details"]');
            if (detailsBtn) {
                toggleDebtorDetail(detailsBtn.getAttribute('data-id'));
                return;
            }

            const editBtn = target.closest('button[data-action="edit-debtor"]');
            if (editBtn) {
                const debtor = debtorsState.debtors.find(item => sameId(item.id, editBtn.getAttribute('data-id')));
                if (debtor) openDebtorModal('edit', debtor);
                return;
            }

            const deleteBtn = target.closest('button[data-action="delete-debtor"]');
            if (deleteBtn) {
                deleteDebtor(deleteBtn.getAttribute('data-id'));
                return;
            }
        }

        const debtorsTableBody = document.getElementById('debtorsTableBody');
        if (debtorsTableBody) debtorsTableBody.addEventListener('click', handleDebtorsListClick);
        if (debtorsMobileList) debtorsMobileList.addEventListener('click', handleDebtorsListClick);

        if (registerPaymentForm) {
            registerPaymentForm.addEventListener('submit', async function (event) {
                event.preventDefault();
                const target = debtorsState.registeringPaymentTarget;
                if (!target) return;

                const amount = parseCurrencyInput(registerPaymentAmount?.value || 0);
                if (!Number.isFinite(amount) || amount <= 0) {
                    showMessage('Informe um valor válido maior que zero.', 'error');
                    if (registerPaymentAmount) registerPaymentAmount.focus();
                    return;
                }

                const paymentDateValue = String(registerPaymentDate?.value || '').trim() || getLocalTodayDateInputValue();
                const methodValue = String(registerPaymentMethod?.value || 'PIX').trim();

                setRegisterPaymentSaving(true);
                try {
                    const response = await fetch('/api/payments', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({
                            loanId: target.loanId,
                            installmentId: target.installmentId,
                            amount,
                            paymentDate: paymentDateValue,
                            method: methodValue,
                            notes: 'Registrado via Clientes',
                        }),
                    });

                    if (!response.ok) {
                        let message = 'Erro ao registrar pagamento.';
                        try {
                            const payload = await response.json();
                            if (payload?.message) message = payload.message;
                        } catch {}
                        throw new Error(message);
                    }

                    closeRegisterPaymentModal();
                    showMessage('Pagamento registrado com sucesso.', 'success');
                    await loadDebtorsData({ showSkeleton: false });
                } catch (error) {
                    console.error(error);
                    showMessage(error?.message || 'Erro ao registrar pagamento.', 'error');
                } finally {
                    setRegisterPaymentSaving(false);
                }
            });
        }

        if (registerPaymentAmount) {
            registerPaymentAmount.addEventListener('blur', function () {
                registerPaymentAmount.value = formatCurrencyInput(registerPaymentAmount.value);
            });
        }

        newDebtorForm.addEventListener('submit', async function (event) {
            event.preventDefault();

            clearDebtorFormErrors();

            const isEdit = Boolean(debtorsState.editingDebtorId);

            const name = String(newDebtorNameInput?.value || '').trim();
            if (!name) {
                setInlineError(newDebtorNameError, 'Informe o nome.');
                if (newDebtorNameInput) newDebtorNameInput.focus();
                return;
            }

            const phoneDigits = normalizeBrazilPhoneDigits(newDebtorPhoneInput?.value || '');
            if (!phoneDigits || (phoneDigits.length !== 10 && phoneDigits.length !== 11)) {
                    setInlineError(newDebtorPhoneError, 'Informe um telefone válido (10 ou 11 dígitos).');
                if (newDebtorPhoneInput) newDebtorPhoneInput.focus();
                return;
            }

            const cpfDigits = toDigits(newDebtorCpfInput?.value || '');
            if (cpfDigits && !isValidCpfDigits(cpfDigits)) {
                    setInlineError(newDebtorCpfError, 'CPF inválido.');
                if (newDebtorCpfInput) newDebtorCpfInput.focus();
                return;
            }

            const email = String(newDebtorEmailInput?.value || '').trim();
            if (!isValidEmail(email)) {
                    setInlineError(newDebtorEmailError, 'E-mail inválido.');
                if (newDebtorEmailInput) newDebtorEmailInput.focus();
                return;
            }

            const status = normalizeEditableClientStatus(newDebtorStatusInput?.value || 'Ativo');
            const address = String(newDebtorAddressInput?.value || '').trim();

            if (newDebtorPhoneInput) newDebtorPhoneInput.value = formatPhonePartial(phoneDigits);
            if (newDebtorCpfInput) newDebtorCpfInput.value = formatCpfPartial(cpfDigits);
            const cpfValue = cpfDigits || null;

            const basePayload = {
                name,
                phone: phoneDigits,
                cpf: cpfValue,
                document: cpfValue,
                email,
                status,
                address,
            };

            const payload = basePayload;

            const previousDebtors = [...debtorsState.debtors];

            if (debtorsState.editingDebtorId) {
                debtorsState.debtors = debtorsState.debtors.map(debtor =>
                    sameId(debtor.id, debtorsState.editingDebtorId) ? normalizeDebtorRow({ ...debtor, ...payload }) : debtor
                );
            } else {
                const newDebtor = normalizeDebtorRow({
                    ...payload
                });
                debtorsState.debtors = [newDebtor, ...debtorsState.debtors];
            }

            try {
                const persistedDebtors = await saveTableData('debtors', debtorsState.debtors);
                debtorsState.debtors = (Array.isArray(persistedDebtors) ? persistedDebtors : debtorsState.debtors)
                    .map(normalizeDebtorRow);
                updateDebtorMetrics();
                applyDebtorsFilters(true);
                closeDebtorModal();
                showMessage(isEdit ? 'Cliente atualizado com sucesso.' : 'Cliente cadastrado com sucesso.', 'success');
            } catch (error) {
                debtorsState.debtors = previousDebtors;
                updateDebtorMetrics();
                applyDebtorsFilters(false);
                showMessage(error instanceof Error ? error.message : 'Erro ao salvar cliente.', 'error');
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            restoreDebtorMetricsSnapshot();
            loadDebtorsData({ showSkeleton: true });
        });
    </script>
</body>
</html>



