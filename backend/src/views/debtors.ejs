    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        const userNameEl = document.getElementById('userName');
        let fullDisplayName = 'Administrador';

        function getFirstName(name) {
            const normalized = String(name || '').trim().replace(/\s+/g, ' ');
            if (!normalized) return 'Administrador';
            const [firstName] = normalized.split(' ');
            return firstName || 'Administrador';
        }

        function renderHeaderUserName() {
            if (!userNameEl) return;
            const compactMobile = window.matchMedia('(max-width: 640px)').matches;
            const shortName = getFirstName(fullDisplayName);
            const label = compactMobile ? `Olá, ${shortName}` : `Olá, ${fullDisplayName}`;
            userNameEl.textContent = label;
            userNameEl.setAttribute('title', `Olá, ${fullDisplayName}`);
        }

        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            fullDisplayName = currentUser.name || currentUser.full_name || 'Administrador';
            renderHeaderUserName();
        }
        window.addEventListener('resize', renderHeaderUserName);

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const sidebarLinks = document.querySelectorAll('#sidebar .sidebar-item');
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');

        const tableCache = {};
        function getDemoTable(tableName) {
            return Array.isArray(tableCache[tableName]) ? tableCache[tableName] : [];
        }

        async function fetchTableData(tableName) {
            try {
                const response = await fetch(`/api/tables/${tableName}`, { credentials: 'include' });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const payload = await response.json();
                if (Array.isArray(payload?.data)) {
                    tableCache[tableName] = payload.data;
                    return payload.data;
                }
            } catch (error) {
                console.warn(`Fallback para dados demo: ${tableName}`, error);
            }
            return getDemoTable(tableName);
        }

        async function saveTableData(tableName, rows) {
            const safeRows = Array.isArray(rows) ? rows : [];
            const previousRows = Array.isArray(tableCache[tableName]) ? tableCache[tableName] : [];
            tableCache[tableName] = safeRows;

            const response = await fetch(`/api/tables/${tableName}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ rows: safeRows })
            });

            if (!response.ok) {
                tableCache[tableName] = previousRows;

                let details = `HTTP ${response.status}`;
                try {
                    const errorPayload = await response.json();
                    if (errorPayload && typeof errorPayload.message === 'string' && errorPayload.message.trim()) {
                        details = errorPayload.message.trim();
                    }
                } catch (_error) {
                    // Mantem fallback com status HTTP quando nao houver JSON de erro.
                }

                throw new Error(`Falha ao salvar ${tableName}: ${details}`);
            }

            const payload = await response.json().catch(() => null);
            if (Array.isArray(payload?.data)) {
                tableCache[tableName] = payload.data;
            }

            return tableCache[tableName];
        }

        function setActiveSidebarItem(targetHref) {
            sidebarLinks.forEach(link => {
                const isActive = link.getAttribute('href') === targetHref;
                link.classList.toggle('active', isActive);
                if (isActive) link.setAttribute('aria-current', 'page');
                else link.removeAttribute('aria-current');
            });
        }

        function syncActiveSidebarWithRoute() {
            const currentPage = window.location.pathname.split('/').pop() || 'debtors.html';
            setActiveSidebarItem(currentPage);
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                return;
            }
            sidebar.classList.remove('mobile-open');
            main.style.marginLeft = document.body.classList.contains('sidebar-collapsed') ? '0' : '16rem';
        }

        sidebarToggle.addEventListener('click', function() {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();
        syncActiveSidebarWithRoute();

        function closeUserMenu() {
            if (!userMenuDropdown) return;
            userMenuDropdown.classList.add('hidden');
        }

        function showUserMenuNotice(message) {
            if (typeof showMessage === 'function') {
                showMessage(message, 'success');
                return;
            }
            window.alert(message);
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        async function handleUserMenuAction(action) {
            if (action === 'logout') {
                await performLogout();
                return;
            }

            const allowedTabs = new Set(['profile', 'security', 'help']);
            const destination = allowedTabs.has(action) ? action : 'profile';
            window.location.href = `/admin/account.html?tab=${encodeURIComponent(destination)}`;
        }

        if (userMenuBtn && userMenuDropdown) {
            userMenuBtn.addEventListener('click', (event) => {
                event.stopPropagation();
                userMenuDropdown.classList.toggle('hidden');
            });

            userMenuDropdown.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Element)) return;
                const actionBtn = target.closest('[data-user-menu-action]');
                if (!actionBtn) return;
                const action = actionBtn.getAttribute('data-user-menu-action');
                closeUserMenu();
                void handleUserMenuAction(action);
            });

            document.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Node)) return;
                if (userMenuDropdown.classList.contains('hidden')) return;
                if (userMenuDropdown.contains(target) || userMenuBtn.contains(target)) return;
                closeUserMenu();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeUserMenu();
            });
        }

        const debtorsState = {
            debtors: [],
            loans: [],
            installments: [],
            filtered: [],
            currentPage: 1,
            pageSize: window.matchMedia('(max-width: 639px)').matches ? 6 : 8,
            sortField: 'name',
            sortDir: 'asc',
            editingDebtorId: null,
            registeringPaymentTarget: null,
            expandedDebtorIds: new Set()
        };
        const focusDebtorId = String(new URLSearchParams(window.location.search).get('debtorId') || '').trim();
        let hasAppliedDebtorFocus = false;

        const debtorModal = document.getElementById('debtorModal');
        const debtorModalTitle = document.getElementById('debtorModalTitle');
        const newDebtorBtn = document.getElementById('newDebtorBtn');
        const closeDebtorModalBtn = document.getElementById('closeDebtorModalBtn');
        const cancelDebtorModalBtn = document.getElementById('cancelDebtorModalBtn');
        const newDebtorForm = document.getElementById('newDebtorForm');
        const newDebtorNameInput = document.getElementById('newDebtorName');
        const newDebtorPhoneInput = document.getElementById('newDebtorPhone');
        const newDebtorCpfInput = document.getElementById('newDebtorCpf');
        const newDebtorEmailInput = document.getElementById('newDebtorEmail');
        const newDebtorStatusInput = document.getElementById('newDebtorStatus');
        const newDebtorAddressInput = document.getElementById('newDebtorAddress');
        const newDebtorNameError = document.getElementById('newDebtorNameError');
        const newDebtorPhoneError = document.getElementById('newDebtorPhoneError');
        const newDebtorCpfError = document.getElementById('newDebtorCpfError');
        const newDebtorEmailError = document.getElementById('newDebtorEmailError');
        const clearFiltersBtn = document.getElementById('clearFiltersBtn');
        const refreshBtn = document.getElementById('refreshBtn');
        const refreshBtnText = document.getElementById('refreshBtnText');
        const sortBy = document.getElementById('sortBy');
        const prevPageBtn = document.getElementById('prevPageBtn');
        const nextPageBtn = document.getElementById('nextPageBtn');
        const registerPaymentModal = document.getElementById('registerPaymentModal');
        const registerPaymentForm = document.getElementById('registerPaymentForm');
        const registerPaymentDebtorName = document.getElementById('registerPaymentDebtorName');
        const registerPaymentAmount = document.getElementById('registerPaymentAmount');
        const registerPaymentDate = document.getElementById('registerPaymentDate');
