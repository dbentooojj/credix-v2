        let deleteToastHideTimeoutId = null;
        let isDebtorsLoading = false;
        const DEBTORS_METRICS_CACHE_KEY = 'credfacil:debtors-metrics:v1';
        const debtorsModalScrollState = {
            previousBodyOverflow: '',
            openModalIds: new Set(),
        };

        function applyDebtorMetricsSnapshot(snapshot) {
            if (!snapshot || typeof snapshot !== 'object') return;

            const totalDebtors = document.getElementById('totalDebtors');
            const activeDebtors = document.getElementById('activeDebtors');
            const inactiveDebtors = document.getElementById('inactiveDebtors');
            const overdueDebtors = document.getElementById('overdueDebtors');
            const totalDebtorsInsight = document.getElementById('totalDebtorsInsight');
            const activeDebtorsInsight = document.getElementById('activeDebtorsInsight');
            const inactiveDebtorsInsight = document.getElementById('inactiveDebtorsInsight');
            const overdueDebtorsInsight = document.getElementById('overdueDebtorsInsight');

            if (totalDebtors) totalDebtors.textContent = String(snapshot.total);
            if (activeDebtors) activeDebtors.textContent = String(snapshot.active);
            if (inactiveDebtors) inactiveDebtors.textContent = String(snapshot.inactive);
            if (overdueDebtors) overdueDebtors.textContent = String(snapshot.withOverdue);
            if (totalDebtorsInsight) totalDebtorsInsight.textContent = String(snapshot.totalInsight || '');
            if (activeDebtorsInsight) activeDebtorsInsight.textContent = String(snapshot.activeInsight || '');
            if (inactiveDebtorsInsight) inactiveDebtorsInsight.textContent = String(snapshot.inactiveInsight || '');
            if (overdueDebtorsInsight) overdueDebtorsInsight.textContent = String(snapshot.overdueInsight || '');
        }

        function cacheDebtorMetricsSnapshot(snapshot) {
            try {
                localStorage.setItem(DEBTORS_METRICS_CACHE_KEY, JSON.stringify(snapshot));
            } catch (_error) {}
        }

        function restoreDebtorMetricsSnapshot() {
            try {
                const raw = localStorage.getItem(DEBTORS_METRICS_CACHE_KEY);
                if (!raw) return false;
                const snapshot = JSON.parse(raw);
                if (!snapshot || typeof snapshot !== 'object') return false;

                const numericFields = ['total', 'active', 'inactive', 'withOverdue'];
                const hasValidNumbers = numericFields.every((field) => Number.isFinite(Number(snapshot[field])));
                if (!hasValidNumbers) return false;

                applyDebtorMetricsSnapshot({
                    total: Number(snapshot.total),
                    active: Number(snapshot.active),
                    inactive: Number(snapshot.inactive),
                    withOverdue: Number(snapshot.withOverdue),
                    totalInsight: snapshot.totalInsight || '',
                    activeInsight: snapshot.activeInsight || '',
                    inactiveInsight: snapshot.inactiveInsight || '',
                    overdueInsight: snapshot.overdueInsight || '',
                });
                return true;
            } catch (_error) {
                return false;
            }
        }

        function lockBodyScrollForDebtorsModal(modalElement) {
            if (!modalElement) return;
            const modalId = modalElement.id || '';
            if (!modalId || debtorsModalScrollState.openModalIds.has(modalId)) return;

            if (debtorsModalScrollState.openModalIds.size === 0) {
                debtorsModalScrollState.previousBodyOverflow = document.body.style.overflow || '';
                document.body.style.overflow = 'hidden';
            }

            debtorsModalScrollState.openModalIds.add(modalId);
        }

        function unlockBodyScrollForDebtorsModal(modalElement) {
            if (!modalElement) return;
            const modalId = modalElement.id || '';
            if (!modalId || !debtorsModalScrollState.openModalIds.has(modalId)) return;

            debtorsModalScrollState.openModalIds.delete(modalId);

            if (debtorsModalScrollState.openModalIds.size === 0) {
                document.body.style.overflow = debtorsModalScrollState.previousBodyOverflow;
                debtorsModalScrollState.previousBodyOverflow = '';
            }
        }

        function sameId(a, b) {
            return String(a ?? '') === String(b ?? '');
        }

        function getLocalTodayDateInputValue() {
            const now = new Date();
            const yyyy = String(now.getFullYear());
            const mm = String(now.getMonth() + 1).padStart(2, '0');
            const dd = String(now.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        }

        function highlightFocusedDebtorRow(debtorId) {
            const candidates = [
                ...document.querySelectorAll('#debtorsTableBody tr[data-debtor-id]'),
                ...document.querySelectorAll('#debtorsMobileList [data-debtor-id]'),
            ];
            const target = candidates.find(node => sameId(node.getAttribute('data-debtor-id'), debtorId));
