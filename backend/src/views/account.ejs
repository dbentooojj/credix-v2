    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            const displayName = currentUser.name || currentUser.full_name || 'Administrador';
            document.getElementById('userName').textContent = `Olá, ${displayName}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebarLinks = document.querySelectorAll('#sidebar .sidebar-item');
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;

        const profileForm = document.getElementById('profileForm');
        const securityForm = document.getElementById('securityForm');
        const newPasswordInput = document.getElementById('newPassword');
        const passwordStrengthLabel = document.getElementById('passwordStrengthLabel');
        const passwordStrengthBar = document.getElementById('passwordStrengthBar');

        const PASSWORD_RULES = [
            { id: 'pwRuleLen', label: '8+ caracteres', test: (value) => value.length >= 8 },
            { id: 'pwRuleUpper', label: '1 letra maiúscula', test: (value) => /[A-Z]/.test(value) },
            { id: 'pwRuleLower', label: '1 letra minúscula', test: (value) => /[a-z]/.test(value) },
            { id: 'pwRuleDigit', label: '1 número', test: (value) => /\d/.test(value) },
            { id: 'pwRuleSymbol', label: '1 símbolo', test: (value) => /[^A-Za-z0-9]/.test(value) },
            { id: 'pwRuleNoSpace', label: 'sem espaços', test: (value) => !/\s/.test(value) },
        ];

        function setPasswordRuleState(ruleId, ok) {
            const row = document.getElementById(ruleId);
            if (!row) return;
            const icon = row.querySelector('i');
            if (!icon) return;

            if (ok) {
                icon.classList.remove('fa-circle', 'text-slate-400');
                icon.classList.add('fa-check-circle', 'text-emerald-600');
            } else {
                icon.classList.remove('fa-check-circle', 'text-emerald-600');
                icon.classList.add('fa-circle', 'text-slate-400');
            }
        }

        function getPasswordStrengthMeta(password) {
            const total = PASSWORD_RULES.length;
            const passed = PASSWORD_RULES.filter((rule) => rule.test(password)).length;
            const percent = Math.round((passed / total) * 100);

            if (!password) return { label: '-', color: '#94a3b8', percent: 0 };
            if (passed <= 2) return { label: 'Fraca', color: '#ef4444', percent };
            if (passed <= 4) return { label: 'Média', color: '#f59e0b', percent };
            if (passed < total) return { label: 'Boa', color: '#22c55e', percent };
            return { label: 'Forte', color: '#16a34a', percent: 100 };
        }

        function renderPasswordStrength(password) {
            PASSWORD_RULES.forEach((rule) => setPasswordRuleState(rule.id, rule.test(password)));

            const meta = getPasswordStrengthMeta(password);
            if (passwordStrengthLabel) passwordStrengthLabel.textContent = meta.label;
            if (passwordStrengthBar) {
                passwordStrengthBar.style.width = `${meta.percent}%`;
                passwordStrengthBar.style.backgroundColor = meta.color;
            }
        }

        function validateStrongPassword(password) {
            const missing = PASSWORD_RULES.filter((rule) => !rule.test(password)).map((rule) => rule.label);
            return { ok: missing.length === 0, missing };
        }

        function showMessage(message, type) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `fixed left-4 right-4 top-4 rounded-xl px-4 py-3 text-white font-medium z-50 shadow-lg sm:left-auto sm:right-6 sm:top-6 sm:max-w-md sm:px-6 sm:py-4 ${type === 'success' ? 'bg-green-600' : 'bg-red-600'}`;
            messageDiv.innerHTML = `<div class="flex items-center"><i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} mr-3 text-lg"></i><span>${message}</span></div>`;
            document.body.appendChild(messageDiv);
            setTimeout(() => messageDiv.remove(), 3500);
        }

        function setActiveSidebarItem(targetHref) {
            sidebarLinks.forEach((link) => {
                const isActive = link.getAttribute('href') === targetHref;
                link.classList.toggle('active', isActive);
                if (isActive) link.setAttribute('aria-current', 'page');
                else link.removeAttribute('aria-current');
            });
        }

        function syncActiveSidebarWithRoute() {
            const currentPage = window.location.pathname.split('/').pop() || 'account.html';
            setActiveSidebarItem(currentPage);
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                return;
            }
            sidebar.classList.remove('mobile-open');
            main.style.marginLeft = document.body.classList.contains('sidebar-collapsed') ? '0' : '16rem';
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        function closeUserMenu() {
            userMenuDropdown.classList.add('hidden');
        }

        function activateTab(tabName, updateUrl = true) {
            const tabs = ['profile', 'security', 'help'];
            const safe = tabs.includes(tabName) ? tabName : 'profile';

            tabs.forEach((tab) => {
                const panel = document.getElementById(`tab-${tab}`);
                const button = document.querySelector(`[data-account-tab="${tab}"]`);
                if (!panel || !button) return;

                panel.classList.toggle('hidden', tab !== safe);
                button.classList.toggle('active', tab === safe);
            });

            if (updateUrl) {
                const url = new URL(window.location.href);
                url.searchParams.set('tab', safe);
                window.history.replaceState({}, '', url.toString());
            }
        }

        function handleUserMenuAction(action) {
            if (action === 'logout') {
                void performLogout();
                return;
            }
            activateTab(action || 'profile');
        }

        async function saveProfile(event) {
            event.preventDefault();
            const name = document.getElementById('profileName').value.trim();
            const email = document.getElementById('profileEmail').value.trim().toLowerCase();
            if (!name || !email) {
                showMessage('Preencha nome e e-mail.', 'error');
                return;
            }

            try {
                const response = await fetch('/auth/profile', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ name, email }),
                });
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    showMessage(payload?.message || 'Falha ao atualizar perfil.', 'error');
                    return;
                }

                const user = payload?.user;
                if (user) {
                    localStorage.setItem('currentUser', JSON.stringify(user));
                    const displayName = user.name || 'Administrador';
            document.getElementById('userName').textContent = `Olá, ${displayName}`;
                }
                showMessage('Perfil atualizado com sucesso.', 'success');
            } catch {
                showMessage('Erro de conexão ao salvar perfil.', 'error');
            }
        }

        async function savePassword(event) {
            event.preventDefault();
            const currentPassword = document.getElementById('currentPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (newPassword !== confirmPassword) {
                showMessage('A confirmação da nova senha não confere.', 'error');
                return;
            }

            if (newPassword === currentPassword) {
                showMessage('A nova senha deve ser diferente da atual.', 'error');
                return;
            }

            const validation = validateStrongPassword(newPassword);
            if (!validation.ok) {
                showMessage(`Senha fraca. Use: ${validation.missing.join(', ')}.`, 'error');
                return;
            }

            try {
                const response = await fetch('/auth/password', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ currentPassword, newPassword }),
                });
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    const fieldErrors = payload?.issues?.fieldErrors;
                    const serverPasswordErrors = Array.isArray(fieldErrors?.newPassword) ? fieldErrors.newPassword : [];
                    const serverCurrentErrors = Array.isArray(fieldErrors?.currentPassword) ? fieldErrors.currentPassword : [];
                    const serverMessage = serverPasswordErrors[0] || serverCurrentErrors[0] || payload?.message;
                    showMessage(serverMessage || 'Falha ao alterar senha.', 'error');
                    return;
                }

                securityForm.reset();
                renderPasswordStrength('');
                showMessage('Senha alterada com sucesso.', 'success');
            } catch {
                showMessage('Erro de conexão ao alterar senha.', 'error');
            }
        }

        sidebarToggle.addEventListener('click', () => {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();
        syncActiveSidebarWithRoute();

        userMenuBtn.addEventListener('click', (event) => {
            event.stopPropagation();
            userMenuDropdown.classList.toggle('hidden');
        });

        userMenuDropdown.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;
            const actionBtn = target.closest('[data-user-menu-action]');
            if (!actionBtn) return;
            const action = actionBtn.getAttribute('data-user-menu-action');
            closeUserMenu();
            handleUserMenuAction(action);
        });

        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Node)) return;
            if (userMenuDropdown.classList.contains('hidden')) return;
            if (userMenuDropdown.contains(target) || userMenuBtn.contains(target)) return;
            closeUserMenu();
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') closeUserMenu();
        });

        document.querySelectorAll('[data-account-tab]').forEach((button) => {
            button.addEventListener('click', () => {
                activateTab(button.getAttribute('data-account-tab') || 'profile');
            });
        });

        profileForm.addEventListener('submit', saveProfile);
        securityForm.addEventListener('submit', savePassword);
        if (newPasswordInput) {
            newPasswordInput.addEventListener('input', (event) => {
                const target = event.target;
                if (!(target instanceof HTMLInputElement)) return;
                renderPasswordStrength(target.value);
            });
            renderPasswordStrength(newPasswordInput.value || '');
        }

        document.getElementById('profileName').value = currentUser.name || '';
        document.getElementById('profileEmail').value = currentUser.email || '';

        const initialTab = new URLSearchParams(window.location.search).get('tab') || 'profile';
        activateTab(initialTab, false);
    </script>
</body>
</html>









