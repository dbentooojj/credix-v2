<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Credix - Login</title>
<%- include('partials/favicon') %>

<style>
html, body { background-color: #020617; }
</style>
<script>
(() => {
    const root = document.documentElement;
    try {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') root.classList.add('dark');
        if (savedTheme === 'light') root.classList.remove('dark');
    } catch (error) {}
})();

window.tailwind = window.tailwind || {};
window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
</script>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
html { font-size: 16px; }
body {
    font-family: 'Inter', sans-serif;
    color: #d9ecff;
    overflow-x: hidden;
}

:root {
    --login-bg: #060b18;
    --login-surface: rgba(255, 255, 255, 0.04);
    --login-surface-hover: rgba(255, 255, 255, 0.06);
    --login-border: rgba(148, 163, 184, 0.26);
    --login-border-focus: rgba(129, 140, 248, 0.54);
    --login-text: #e5e7eb;
    --login-muted: #a7b0c0;
    --login-placeholder: #93a4bc;
    --login-icon: #9bb7d7;
    --login-link: #a7b0c0;
    --login-link-hover: #d7deea;
    --login-btn-border: rgba(99, 102, 241, 0.52);
    --login-btn-bg-1: #2f5fde;
    --login-btn-bg-2: #2563eb;
    --login-btn-text: #eef2ff;
}

html, body {
    background-color: var(--login-bg);
}

.auth-page {
    background:
        radial-gradient(1200px 560px at 8% -18%, rgba(99, 102, 241, 0.22), transparent 56%),
        radial-gradient(900px 420px at 100% -6%, rgba(37, 99, 235, 0.17), transparent 60%),
        linear-gradient(165deg, #060b18 0%, #0b1220 50%, #111827 100%);
}

.auth-wrapper {
    width: min(100%, 460px);
    padding: 0;
    position: relative;
}

.auth-brand {
    display: flex;
    justify-content: center;
    margin-bottom: 34px;
}

.auth-form-block {
    width: 100%;
    margin: 0;
}

.field-shell {
    width: 100%;
    height: 58px;
    border: 1px solid var(--login-border);
    border-radius: 12px;
    background: var(--login-surface);
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 14px;
    transition: border-color 140ms ease-out, box-shadow 140ms ease-out;
}

.field-shell:focus-within {
    border-color: var(--login-border-focus);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.16);
    background: var(--login-surface-hover);
}

.field-icon {
    color: var(--login-icon);
    font-size: 1rem;
    width: 18px;
    text-align: center;
}

.modern-input {
    background: transparent;
    border: 0;
    color: var(--login-text);
    width: 100%;
    font-size: 1.08rem;
    line-height: 1.2;
    font-weight: 500;
    padding-right: 0;
}

.modern-input::placeholder {
    color: var(--login-placeholder);
    opacity: 0.95;
}

.modern-input:focus {
    outline: none;
}

.password-field {
    position: relative;
}

.password-toggle {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid transparent;
    color: var(--login-placeholder);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 140ms ease-out, background-color 140ms ease-out;
}

.password-toggle:hover {
    color: #dbe4f2;
    background: rgba(148, 163, 184, 0.16);
}

.auth-options {
    margin-top: 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-size: 1.05rem;
}

.remember-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--login-muted);
}

.auth-check {
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.66);
    background: rgba(15, 23, 42, 0.78);
    position: relative;
    cursor: pointer;
    flex-shrink: 0;
}

.auth-check:checked {
    border-color: #10b981;
    background: #10b981;
}

.auth-check:checked::after {
    content: '\f00c';
    position: absolute;
    left: 2px;
    top: -1px;
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    font-size: 9px;
    color: #04291f;
}

.forgot-link {
    color: var(--login-link);
    font-style: italic;
    font-size: 1.05rem;
    transition: color 140ms ease-out;
}

.forgot-link:hover {
    color: var(--login-link-hover);
}

.modern-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 50px;
    border-radius: 12px;
    border: 1px solid rgba(96, 165, 250, 0.6);
    background: linear-gradient(135deg, #3a5ff1 0%, #2f66f5 54%, #2b7ff7 100%);
    color: var(--login-btn-text);
    font-weight: 700;
    font-size: 1.03rem;
    letter-spacing: 0.01em;
    box-shadow: 0 12px 28px -16px rgba(37, 99, 235, 0.9), inset 0 1px 0 rgba(219, 234, 254, 0.3);
    transition: transform 140ms ease-out, filter 140ms ease-out, box-shadow 140ms ease-out, border-color 140ms ease-out;
}

.modern-button:hover {
    transform: translateY(-1px);
    filter: brightness(1.04);
    border-color: rgba(147, 197, 253, 0.72);
    box-shadow: 0 16px 32px -18px rgba(59, 130, 246, 0.95), inset 0 1px 0 rgba(219, 234, 254, 0.34);
}

.modern-button:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.26), 0 12px 28px -16px rgba(37, 99, 235, 0.9), inset 0 1px 0 rgba(219, 234, 254, 0.3);
}

.modern-button:active {
    transform: translateY(0);
}

.login-message {
    border-radius: 11px;
    padding: 10px 12px;
    border: 1px solid transparent;
    font-size: 0.9rem;
}

.login-message.is-warning {
    background: rgba(255, 193, 7, 0.14);
    color: #f6d58d;
    border-color: rgba(255, 193, 7, 0.32);
}

.login-message.is-success {
    background: rgba(64, 217, 174, 0.14);
    color: #95f0d2;
    border-color: rgba(64, 217, 174, 0.34);
}

.login-message.is-error {
    background: rgba(244, 63, 94, 0.15);
    color: #ffcad5;
    border-color: rgba(244, 63, 94, 0.35);
}

.auth-footer {
    margin-top: 22px;
    color: rgba(148, 163, 184, 0.74);
    text-align: center;
    font-size: 0.8rem;
}

@media (max-width: 768px) {
    .auth-form-block {
        margin-top: 0;
    }

    .modern-input {
        font-size: 1rem;
    }

    .modern-button {
        width: 100%;
        height: 46px;
    }
}
</style>
</head>

<body class="auth-page min-h-screen flex items-center justify-center p-4 sm:p-6">
<div class="auth-wrapper">
    <div class="auth-brand">
        <%- include('partials/brand-wordmark', { size: 'login' }) %>
    </div>

    <div class="auth-form-block">
        <form id="loginForm" class="space-y-5">
            <label class="field-shell">
                <span class="sr-only">Email</span>
                <i class="fas fa-user field-icon" aria-hidden="true"></i>
                <input
                    type="email"
                    id="email"
                    required
                    autocomplete="email"
                    class="modern-input"
                    placeholder="Email">
            </label>

            <div class="password-field">
                <label class="field-shell">
                    <span class="sr-only">Senha</span>
                    <i class="fas fa-lock field-icon" aria-hidden="true"></i>
                    <input
                        type="password"
                        id="password"
                        required
                        autocomplete="current-password"
                        class="modern-input"
                        placeholder="Senha">
                </label>
                <button
                    type="button"
                    id="togglePassword"
                    class="password-toggle"
                    aria-label="Mostrar senha"
                    aria-pressed="false">
                    <i class="fas fa-eye"></i>
                </button>
            </div>

            <div class="auth-options">
                <label class="remember-label">
                    <input type="checkbox" id="rememberMe" class="auth-check">
                    <span>Lembrar-me</span>
                </label>
                <a href="/forgot-password" class="forgot-link">Esqueceu?</a>
            </div>

            <div id="loginMessage" class="hidden login-message"></div>

            <button type="submit" class="modern-button">
                Entrar
            </button>
        </form>
        <p class="auth-footer">&copy; 2026 Credix</p>
    </div>
</div>

<script>
async function checkSession() {
    try {
        const response = await fetch('/auth/me', { credentials: 'include' });
        if (response.ok) {
            window.location.href = '/admin/visao-geral.html';
        }
    } catch (error) {
        // Ignora erro de rede aqui e mantem tela de login
    }
}

checkSession();

function showLoginReasonMessage() {
    const params = new URLSearchParams(window.location.search);
    const reason = String(params.get('reason') || '').trim().toLowerCase();
    if (!reason) return;

    const message = document.getElementById('loginMessage');
    if (!message) return;

    if (reason === 'timeout') {
        message.className = 'login-message is-warning';
        message.textContent = 'Sua sessao expirou por inatividade. Faca login novamente.';
        message.classList.remove('hidden');
    } else if (reason === 'reset-success') {
        message.className = 'login-message is-success';
        message.textContent = 'Senha redefinida com sucesso. Entre com sua nova senha.';
        message.classList.remove('hidden');
    }
}

showLoginReasonMessage();

document.getElementById('togglePassword').addEventListener('click', function() {
    const input = document.getElementById('password');
    const icon = this.querySelector('i');

    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye','fa-eye-slash');
        this.setAttribute('aria-label', 'Ocultar senha');
        this.setAttribute('aria-pressed', 'true');
    } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash','fa-eye');
        this.setAttribute('aria-label', 'Mostrar senha');
        this.setAttribute('aria-pressed', 'false');
    }
});

document.getElementById('loginForm').addEventListener('submit', async function(event) {
    event.preventDefault();

    const email = document.getElementById('email').value.trim().toLowerCase();
    const password = document.getElementById('password').value;
    const rememberMe = document.getElementById('rememberMe').checked;
    const message = document.getElementById('loginMessage');

    try {
        const response = await fetch('/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ email, password })
        });

        const payload = await response.json();

        if (!response.ok) {
            throw new Error(payload?.message || 'E-mail ou senha invalidos.');
        }

        localStorage.setItem('isLoggedIn', 'true');
        localStorage.setItem('currentUser', JSON.stringify(payload.user || {}));
        localStorage.setItem('rememberMe', rememberMe ? 'true' : 'false');
        localStorage.setItem('credix:last-activity-at', String(Date.now()));
        localStorage.removeItem('credix:force-logout-at');

        message.className = 'login-message is-success';
        message.textContent = 'Login realizado com sucesso. Redirecionando...';
        message.classList.remove('hidden');

        setTimeout(() => {
            window.location.href = '/admin/visao-geral.html';
        }, 600);
    } catch (error) {
        message.className = 'login-message is-error';
        message.textContent = error.message || 'Falha ao realizar login.';
        message.classList.remove('hidden');
    }
});
</script>
</body>
</html>










