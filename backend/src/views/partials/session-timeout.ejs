<script>
    (function () {
        const idleMinutes = Number(<%= typeof sessionIdleMinutes === 'number' ? sessionIdleMinutes : 30 %>);
        if (!Number.isFinite(idleMinutes) || idleMinutes <= 0) return;

        const IDLE_MS = idleMinutes * 60 * 1000;
        const CHECK_INTERVAL_MS = 15000;
        const ACTIVITY_WRITE_THROTTLE_MS = 12000;
        const LAST_ACTIVITY_KEY = 'credfacil:last-activity-at';
        const FORCE_LOGOUT_KEY = 'credfacil:force-logout-at';

        let lastActivityWriteAt = 0;
        let logoutInProgress = false;
        let inMemoryLastActivityAt = nowMs();

        function nowMs() {
            return Date.now();
        }

        function safeSetLocalStorage(key, value) {
            try {
                localStorage.setItem(key, value);
            } catch (error) {}
        }

        function safeGetLocalStorage(key) {
            try {
                return localStorage.getItem(key);
            } catch (error) {
                return null;
            }
        }

        function markActivity(force) {
            const current = nowMs();
            if (!force && (current - lastActivityWriteAt) < ACTIVITY_WRITE_THROTTLE_MS) return;
            lastActivityWriteAt = current;
            inMemoryLastActivityAt = current;
            safeSetLocalStorage(LAST_ACTIVITY_KEY, String(current));
        }

        function getLastActivity() {
            const raw = safeGetLocalStorage(LAST_ACTIVITY_KEY);
            const parsed = Number(raw);
            if (!Number.isFinite(parsed) || parsed <= 0) return inMemoryLastActivityAt;
            return parsed;
        }

        async function logoutAndRedirect(reason, broadcast) {
            if (logoutInProgress) return;
            logoutInProgress = true;

            if (broadcast) safeSetLocalStorage(FORCE_LOGOUT_KEY, String(nowMs()));

            try {
                await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            } catch (error) {}

            try {
                localStorage.removeItem('isLoggedIn');
                localStorage.removeItem('currentUser');
            } catch (error) {}

            const safeReason = encodeURIComponent(reason || 'timeout');
            window.location.href = `/login?reason=${safeReason}`;
        }

        function checkInactivity() {
            const lastActivity = getLastActivity();
            if (!lastActivity) {
                markActivity(true);
                return;
            }

            if ((nowMs() - lastActivity) >= IDLE_MS) {
                void logoutAndRedirect('timeout', true);
            }
        }

        ['click', 'keydown', 'mousemove', 'touchstart', 'scroll'].forEach((eventName) => {
            window.addEventListener(eventName, () => markActivity(false), { passive: true });
        });

        function handleResumeFromBackground() {
            checkInactivity();
            if (logoutInProgress) return;
            const lastActivity = getLastActivity();
            if ((nowMs() - lastActivity) < IDLE_MS) {
                markActivity(true);
            }
        }

        window.addEventListener('focus', handleResumeFromBackground);
        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'visible') {
                handleResumeFromBackground();
            }
        });
        window.addEventListener('storage', (event) => {
            if (event.key === FORCE_LOGOUT_KEY && event.newValue) {
                void logoutAndRedirect('timeout', false);
            }
        });

        checkInactivity();
        if (!logoutInProgress) {
            markActivity(true);
        }
        window.setInterval(checkInactivity, CHECK_INTERVAL_MS);
    })();
</script>
