        </section>

        <section class="sidebar-section">
            <h3 class="sidebar-section-title">Emprestimos</h3>
            <div class="sidebar-section-menu">
                <a href="/admin/dashboard.html" class="<%= navLinkClass('dashboard.html') %>">
                    <span class="sidebar-icon-slot"><%- icon('dashboard') %></span>
                    <span class="sidebar-item-label">Painel da carteira</span>
                </a>
                <a href="/admin/debtors.html" class="<%= navLinkClass('debtors.html') %>">
                    <span class="sidebar-icon-slot"><%- icon('clients') %></span>
                    <span class="sidebar-item-label">Clientes</span>
                </a>
                <a href="/admin/loans.html" class="<%= navLinkClass('loans.html') %>">
                    <span class="sidebar-icon-slot"><%- icon('loans') %></span>
                    <span class="sidebar-item-label">Emprestimos</span>
                </a>
                <a href="/admin/installments.html" class="<%= navLinkClass('installments.html') %>">
                    <span class="sidebar-icon-slot"><%- icon('installments') %></span>
                    <span class="sidebar-item-label">Parcelas</span>
                </a>
                <a href="/admin/reports.html" class="<%= navLinkClass('reports.html') %>">
                    <span class="sidebar-icon-slot"><%- icon('reports') %></span>
                    <span class="sidebar-item-label">Relatorios</span>
                </a>
            </div>
        </section>

        <section class="sidebar-section">
            <h3 class="sidebar-section-title">Financeiro</h3>
            <div class="sidebar-section-menu">
                <a href="/admin/contas-a-pagar.html" class="<%= navLinkClass('contas-a-pagar.html', 'danger') %>">
                    <span class="sidebar-icon-slot"><%- icon('payable') %></span>
                    <span class="sidebar-item-label">Contas a pagar</span>
                </a>
                <a href="/admin/contas-a-receber.html" class="<%= navLinkClass('contas-a-receber.html', 'success') %>">
                    <span class="sidebar-icon-slot"><%- icon('receivable') %></span>
                    <span class="sidebar-item-label">Contas a receber</span>
                </a>
                <a href="/admin/finance-reports.html" class="<%= navLinkClass('finance-reports.html') %>">
                    <span class="sidebar-icon-slot"><%- icon('reports') %></span>
                    <span class="sidebar-item-label">Relatorios</span>
                </a>
            </div>
        </section>
    </nav>
</aside>
