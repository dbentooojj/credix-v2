<%
    const normalizePageKey = (value) => String(value || '').trim().replace(/^\/+/, '');
    const currentNavPage = normalizePageKey(activePage);
    const isActivePage = (href) => currentNavPage === normalizePageKey(href);
    const navLinkClass = (href, tone = '') => [
        'sidebar-item',
        isActivePage(href) ? 'active text-white' : 'text-slate-300 hover:text-white',
        tone ? `sidebar-item--${tone}` : '',
    ].filter(Boolean).join(' ');

    const icon = (name) => {
        const icons = {
            overview: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.6"></rect><rect x="14" y="3" width="7" height="7" rx="1.6"></rect><rect x="3" y="14" width="7" height="7" rx="1.6"></rect><rect x="14" y="14" width="7" height="7" rx="1.6"></rect></svg>`,
            dashboard: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19V9"></path><path d="M10 19V5"></path><path d="M16 19v-8"></path><path d="M22 19V3"></path></svg>`,
            clients: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path><circle cx="9.5" cy="7" r="3.5"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
            loans: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 17h20"></path><path d="M6 13V7a2 2 0 0 1 2-2h9l5 5v3"></path><path d="M14 5v5h5"></path><path d="M8 21a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"></path><path d="M18 21a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"></path></svg>`,
            installments: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect x="3" y="4" width="18" height="18" rx="3"></rect><path d="M3 10h18"></path><path d="m9 15 2 2 4-4"></path></svg>`,
            reports: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><path d="M14 2v6h6"></path><path d="M8 13h8"></path><path d="M8 17h5"></path><path d="M8 9h3"></path></svg>`,
            payable: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v18"></path><path d="m17 8-5-5-5 5"></path><path d="M5 21h14"></path></svg>`,
            receivable: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v18"></path><path d="m7 16 5 5 5-5"></path><path d="M5 3h14"></path></svg>`,
        };

        return icons[name] || icons.overview;
    };
%>
<style>
    #sidebar.modern-sidebar {
        width: 16rem;
        background:
            radial-gradient(140% 140% at 0% 0%, rgba(37, 99, 235, 0.12), transparent 42%),
            linear-gradient(180deg, rgba(6, 18, 38, 0.98) 0%, rgba(5, 15, 31, 0.98) 100%);
        border-right: 1px solid rgba(59, 130, 246, 0.12);
        box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.02);
    }

    #sidebar .sidebar-scroll {
        height: 100%;
        padding: 1.05rem 0.9rem 1.4rem;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(59, 130, 246, 0.35) transparent;
    }

    #sidebar .sidebar-scroll::-webkit-scrollbar {
        width: 8px;
    }

    #sidebar .sidebar-scroll::-webkit-scrollbar-thumb {
        background: rgba(59, 130, 246, 0.35);
        border-radius: 999px;
    }

    #sidebar .sidebar-section + .sidebar-section {
        margin-top: 1.3rem;
    }

    #sidebar .sidebar-section-title {
        margin: 0 0 0.55rem;
        padding: 0 0.6rem;
        font-size: 0.62rem;
        line-height: 1;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 800;
        color: #6b7280;
    }

    #sidebar .sidebar-section-menu {
        display: flex;
        flex-direction: column;
        gap: 0.22rem;
    }

    #sidebar .sidebar-item {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.74rem;
        min-height: 42px;
        padding: 0.72rem 0.9rem;
        border: 1px solid transparent;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 600;
        line-height: 1.2;
        color: #cbd5e1;
        transition:
            background-color 160ms ease,
            border-color 160ms ease,
            color 160ms ease,
            box-shadow 160ms ease,
            transform 160ms ease;
    }

    #sidebar .sidebar-item:hover {
        background: rgba(15, 23, 42, 0.92);
        border-color: rgba(59, 130, 246, 0.18);
        color: #f8fafc;
        transform: translateX(1px);
    }

    #sidebar .sidebar-item.active {
        background:
            linear-gradient(135deg, rgba(37, 99, 235, 0.38) 0%, rgba(30, 64, 175, 0.3) 100%);
        border-color: rgba(96, 165, 250, 0.34);
        color: #ffffff;
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.08),
            0 14px 24px -22px rgba(37, 99, 235, 0.72);
    }

    #sidebar .sidebar-item.sidebar-item--danger:not(.active) {
        color: #f87171;
    }

    #sidebar .sidebar-item.sidebar-item--success:not(.active) {
        color: #34d399;
    }

    #sidebar .sidebar-item:focus-visible {
        outline: none;
        border-color: rgba(96, 165, 250, 0.4);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18);
    }

    #sidebar .sidebar-icon-slot {
        width: 1rem;
        height: 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #8b95aa;
        flex-shrink: 0;
        transition: color 160ms ease;
    }

    #sidebar .sidebar-icon-slot svg {
        width: 1rem;
        height: 1rem;
        display: block;
    }

    #sidebar .sidebar-item.sidebar-item--danger:not(.active) .sidebar-icon-slot {
        color: #ef4444;
    }

    #sidebar .sidebar-item.sidebar-item--success:not(.active) .sidebar-icon-slot {
        color: #10b981;
    }

    #sidebar .sidebar-item:hover .sidebar-icon-slot,
    #sidebar .sidebar-item.active .sidebar-icon-slot {
        color: #dbeafe;
    }

    #sidebar .sidebar-item-label {
        min-width: 0;
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>

<aside id="sidebar" class="modern-sidebar fixed left-0 top-16 h-[calc(100%-4rem)] w-64 z-40 sm:top-20 sm:h-[calc(100%-5rem)]">
    <nav class="sidebar-scroll" aria-label="Navegacao principal">
        <section class="sidebar-section">
            <div class="sidebar-section-menu">
