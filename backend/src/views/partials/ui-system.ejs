<style>
  :root {
    --app-bg: 2 6 23;
    --card: 15 23 42;
    --input: 30 41 59;
    --border: 148 163 184;
    --text: 226 232 240;
    --muted: 148 163 184;
    --primary: 37 99 235;
  }

  .app-layout {
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
    padding: 2.5rem 1.5rem;
  }

  .app-space-y-8 > * + * {
    margin-top: 2rem;
  }

  .app-form-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr);
  }

  @media (min-width: 768px) {
    .app-form-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .app-card {
    border-radius: 1rem;
    background: rgb(var(--card) / 0.8);
    border: 1px solid rgb(var(--border) / 0.1);
    padding: 1.5rem;
    box-shadow: 0 14px 36px -28px rgba(15, 23, 42, 0.9);
  }

  .app-section-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .app-section-title {
    font-size: 1.9rem;
    line-height: 1.1;
    font-weight: 700;
    color: rgb(var(--text));
    letter-spacing: -0.02em;
  }

  .app-section-subtitle {
    margin-top: 0.35rem;
    font-size: 0.95rem;
    color: rgb(var(--muted));
  }

  .app-field {
    min-width: 0;
  }

  .app-field-label {
    display: block;
    margin-bottom: 0.35rem;
    color: rgb(var(--muted));
    font-size: 0.95rem;
    font-weight: 500;
  }

  .app-field-help {
    margin-top: 0.35rem;
    font-size: 0.78rem;
    color: rgb(var(--muted));
  }

  .app-input,
  .app-select,
  .app-textarea {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgb(255 255 255 / 0.1);
    background: rgb(var(--input) / 0.7);
    color: rgb(var(--text));
    transition: border-color 140ms ease-out, box-shadow 140ms ease-out, background-color 140ms ease-out;
  }

  .app-input,
  .app-select {
    height: 2.75rem;
    padding: 0 0.75rem;
  }

  .app-textarea {
    min-height: 7rem;
    padding: 0.65rem 0.75rem;
    resize: vertical;
  }

  .app-input::placeholder,
  .app-textarea::placeholder {
    color: rgb(var(--muted) / 0.82);
  }

  .app-input:hover,
  .app-select:hover,
  .app-textarea:hover {
    border-color: rgb(255 255 255 / 0.15);
  }

  .app-input:focus,
  .app-select:focus,
  .app-textarea:focus {
    outline: none;
    border-color: rgb(59 130 246 / 1);
    box-shadow: 0 0 0 4px rgb(59 130 246 / 0.2);
  }

  .app-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 0.75rem;
    border: 1px solid transparent;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0 1rem;
    transition: background-color 140ms ease-out, border-color 140ms ease-out, color 140ms ease-out;
  }

  .app-btn-primary {
    height: 3rem;
    color: #fff;
    background: rgb(37 99 235 / 1);
  }

  .app-btn-primary:hover {
    background: rgb(59 130 246 / 1);
  }

  .app-btn-secondary {
    height: 3rem;
    color: rgb(var(--text));
    background: rgb(var(--input) / 0.68);
    border-color: rgb(var(--border) / 0.1);
  }

  .app-btn-secondary:hover {
    background: rgb(var(--input) / 0.86);
    border-color: rgb(var(--border) / 0.22);
  }

  .flatpickr-calendar {
    background: rgb(var(--card) / 0.96) !important;
    border: 1px solid rgb(var(--border) / 0.22) !important;
    box-shadow: 0 16px 44px -24px rgba(2, 6, 23, 0.92) !important;
  }

  .flatpickr-months .flatpickr-month,
  .flatpickr-current-month .flatpickr-monthDropdown-months,
  .flatpickr-current-month input.cur-year,
  .flatpickr-weekdays,
  .flatpickr-weekday,
  .flatpickr-day,
  .flatpickr-time input,
  .flatpickr-time .flatpickr-time-separator,
  .flatpickr-time .flatpickr-am-pm {
    color: rgb(var(--text)) !important;
  }

  .flatpickr-day:hover {
    background: rgb(var(--primary) / 0.2) !important;
    border-color: rgb(var(--primary) / 0.25) !important;
  }

  .flatpickr-day.selected,
  .flatpickr-day.startRange,
  .flatpickr-day.endRange {
    background: rgb(var(--primary) / 1) !important;
    border-color: rgb(var(--primary) / 1) !important;
    color: #fff !important;
  }
</style>

