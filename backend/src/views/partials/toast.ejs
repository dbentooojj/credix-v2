<style>
    #cfToastContainer {
        position: fixed;
        top: 1rem;
        left: 1rem;
        right: 1rem;
        z-index: 90;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        pointer-events: none;
    }

    .cf-toast {
        pointer-events: auto;
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        border-radius: 14px;
        border: 1px solid;
        padding: 0.75rem 0.85rem;
        font-size: 0.92rem;
        font-weight: 600;
        line-height: 1.35;
        backdrop-filter: blur(10px);
        opacity: 0;
        transform: translateY(-6px);
        transition: opacity 170ms ease, transform 170ms ease;
        box-shadow: 0 16px 32px -24px rgba(15, 23, 42, 0.85);
        word-break: break-word;
    }

    .cf-toast.is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    .cf-toast-icon {
        width: 1.8rem;
        height: 1.8rem;
        border-radius: 9999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .cf-toast-text {
        flex: 1 1 auto;
    }

    .cf-toast-success {
        border-color: rgba(16, 185, 129, 0.45);
        background: linear-gradient(135deg, rgba(5, 85, 70, 0.92) 0%, rgba(3, 55, 48, 0.96) 100%);
        color: #d1fae5;
    }

    .cf-toast-success .cf-toast-icon {
        background: rgba(16, 185, 129, 0.22);
        color: #a7f3d0;
        box-shadow: inset 0 0 0 1px rgba(16, 185, 129, 0.36);
    }

    .cf-toast-error {
        border-color: rgba(239, 68, 68, 0.45);
        background: linear-gradient(135deg, rgba(127, 29, 29, 0.92) 0%, rgba(69, 10, 10, 0.96) 100%);
        color: #fee2e2;
    }

    .cf-toast-error .cf-toast-icon {
        background: rgba(239, 68, 68, 0.22);
        color: #fecaca;
        box-shadow: inset 0 0 0 1px rgba(239, 68, 68, 0.36);
    }

    .cf-toast-warning {
        border-color: rgba(245, 158, 11, 0.45);
        background: linear-gradient(135deg, rgba(146, 64, 14, 0.92) 0%, rgba(120, 53, 15, 0.96) 100%);
        color: #fef3c7;
    }

    .cf-toast-warning .cf-toast-icon {
        background: rgba(245, 158, 11, 0.22);
        color: #fcd34d;
        box-shadow: inset 0 0 0 1px rgba(245, 158, 11, 0.36);
    }

    .cf-toast-info {
        border-color: rgba(59, 130, 246, 0.45);
        background: linear-gradient(135deg, rgba(30, 64, 175, 0.92) 0%, rgba(30, 58, 138, 0.96) 100%);
        color: #dbeafe;
    }

    .cf-toast-info .cf-toast-icon {
        background: rgba(59, 130, 246, 0.22);
        color: #bfdbfe;
        box-shadow: inset 0 0 0 1px rgba(59, 130, 246, 0.36);
    }

    @media (min-width: 640px) {
        #cfToastContainer {
            left: auto;
            right: 1.5rem;
            max-width: 420px;
        }
    }
</style>

<script>
    (function () {
        const TOAST_CONTAINER_ID = 'cfToastContainer';
        const MAX_VISIBLE_TOASTS = 3;

        const TOAST_META = {
            success: { icon: 'check', duration: 3000 },
            error: { icon: 'triangle-exclamation', duration: 4000 },
            warning: { icon: 'triangle-exclamation', duration: 3600 },
            info: { icon: 'circle-info', duration: 3000 },
        };

        function normalizeType(type) {
            const raw = String(type || '').trim().toLowerCase();
            if (raw === 'success' || raw === 'error' || raw === 'warning' || raw === 'info') return raw;
            return 'info';
        }

        function resolveDuration(type, options) {
            const customDuration = Number(options && options.duration);
            if (Number.isFinite(customDuration) && customDuration >= 0) return customDuration;
            return TOAST_META[type].duration;
        }

        function ensureContainer() {
            let container = document.getElementById(TOAST_CONTAINER_ID);
            if (container) return container;

            container = document.createElement('div');
            container.id = TOAST_CONTAINER_ID;
            document.body.appendChild(container);
            return container;
        }

        function removeToast(toast) {
            if (!toast || !toast.isConnected) return;
            toast.classList.remove('is-visible');
            window.setTimeout(() => {
                if (toast.isConnected) toast.remove();
            }, 180);
        }

        function buildToastElement(message, type) {
            const meta = TOAST_META[type];
            const toast = document.createElement('div');
            toast.className = `cf-toast cf-toast-${type}`;

            const iconWrap = document.createElement('span');
            iconWrap.className = 'cf-toast-icon';

            const icon = document.createElement('i');
            icon.className = `fas fa-${meta.icon}`;
            iconWrap.appendChild(icon);

            const text = document.createElement('span');
            text.className = 'cf-toast-text';
            text.textContent = message;

            toast.appendChild(iconWrap);
            toast.appendChild(text);
            return toast;
        }

        function showMessage(message, type, options) {
            const text = String(message || '').trim();
            if (!text) return;

            const normalizedType = normalizeType(type);
            const duration = resolveDuration(normalizedType, options);
            const container = ensureContainer();

            while (container.children.length >= MAX_VISIBLE_TOASTS) {
                container.firstElementChild.remove();
            }

            const toast = buildToastElement(text, normalizedType);
            container.appendChild(toast);

            requestAnimationFrame(() => {
                toast.classList.add('is-visible');
            });

            if (duration === 0) return;
            window.setTimeout(() => removeToast(toast), duration);
        }

        window.showMessage = showMessage;
        window.appShowMessage = showMessage;
    })();
</script>
