<%
  const size = (typeof locals?.size === 'string' ? locals.size : 'header');
  const isLogin = size === 'login';
  const wrapperClasses = isLogin
    ? 'inline-flex select-none flex-col items-center gap-2 text-center leading-none'
    : 'inline-flex select-none flex-col leading-none';
  const wordClasses = isLogin
    ? 'text-4xl sm:text-5xl font-semibold tracking-tight'
    : 'text-2xl sm:text-3xl font-semibold tracking-tight';
  const subtitleClasses = isLogin
    ? 'text-[0.72rem] sm:text-sm font-semibold uppercase tracking-[0.22em] text-slate-300'
    : 'mt-1 hidden text-[0.52rem] font-semibold uppercase tracking-[0.18em] text-slate-300/90 xl:block';
%>
<span class="<%= wrapperClasses %>" aria-label="Credix">
  <span class="<%= wordClasses %>">
    <span class="text-white">Cred</span><span class="text-[#D8AF2F]">ix</span>
  </span>
  <span class="<%= subtitleClasses %>">Gerenciamento Inteligente</span>
</span>
