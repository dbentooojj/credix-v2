        function renderDashboard(payload) {
            renderKpis(payload.kpis, payload.kpiCards);
            renderDailySummary(payload.dailySummary);
            renderChart(payload.chart);
            renderUpcoming(payload.upcomingDue);
            renderOverduePayments(payload.overduePayments);
            requestAnimationFrame(syncBottomPanelsHeight);
            document.getElementById('lastRefresh').textContent = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
        }

        async function fetchDashboard() {
            const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || 'America/Sao_Paulo';
            const params = new URLSearchParams({
                period: dashboardState.period,
                metric: dashboardState.metric,
                tz: timezone,
            });

            const response = await fetch(`/api/dashboard?${params.toString()}`, { credentials: 'include' });
            const payload = await response.json().catch(() => null);
            if (!response.ok) throw new Error(payload?.message || 'Falha ao carregar dashboard.');
            return payload;
        }

        async function loadDashboard() {
            setLoading(true);
            try {
                const payload = await fetchDashboard();
                renderDashboard(payload);
            } catch (error) {
                console.error(error);
                showMessage(error instanceof Error ? error.message : 'Erro ao carregar dashboard.', 'error');
            } finally {
                setLoading(false);
            }
        }

        function openCollectionModal(item) {
            dashboardState.selectedCollection = item;
            collectionMessageInput.value = COLLECTION_TEMPLATE;
            collectionPreview.textContent = buildCollectionMessage(item, COLLECTION_TEMPLATE);
            collectionModal.classList.remove('hidden');
            collectionModal.classList.add('flex');
            lockBodyScrollForModal(collectionModal);
        }

        function closeCollectionModal() {
            collectionModal.classList.add('hidden');
            collectionModal.classList.remove('flex');
            unlockBodyScrollForModal(collectionModal);
            dashboardState.selectedCollection = null;
        }

        function setPaymentConfirmLoading(loading) {
            dashboardState.paymentSubmitting = loading;
            confirmPaymentBtn.disabled = loading;
            if (paymentMethodSelect) paymentMethodSelect.disabled = loading;
            if (paymentDateInput) paymentDateInput.disabled = loading;
            confirmPaymentBtn.classList.toggle('opacity-70', loading);
            confirmPaymentBtn.classList.toggle('cursor-not-allowed', loading);
            confirmPaymentBtn.innerHTML = loading
                ? '<i class="fas fa-spinner fa-spin mr-2"></i>Processando...'
                : '<i class="fas fa-check mr-2"></i>Confirmar pagamento';
        }

        function openPaymentConfirmModal(item) {
            if (!item) return;
            dashboardState.selectedPayment = item;
            const method = normalizePaymentMethod(item.paymentMethod || 'PIX');
            if (paymentMethodSelect) paymentMethodSelect.value = method;
            if (paymentDateInput) paymentDateInput.value = getLocalTodayDateInputValue();
            const statusCode = String(item.status || '').toUpperCase();
            const dueRelative = String(item.dueRelative || '').toLowerCase();
            const fallbackStatus = dueRelative.startsWith('ha ') ? 'ATRASADA' : 'EM_DIA';
            const resolvedStatus = statusCode || fallbackStatus;
            const statusLabel = item.statusLabel
                || (resolvedStatus === 'ATRASADA' ? 'Em atraso'
                    : resolvedStatus === 'VENCE_HOJE' ? 'Vence hoje'
                    : 'Em dia');
            const statusClass = resolvedStatus === 'ATRASADA'
                ? 'text-red-600'
                : resolvedStatus === 'VENCE_HOJE'
                    ? 'text-amber-600'
                    : 'text-emerald-600';
            paymentConfirmInfo.innerHTML = `
                <div class="space-y-2">
                    <div class="flex items-center justify-between gap-3"><span class="text-gray-500">Cliente</span><span class="font-semibold text-gray-900">${item.debtorName || '-'}</span></div>
                    <div class="flex items-center justify-between gap-3"><span class="text-gray-500">Parcela</span><span class="font-semibold text-gray-900">#${item.installmentId || '-'}</span></div>
                    <div class="flex items-center justify-between gap-3"><span class="text-gray-500">Vencimento</span><span class="font-semibold text-gray-900">${formatDate(item.dueDate)} (${item.dueRelative || '-'})</span></div>
                    <div class="flex items-center justify-between gap-3"><span class="text-gray-500">Valor</span><span class="font-semibold text-gray-900">${formatCurrency(item.amount)}</span></div>
                    <div class="pt-1 text-xs text-gray-500">Status atual: <span class="font-semibold ${statusClass}">${statusLabel}</span></div>
                </div>
            `;
            setPaymentConfirmLoading(false);
            paymentConfirmModal.classList.remove('hidden');
            paymentConfirmModal.classList.add('flex');
            lockBodyScrollForModal(paymentConfirmModal);
        }

        function closePaymentConfirmModal(force = false) {
            if (dashboardState.paymentSubmitting && !force) return;
            paymentConfirmModal.classList.add('hidden');
            paymentConfirmModal.classList.remove('flex');
            unlockBodyScrollForModal(paymentConfirmModal);
            dashboardState.selectedPayment = null;
            if (paymentDateInput) paymentDateInput.value = '';
            setPaymentConfirmLoading(false);
        }

        function refreshCollectionPreview() {
            const item = dashboardState.selectedCollection;
            if (!item) return;
            collectionPreview.textContent = buildCollectionMessage(item, collectionMessageInput.value);
        }

        async function copyCollectionMessage() {
            const item = dashboardState.selectedCollection;
            if (!item) return;
            const text = buildCollectionMessage(item, collectionMessageInput.value);

            try {
                await navigator.clipboard.writeText(text);
                showMessage('Mensagem copiada.', 'success');
            } catch (error) {
                console.error(error);
                showMessage('Não foi possível copiar a mensagem.', 'error');
            }
        }

        async function markInstallmentAsPaid(item, paymentMethod = 'PIX', paymentDateValue = '') {
            try {
                const candidateDate = String(paymentDateValue || '').trim();
                const paymentDate = /^\d{4}-\d{2}-\d{2}$/.test(candidateDate)
                    ? candidateDate
                    : getLocalTodayDateInputValue();
                const response = await fetch('/api/payments', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({
                        loanId: item.loanId,
                        installmentId: item.installmentId,
                        amount: item.amount,
                        paymentDate,
                        method: normalizePaymentMethod(paymentMethod),
                        notes: `Atualizado via dashboard (${normalizePaymentMethod(paymentMethod)})`,
                    }),
                });

                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    showMessage(payload?.message || 'Falha ao marcar parcela como paga.', 'error');
                    return false;
                }

                showMessage('Parcela marcada como paga.', 'success');
                await loadDashboard();
                return true;
            } catch (error) {
                console.error(error);
                showMessage('Erro de conexão ao marcar como pago.', 'error');
                return false;
            }
        }

        async function confirmPaymentFromModal() {
            if (dashboardState.paymentSubmitting) return;
            const item = dashboardState.selectedPayment;
            if (!item) return;
            const method = normalizePaymentMethod(paymentMethodSelect?.value || item.paymentMethod || 'PIX');
            const paymentDate = String(paymentDateInput?.value || '').trim() || getLocalTodayDateInputValue();
            if (!/^\d{4}-\d{2}-\d{2}$/.test(paymentDate)) {
                showMessage('Informe uma data de pagamento valida.', 'error');
                return;
            }

            setPaymentConfirmLoading(true);
            const success = await markInstallmentAsPaid(item, method, paymentDate);
            setPaymentConfirmLoading(false);
            if (success) closePaymentConfirmModal(true);
        }

        sidebarToggle.addEventListener('click', () => {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        window.addEventListener('resize', () => {
            syncSidebarLayout();
            syncBottomPanelsHeight();
        });
        syncSidebarLayout();
        syncActiveSidebarWithRoute();

        periodSelect.addEventListener('change', async (event) => {
            dashboardState.period = event.target.value;
            await loadDashboard();
        });

        if (chartTypeLineBtn && chartTypeStackedBtn) {
            chartTypeLineBtn.addEventListener('click', () => {
                dashboardState.chartView = 'line';
                localStorage.setItem('dashboardChartView', 'line');
                updateChartTypeButtons();
                renderChart(dashboardState.lastChartPayload);
            });

            chartTypeStackedBtn.addEventListener('click', () => {
                dashboardState.chartView = 'stacked';
                localStorage.setItem('dashboardChartView', 'stacked');
                updateChartTypeButtons();
                renderChart(dashboardState.lastChartPayload);
            });
        }

        if (metricSelect) {
            metricSelect.addEventListener('change', async (event) => {
                dashboardState.metric = event.target.value;
                await loadDashboard();
            });
        }

        document.getElementById('upcomingPrevPageBtn').addEventListener('click', () => {
            if (dashboardState.upcomingPage <= 1) return;
            dashboardState.upcomingPage -= 1;
            renderUpcoming(dashboardState.upcomingItems);
            requestAnimationFrame(syncBottomPanelsHeight);
        });

        document.getElementById('upcomingNextPageBtn').addEventListener('click', () => {
            const totalPages = Math.max(1, Math.ceil(dashboardState.upcomingItems.length / dashboardState.panelPageSize));
            if (dashboardState.upcomingPage >= totalPages) return;
            dashboardState.upcomingPage += 1;
            renderUpcoming(dashboardState.upcomingItems);
            requestAnimationFrame(syncBottomPanelsHeight);
        });

        document.getElementById('overduePrevPageBtn').addEventListener('click', () => {
            if (dashboardState.overduePage <= 1) return;
            dashboardState.overduePage -= 1;
            renderOverduePayments(dashboardState.overdueItems);
            requestAnimationFrame(syncBottomPanelsHeight);
        });

        document.getElementById('overdueNextPageBtn').addEventListener('click', () => {
            const totalPages = Math.max(1, Math.ceil(dashboardState.overdueItems.length / dashboardState.panelPageSize));
            if (dashboardState.overduePage >= totalPages) return;
            dashboardState.overduePage += 1;
            renderOverduePayments(dashboardState.overdueItems);
            requestAnimationFrame(syncBottomPanelsHeight);
        });

        document.getElementById('upcomingList').addEventListener('click', (event) => {
            const actionButton = event.target.closest('button[data-action]');
            if (!actionButton) return;

            const item = dashboardState.upcomingById.get(String(actionButton.getAttribute('data-id')));
            if (!item) return;

            if (actionButton.getAttribute('data-action') === 'mark-paid') {
                openPaymentConfirmModal(item);
            }
        });

        document.getElementById('overdueList').addEventListener('click', (event) => {
            const actionButton = event.target.closest('button[data-action]');
            if (!actionButton) return;

            const item = dashboardState.overdueById.get(String(actionButton.getAttribute('data-id')));
            if (!item) return;

            if (actionButton.getAttribute('data-action') === 'charge') {
                openWhatsAppCharge(item);
                return;
            }

            if (actionButton.getAttribute('data-action') === 'mark-paid') {
                openPaymentConfirmModal(item);
            }
        });

        document.getElementById('closeCollectionModalBtn').addEventListener('click', closeCollectionModal);
        document.getElementById('cancelCollectionBtn').addEventListener('click', closeCollectionModal);
        document.getElementById('copyCollectionBtn').addEventListener('click', copyCollectionMessage);
        collectionMessageInput.addEventListener('input', refreshCollectionPreview);
        collectionModal.addEventListener('click', (event) => {
            if (event.target === collectionModal) closeCollectionModal();
        });
        document.getElementById('closePaymentConfirmModalBtn').addEventListener('click', () => closePaymentConfirmModal());
        document.getElementById('cancelPaymentConfirmBtn').addEventListener('click', () => closePaymentConfirmModal());
        confirmPaymentBtn.addEventListener('click', confirmPaymentFromModal);
        paymentConfirmModal.addEventListener('click', (event) => {
            if (event.target === paymentConfirmModal) closePaymentConfirmModal();
        });

        if (userMenuBtn && userMenuDropdown) {
            userMenuBtn.addEventListener('click', (event) => {
                event.stopPropagation();
                userMenuDropdown.classList.toggle('hidden');
            });

            userMenuDropdown.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Element)) return;
                const actionBtn = target.closest('[data-user-menu-action]');
                if (!actionBtn) return;
                const action = actionBtn.getAttribute('data-user-menu-action');
                closeUserMenu();
                void handleUserMenuAction(action);
            });

            document.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Node)) return;
                if (userMenuDropdown.classList.contains('hidden')) return;
                if (userMenuDropdown.contains(target) || userMenuBtn.contains(target)) return;
                closeUserMenu();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeUserMenu();
            });
        }

        document.addEventListener('DOMContentLoaded', async () => {
            periodSelect.value = dashboardState.period;
            if (metricSelect) metricSelect.value = dashboardState.metric;
            const savedView = localStorage.getItem('dashboardChartView');
            if (savedView === 'stacked' || savedView === 'line') {
                dashboardState.chartView = savedView;
            }
            updateChartTypeButtons();
            await loadDashboard();
        });
    </script>
</body>
</html>

