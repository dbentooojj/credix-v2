    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const authUser = window.__AUTH_USER__;
        if (!authUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(authUser));
            const displayName = authUser.name || authUser.full_name || 'Administrador';
            document.getElementById('userName').textContent = `Olá, ${displayName}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebarLinks = document.querySelectorAll('#sidebar .sidebar-item');
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');
        const collectionModal = document.getElementById('collectionModal');
        const paymentConfirmModal = document.getElementById('paymentConfirmModal');
        const paymentConfirmInfo = document.getElementById('paymentConfirmInfo');
        const paymentDateInput = document.getElementById('paymentDateInput');
        const paymentMethodSelect = document.getElementById('paymentMethodSelect');
        const confirmPaymentBtn = document.getElementById('confirmPaymentBtn');
        const collectionMessageInput = document.getElementById('collectionMessage');
        const collectionPreview = document.getElementById('collectionPreview');
        const periodSelect = document.getElementById('periodSelect');
        const metricSelect = document.getElementById('metricSelect');
        const chartTypeLineBtn = document.getElementById('chartTypeLineBtn');
        const chartTypeStackedBtn = document.getElementById('chartTypeStackedBtn');
        const chartReceivedMonthValue = document.getElementById('chartReceivedMonthValue');
        const chartReceivedMoMValue = document.getElementById('chartReceivedMoMValue');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const modalScrollState = {
            previousBodyOverflow: '',
            openModalIds: new Set(),
        };

        const dashboardState = {
            period: '6m',
            metric: 'recebido',
            chart: null,
            chartView: 'line',
            lastChartPayload: null,
            upcomingById: new Map(),
            overdueById: new Map(),
            upcomingItems: [],
            overdueItems: [],
            upcomingPage: 1,
            overduePage: 1,
            panelPageSize: 5,
            selectedCollection: null,
            selectedPayment: null,
            paymentSubmitting: false,
        };

        const KPI_IDS = [
            'kpiTotalToReceive',
            'kpiTotalOverdue',
            'kpiReceivedThisMonth',
            'kpiTotalLoaned',
            'kpiProfitTotal',
            'kpiTotalReceived',
        ];

        const KPI_CARD_CONFIG = [
            { key: 'totalToReceive', insightId: 'kpiTotalToReceiveInsight', sparklineId: 'kpiTotalToReceiveSparkline' },
            { key: 'totalOverdue', insightId: 'kpiTotalOverdueInsight', sparklineId: 'kpiTotalOverdueSparkline' },
            { key: 'receivedThisMonth', insightId: 'kpiReceivedThisMonthInsight', sparklineId: 'kpiReceivedThisMonthSparkline' },
            { key: 'totalLoaned', insightId: 'kpiTotalLoanedInsight', sparklineId: 'kpiTotalLoanedSparkline' },
            { key: 'profitTotal', insightId: 'kpiProfitTotalInsight', sparklineId: 'kpiProfitTotalSparkline' },
            { key: 'totalReceived', insightId: 'kpiTotalReceivedInsight', sparklineId: 'kpiTotalReceivedSparkline' },
        ];

        function lockBodyScrollForModal(modalElement) {
            if (!modalElement) return;
            const modalId = modalElement.id || '';
            if (!modalId || modalScrollState.openModalIds.has(modalId)) return;

            if (modalScrollState.openModalIds.size === 0) {
                modalScrollState.previousBodyOverflow = document.body.style.overflow || '';
                document.body.style.overflow = 'hidden';
            }

            modalScrollState.openModalIds.add(modalId);
        }

        function unlockBodyScrollForModal(modalElement) {
            if (!modalElement) return;
            const modalId = modalElement.id || '';
            if (!modalId || !modalScrollState.openModalIds.has(modalId)) return;

            modalScrollState.openModalIds.delete(modalId);

            if (modalScrollState.openModalIds.size === 0) {
                document.body.style.overflow = modalScrollState.previousBodyOverflow;
                modalScrollState.previousBodyOverflow = '';
            }
        }

        function formatCurrency(value) {
            const safe = Number.isFinite(Number(value)) ? Number(value) : 0;
            return new Intl.NumberFormat('pt-BR', {
                style: 'currency',
                currency: 'BRL',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            }).format(safe);
        }

        function formatPercent(value) {
            const safe = Number.isFinite(Number(value)) ? Number(value) : 0;
            return `${safe.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}%`;
        }

        function buildKpiInsight(currentValue, previousValue) {
            const current = Number.isFinite(Number(currentValue)) ? Number(currentValue) : 0;
            const previous = Number.isFinite(Number(previousValue)) ? Number(previousValue) : 0;
            const delta = current - previous;

            if (Math.abs(previous) < 0.00001) {
                if (Math.abs(current) < 0.00001) {
                    return {
                        tone: 'neutral',
                        text: '0,00% em relação ao mês anterior',
                    };
                }

                return {
                    tone: delta >= 0 ? 'positive' : 'negative',
                    text: `${delta >= 0 ? '↑' : '↓'} sem base comparativa no mês anterior`,
                };
            }

            const pct = (delta / Math.abs(previous)) * 100;
            const pctText = Math.abs(pct).toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            });

            if (Math.abs(pct) < 0.005) {
                return {
                    tone: 'neutral',
                        text: '0,00% em relação ao mês anterior',
                };
            }

            return {
                tone: pct > 0 ? 'positive' : 'negative',
                text: `${pct > 0 ? '↑' : '↓'} ${pctText}% em relação ao mês anterior`,
            };
        }

        function renderSparkline(svgElement, seriesValues, tone = 'neutral') {
            if (!svgElement) return;

            const values = Array.isArray(seriesValues)
                ? seriesValues
                    .map((value) => Number(value))
                    .filter((value) => Number.isFinite(value))
                : [];

            if (!values.length) {
                svgElement.innerHTML = '';
                return;
            }

            const color = tone === 'positive' ? '#10B981' : tone === 'negative' ? '#F87171' : '#9CA3AF';
            const fillColor = tone === 'positive'
                ? 'rgba(16, 185, 129, 0.15)'
                : tone === 'negative'
                    ? 'rgba(248, 113, 113, 0.15)'
                    : 'rgba(123, 134, 155, 0.13)';
            const glowColor = tone === 'positive'
                ? 'rgba(16, 185, 129, 0.35)'
                : tone === 'negative'
                    ? 'rgba(248, 113, 113, 0.35)'
                    : 'rgba(99, 102, 241, 0.35)';

            const width = 100;
            const height = 34;
            const topPad = 3;
            const bottomPad = 3;
            const usableHeight = height - topPad - bottomPad;
            const minValue = Math.min(...values);
            const maxValue = Math.max(...values);
            const range = maxValue - minValue || 1;
            const stepX = values.length > 1 ? width / (values.length - 1) : width;

            const points = values.map((value, index) => {
                const x = values.length > 1 ? index * stepX : width / 2;
                const normalized = (value - minValue) / range;
                const y = topPad + (1 - normalized) * usableHeight;
                return { x, y };
            });

            const linePath = points
                .map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`)
                .join(' ');
            const firstPoint = points[0];
            const lastPoint = points[points.length - 1];
            const areaPath = `${linePath} L ${lastPoint.x.toFixed(2)} ${(height - 1).toFixed(2)} L ${firstPoint.x.toFixed(2)} ${(height - 1).toFixed(2)} Z`;

            svgElement.innerHTML = `
                <path d="${areaPath}" fill="${fillColor}"></path>
                <path d="${linePath}" fill="none" stroke="${color}" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="filter: drop-shadow(0 0 8px ${glowColor});"></path>
            `;

            const lineElement = svgElement.querySelector('path:last-child');
            if (!lineElement) return;

            const pathLength = lineElement.getTotalLength();
            lineElement.style.strokeDasharray = `${pathLength}`;
            lineElement.style.strokeDashoffset = `${pathLength}`;
            lineElement.style.transition = 'stroke-dashoffset 520ms ease-out';
            requestAnimationFrame(() => {
                lineElement.style.strokeDashoffset = '0';
            });
        }

        function renderKpiCardExtras(kpiCardsPayload) {
            const payload = (kpiCardsPayload && typeof kpiCardsPayload === 'object') ? kpiCardsPayload : {};

            KPI_CARD_CONFIG.forEach((card) => {
                const insightElement = document.getElementById(card.insightId);
                const sparklineElement = document.getElementById(card.sparklineId);
                const metricData = payload[card.key] || {};

                const currentValue = Number(metricData.currentValue ?? 0);
                const previousValue = Number(metricData.previousValue ?? 0);
                const customInsight = metricData.insight && typeof metricData.insight === 'object'
                    ? metricData.insight
                    : null;
                const customTone = customInsight && typeof customInsight.tone === 'string'
                    ? customInsight.tone
                    : '';
                const hasCustomText = Boolean(customInsight && typeof customInsight.text === 'string' && customInsight.text.trim().length > 0);

                const insight = hasCustomText
                    ? {
                        tone: customTone === 'positive' || customTone === 'negative' ? customTone : 'neutral',
                        text: customInsight.text,
                    }
                    : buildKpiInsight(currentValue, previousValue);

                if (insightElement) {
                    insightElement.classList.remove('kpi-insight-positive', 'kpi-insight-negative');
                    if (insight.tone === 'positive') insightElement.classList.add('kpi-insight-positive');
                    if (insight.tone === 'negative') insightElement.classList.add('kpi-insight-negative');
                    insightElement.textContent = insight.text;
                }

                const rawSeries = Array.isArray(metricData.series) ? metricData.series : [];
                const seriesValues = rawSeries.map((point) => {
                    if (typeof point === 'number') return point;
                    if (point && typeof point === 'object' && 'value' in point) return Number(point.value);
                    return Number.NaN;
                });

                renderSparkline(sparklineElement, seriesValues, insight.tone);
            });
        }

        function formatDate(isoDate) {
            if (!isoDate) return '-';
            const date = new Date(`${isoDate}T00:00:00Z`);
            if (Number.isNaN(date.getTime())) return '-';
            return new Intl.DateTimeFormat('pt-BR', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                timeZone: 'UTC',
            }).format(date);
        }

        function getLocalTodayDateInputValue() {
            const now = new Date();
            const local = new Date(now.getTime() - (now.getTimezoneOffset() * 60000));
            return local.toISOString().slice(0, 10);
        }

        function normalizePaymentMethod(value) {
            const method = String(value || '').trim().toUpperCase();
            if (method === 'DINHEIRO' || method === 'TRANSFERENCIA' || method === 'PIX') return method;
            return 'PIX';
        }

        function closeUserMenu() {
            if (!userMenuDropdown) return;
            userMenuDropdown.classList.add('hidden');
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        async function handleUserMenuAction(action) {
            if (action === 'logout') {
                await performLogout();
                return;
            }

            const allowedTabs = new Set(['profile', 'security', 'help']);
            const destination = allowedTabs.has(action) ? action : 'profile';
            window.location.href = `/admin/account.html?tab=${encodeURIComponent(destination)}`;
        }

        function setLoading(loading) {
            KPI_IDS.forEach((id) => {
                const element = document.getElementById(id);
                if (!element) return;
                if (loading) {
                    element.classList.add('skeleton');
                    element.textContent = ' ';
                } else {
                    element.classList.remove('skeleton');
                }
            });
        }

        function replacePlaceholders(template, data) {
            return template
                .replaceAll('{nome}', data.nome || '-')
                .replaceAll('{valor}', data.valor || '-')
                .replaceAll('{vencimento}', data.vencimento || '-')
                .replaceAll('{pix_chave}', data.pix_chave || 'não informado');
        }

        const COLLECTION_TEMPLATE = 'Olá, {nome}. Parcela em aberto: {valor} (venc. {vencimento}).\nChave PIX: {pix_chave}.';

        function buildCollectionData(item) {
            return {
                nome: item?.debtorName,
                valor: formatCurrency(item?.amount),
                vencimento: formatDate(item?.dueDate),
                pix_chave: item?.pixKey || 'não informado',
            };
        }

        function buildCollectionMessage(item, template = COLLECTION_TEMPLATE) {
            return replacePlaceholders(template, buildCollectionData(item));
        }

        function normalizeWhatsAppPhone(rawPhone) {
            const digits = String(rawPhone || '').replace(/\D/g, '');
            if (!digits) return '';

            if (digits.startsWith('55') && digits.length >= 12) return digits;
            if (digits.length === 10 || digits.length === 11) return `55${digits}`;
            if (digits.length > 11) return digits;
            return '';
        }

        function openWhatsAppCharge(item) {
            const phone = normalizeWhatsAppPhone(item?.phone);
            if (!phone) {
                showMessage('Cliente sem telefone válido para WhatsApp.', 'error');
                return;
            }

            const text = buildCollectionMessage(item);
            const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(text)}`;
            const opened = window.open(whatsappUrl, '_blank', 'noopener,noreferrer');
            if (opened) return;

            // Fallback para navegadores que bloqueiam nova aba.
            window.location.href = whatsappUrl;
        }

        function setActiveSidebarItem(targetHref) {
            sidebarLinks.forEach((link) => {
                const isActive = link.getAttribute('href') === targetHref;
                link.classList.toggle('active', isActive);
                if (isActive) link.setAttribute('aria-current', 'page');
                else link.removeAttribute('aria-current');
            });
        }

        function syncActiveSidebarWithRoute() {
            const currentPage = window.location.pathname.split('/').pop() || 'dashboard.html';
            setActiveSidebarItem(currentPage);
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            sidebar.classList.remove('mobile-open');
            if (document.body.classList.contains('sidebar-collapsed')) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            main.style.marginLeft = '16rem';
            main.style.width = 'calc(100% - 16rem)';
            main.style.flex = '0 1 calc(100% - 16rem)';
        }

        function syncBottomPanelsHeight() {
            const upcomingList = document.getElementById('upcomingList');
            const overdueList = document.getElementById('overdueList');
            if (!upcomingList || !overdueList) return;

            const maxVisibleItems = 3;
            const isSingleColumn = window.matchMedia('(max-width: 1279px)').matches;
            const measurePanel = (container, itemSelector) => {
                const items = container.querySelectorAll(itemSelector);
                const itemCount = items.length;
                if (!itemCount) return { itemCount: 0, visibleHeight: 0 };

                const visibleCount = Math.min(itemCount, maxVisibleItems);
                const firstItemRect = items[0].getBoundingClientRect();
                const lastVisibleRect = items[visibleCount - 1].getBoundingClientRect();
                const visibleHeight = Math.ceil(lastVisibleRect.bottom - firstItemRect.top + 2);

                return { itemCount, visibleHeight };
            };

            upcomingList.style.minHeight = '0';
            upcomingList.style.height = 'auto';
            upcomingList.style.maxHeight = 'none';
            overdueList.style.minHeight = '0';
            overdueList.style.height = 'auto';
            overdueList.style.maxHeight = 'none';

            const upcomingMetrics = measurePanel(upcomingList, '.upcoming-item');
            const overdueMetrics = measurePanel(overdueList, '.overdue-item');

            const canEqualize = !isSingleColumn && upcomingMetrics.visibleHeight > 0 && overdueMetrics.visibleHeight > 0;
            const equalizedHeight = canEqualize
                ? Math.max(upcomingMetrics.visibleHeight, overdueMetrics.visibleHeight)
                : 0;

            if (upcomingMetrics.visibleHeight > 0) {
                upcomingList.style.height = `${canEqualize ? equalizedHeight : upcomingMetrics.visibleHeight}px`;
            } else {
                upcomingList.style.height = 'auto';
            }
            upcomingList.style.overflowY = upcomingMetrics.itemCount > maxVisibleItems ? 'auto' : 'hidden';

            if (overdueMetrics.visibleHeight > 0) {
                overdueList.style.height = `${canEqualize ? equalizedHeight : overdueMetrics.visibleHeight}px`;
            } else {
                overdueList.style.height = 'auto';
            }
            overdueList.style.overflowY = overdueMetrics.itemCount > maxVisibleItems ? 'auto' : 'hidden';
        }

        function getPaginationMeta(totalItems, currentPage) {
            const totalPages = Math.max(1, Math.ceil(totalItems / dashboardState.panelPageSize));
            const safePage = Math.min(Math.max(currentPage, 1), totalPages);
            const startIndex = (safePage - 1) * dashboardState.panelPageSize;
            const endIndex = startIndex + dashboardState.panelPageSize;
            return { totalPages, safePage, startIndex, endIndex };
        }

        function updatePaginationControls(prefix, currentPage, totalPages, hasItems) {
            const prevBtn = document.getElementById(`${prefix}PrevPageBtn`);
            const nextBtn = document.getElementById(`${prefix}NextPageBtn`);
            const info = document.getElementById(`${prefix}PageInfo`);
            if (!prevBtn || !nextBtn || !info) return;

            const canGoPrev = hasItems && currentPage > 1;
            const canGoNext = hasItems && currentPage < totalPages;

            prevBtn.disabled = !canGoPrev;
            nextBtn.disabled = !canGoNext;
            prevBtn.classList.toggle('opacity-50', !canGoPrev);
            nextBtn.classList.toggle('opacity-50', !canGoNext);
            info.textContent = hasItems
                ? `Página ${currentPage} de ${totalPages}`
                : 'Sem registros';
        }

        function renderKpis(kpis, kpiCards) {
            document.getElementById('kpiTotalToReceive').textContent = formatCurrency(kpis?.totalToReceive);
            document.getElementById('kpiTotalOverdue').textContent = formatCurrency(kpis?.totalOverdue);
            document.getElementById('kpiReceivedThisMonth').textContent = formatCurrency(kpis?.receivedThisMonth);
            document.getElementById('kpiTotalLoaned').textContent = formatCurrency(kpis?.totalLoaned);
            document.getElementById('kpiProfitTotal').textContent = formatCurrency(kpis?.profitTotal);
            document.getElementById('kpiTotalReceived').textContent = formatCurrency(kpis?.totalReceived);

            const hasToReceive = Number(kpis?.totalToReceive || 0) > 0;
            document.getElementById('kpiOverdueRate').textContent = hasToReceive
                ? `Inadimplência: ${formatPercent(kpis?.delinquencyRate)}`
                : 'Inadimplência: --';

            document.getElementById('kpiRoiRate').textContent = `ROI: ${formatPercent(kpis?.roiRate)}`;

            renderKpiCardExtras(kpiCards);
        }

        function updateChartTypeButtons() {
            if (chartTypeLineBtn) {
                const isLine = dashboardState.chartView === 'line';
                chartTypeLineBtn.classList.toggle('is-active', isLine);
                chartTypeLineBtn.setAttribute('aria-pressed', isLine ? 'true' : 'false');
            }
            if (chartTypeStackedBtn) {
                const isStacked = dashboardState.chartView === 'stacked';
                chartTypeStackedBtn.classList.toggle('is-active', isStacked);
                chartTypeStackedBtn.setAttribute('aria-pressed', isStacked ? 'true' : 'false');
            }
        }

        function renderMonthlyReceivedComparison(points) {
            if (!Array.isArray(points) || points.length === 0) return;

            const currentPoint = points[points.length - 1];
            const prevPoint = points.length >= 2 ? points[points.length - 2] : null;
            const currentValue = Number(currentPoint?.received ?? currentPoint?.value ?? 0) || 0;
            const prevValue = Number(prevPoint?.received ?? prevPoint?.value ?? 0) || 0;

            if (chartReceivedMonthValue) {
                chartReceivedMonthValue.textContent = formatCurrency(currentValue);
            }

            if (!chartReceivedMoMValue) return;

            chartReceivedMoMValue.classList.remove('chart-delta-positive', 'chart-delta-negative', 'chart-delta-neutral');
            chartReceivedMoMValue.classList.add('chart-delta-neutral');

            if (prevPoint === null) {
                chartReceivedMoMValue.textContent = '--';
                return;
            }

            if (prevValue <= 0) {
                chartReceivedMoMValue.textContent = currentValue > 0 ? 'Novo' : '--';
                return;
            }

            const pct = ((currentValue - prevValue) / prevValue) * 100;
            const pctText = `${pct >= 0 ? '+' : ''}${pct.toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 })}%`;
            chartReceivedMoMValue.textContent = pctText;

            if (pct > 0.05) {
                chartReceivedMoMValue.classList.remove('chart-delta-neutral');
                chartReceivedMoMValue.classList.add('chart-delta-positive');
            } else if (pct < -0.05) {
                chartReceivedMoMValue.classList.remove('chart-delta-neutral');
                chartReceivedMoMValue.classList.add('chart-delta-negative');
            }
        }

        function renderDailySummary(summary) {
            const dueToday = summary?.dueToday || { count: 0, totalValue: 0, href: '/admin/installments.html?status=pending&due=today' };
            const overdue = summary?.overdue || { count: 0, totalValue: 0, href: '/admin/installments.html?status=overdue&due=month' };
            const next7 = summary?.next7Days || { count: 0, totalValue: 0, href: '/admin/installments.html?status=pending&due=next7' };

            document.getElementById('dueTodayCount').textContent = String(dueToday.count || 0);
            document.getElementById('dueTodayValue').textContent = formatCurrency(dueToday.totalValue || 0);
            document.getElementById('summaryDueToday').href = dueToday.href;
            document.getElementById('overdueCount').textContent = String(overdue.count || 0);
            document.getElementById('overdueValue').textContent = formatCurrency(overdue.totalValue || 0);
            document.getElementById('summaryOverdue').href = overdue.href;
            document.getElementById('next7Count').textContent = String(next7.count || 0);
            document.getElementById('next7Value').textContent = formatCurrency(next7.totalValue || 0);
            document.getElementById('summaryNext7').href = next7.href;
        }

        function renderChart(chartPayload) {
            dashboardState.lastChartPayload = chartPayload || null;
            const points = Array.isArray(chartPayload?.points) ? chartPayload.points : [];
            const labels = points.map((point) => point.label);
            const receivedValues = points.map((point) => Number(point.received ?? point.value ?? 0));
            const overdueValues = points.map((point) => Number(point.overdue ?? 0));
            const openValues = points.map((point) => Number(point.open ?? 0));
            const hasData = receivedValues.some((value) => value > 0)
                || overdueValues.some((value) => value > 0)
                || openValues.some((value) => value > 0);
            document.getElementById('chartEmptyState').style.display = hasData ? 'none' : 'flex';

            if (dashboardState.chart) dashboardState.chart.destroy();

            renderMonthlyReceivedComparison(points);

            const view = dashboardState.chartView === 'stacked' ? 'stacked' : 'line';
            const isStacked = view === 'stacked';
            const toGlowColor = (color) => {
                if (typeof color !== 'string') return 'rgba(99, 102, 241, 0.24)';
                if (color.startsWith('#')) {
                    const hex = color.replace('#', '');
                    const fullHex = hex.length === 3 ? hex.split('').map((part) => `${part}${part}`).join('') : hex;
                    const r = Number.parseInt(fullHex.slice(0, 2), 16);
                    const g = Number.parseInt(fullHex.slice(2, 4), 16);
                    const b = Number.parseInt(fullHex.slice(4, 6), 16);
                    if (Number.isFinite(r) && Number.isFinite(g) && Number.isFinite(b)) return `rgba(${r}, ${g}, ${b}, 0.24)`;
                    return 'rgba(99, 102, 241, 0.24)';
                }
                if (color.startsWith('rgb(')) return color.replace('rgb(', 'rgba(').replace(')', ', 0.24)');
                if (color.startsWith('rgba(')) {
                    const parts = color.slice(5, -1).split(',').map((part) => part.trim());
                    if (parts.length >= 3) return `rgba(${parts[0]}, ${parts[1]}, ${parts[2]}, 0.24)`;
                }
                return 'rgba(99, 102, 241, 0.24)';
            };
            const chartLineGlowPlugin = {
                id: 'chartLineGlowPlugin',
                beforeDatasetDraw(chart, args) {
                    if (chart.config.type !== 'line') return;
                    const dataset = chart.data.datasets?.[args.index];
                    if (!dataset) return;
                    chart.ctx.save();
                    chart.ctx.shadowBlur = 5;
                    chart.ctx.shadowOffsetX = 0;
                    chart.ctx.shadowOffsetY = 0;
                    chart.ctx.shadowColor = toGlowColor(dataset.borderColor);
                },
                afterDatasetDraw(chart) {
                    if (chart.config.type !== 'line') return;
                    chart.ctx.restore();
                },
            };

            const datasets = isStacked
                ? [
                    {
                        label: 'Recebido',
                        data: receivedValues,
                        backgroundColor: 'rgba(99, 102, 241, 0.64)',
                        borderColor: 'rgba(129, 140, 248, 0.72)',
                        borderWidth: 1,
                        borderRadius: 8,
                        borderSkipped: false,
                    },
                    {
                        label: 'Em aberto',
                        data: openValues,
                        backgroundColor: 'rgba(6, 182, 212, 0.58)',
                        borderColor: 'rgba(34, 211, 238, 0.68)',
                        borderWidth: 1,
                        borderRadius: 8,
                        borderSkipped: false,
                    },
                    {
                        label: 'Atraso',
                        data: overdueValues,
                        backgroundColor: 'rgba(248, 113, 113, 0.56)',
                        borderColor: 'rgba(244, 63, 94, 0.64)',
                        borderWidth: 1,
                        borderRadius: 8,
                        borderSkipped: false,
                    },
                ]
                : [
                    {
                        label: 'Atraso',
                        data: overdueValues,
                        borderColor: '#F87171',
                        backgroundColor: 'rgba(248, 113, 113, 0.14)',
                        borderWidth: 2,
                        fill: true,
                        pointRadius: 2.5,
                        pointHoverRadius: 4,
                        tension: 0.3,
                    },
                    {
                        label: 'Recebido',
                        data: receivedValues,
                        borderColor: '#6366F1',
                        backgroundColor: 'rgba(99, 102, 241, 0.15)',
                        borderWidth: 2,
                        fill: true,
                        pointRadius: 2.5,
                        pointHoverRadius: 4,
                        tension: 0.3,
                    },
                    {
                        label: 'Em aberto',
                        data: openValues,
                        borderColor: '#06B6D4',
                        backgroundColor: 'rgba(6, 182, 212, 0.14)',
                        borderWidth: 2,
                        fill: true,
                        pointRadius: 2.5,
                        pointHoverRadius: 4,
                        tension: 0.3,
                    },
                ];

            dashboardState.chart = new Chart(document.getElementById('monthlyChart').getContext('2d'), {
                type: isStacked ? 'bar' : 'line',
                data: {
                    labels,
                    datasets,
                },
                plugins: isStacked ? [] : [chartLineGlowPlugin],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: {
                        duration: 170,
                        easing: 'easeOutCubic',
                    },
                    plugins: {
                        legend: {
                            display: true,
                            labels: {
                                color: '#A7B0C0',
                                boxWidth: 12,
                                boxHeight: 12,
                                usePointStyle: true,
                                pointStyle: 'circle',
                            },
                        },
                        tooltip: {
                            backgroundColor: 'rgba(9, 14, 26, 0.96)',
                            titleColor: '#E5E7EB',
                            bodyColor: '#C7D2E0',
                            borderColor: 'rgba(255, 255, 255, 0.14)',
                            borderWidth: 1,
                            padding: 10,
                            displayColors: true,
                            callbacks: {
                                label: (context) => `${context.dataset.label}: ${formatCurrency(context.parsed.y)}`,
                            },
                        },
                    },
                    scales: {
                        x: {
                            stacked: isStacked,
                            ticks: { color: '#A3AEC0' },
                            grid: {
                                color: 'rgba(255, 255, 255, 0.06)',
                                drawBorder: false,
                            },
                        },
                        y: {
                            beginAtZero: true,
                            stacked: isStacked,
                            ticks: {
                                color: '#A3AEC0',
                                callback: (value) => formatCurrency(Number(value)),
                            },
                            grid: {
                                color: 'rgba(255, 255, 255, 0.06)',
                                drawBorder: false,
                            },
                        },
                    },
                },
            });
        }

        function renderUpcoming(upcomingDue) {
            const container = document.getElementById('upcomingList');
            dashboardState.upcomingById.clear();
            dashboardState.upcomingItems = Array.isArray(upcomingDue) ? upcomingDue : [];

            if (!dashboardState.upcomingItems.length) {
                container.style.height = 'auto';
                container.style.maxHeight = 'none';
                container.style.overflowY = 'hidden';
                container.innerHTML = '<div class="text-center py-10 text-gray-500"><i class="fas fa-calendar-check text-4xl mb-3 opacity-50"></i><p>Nenhum vencimento em dia.</p></div>';
                dashboardState.upcomingPage = 1;
                updatePaginationControls('upcoming', 1, 1, false);
                return;
            }

            const pagination = getPaginationMeta(dashboardState.upcomingItems.length, dashboardState.upcomingPage);
            dashboardState.upcomingPage = pagination.safePage;
            const pageItems = dashboardState.upcomingItems.slice(pagination.startIndex, pagination.endIndex);

            container.innerHTML = pageItems.map((item) => {
                dashboardState.upcomingById.set(String(item.installmentId), item);
                const statusClass = item.statusColor === 'red' ? 'status-red' : item.statusColor === 'yellow' ? 'status-yellow' : 'status-green';
                return `
                    <article class="upcoming-item">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="font-semibold text-gray-800">${item.debtorName}</p>
                                <p class="text-xs text-gray-500">Venc.: ${formatDate(item.dueDate)} (${item.dueRelative})</p>
                            </div>
                            <div class="flex items-center justify-end gap-2 shrink-0">
                                <div class="flex flex-col items-end text-right leading-tight">
                                    <p class="font-semibold text-gray-800">${formatCurrency(item.amount)}</p>
                                    <span class="status-pill mt-1 inline-flex ${statusClass}">${item.statusLabel}</span>
                                </div>
                                <button type="button" data-action="mark-paid" data-id="${item.installmentId}" class="quick-action-btn overdue-pay-btn self-center">Pagar<i class="fas fa-check ml-1"></i></button>
                            </div>
                        </div>
                    </article>
                `;
            }).join('');

            updatePaginationControls('upcoming', pagination.safePage, pagination.totalPages, true);
        }

        function renderOverduePayments(overduePayments) {
            const container = document.getElementById('overdueList');
            dashboardState.overdueById.clear();
            dashboardState.overdueItems = Array.isArray(overduePayments) ? overduePayments : [];

            if (!dashboardState.overdueItems.length) {
                container.style.height = 'auto';
                container.style.maxHeight = 'none';
                container.style.overflowY = 'hidden';
                container.innerHTML = '<div class="text-center py-8 text-gray-500"><i class="fas fa-circle-check text-4xl mb-3 opacity-50"></i><p>Sem pagamentos atrasados.</p></div>';
                dashboardState.overduePage = 1;
                updatePaginationControls('overdue', 1, 1, false);
                return;
            }

            const pagination = getPaginationMeta(dashboardState.overdueItems.length, dashboardState.overduePage);
            dashboardState.overduePage = pagination.safePage;
            const pageItems = dashboardState.overdueItems.slice(pagination.startIndex, pagination.endIndex);

            container.innerHTML = pageItems.map((item) => {
                dashboardState.overdueById.set(String(item.installmentId), item);
                return `
                    <article class="overdue-item upcoming-item">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="font-semibold text-gray-800">${item.debtorName}</p>
                                <p class="text-xs text-gray-500">Venc.: ${formatDate(item.dueDate)} (${item.dueRelative})</p>
                            </div>
                            <div class="text-right">
                                <p class="font-semibold text-gray-800">${formatCurrency(item.amount)}</p>
                                <span class="status-pill status-red">Em atraso</span>
                            </div>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <button type="button" data-action="charge" data-id="${item.installmentId}" class="quick-action-btn overdue-charge-btn"><i class="fab fa-whatsapp mr-1"></i>Cobrar no WhatsApp</button>
                            <button type="button" data-action="mark-paid" data-id="${item.installmentId}" class="quick-action-btn overdue-pay-btn">Pagar<i class="fas fa-check ml-1"></i></button>
                        </div>
                    </article>
                `;
            }).join('');

            updatePaginationControls('overdue', pagination.safePage, pagination.totalPages, true);
