            }

            if (action === 'collect-now') {
                const globalCollectionAction = typeof window.startGlobalCollection === 'function'
                    ? window.startGlobalCollection
                    : typeof window.openGlobalCollection === 'function'
                        ? window.openGlobalCollection
                        : null;
                if (globalCollectionAction) {
                    globalCollectionAction();
                    return;
                }
                showReportFeedback('Abrindo parcelas em atraso para cobrança.', 'info');
                window.location.href = 'installments.html?status=overdue';
                return;
            }

            if (action === 'export-risk-csv') {
                exportRiskListCsv();
            }
        }

        function renderStatusDistribution(installments, metrics = null) {
            const container = document.getElementById('statusDistribution');
            if (!container) return;

            const safeMetrics = metrics || calculateReportMetrics(installments);
            const statusCounts = installments.reduce((acc, installment) => {
                const status = normalizeInstallmentStatus(installment);
                acc[status] = (acc[status] || 0) + 1;
                return acc;
            }, { Pago: 0, Pendente: 0, Atrasado: 0 });
            const totalInstallments = installments.length;

            if (!totalInstallments) {
                container.innerHTML = '<div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-8 text-center text-sm text-slate-500">Sem parcelas no filtro atual para distribuição.</div>';
                return;
            }

            const rows = [
                { key: 'Pago', color: '#22c55e', badge: 'badge-success' },
                { key: 'Pendente', color: '#f59e0b', badge: 'badge-warn' },
                { key: 'Atrasado', color: '#ef4444', badge: 'badge-danger' }
            ];
            const amounts = installments.reduce((acc, installment) => {
                const status = normalizeInstallmentStatus(installment);
                const outstanding = getInstallmentOutstanding(installment, status);
                if (status === 'Atrasado') acc.overdue += outstanding;
                if (status !== 'Pago') acc.open += outstanding;
                return acc;
            }, { overdue: 0, open: 0 });
            const paidPct = ((statusCounts.Pago || 0) / totalInstallments) * 100;
            const pendingPct = ((statusCounts.Pendente || 0) / totalInstallments) * 100;
            const overduePct = ((statusCounts.Atrasado || 0) / totalInstallments) * 100;
            const gradient = `conic-gradient(#22c55e 0% ${paidPct}%, #f59e0b ${paidPct}% ${paidPct + pendingPct}%, #ef4444 ${paidPct + pendingPct}% 100%)`;
            const openCount = (statusCounts.Pendente || 0) + (statusCounts.Atrasado || 0);
            const riskRows = buildRiskClientRows(installments);
            const concentrationBase = Math.max(toNumber(safeMetrics.totalExpected), 0) || Math.max(riskRows.reduce((sum, row) => sum + row.openAmount, 0), 1);
            const top1Amount = riskRows[0]?.openAmount || 0;
            const top3Amount = riskRows.slice(0, 3).reduce((sum, row) => sum + row.openAmount, 0);
            const top1Pct = top1Amount / concentrationBase;
            const top3Pct = top3Amount / concentrationBase;
            const isHighConcentration = top1Pct > 0.35;
            const criticalRows = riskRows.slice(0, 5);

            container.innerHTML = `
                ${reportComponents.riskPanel({
                    overduePercent: overduePct,
                    overdueCount: statusCounts.Atrasado || 0,
                    openCount,
                    overdueAmount: amounts.overdue,
                    openAmount: amounts.open,
                })}
                <div class="risk-layout">
                    <section class="risk-block">
                        <p class="risk-block-title">Distribuição de status</p>
                        <div class="risk-distribution-grid">
                            <div class="relative mx-auto h-40 w-40 rounded-full" style="background:${gradient};">
                                <div class="absolute inset-[14px] flex flex-col items-center justify-center rounded-full bg-white text-center text-slate-700">
                                    <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Atraso</p>
                                    <p class="text-xl font-bold text-red-600">${formatPercentAbsolute(overduePct)}</p>
                                </div>
                            </div>
                            <div class="space-y-3">
                                ${rows.map((row) => {
                                    const count = statusCounts[row.key] || 0;
                                    const percentage = totalInstallments > 0 ? (count / totalInstallments) * 100 : 0;
                                    return `
                                        <div>
                                            <div class="mb-1 flex items-center justify-between">
                                                <span class="badge ${row.badge}">${row.key}</span>
                                                <span class="text-sm text-slate-600">${count} (${formatPercentAbsolute(percentage)})</span>
                                            </div>
                                            <div class="progress-track" role="progressbar" aria-valuenow="${percentage.toFixed(2)}" aria-valuemin="0" aria-valuemax="100" aria-label="${row.key}">
                                                <div class="progress-fill" style="width:${percentage}%; background:${row.color};"></div>
                                            </div>
                                        </div>
                                    `;
                                }).join('')}
                            </div>
                        </div>
                    </section>

                    <section class="risk-block">
                        <p class="risk-block-title">Concentração</p>
                        <div class="risk-concentration-grid">
                            <article class="risk-concentration-item">
                                <p class="risk-concentration-label">Top 1 cliente</p>
                                <p class="risk-concentration-value">${formatPercent(top1Pct)}</p>
                                <p class="risk-concentration-meta">${formatCurrency(top1Amount)} do total</p>
                            </article>
                            <article class="risk-concentration-item">
                                <p class="risk-concentration-label">Top 3 clientes</p>
                                <p class="risk-concentration-value">${formatPercent(top3Pct)}</p>
                                <p class="risk-concentration-meta">${formatCurrency(top3Amount)} do total</p>
                            </article>
                        </div>
                        <div class="mt-3">
                            <span class="risk-pill ${isHighConcentration ? 'risk-pill-high' : ''}">
                                ${isHighConcentration ? 'Concentração Alta' : 'Concentração Controlada'}
                            </span>
                        </div>
                    </section>
                </div>

                <section class="risk-block mt-3">
                    <div class="flex items-center justify-between gap-2">
                        <p class="risk-block-title">Clientes críticos</p>
                        <span class="text-xs font-semibold text-slate-500">Top 5</span>
                    </div>
                    <div class="critical-list">
                        ${criticalRows.length ? criticalRows.map((row, index) => `
                            <article class="critical-item">
                                <div>
                                    <p class="critical-name">${index + 1}. ${escapeHtml(row.name)}</p>
                                    <p class="critical-meta">Atraso ${formatCurrency(row.overdueAmount)} | ${row.avgOverdueDays.toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 })} dias | Score ${row.scoreCliente.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}</p>
                                </div>
                                <a href="debtors.html?client=${encodeURIComponent(row.id)}" class="action-btn action-btn-soft py-1.5 text-xs">Ver cliente</a>
                            </article>
                        `).join('') : '<p class="rounded-lg border border-dashed border-slate-300 bg-white px-3 py-3 text-sm text-slate-500">Sem clientes críticos no filtro atual.</p>'}
                    </div>
                </section>

                <section class="risk-block mt-3">
                    <p class="risk-block-title">Ações rápidas</p>
                    <div class="risk-actions">
                        <button type="button" data-risk-action="view-overdue" class="action-btn action-btn-soft text-xs">
                            <i class="fas fa-triangle-exclamation mr-1"></i>Ver parcelas em atraso
                        </button>
                        <button type="button" data-risk-action="collect-now" class="action-btn action-btn-soft text-xs">
                            <i class="fas fa-bullhorn mr-1"></i>Cobrar agora
                        </button>
                        <button type="button" data-risk-action="export-risk-csv" class="action-btn action-btn-soft text-xs">
                            <i class="fas fa-file-export mr-1"></i>Exportar lista de risco
                        </button>
                    </div>
                </section>
            `;
        }

        function buildTopDebtorsRows(installments) {
            const grouped = new Map();
            installments.forEach((installment) => {
                const debtorId = String(installment.debtor_id ?? '');
                if (!debtorId) return;

                if (!grouped.has(debtorId)) {
                    grouped.set(debtorId, {
                        id: debtorId,
                        overdueInstallments: 0,
                        overdueAmount: 0,
                        openAmount: 0,
                        lastPaymentDate: null,
                    });
                }

                const status = normalizeInstallmentStatus(installment);
                const outstanding = getInstallmentOutstanding(installment, status);
                const row = grouped.get(debtorId);

                if (status === 'Atrasado') {
                    row.overdueInstallments += 1;
                    row.overdueAmount += outstanding;
                }
                if (status !== 'Pago') {
                    row.openAmount += outstanding;
                } else if (installment.payment_date) {
                    const paymentDate = startOfDay(installment.payment_date);
                    if (paymentDate && (!row.lastPaymentDate || paymentDate > row.lastPaymentDate)) {
                        row.lastPaymentDate = paymentDate;
                    }
                }
            });

            return Array.from(grouped.values())
                .filter((row) => row.overdueInstallments > 0 || row.openAmount > 0)
                .map((row) => {
                    const debtor = getDebtorById(row.id);
                    return {
                        ...row,
                        name: debtor?.name || `Cliente #${row.id}`,
                    };
                })
                .sort((a, b) => (b.overdueAmount - a.overdueAmount) || (b.openAmount - a.openAmount));
        }

