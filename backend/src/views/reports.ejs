        async function loadReportsData() {
            setLoadingState(true);
            try {
                const [loans, installments, debtors] = await Promise.all([
                    fetchTableData('loans'),
                    fetchTableData('installments'),
                    fetchTableData('debtors'),
                ]);

                reportsState.loans = (Array.isArray(loans) ? loans : []).map(normalizeLoanRow);
                reportsState.installments = (Array.isArray(installments) ? installments : []).map(normalizeInstallmentRow);
                reportsState.debtors = (Array.isArray(debtors) ? debtors : []).map(normalizeDebtorRow);

                buildLoanFrequencyMap();
                populateReportClientFilter();
                updateReportCustomRangeVisibility();
                setLoadingState(false);
                applyReportFilters();
            } catch (error) {
                console.error('Erro ao carregar relatórios:', error);
                setLoadingState(false);
                showReportFeedback('Erro ao carregar dados dos relatórios.', 'error');
                document.getElementById('reportChart').innerHTML = '<p class="text-red-600">Erro ao carregar gráfico.</p>';
                document.getElementById('statusDistribution').innerHTML = '<p class="text-red-600">Erro ao carregar dados.</p>';
                document.getElementById('nextDueList').innerHTML = '<p class="text-red-600">Erro ao carregar dados.</p>';
                document.getElementById('topDebtorsTable').innerHTML = '<tr><td colspan="6" class="text-center py-8 text-red-600">Erro ao carregar dados.</td></tr>';
                document.getElementById('recentPaidTable').innerHTML = '<tr><td colspan="4" class="text-center py-8 text-red-600">Erro ao carregar dados.</td></tr>';
                document.getElementById('reportInsightsList').innerHTML = '<li class="rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-red-700">Erro ao gerar insights.</li>';
            }
        }

        function normalizeInterestType(value) {
            const raw = normalizeAscii(value);
            if (raw.includes('simples')) return 'simples';
            if (raw.includes('fixo')) return 'fixo';
            return 'composto';
        }

        function normalizeLoanRow(row) {
            return {
                ...row,
                id: row.id,
                debtor_id: row.debtor_id ?? row.client_id ?? row.clientId,
                principal_amount: round2(row.principal_amount ?? row.principalAmount ?? 0),
                total_amount: round2(row.total_amount ?? row.totalAmount ?? 0),
                installments_count: Math.max(1, Math.trunc(toNumber(row.installments_count ?? row.installments ?? row.installmentsCount ?? 1))),
                interest_type: normalizeInterestType(row.interest_type ?? row.interestType),
            };
        }

        function normalizeDebtorRow(row) {
            return {
                ...row,
                id: row.id,
                name: row.name || row.full_name || 'Cliente sem nome',
                phone: row.phone || '',
                document: row.document || row.cpf || '',
            };
        }

        function buildLoanFrequencyMap() {
            const map = new Map();
            reportsState.loans.forEach((loan) => map.set(String(loan.id), 'mensal'));

            const grouped = new Map();
            reportsState.installments.forEach((installment) => {
                const key = String(installment.loan_id ?? '');
                if (!key) return;
                if (!grouped.has(key)) grouped.set(key, []);
                grouped.get(key).push(installment);
            });

            grouped.forEach((rows, loanId) => {
                const sorted = rows
                    .map((item) => startOfDay(item.due_date))
                    .filter((item) => item instanceof Date)
                    .sort((a, b) => a.getTime() - b.getTime());
                if (sorted.length < 2) return;

                let totalDiff = 0;
                let count = 0;
                for (let index = 1; index < sorted.length; index += 1) {
                    const diff = Math.round((sorted[index].getTime() - sorted[index - 1].getTime()) / (24 * 60 * 60 * 1000));
                    if (Number.isFinite(diff) && diff > 0) {
                        totalDiff += diff;
                        count += 1;
                    }
                }
                if (!count) return;
                map.set(loanId, (totalDiff / count) <= 17 ? 'quinzenal' : 'mensal');
            });

            reportsState.loanFrequencyById = map;
        }

        function getLoanFrequency(loanId) {
            return reportsState.loanFrequencyById.get(String(loanId ?? '')) || 'mensal';
        }

        function parseOptionalNumber(value) {
            const raw = String(value ?? '').trim();
            if (!raw) return null;
            const normalized = raw
                .replace(/\s/g, '')
                .replace(/\.(?=\d{3}(?:\D|$))/g, '')
                .replace(',', '.');
            const parsed = Number(normalized);
            return Number.isFinite(parsed) ? parsed : null;
        }

        function getPeriodBounds(periodValue) {
            const today = startOfDay(new Date());
            if (!today) return { start: null, end: null };

            if (periodValue === 'month_current') {
                return { start: new Date(today.getFullYear(), today.getMonth(), 1), end: today };
            }
            if (periodValue === 'month_previous') {
                const prevMonthStart = new Date(today.getFullYear(), today.getMonth() - 1, 1);
                const prevMonthEnd = new Date(today.getFullYear(), today.getMonth(), 0);
                prevMonthEnd.setHours(0, 0, 0, 0);
                return { start: prevMonthStart, end: prevMonthEnd };
            }
            if (periodValue === 'last7') {
                const start = new Date(today.getTime());
                start.setDate(start.getDate() - 6);
                return { start, end: today };
            }
            if (periodValue === 'last15') {
                const start = new Date(today.getTime());
                start.setDate(start.getDate() - 14);
                return { start, end: today };
            }
            if (periodValue === 'last30') {
                const start = new Date(today.getTime());
                start.setDate(start.getDate() - 29);
                return { start, end: today };
            }
            if (periodValue === 'custom') {
                let start = startOfDay(document.getElementById('reportCustomStartDate')?.value || '');
                let end = startOfDay(document.getElementById('reportCustomEndDate')?.value || '');
                if (start && end && start > end) {
                    const temp = start;
                    start = end;
                    end = temp;
                }
                return { start, end };
            }

            return { start: null, end: null };
        }

        function getPreviousPeriodBounds(start, end) {
            if (!start || !end) return { start: null, end: null };
            const startDate = startOfDay(start);
            const endDate = startOfDay(end);
            if (!startDate || !endDate || endDate < startDate) return { start: null, end: null };

            const dayMs = 24 * 60 * 60 * 1000;
            const durationDays = Math.max(1, Math.round((endDate.getTime() - startDate.getTime()) / dayMs) + 1);
            const previousEnd = new Date(startDate.getTime() - dayMs);
            const previousStart = new Date(previousEnd.getTime() - ((durationDays - 1) * dayMs));
            previousStart.setHours(0, 0, 0, 0);
            previousEnd.setHours(0, 0, 0, 0);
            return { start: previousStart, end: previousEnd };
        }

        function filterInstallments(sourceInstallments, filters = {}) {
            const {
                clientValue = 'all',
                clientSearch = '',
                statusValue = 'all',
                interestTypeValue = 'all',
                frequencyValue = 'all',
                minValue = null,
                maxValue = null,
                onlyOverdue = false,
                start = null,
                end = null,
            } = filters;

            const normalizedSearch = normalizeAscii(clientSearch);
            const minAmount = parseOptionalNumber(minValue);
            const maxAmount = parseOptionalNumber(maxValue);

            return sourceInstallments.filter((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const referenceDate = getInstallmentReferenceDate(installment, status);
                const amount = toNumber(installment.amount);

                if (clientValue !== 'all' && !sameId(installment.debtor_id, clientValue)) return false;
                if (statusValue === 'paid' && status !== 'Pago') return false;
                if (statusValue === 'pending' && status !== 'Pendente') return false;
                if (statusValue === 'overdue' && status !== 'Atrasado') return false;
                if (onlyOverdue && status !== 'Atrasado') return false;

                if (start && (!referenceDate || referenceDate < start)) return false;
                if (end && (!referenceDate || referenceDate > end)) return false;

                const loan = getLoanById(installment.loan_id);
                if (interestTypeValue !== 'all' && normalizeInterestType(loan?.interest_type) !== interestTypeValue) return false;
                if (frequencyValue !== 'all' && getLoanFrequency(installment.loan_id) !== frequencyValue) return false;

                if (minAmount !== null && amount < minAmount) return false;
                if (maxAmount !== null && amount > maxAmount) return false;

                if (normalizedSearch) {
                    const debtor = getDebtorById(installment.debtor_id);
                    const haystack = [
                        debtor?.name || '',
                        debtor?.phone || '',
                        debtor?.document || '',
                        String(installment.loan_id ?? ''),
                    ].map(normalizeAscii).join(' ');
                    if (!haystack.includes(normalizedSearch)) return false;
                }

                return true;
            });
        }

        function calculateReportMetrics(installments) {
            const loanIds = new Set();
            const clientIds = new Set();
            const metrics = {
                totalLoaned: 0,
                totalExpected: 0,
                totalReceived: 0,
                totalOpen: 0,
                totalOverdue: 0,
                estimatedProfit: 0,
                delinquencyRate: 0,
                ticketAverage: 0,
                totalCount: installments.length,
                paidCount: 0,
                pendingCount: 0,
                overdueCount: 0,
                uniqueLoanCount: 0,
                uniqueClientCount: 0,
            };

            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const amount = toNumber(installment.amount);
                const principal = getInstallmentPrincipal(installment);
                const received = getInstallmentPaidAmount(installment, status);
                const outstanding = getInstallmentOutstanding(installment, status);

                metrics.totalExpected += amount;
                metrics.totalLoaned += principal;
                metrics.totalReceived += received;
                if (status !== 'Pago') metrics.totalOpen += outstanding;
                if (status === 'Atrasado') metrics.totalOverdue += outstanding;

                if (status === 'Pago') metrics.paidCount += 1;
                if (status === 'Pendente') metrics.pendingCount += 1;
                if (status === 'Atrasado') metrics.overdueCount += 1;

                if (installment.loan_id !== null && installment.loan_id !== undefined) loanIds.add(String(installment.loan_id));
                if (installment.debtor_id !== null && installment.debtor_id !== undefined) clientIds.add(String(installment.debtor_id));
            });

            metrics.uniqueLoanCount = loanIds.size;
            metrics.uniqueClientCount = clientIds.size;
            metrics.estimatedProfit = metrics.totalExpected - metrics.totalLoaned;
            metrics.delinquencyRate = metrics.totalExpected > 0 ? (metrics.totalOverdue / metrics.totalExpected) : 0;
            metrics.ticketAverage = loanIds.size > 0
                ? (metrics.totalLoaned / loanIds.size)
                : clientIds.size > 0
                    ? (metrics.totalLoaned / clientIds.size)
                    : 0;

            return metrics;
        }

        function buildPeriodInsights(installments, metrics) {
            const insights = [];
            const uniqueClients = new Set(
                installments.map((installment) => String(installment.debtor_id ?? '')).filter(Boolean)
            ).size;

            const expected = toNumber(metrics.totalExpected);
            const receivedRate = expected > 0 ? (toNumber(metrics.totalReceived) / expected) : 0;
            insights.push(`Você emprestou ${formatCurrency(metrics.totalLoaned)} para ${uniqueClients} cliente(s).`);
            insights.push(`Recebeu ${formatCurrency(metrics.totalReceived)} (${formatPercent(receivedRate)}) do previsto.`);

            const overdueByClient = new Map();
            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                if (status !== 'Atrasado') return;
                const debtorId = String(installment.debtor_id ?? '');
                if (!debtorId) return;
                overdueByClient.set(
                    debtorId,
                    (overdueByClient.get(debtorId) || 0) + getInstallmentOutstanding(installment, status)
                );
            });

            if (overdueByClient.size) {
                insights.push(`Atraso concentra em ${overdueByClient.size} cliente(s).`);
                const [topDebtorId, topAmount] = Array.from(overdueByClient.entries())
                    .sort((a, b) => b[1] - a[1])[0];
                const topDebtor = getDebtorById(topDebtorId);
                insights.push(`Maior saldo em atraso: ${topDebtor?.name || `Cliente #${topDebtorId}`} (${formatCurrency(topAmount)}).`);
            } else {
                insights.push('Sem concentração de atraso no período filtrado.');
            }

            const today = startOfDay(new Date());
            const nextDue = installments
                .filter((installment) => normalizeInstallmentStatus(installment) !== 'Pago')
                .filter((installment) => {
                    const dueDate = startOfDay(installment.due_date);
                    return !!(today && dueDate && dueDate >= today);
                })
                .sort((a, b) => (startOfDay(a.due_date)?.getTime() ?? 0) - (startOfDay(b.due_date)?.getTime() ?? 0))[0];

            if (nextDue) {
                const debtor = getDebtorById(nextDue.debtor_id);
                insights.push(`Próximo vencimento: ${debtor?.name || 'Cliente'} em ${formatDate(nextDue.due_date)} (${formatCurrency(nextDue.amount)}).`);
            } else {
                insights.push('Sem próximo vencimento no recorte atual.');
            }

            const dueDayMap = new Map();
            installments.forEach((installment) => {
                const dueDate = startOfDay(installment.due_date);
                if (!dueDate) return;
                const day = dueDate.getDate();
                dueDayMap.set(day, (dueDayMap.get(day) || 0) + 1);
            });
            const topDay = Array.from(dueDayMap.entries()).sort((a, b) => b[1] - a[1])[0];
            if (topDay) insights.push(`Top dia do mês com mais vencimentos: dia ${topDay[0]} (${topDay[1]} parcela(s)).`);

            return insights.slice(0, 6);
        }

        function renderInsights(installments, metrics) {
            const list = document.getElementById('reportInsightsList');
            if (!list) return;

            const insights = buildPeriodInsights(installments, metrics);
            if (!insights.length) {
                list.innerHTML = '<li class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-slate-500">Sem insights para o filtro atual.</li>';
                return;
            }

            list.innerHTML = insights.map((text) => `
                <li class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                    <span class="mr-2 text-slate-400"><i class="fas fa-lightbulb"></i></span>${escapeHtml(text)}
                </li>
            `).join('');
        }

        function buildMonthlyMetricsSeries(installments, maxMonths = 12) {
            const grouped = new Map();
            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const referenceDate = getInstallmentReferenceDate(installment, status) || startOfDay(installment.due_date);
                const monthKey = toMonthKey(referenceDate);
                if (!monthKey) return;
                if (!grouped.has(monthKey)) grouped.set(monthKey, []);
                grouped.get(monthKey).push(installment);
            });

            let rows = Array.from(grouped.entries())
                .map(([month, items]) => ({ month, metrics: calculateReportMetrics(items) }))
                .sort((a, b) => a.month.localeCompare(b.month));
            if (rows.length > maxMonths) rows = rows.slice(rows.length - maxMonths);
            return rows;
        }

        function getVariation(currentValue, previousValue, options = {}) {
            const { invert = false, minBase = 0.00001 } = options;
            if (!Number.isFinite(previousValue)) return null;
            const previous = Number(previousValue);
            if (Math.abs(previous) < minBase) return null;

            const current = Number.isFinite(Number(currentValue)) ? Number(currentValue) : 0;
            const pct = ((current - previous) / Math.abs(previous)) * 100;
            if (!Number.isFinite(pct)) return null;
            if (Math.abs(pct) < 0.005) return { tone: 'neutral', text: '0,00% vs período anterior' };

            const baseTone = pct > 0 ? 'positive' : 'negative';
            const tone = invert ? (baseTone === 'positive' ? 'negative' : 'positive') : baseTone;
            return {
                tone,
                text: `${pct > 0 ? '↑' : '↓'} ${Math.abs(pct).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}% vs período anterior`,
            };
        }

        function renderSparkline(svgElement, seriesValues, tone = 'neutral') {
            if (!svgElement) return;
            const values = Array.isArray(seriesValues) ? seriesValues.map((value) => Number(value)).filter((value) => Number.isFinite(value)) : [];
            if (!values.length) {
                svgElement.innerHTML = '';
                return;
            }

            const color = tone === 'positive' ? '#16a34a' : tone === 'negative' ? '#dc2626' : '#64748b';
            const fillColor = tone === 'positive'
                ? 'rgba(22, 163, 74, 0.12)'
                : tone === 'negative'
                    ? 'rgba(220, 38, 38, 0.12)'
                    : 'rgba(100, 116, 139, 0.10)';

            const width = 100;
            const height = 34;
            const topPad = 3;
            const bottomPad = 3;
            const usableHeight = height - topPad - bottomPad;
            const minValue = Math.min(...values);
            const maxValue = Math.max(...values);
            const range = maxValue - minValue || 1;
            const stepX = values.length > 1 ? width / (values.length - 1) : width;

            const points = values.map((value, index) => {
                const x = values.length > 1 ? index * stepX : width / 2;
                const normalized = (value - minValue) / range;
                const y = topPad + (1 - normalized) * usableHeight;
                return { x, y };
            });

            const linePath = points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(' ');
            const firstPoint = points[0];
            const lastPoint = points[points.length - 1];
            const areaPath = `${linePath} L ${lastPoint.x.toFixed(2)} ${(height - 1).toFixed(2)} L ${firstPoint.x.toFixed(2)} ${(height - 1).toFixed(2)} Z`;
            let pathLength = 0;
            for (let index = 1; index < points.length; index += 1) {
                const dx = points[index].x - points[index - 1].x;
                const dy = points[index].y - points[index - 1].y;
                pathLength += Math.sqrt((dx * dx) + (dy * dy));
            }

            svgElement.innerHTML = `
                <path d="${areaPath}" fill="${fillColor}"></path>
                <path d="${linePath}" fill="none" stroke="${color}" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="stroke-dasharray:${pathLength};stroke-dashoffset:${pathLength};animation:sparkline-draw 0.7s ease forwards;"></path>
            `;
        }

        function renderCards(installments, previousInstallments = []) {
            const currentMetrics = calculateReportMetrics(installments);
            const previousMetrics = calculateReportMetrics(previousInstallments);
            const monthlySeries = buildMonthlyMetricsSeries(
                reportsState.sparkInstallments.length ? reportsState.sparkInstallments : installments,
                8
            );
            const grid = document.getElementById('reportKpiGrid');
            const skeleton = document.getElementById('reportKpiSkeleton');
            if (!grid || !skeleton) return;

            reportsState.currentMetrics = currentMetrics;
            reportsState.previousMetrics = previousMetrics;
            skeleton.classList.add('hidden');
            grid.classList.remove('hidden');

            grid.innerHTML = reportKpiDefinitions.map((definition) => {
                const currentValue = toNumber(currentMetrics[definition.key]);
                const previousValue = toNumber(previousMetrics[definition.key], NaN);
                const variation = getVariation(currentValue, previousValue, {
                    invert: definition.invert,
                    minBase: definition.minBase,
                });
                const badgeClass = variation?.tone === 'positive'
                    ? 'border-emerald-200 bg-emerald-50 text-emerald-700'
                    : variation?.tone === 'negative'
                        ? 'border-red-200 bg-red-50 text-red-700'
                        : 'border-slate-200 bg-slate-50 text-slate-600';
                const sparkId = `kpiSpark_${definition.key}`;
                const valueLabel = definition.type === 'percent' ? formatPercent(currentValue) : formatCurrency(currentValue);

                return `
                    <article class="glass-card rounded-2xl p-5">
                        <div class="flex items-start justify-between gap-3">
                            <p class="kpi-label">${definition.label}</p>
                            <i class="fas fa-circle-info cursor-help text-slate-400" title="${escapeHtml(definition.help)}"></i>
                        </div>
                        <p class="kpi-value mt-2">${valueLabel}</p>
                        <p class="kpi-note">${definition.note}</p>
                        ${variation
                            ? `<span class="mt-2 inline-flex rounded-full border px-2 py-0.5 text-[11px] font-semibold ${badgeClass}">${variation.text}</span>`
                            : '<span class="mt-2 inline-flex rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-[11px] font-semibold text-slate-600">Sem base robusta para comparação</span>'
                        }
                        <div class="mt-3 h-[34px] w-full"><svg id="${sparkId}" class="h-full w-full" viewBox="0 0 100 34" preserveAspectRatio="none"></svg></div>
                    </article>
                `;
            }).join('');

            reportKpiDefinitions.forEach((definition) => {
                const svg = document.getElementById(`kpiSpark_${definition.key}`);
                const series = monthlySeries.slice(-8).map((point) => toNumber(point.metrics[definition.key]));
                const variation = getVariation(
                    toNumber(currentMetrics[definition.key]),
                    toNumber(previousMetrics[definition.key], NaN),
                    { invert: definition.invert, minBase: definition.minBase }
                );
                renderSparkline(svg, series, variation?.tone || 'neutral');
            });
        }

        function bindReportEvents() {
            document.getElementById('reportPeriodFilter').addEventListener('change', () => {
                updateReportCustomRangeVisibility();
                applyReportFilters();
            });
            document.getElementById('reportClientFilter').addEventListener('change', applyReportFilters);
            document.getElementById('reportStatusFilter').addEventListener('change', applyReportFilters);
            document.getElementById('reportInterestTypeFilter').addEventListener('change', applyReportFilters);
            document.getElementById('reportFrequencyFilter').addEventListener('change', applyReportFilters);
            document.getElementById('reportCustomStartDate').addEventListener('change', applyReportFilters);
            document.getElementById('reportCustomEndDate').addEventListener('change', applyReportFilters);
            document.getElementById('reportOnlyOverdue').addEventListener('change', applyReportFilters);
            document.getElementById('reportApplyFiltersBtn').addEventListener('click', applyReportFilters);
            document.getElementById('reportClearFiltersBtn').addEventListener('click', clearReportFilters);
            document.getElementById('exportCsvBtn').addEventListener('click', () => notifyExportPlaceholder('CSV'));
            document.getElementById('exportPdfBtn').addEventListener('click', () => notifyExportPlaceholder('PDF'));

            ['reportClientSearch', 'reportMinValue', 'reportMaxValue'].forEach((fieldId) => {
                const field = document.getElementById(fieldId);
                if (!field) return;
                field.addEventListener('input', () => {
                    if (searchDebounceTimer) clearTimeout(searchDebounceTimer);
                    searchDebounceTimer = setTimeout(applyReportFilters, 260);
                });
            });

            document.getElementById('dueTab7').addEventListener('click', () => {
                reportsState.activeDueTab = 'next7';
                renderNextDueDates(reportsState.sparkInstallments.length ? reportsState.sparkInstallments : reportsState.filteredInstallments);
            });
            document.getElementById('dueTab15').addEventListener('click', () => {
                reportsState.activeDueTab = 'next15';
                renderNextDueDates(reportsState.sparkInstallments.length ? reportsState.sparkInstallments : reportsState.filteredInstallments);
            });

            document.getElementById('topDebtorsMoreBtn').addEventListener('click', () => {
                reportsState.topDebtorsLimit += 8;
                renderTopDebtors(reportsState.filteredInstallments);
            });
            document.getElementById('recentPaidMoreBtn').addEventListener('click', () => {
                reportsState.recentPaidLimit += 8;
                renderRecentPaid(reportsState.filteredInstallments);
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            bindReportEvents();
            loadReportsData();
        });
    </script>
</body>
</html>











