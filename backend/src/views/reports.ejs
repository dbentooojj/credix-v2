        function setLoadingState(isLoading) {
            reportsState.isLoading = isLoading;
            const skeleton = document.getElementById('reportKpiSkeleton');
            const grid = document.getElementById('reportKpiGrid');
            if (skeleton && grid) {
                skeleton.classList.toggle('hidden', !isLoading);
