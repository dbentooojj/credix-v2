            if (dueList) dueList.innerHTML = '<div class="skeleton h-14 w-full rounded-xl"></div><div class="skeleton h-14 w-full rounded-xl"></div>';
            if (distribution) distribution.innerHTML = '<div class="skeleton h-44 w-full rounded-xl"></div>';
        }

        function renderChart(installments) {
            const chartContainer = document.getElementById('reportChart');
            const subtitle = document.getElementById('reportChartSubtitle');
            if (!chartContainer || !subtitle) return;

            const monthMap = new Map();

            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const referenceDate = getInstallmentReferenceDate(installment, status) || startOfDay(installment.due_date);
                if (!referenceDate) return;

                const monthKey = toMonthKey(referenceDate);
                if (!monthKey) return;

                if (!monthMap.has(monthKey)) {
                    monthMap.set(monthKey, { month: monthKey, loaned: 0, received: 0, overdue: 0, profit: 0 });
                }

                const point = monthMap.get(monthKey);
                const principal = getInstallmentPrincipal(installment);
                point.loaned += principal;
                point.profit += Math.max(toNumber(installment.amount) - principal, 0);

                if (status === 'Pago') {
                    point.received += toNumber(installment.amount);
                } else if (status === 'Atrasado') {
                    point.overdue += getInstallmentOutstanding(installment, status);
                }
            });

            let points = Array.from(monthMap.values()).sort((a, b) => a.month.localeCompare(b.month));
            if (points.length > 8) points = points.slice(points.length - 8);

            const selectedPeriodLabel = document.getElementById('reportPeriodFilter')?.selectedOptions?.[0]?.textContent || 'todo período';
            subtitle.textContent = `Comparativo mensal em ${selectedPeriodLabel.toLowerCase()}.`;

            if (!points.length) {
                chartContainer.innerHTML = '<div class="flex h-56 items-center justify-center rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 text-center text-sm text-slate-500">Sem dados suficientes no filtro atual para montar o comparativo mensal.</div>';
                return;
            }

            const maxValue = Math.max(1, ...points.flatMap((point) => [point.loaned, point.received, point.overdue, point.profit]));
            const heightPct = (value) => {
                if (value <= 0) return 2;
                return Math.max((value / maxValue) * 100, 4);
            };

            chartContainer.innerHTML = `
                <div class="report-chart-grid">
                    ${points.map((point) => `
                        <div class="report-chart-column">
                            <div class="report-chart-bars">
                                <div class="chart-bar chart-bar-loaned" style="height:${heightPct(point.loaned)}%;animation:bar-grow 0.45s ease;" title="Emprestado ${formatCurrency(point.loaned)}"></div>
                                <div class="chart-bar chart-bar-received" style="height:${heightPct(point.received)}%;animation:bar-grow 0.45s ease;" title="Recebido ${formatCurrency(point.received)}"></div>
                                <div class="chart-bar chart-bar-overdue" style="height:${heightPct(point.overdue)}%;animation:bar-grow 0.45s ease;" title="Atrasado ${formatCurrency(point.overdue)}"></div>
                                <div class="chart-bar chart-bar-profit" style="height:${heightPct(point.profit)}%;animation:bar-grow 0.45s ease;" title="Lucro ${formatCurrency(point.profit)}"></div>
                            </div>
                            <p class="report-chart-label">${formatMonthLabel(point.month)}</p>
                        </div>
                    `).join('')}
                </div>
            `;
        }

        function renderReports() {
            const installments = reportsState.filteredInstallments;
            renderCards(installments, reportsState.previousInstallments);
            renderChart(installments);
            renderInsights(installments, reportsState.currentMetrics || calculateReportMetrics(installments));
            renderStatusDistribution(installments);
            renderNextDueDates(reportsState.sparkInstallments.length ? reportsState.sparkInstallments : installments);
            renderTopDebtors(installments);
            renderRecentPaid(installments);
        }

        function applyReportFilters() {
            const periodValue = document.getElementById('reportPeriodFilter')?.value || 'month_current';
            const clientValue = document.getElementById('reportClientFilter')?.value || 'all';
            const clientSearch = document.getElementById('reportClientSearch')?.value || '';
            const statusValue = document.getElementById('reportStatusFilter')?.value || 'all';
            const interestTypeValue = document.getElementById('reportInterestTypeFilter')?.value || 'all';
            const frequencyValue = document.getElementById('reportFrequencyFilter')?.value || 'all';
            const minValue = document.getElementById('reportMinValue')?.value || '';
            const maxValue = document.getElementById('reportMaxValue')?.value || '';
            const onlyOverdue = !!document.getElementById('reportOnlyOverdue')?.checked;
            const { start, end } = getPeriodBounds(periodValue);

            if (periodValue === 'custom' && (!start || !end)) {
                showReportFeedback('Defina data inicial e final para o intervalo custom.', 'error');
                return;
            }

            const previousBounds = getPreviousPeriodBounds(start, end);
            const sharedFilters = {
                clientValue,
                clientSearch,
                statusValue,
                interestTypeValue,
                frequencyValue,
                minValue,
                maxValue,
                onlyOverdue,
            };

            reportsState.sparkInstallments = filterInstallments(reportsState.installments, {
                ...sharedFilters,
                start: null,
                end: null,
            });
            reportsState.filteredInstallments = filterInstallments(reportsState.installments, {
                ...sharedFilters,
                start,
                end,
            });
            reportsState.previousInstallments = previousBounds.start && previousBounds.end
                ? filterInstallments(reportsState.installments, {
                    ...sharedFilters,
                    start: previousBounds.start,
                    end: previousBounds.end,
                })
                : [];

            reportsState.topDebtorsLimit = 8;
            reportsState.recentPaidLimit = 8;
            showReportFeedback('');
            renderReports();
            document.getElementById('reportUpdatedAt').textContent = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
        }

        function clearReportFilters() {
            document.getElementById('reportPeriodFilter').value = 'month_current';
            document.getElementById('reportClientFilter').value = 'all';
            document.getElementById('reportClientSearch').value = '';
            document.getElementById('reportStatusFilter').value = 'all';
            document.getElementById('reportInterestTypeFilter').value = 'all';
            document.getElementById('reportFrequencyFilter').value = 'all';
            document.getElementById('reportMinValue').value = '';
            document.getElementById('reportMaxValue').value = '';
            document.getElementById('reportOnlyOverdue').checked = false;
            document.getElementById('reportCustomStartDate').value = '';
            document.getElementById('reportCustomEndDate').value = '';
            updateReportCustomRangeVisibility();
            showReportFeedback('');
            applyReportFilters();
        }

        function escapeCsvField(value) {
            const text = String(value ?? '');
            if (/[;"\n]/.test(text)) return `"${text.replace(/"/g, '""')}"`;
            return text;
        }

        function downloadBlob(filename, blob) {
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = filename;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(url);
        }

        function notifyExportPlaceholder(format) {
            const rows = reportsState.filteredInstallments || [];
            if (!rows.length) {
                showReportFeedback(`Sem dados no filtro atual para exportar ${format}.`, 'error');
                return;
            }

            if (format === 'CSV') {
                const header = ['Data referência', 'Cliente', 'Empréstimo', 'Parcela', 'Status', 'Valor', 'Valor pago', 'Saldo em aberto'];
                const lines = rows.map((installment) => {
                    const status = normalizeInstallmentStatus(installment);
                    const debtor = getDebtorById(installment.debtor_id);
                    const loan = getLoanById(installment.loan_id);
                    const referenceDate = getInstallmentReferenceDate(installment, status);
                    return [
                        formatDate(referenceDate),
                        debtor?.name || `Cliente #${installment.debtor_id ?? '-'}`,
                        `#${installment.loan_id ?? '-'}`,
                        `${installment.installment_number}/${loan?.installments_count ?? '-'}`,
                        status,
                        round2(installment.amount).toFixed(2).replace('.', ','),
                        round2(getInstallmentPaidAmount(installment, status)).toFixed(2).replace('.', ','),
                        round2(getInstallmentOutstanding(installment, status)).toFixed(2).replace('.', ','),
                    ].map(escapeCsvField).join(';');
                });
                const csvContent = [header.map(escapeCsvField).join(';'), ...lines].join('\n');
                downloadBlob(`relatorios-${new Date().toISOString().slice(0, 10)}.csv`, new Blob([csvContent], { type: 'text/csv;charset=utf-8;' }));
                showReportFeedback('CSV exportado com sucesso.', 'info');
                return;
            }

            const popup = window.open('', '_blank', 'width=1024,height=768');
