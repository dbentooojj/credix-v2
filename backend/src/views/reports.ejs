        function renderChart(installments) {
            const chartContainer = document.getElementById('reportChart');
            const subtitle = document.getElementById('reportChartSubtitle');
            const peakReceivedElement = document.getElementById('reportChartPeakReceived');
            const peakOverdueElement = document.getElementById('reportChartPeakOverdue');
            const currentProfitElement = document.getElementById('reportChartCurrentProfit');
            if (!chartContainer || !subtitle) return;

            const periodValue = document.getElementById('reportPeriodFilter')?.value || 'month_current';
            const periodBounds = getPeriodBounds(periodValue);
            const selectedPeriodLabel = document.getElementById('reportPeriodFilter')?.selectedOptions?.[0]?.textContent || 'todo período';
            const startOfWeek = (value) => {
                const date = startOfDay(value);
                if (!date) return null;
                const dayIndex = (date.getDay() + 6) % 7;
                date.setDate(date.getDate() - dayIndex);
                return date;
            };

            let granularity = 'month';
            if (periodValue === 'last7' || periodValue === 'last15') {
                granularity = 'day';
            } else if (periodValue === 'last30' || periodValue === 'month_current' || periodValue === 'month_previous') {
                granularity = 'week';
            } else if (periodValue === 'custom' && periodBounds.start && periodBounds.end) {
                const diffDays = Math.max(1, Math.round((periodBounds.end.getTime() - periodBounds.start.getTime()) / (24 * 60 * 60 * 1000)) + 1);
                granularity = diffDays <= 31 ? 'day' : diffDays <= 120 ? 'week' : 'month';
            }

            const granularityLabel = granularity === 'day' ? 'diário' : granularity === 'week' ? 'semanal' : 'mensal';
            subtitle.textContent = `Comparativo ${granularityLabel} em ${selectedPeriodLabel.toLowerCase()}.`;

            const grouped = new Map();
            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const referenceDate = getInstallmentReferenceDate(installment, status) || startOfDay(installment.due_date);
                if (!referenceDate) return;

                let key = '';
                let label = '';
                let orderKey = 0;

                if (granularity === 'day') {
                    key = toIsoDate(referenceDate);
                    label = referenceDate.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
                    orderKey = referenceDate.getTime();
                } else if (granularity === 'week') {
                    const weekStart = startOfWeek(referenceDate);
                    if (!weekStart) return;
                    key = `week-${toIsoDate(weekStart)}`;
                    label = `Sem ${weekStart.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' })}`;
                    orderKey = weekStart.getTime();
                } else {
                    key = toMonthKey(referenceDate);
                    label = formatMonthLabel(key);
                    orderKey = new Date(referenceDate.getFullYear(), referenceDate.getMonth(), 1).getTime();
                }

                if (!grouped.has(key)) {
                    grouped.set(key, { key, label, orderKey, expected: 0, received: 0, open: 0 });
                }
                const point = grouped.get(key);
                point.expected += toNumber(installment.amount);
                point.received += getInstallmentPaidAmount(installment, status);
                point.open += getInstallmentOutstanding(installment, status);
            });

            let points = Array.from(grouped.values()).sort((a, b) => a.orderKey - b.orderKey);
            const maxBuckets = granularity === 'day' ? 14 : granularity === 'week' ? 12 : 8;
            if (points.length > maxBuckets) points = points.slice(points.length - maxBuckets);

            if (!points.length) {
                if (peakReceivedElement) peakReceivedElement.textContent = formatCompactCurrency(0);
                if (peakOverdueElement) peakOverdueElement.textContent = formatCompactCurrency(0);
                if (currentProfitElement) currentProfitElement.textContent = formatCompactCurrency(0);
                subtitle.textContent = `Sem dados para comparativo em ${selectedPeriodLabel.toLowerCase()}.`;
                renderPerformanceEmptyState(chartContainer, {
                    selectedPeriodLabel,
                    hasSourceData: reportsState.installments.length > 0,
                });
                return;
            }

            const maxValue = Math.max(1, ...points.flatMap((point) => [point.expected, point.received, point.open]));
            const heightPct = (value) => {
                if (value <= 0) return 2;
                return Math.max((value / maxValue) * 100, 4);
            };
            const axisLevels = [1, 0.75, 0.5, 0.25, 0];
            const peakExpected = points.reduce((max, point) => Math.max(max, point.expected), 0);
            const peakReceived = points.reduce((max, point) => Math.max(max, point.received), 0);
            const currentOpen = points[points.length - 1]?.open ?? 0;

            if (peakReceivedElement) peakReceivedElement.textContent = formatCompactCurrency(peakExpected);
            if (peakOverdueElement) peakOverdueElement.textContent = formatCompactCurrency(peakReceived);
            if (currentProfitElement) currentProfitElement.textContent = formatCompactCurrency(currentOpen);

            chartContainer.innerHTML = `
                <div class="report-chart-stage">
                    <div class="report-chart-axis">
                        ${axisLevels.map((level) => `<span>${formatCompactCurrency(maxValue * level)}</span>`).join('')}
                    </div>
                    <div class="report-chart-scaffold">
                        ${axisLevels.map(() => '<span></span>').join('')}
                    </div>
                    <div class="report-chart-grid">
                        ${points.map((point) => `
                            <div class="report-chart-column">
                                <div class="report-chart-bars">
                                    <div class="chart-bar chart-bar-loaned" style="height:${heightPct(point.expected)}%;" title="Previsto ${formatCurrency(point.expected)}"></div>
                                    <div class="chart-bar chart-bar-received" style="height:${heightPct(point.received)}%;" title="Recebido ${formatCurrency(point.received)}"></div>
                                    <div class="chart-bar chart-bar-profit" style="height:${heightPct(point.open)}%;" title="Em aberto ${formatCurrency(point.open)}"></div>
                                </div>
                                <p class="report-chart-label">${point.label}</p>
                            </div>
                        `).join('')}
                    </div>
                </div>
            `;
        }

