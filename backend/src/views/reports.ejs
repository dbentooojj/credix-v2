        function getPeriodBounds(periodValue) {
            const today = startOfDay(new Date());
            if (!today) return { start: null, end: null };

            if (periodValue === 'month_current') {
                return { start: new Date(today.getFullYear(), today.getMonth(), 1), end: today };
            }

            if (periodValue === 'last30') {
                const start = new Date(today.getTime());
                start.setDate(start.getDate() - 29);
                return { start, end: today };
            }

            if (periodValue === 'quarter_current') {
                const quarterStartMonth = Math.floor(today.getMonth() / 3) * 3;
                return { start: new Date(today.getFullYear(), quarterStartMonth, 1), end: today };
            }

            if (periodValue === 'year_current') {
                return { start: new Date(today.getFullYear(), 0, 1), end: today };
            }

            if (periodValue === 'custom') {
                let start = startOfDay(document.getElementById('reportCustomStartDate')?.value || '');
                let end = startOfDay(document.getElementById('reportCustomEndDate')?.value || '');
                if (start && end && start > end) {
                    const temp = start;
                    start = end;
                    end = temp;
                }
                return { start, end };
            }

            return { start: null, end: null };
        }

        function getPreviousPeriodBounds(start, end) {
            if (!start || !end) return { start: null, end: null };
            const startDate = startOfDay(start);
            const endDate = startOfDay(end);
            if (!startDate || !endDate || endDate < startDate) return { start: null, end: null };

            const dayMs = 24 * 60 * 60 * 1000;
            const durationDays = Math.max(1, Math.round((endDate.getTime() - startDate.getTime()) / dayMs) + 1);
            const previousEnd = new Date(startDate.getTime() - dayMs);
            const previousStart = new Date(previousEnd.getTime() - ((durationDays - 1) * dayMs));
            previousStart.setHours(0, 0, 0, 0);
            previousEnd.setHours(0, 0, 0, 0);
            return { start: previousStart, end: previousEnd };
        }

        function filterInstallmentsByRangeAndClient(sourceInstallments, filters = {}) {
            const {
                clientValue = 'all',
                start = null,
                end = null,
            } = filters;

            return sourceInstallments.filter((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const referenceDate = getInstallmentReferenceDate(installment, status);
                if (clientValue !== 'all' && !sameId(installment.debtor_id, clientValue)) return false;
                if (start && (!referenceDate || referenceDate < start)) return false;
                if (end && (!referenceDate || referenceDate > end)) return false;
                return true;
            });
        }

        function updateReportCustomRangeVisibility() {
            const periodValue = document.getElementById('reportPeriodFilter').value;
            const wrap = document.getElementById('reportCustomRangeWrap');
            wrap.classList.toggle('hidden', periodValue !== 'custom');
        }

        function populateReportClientFilter() {
            const select = document.getElementById('reportClientFilter');
            if (!select) return;

            const previousValue = select.value || 'all';
            const byId = new Map();

            reportsState.debtors.forEach((debtor) => {
                const key = String(debtor.id ?? '');
                if (!key) return;
                byId.set(key, { id: key, name: debtor.name || 'Cliente sem nome' });
            });

            reportsState.installments.forEach((installment) => {
                const key = String(installment.debtor_id ?? '');
                if (!key || byId.has(key)) return;
                const debtor = getDebtorById(key);
                byId.set(key, { id: key, name: debtor?.name || `Cliente #${key}` });
            });

            const options = Array.from(byId.values()).sort((a, b) => a.name.localeCompare(b.name, 'pt-BR'));
            select.innerHTML = `<option value="all">Todos os clientes</option>${options.map((option) => `<option value="${option.id}">${escapeHtml(option.name)}</option>`).join('')}`;
            const hasPrevious = previousValue === 'all' || options.some((option) => option.id === previousValue);
            select.value = hasPrevious ? previousValue : 'all';
        }

        function showReportFeedback(message, tone = 'info') {
            const element = document.getElementById('reportFeedback');
            if (!element) return;

            if (!message) {
                element.classList.add('hidden');
                element.textContent = '';
                return;
            }

            element.textContent = message;
            element.classList.remove('hidden', 'info', 'error');
            element.classList.add(tone === 'error' ? 'error' : 'info');
        }

        function buildSkeletonRows(columns, rows = 4) {
            return Array.from({ length: rows }, () => `
                <tr>
                    ${Array.from({ length: columns }, () => `<td><div class="skeleton h-3 w-full"></div></td>`).join('')}
                </tr>
