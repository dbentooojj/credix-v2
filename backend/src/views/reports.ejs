        function normalizeInterestType(value) {
            const raw = normalizeAscii(value);
            if (raw.includes('simples')) return 'simples';
            if (raw.includes('fixo')) return 'fixo';
            return 'composto';
        }

        function normalizeLoanRow(row) {
            return {
                ...row,
                id: row.id,
                debtor_id: row.debtor_id ?? row.client_id ?? row.clientId,
                principal_amount: round2(row.principal_amount ?? row.principalAmount ?? 0),
                total_amount: round2(row.total_amount ?? row.totalAmount ?? 0),
                installments_count: Math.max(1, Math.trunc(toNumber(row.installments_count ?? row.installments ?? row.installmentsCount ?? 1))),
                interest_type: normalizeInterestType(row.interest_type ?? row.interestType),
            };
        }

        function normalizeDebtorRow(row) {
            return {
                ...row,
                id: row.id,
                name: row.name || row.full_name || 'Cliente sem nome',
                phone: row.phone || '',
                document: row.document || row.cpf || '',
            };
        }

        function buildLoanFrequencyMap() {
            const map = new Map();
            reportsState.loans.forEach((loan) => map.set(String(loan.id), 'mensal'));

            const grouped = new Map();
            reportsState.installments.forEach((installment) => {
                const key = String(installment.loan_id ?? '');
                if (!key) return;
                if (!grouped.has(key)) grouped.set(key, []);
                grouped.get(key).push(installment);
            });

            grouped.forEach((rows, loanId) => {
                const sorted = rows
                    .map((item) => startOfDay(item.due_date))
                    .filter((item) => item instanceof Date)
                    .sort((a, b) => a.getTime() - b.getTime());
                if (sorted.length < 2) return;

                let totalDiff = 0;
                let count = 0;
                for (let index = 1; index < sorted.length; index += 1) {
                    const diff = Math.round((sorted[index].getTime() - sorted[index - 1].getTime()) / (24 * 60 * 60 * 1000));
                    if (Number.isFinite(diff) && diff > 0) {
                        totalDiff += diff;
                        count += 1;
                    }
                }
                if (!count) return;
                map.set(loanId, (totalDiff / count) <= 17 ? 'quinzenal' : 'mensal');
            });

            reportsState.loanFrequencyById = map;
        }

        function getLoanFrequency(loanId) {
            return reportsState.loanFrequencyById.get(String(loanId ?? '')) || 'mensal';
        }

        function parseOptionalNumber(value) {
            const raw = String(value ?? '').trim();
            if (!raw) return null;
            const normalized = raw
                .replace(/\s/g, '')
                .replace(/\.(?=\d{3}(?:\D|$))/g, '')
                .replace(',', '.');
            const parsed = Number(normalized);
            return Number.isFinite(parsed) ? parsed : null;
        }

        function getPeriodBounds(periodValue) {
            const today = startOfDay(new Date());
            if (!today) return { start: null, end: null };

            if (periodValue === 'month_current') {
                return { start: new Date(today.getFullYear(), today.getMonth(), 1), end: today };
            }
            if (periodValue === 'month_previous') {
                const prevMonthStart = new Date(today.getFullYear(), today.getMonth() - 1, 1);
                const prevMonthEnd = new Date(today.getFullYear(), today.getMonth(), 0);
                prevMonthEnd.setHours(0, 0, 0, 0);
                return { start: prevMonthStart, end: prevMonthEnd };
            }
            if (periodValue === 'last7') {
                const start = new Date(today.getTime());
                start.setDate(start.getDate() - 6);
                return { start, end: today };
            }
            if (periodValue === 'last15') {
                const start = new Date(today.getTime());
                start.setDate(start.getDate() - 14);
                return { start, end: today };
            }
            if (periodValue === 'last30') {
                const start = new Date(today.getTime());
                start.setDate(start.getDate() - 29);
                return { start, end: today };
            }
            if (periodValue === 'custom') {
                let start = startOfDay(document.getElementById('reportCustomStartDate')?.value || '');
                let end = startOfDay(document.getElementById('reportCustomEndDate')?.value || '');
                if (start && end && start > end) {
                    const temp = start;
                    start = end;
                    end = temp;
                }
                return { start, end };
            }

            return { start: null, end: null };
        }

        function getPreviousPeriodBounds(start, end) {
            if (!start || !end) return { start: null, end: null };
            const startDate = startOfDay(start);
            const endDate = startOfDay(end);
            if (!startDate || !endDate || endDate < startDate) return { start: null, end: null };

            const dayMs = 24 * 60 * 60 * 1000;
            const durationDays = Math.max(1, Math.round((endDate.getTime() - startDate.getTime()) / dayMs) + 1);
            const previousEnd = new Date(startDate.getTime() - dayMs);
            const previousStart = new Date(previousEnd.getTime() - ((durationDays - 1) * dayMs));
            previousStart.setHours(0, 0, 0, 0);
            previousEnd.setHours(0, 0, 0, 0);
            return { start: previousStart, end: previousEnd };
        }

        function filterInstallments(sourceInstallments, filters = {}) {
            const {
                clientValue = 'all',
                clientSearch = '',
                statusValue = 'all',
                interestTypeValue = 'all',
                frequencyValue = 'all',
                minValue = null,
                maxValue = null,
                onlyOverdue = false,
                start = null,
                end = null,
            } = filters;

            const normalizedSearch = normalizeAscii(clientSearch);
            const minAmount = parseOptionalNumber(minValue);
            const maxAmount = parseOptionalNumber(maxValue);

            return sourceInstallments.filter((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const referenceDate = getInstallmentReferenceDate(installment, status);
                const amount = toNumber(installment.amount);

                if (clientValue !== 'all' && !sameId(installment.debtor_id, clientValue)) return false;
                if (statusValue === 'paid' && status !== 'Pago') return false;
                if (statusValue === 'pending' && status !== 'Pendente') return false;
                if (statusValue === 'overdue' && status !== 'Atrasado') return false;
                if (onlyOverdue && status !== 'Atrasado') return false;

                if (start && (!referenceDate || referenceDate < start)) return false;
                if (end && (!referenceDate || referenceDate > end)) return false;

                const loan = getLoanById(installment.loan_id);
                if (interestTypeValue !== 'all' && normalizeInterestType(loan?.interest_type) !== interestTypeValue) return false;
                if (frequencyValue !== 'all' && getLoanFrequency(installment.loan_id) !== frequencyValue) return false;

                if (minAmount !== null && amount < minAmount) return false;
                if (maxAmount !== null && amount > maxAmount) return false;

                if (normalizedSearch) {
                    const debtor = getDebtorById(installment.debtor_id);
                    const haystack = [
                        debtor?.name || '',
                        debtor?.phone || '',
                        debtor?.document || '',
                        String(installment.loan_id ?? ''),
                    ].map(normalizeAscii).join(' ');
                    if (!haystack.includes(normalizedSearch)) return false;
                }

                return true;
            });
        }

        function calculateReportMetrics(installments) {
            const loanIds = new Set();
            const clientIds = new Set();
            const metrics = {
                totalLoaned: 0,
                totalExpected: 0,
                totalReceived: 0,
                totalOpen: 0,
                totalOverdue: 0,
                expectedRiskLoss: 0,
                estimatedProfit: 0,
                delinquencyRate: 0,
                ticketAverage: 0,
                totalCount: installments.length,
                paidCount: 0,
                pendingCount: 0,
                overdueCount: 0,
                uniqueLoanCount: 0,
                uniqueClientCount: 0,
            };

            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const amount = toNumber(installment.amount);
                const principal = getInstallmentPrincipal(installment);
                const received = getInstallmentPaidAmount(installment, status);
                const outstanding = getInstallmentOutstanding(installment, status);

                metrics.totalExpected += amount;
                metrics.totalLoaned += principal;
                metrics.totalReceived += received;
                if (status !== 'Pago') metrics.totalOpen += outstanding;
                if (status === 'Atrasado') metrics.totalOverdue += outstanding;

                if (status === 'Pago') metrics.paidCount += 1;
                if (status === 'Pendente') metrics.pendingCount += 1;
                if (status === 'Atrasado') metrics.overdueCount += 1;

                if (installment.loan_id !== null && installment.loan_id !== undefined) loanIds.add(String(installment.loan_id));
                if (installment.debtor_id !== null && installment.debtor_id !== undefined) clientIds.add(String(installment.debtor_id));
            });

            metrics.uniqueLoanCount = loanIds.size;
            metrics.uniqueClientCount = clientIds.size;
            metrics.delinquencyRate = metrics.totalExpected > 0 ? (metrics.totalOverdue / metrics.totalExpected) : 0;
            const riskProvisionRate = Math.min(1, Math.max(0.35, metrics.delinquencyRate * 2));
            metrics.expectedRiskLoss = metrics.totalOverdue * riskProvisionRate;
            metrics.estimatedProfit = metrics.totalExpected - metrics.totalLoaned - metrics.expectedRiskLoss;
            metrics.ticketAverage = loanIds.size > 0
                ? (metrics.totalLoaned / loanIds.size)
                : clientIds.size > 0
                    ? (metrics.totalLoaned / clientIds.size)
                    : 0;

            return metrics;
        }

        function calculatePortfolioScore(installments, metrics) {
            const safeMetrics = metrics || {};
            const totalExpected = Math.max(toNumber(safeMetrics.totalExpected), 0);
            const totalOverdue = Math.max(toNumber(safeMetrics.totalOverdue), 0);

            const inad = totalExpected > 0 ? (totalOverdue / totalExpected) : 0;
            const penaltyA = Math.min(45, Math.max(0, inad * 90));

            const openByClient = new Map();
            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                if (status === 'Pago') return;
                const debtorId = String(installment.debtor_id ?? '');
                if (!debtorId) return;
                const outstanding = getInstallmentOutstanding(installment, status);
                openByClient.set(debtorId, (openByClient.get(debtorId) || 0) + outstanding);
            });
            const top1Open = openByClient.size ? Math.max(...Array.from(openByClient.values())) : 0;
            const conc = totalExpected > 0 ? (top1Open / totalExpected) : 0;
            const penaltyB = Math.min(25, Math.max(0, (conc - 0.25) * 100));

            const today = startOfDay(new Date());
            const horizon = startOfDay(new Date());
            if (horizon) horizon.setDate(horizon.getDate() + 7);
            let due7Total = 0;
            if (today && horizon) {
                installments.forEach((installment) => {
                    const status = normalizeInstallmentStatus(installment);
                    if (status === 'Pago') return;
                    const dueDate = startOfDay(installment.due_date);
                    if (!dueDate || dueDate < today || dueDate > horizon) return;
                    due7Total += getInstallmentOutstanding(installment, status);
                });
            }
            const press7 = totalExpected > 0 ? (due7Total / totalExpected) : 0;
            const penaltyC = Math.min(15, Math.max(0, press7 * 30));

            let overdueDaysTotal = 0;
            let overdueCount = 0;
            if (today) {
                installments.forEach((installment) => {
                    const status = normalizeInstallmentStatus(installment);
                    if (status !== 'Atrasado') return;
                    const dueDate = startOfDay(installment.due_date);
                    if (!dueDate) return;
                    const days = Math.max(0, Math.floor((today.getTime() - dueDate.getTime()) / (24 * 60 * 60 * 1000)));
                    overdueDaysTotal += days;
                    overdueCount += 1;
                });
            }
            const atrasoMedDias = overdueCount > 0 ? (overdueDaysTotal / overdueCount) : 0;
            const penaltyD = Math.min(15, (Math.min(atrasoMedDias, 60) / 60) * 15);

            const totalPenalty = penaltyA + penaltyB + penaltyC + penaltyD;
            const score = clamp(100 - totalPenalty, 0, 100);

            let badgeLabel = 'Carteira em Risco';
            let badgeTone = 'risk';
            if (score >= 80) {
                badgeLabel = 'Carteira Saudável';
                badgeTone = 'healthy';
            } else if (score >= 60) {
                badgeLabel = 'Carteira Moderada';
                badgeTone = 'moderate';
            }

            return {
                score,
                badgeLabel,
                badgeTone,
                factors: [
                    { key: 'A', label: 'Inadimplência', penalty: penaltyA, maxPenalty: 45, indicator: formatPercent(inad) },
                    { key: 'B', label: 'Concentração Top 1', penalty: penaltyB, maxPenalty: 25, indicator: formatPercent(conc) },
                    { key: 'C', label: 'Pressão 7 dias', penalty: penaltyC, maxPenalty: 15, indicator: formatPercent(press7) },
                    { key: 'D', label: 'Recência de atrasos', penalty: penaltyD, maxPenalty: 15, indicator: `${atrasoMedDias.toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 })} dias` },
                ],
            };
        }

        function renderPortfolioScore(installments, metrics) {
            const container = document.getElementById('reportPortfolioScoreCard');
            if (!container) return;

            const scoreData = calculatePortfolioScore(installments, metrics);
            const badgeClass = scoreData.badgeTone === 'healthy'
                ? 'score-badge score-badge-healthy'
                : scoreData.badgeTone === 'moderate'
                    ? 'score-badge score-badge-moderate'
                    : 'score-badge score-badge-risk';
            const tooltip = 'Score 0-100: 100 - (inadimplência + concentração + pressão 7d + recência de atrasos). Penalidades máximas: 45/25/15/15.';

            container.innerHTML = `
                <div class="score-head">
                    <div>
                        <p class="score-title">Score da Carteira</p>
                        <div class="score-main">
                            <p class="score-value">${Math.round(scoreData.score)}</p>
                            <span class="${badgeClass}">${scoreData.badgeLabel}</span>
                            <i class="fas fa-circle-info cursor-help text-slate-400" title="${escapeHtml(tooltip)}" aria-label="Como o score é calculado"></i>
                        </div>
                    </div>
                </div>
                <div class="score-factors">
                    ${scoreData.factors.map((factor) => {
                        const width = factor.maxPenalty > 0 ? clamp((factor.penalty / factor.maxPenalty) * 100, 0, 100) : 0;
                        return `
                            <article class="score-factor">
                                <div class="score-factor-head">
                                    <span class="score-factor-label">${factor.key}) ${escapeHtml(factor.label)}</span>
                                    <span class="score-factor-impact">-${factor.penalty.toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 })} pts</span>
                                </div>
                                <div class="score-bar-track"><div class="score-bar-fill" style="width:${width}%;"></div></div>
                                <p class="score-factor-meta">Indicador: ${escapeHtml(factor.indicator)}</p>
                            </article>
                        `;
                    }).join('')}
                </div>
            `;
        }

        function buildProjection30dData(installments, metrics) {
            const safeInstallments = Array.isArray(installments) ? installments : [];
            const safeMetrics = metrics || {};
            const today = startOfDay(new Date());
            const horizon = startOfDay(new Date());
            if (!today || !horizon) {
                return {
                    totalDue30: 0,
                    adjustedRate: 0,
                    projectedReceipt30: 0,
                    projectedProfit30: 0,
                    projectedInterest30: 0,
                    expectedLoss30: 0,
                    stressImpactCash30: 0,
                    top1ClientName: 'Top 1',
                    top1Due30: 0,
                    top1Share30: 0,
                    weekly: [],
                    hasUpcomingDue: false,
                    tooltip: 'Projeção baseada no histórico e ajustada por risco. Valor apenas indicativo.',
                };
            }
            horizon.setDate(horizon.getDate() + 30);

            const projectionItems = [];
            safeInstallments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                if (status === 'Pago') return;
                const dueDate = startOfDay(installment.due_date);
                if (!dueDate || dueDate < today || dueDate > horizon) return;

                const outstanding = getInstallmentOutstanding(installment, status);
                if (outstanding <= 0) return;

                const amount = Math.max(toNumber(installment.amount), 0);
                const principal = Math.max(Math.min(getInstallmentPrincipal(installment), amount), 0);
                const expectedInterestFull = Math.max(amount - principal, 0);
                const ratio = amount > 0 ? clamp(outstanding / amount, 0, 1) : 1;
                const expectedInterest = expectedInterestFull * ratio;

                projectionItems.push({
                    debtorId: String(installment.debtor_id ?? ''),
                    dueDate,
                    outstanding,
                    expectedInterest,
                });
            });

            const totalDue30 = projectionItems.reduce((sum, item) => sum + item.outstanding, 0);
            const projectedInterest30 = projectionItems.reduce((sum, item) => sum + item.expectedInterest, 0);

            const totalExpected = Math.max(toNumber(safeMetrics.totalExpected), 0);
            const totalReceived = Math.max(toNumber(safeMetrics.totalReceived), 0);
            const totalOverdue = Math.max(toNumber(safeMetrics.totalOverdue), 0);
            const paidCount = Math.max(toNumber(safeMetrics.paidCount), 0);
            const totalCount = Math.max(toNumber(safeMetrics.totalCount), 0);

            const historicalRate = totalExpected > 0
                ? clamp(totalReceived / totalExpected, 0, 1.15)
                : totalCount > 0
                    ? clamp(paidCount / totalCount, 0.35, 0.9)
                    : 0.7;
            const delinquencyRate = totalExpected > 0 ? (totalOverdue / totalExpected) : 0;
            const riskAdjustment = clamp(1 - (delinquencyRate * 0.55), 0.55, 1);
            const adjustedRate = clamp(historicalRate * riskAdjustment, 0.25, 0.98);

            const projectedReceipt30 = totalDue30 * adjustedRate;
            const expectedRiskLossRate = Math.min(1, Math.max(0.35, delinquencyRate * 2));
            const expectedLoss30 = totalDue30 * expectedRiskLossRate;
            const projectedProfit30 = projectedInterest30 - expectedLoss30;

            const openByClient = new Map();
            projectionItems.forEach((item) => {
                if (!item.debtorId) return;
                openByClient.set(item.debtorId, (openByClient.get(item.debtorId) || 0) + item.outstanding);
            });
            const [top1ClientId, top1Due30] = openByClient.size
                ? Array.from(openByClient.entries()).sort((a, b) => b[1] - a[1])[0]
                : ['', 0];
            const top1ClientName = top1ClientId
                ? (getDebtorById(top1ClientId)?.name || `Cliente #${top1ClientId}`)
                : 'Top 1';
            const top1Share30 = totalDue30 > 0 ? (top1Due30 / totalDue30) : 0;
            const stressImpactCash30 = top1Due30 * adjustedRate;

            const dayMs = 24 * 60 * 60 * 1000;
            const weeklyBuckets = Array.from({ length: 5 }, (_, index) => ({
                label: index === 4 ? 'Sem 5 (D+28-30)' : `Sem ${index + 1} (D+${index * 7}-${(index * 7) + 6})`,
                totalDue: 0,
                projectedReceipt: 0,
            }));
            projectionItems.forEach((item) => {
                const daysAhead = Math.max(0, Math.floor((item.dueDate.getTime() - today.getTime()) / dayMs));
                const weekIndex = Math.min(4, Math.floor(daysAhead / 7));
                weeklyBuckets[weekIndex].totalDue += item.outstanding;
            });
            weeklyBuckets.forEach((bucket) => {
                bucket.projectedReceipt = bucket.totalDue * adjustedRate;
            });

            return {
                totalDue30,
                adjustedRate,
                projectedReceipt30,
                projectedProfit30,
                projectedInterest30,
                expectedLoss30,
                stressImpactCash30,
                top1ClientName,
                top1Due30,
                top1Share30,
                weekly: weeklyBuckets,
                hasUpcomingDue: projectionItems.length > 0,
                tooltip: 'Projeção baseada no histórico do filtro atual e ajustada por risco. Não representa garantia de resultado.',
            };
        }

        function renderProjection30d(installments, metrics) {
            const panel = document.getElementById('projection30dPanel');
            if (!panel) return;

            const projection = buildProjection30dData(installments, metrics);
            const maxWeekProjected = Math.max(
                1,
                ...projection.weekly.map((bucket) => bucket.projectedReceipt)
            );

            panel.innerHTML = `
                <div class="report-projection-grid grid grid-cols-1 gap-3 md:grid-cols-3">
                    <article class="report-projection-card rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex items-start justify-between gap-2">
                            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Projeção de recebimento 30d</p>
                            <i class="fas fa-circle-info cursor-help text-slate-400" title="${escapeHtml(projection.tooltip)}" aria-label="Explicação da projeção de recebimento"></i>
                        </div>
                        <p class="report-projection-card-value text-2xl font-semibold text-slate-900">${formatCurrency(projection.projectedReceipt30)}</p>
                        <p class="report-projection-card-note text-xs text-slate-600">A vencer: ${formatCurrency(projection.totalDue30)} • taxa ajustada: ${formatPercent(projection.adjustedRate)}</p>
                    </article>
                    <article class="report-projection-card rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex items-start justify-between gap-2">
                            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Projeção de lucro 30d</p>
                            <i class="fas fa-circle-info cursor-help text-slate-400" title="${escapeHtml(projection.tooltip)}" aria-label="Explicação da projeção de lucro"></i>
                        </div>
                        <p class="report-projection-card-value text-2xl font-semibold ${projection.projectedProfit30 >= 0 ? 'text-emerald-700' : 'text-red-700'}">${formatCurrency(projection.projectedProfit30)}</p>
                        <p class="report-projection-card-note text-xs text-slate-600">Juros previstos: ${formatCurrency(projection.projectedInterest30)} • perdas esperadas: ${formatCurrency(projection.expectedLoss30)}</p>
                    </article>
                    <article class="report-projection-card rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex items-start justify-between gap-2">
                            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Cenário de estresse (Top1 +30d)</p>
                            <i class="fas fa-circle-info cursor-help text-slate-400" title="Simulação simples: atraso de 30 dias no maior cliente projetado no horizonte." aria-label="Explicação do cenário de estresse"></i>
                        </div>
                        <p class="report-projection-card-value text-2xl font-semibold text-red-700">-${formatCurrency(Math.abs(projection.stressImpactCash30))}</p>
                        <p class="report-projection-card-note text-xs text-slate-600">${escapeHtml(projection.top1ClientName)}: ${formatCurrency(projection.top1Due30)} (${formatPercent(projection.top1Share30)} do total projetado)</p>
                    </article>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                        <p class="text-sm font-semibold text-slate-800">Projeção de recebimento por semana</p>
                        <span class="text-xs text-slate-500">Base 30d: ${projection.hasUpcomingDue ? formatCurrency(projection.totalDue30) : 'sem vencimentos no horizonte'}</span>
                    </div>
                    <div class="report-projection-week-grid mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-5">
                        ${projection.weekly.map((bucket) => {
                            const widthPct = bucket.projectedReceipt > 0
                                ? clamp((bucket.projectedReceipt / maxWeekProjected) * 100, 5, 100)
                                : 0;
                            return `
                                <article class="report-projection-week-card rounded-lg border border-slate-200 bg-white px-3 py-2">
                                    <div class="flex items-center justify-between gap-2 text-[11px] text-slate-600">
                                        <span>${escapeHtml(bucket.label)}</span>
                                        <span class="font-semibold text-slate-800">${formatCurrency(bucket.projectedReceipt)}</span>
                                    </div>
                                    <div class="mt-2 h-2 rounded-full bg-slate-200">
                                        <div class="h-2 rounded-full bg-blue-500" style="width:${widthPct.toFixed(2)}%;"></div>
                                    </div>
                                    <p class="mt-1 text-[11px] text-slate-500">A vencer: ${formatCurrency(bucket.totalDue)}</p>
                                </article>
                            `;
                        }).join('')}
                    </div>
                </div>
            `;
        }

        function calculateAverageOverdueDays(installments) {
            const today = startOfDay(new Date());
            if (!today || !Array.isArray(installments)) return { averageDays: 0, count: 0 };

            let sumDays = 0;
            let count = 0;
            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                if (status !== 'Atrasado') return;
                const dueDate = startOfDay(installment.due_date);
                if (!dueDate) return;
                const overdueDays = Math.max(0, Math.floor((today.getTime() - dueDate.getTime()) / (24 * 60 * 60 * 1000)));
                sumDays += overdueDays;
                count += 1;
            });

            return {
                averageDays: count > 0 ? (sumDays / count) : 0,
                count,
            };
        }

        function buildPeriodInsights(installments, metrics, previousMetrics, previousInstallments) {
            const safeInstallments = Array.isArray(installments) ? installments : [];
            const safePreviousInstallments = Array.isArray(previousInstallments) ? previousInstallments : [];
            const safeMetrics = metrics || {};
            const safePreviousMetrics = previousMetrics || {};

            const insights = [];

            const currentReceived = toNumber(safeMetrics.totalReceived);
            const previousReceived = toNumber(safePreviousMetrics.totalReceived, NaN);
            const hasGrowthBase = Number.isFinite(previousReceived)
                && Math.abs(previousReceived) >= 50
                && safePreviousInstallments.length >= 3;
            if (hasGrowthBase) {
                const growthPct = previousReceived !== 0 ? ((currentReceived - previousReceived) / Math.abs(previousReceived)) : 0;
                insights.push({
                    icon: 'fa-chart-line',
                    text: `Crescimento: recebido variou ${formatSignedPercent(growthPct)} vs período anterior.`,
                    href: '#reportChart',
                });
            } else {
                insights.push({
                    icon: 'fa-chart-line',
                    text: 'Crescimento: base insuficiente para comparar recebido vs período anterior.',
                    href: '#reportChart',
                });
            }

            const openByClient = new Map();
            safeInstallments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                if (status === 'Pago') return;
                const debtorId = String(installment.debtor_id ?? '');
                if (!debtorId) return;
                const outstanding = getInstallmentOutstanding(installment, status);
                openByClient.set(debtorId, (openByClient.get(debtorId) || 0) + outstanding);
            });
            const totalOpen = Math.max(toNumber(safeMetrics.totalOpen), 0);
            if (totalOpen > 0 && openByClient.size > 0) {
                const [topClientId, topClientOpen] = Array.from(openByClient.entries())
                    .sort((a, b) => b[1] - a[1])[0];
                const topClient = getDebtorById(topClientId);
                const concentrationPct = topClientOpen / totalOpen;
                insights.push({
                    icon: 'fa-user-group',
                    text: `Concentração: ${topClient?.name || `Cliente #${topClientId}`} representa ${formatPercent(concentrationPct)} do valor em aberto.`,
                    href: '#statusDistribution',
                });
            } else {
                insights.push({
                    icon: 'fa-user-group',
                    text: 'Concentração: sem saldo em aberto relevante no filtro atual.',
                    href: '#statusDistribution',
                });
            }

            const overdueByClient = new Map();
            safeInstallments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                if (status !== 'Atrasado') return;
                const debtorId = String(installment.debtor_id ?? '');
                if (!debtorId) return;
                const overdueAmount = getInstallmentOutstanding(installment, status);
                overdueByClient.set(debtorId, (overdueByClient.get(debtorId) || 0) + overdueAmount);
            });
            const totalOverdue = Math.max(toNumber(safeMetrics.totalOverdue), 0);
            if (totalOverdue > 0 && overdueByClient.size > 0) {
                const rankedOverdue = Array.from(overdueByClient.values()).sort((a, b) => b - a);
                const topClientsCount = Math.min(3, rankedOverdue.length);
                const topClientsOverdue = rankedOverdue.slice(0, topClientsCount).reduce((sum, value) => sum + value, 0);
                const topOverduePct = topClientsOverdue / totalOverdue;
                insights.push({
                    icon: 'fa-triangle-exclamation',
                    text: `Risco: ${topClientsCount} cliente(s) concentram ${formatPercent(topOverduePct)} do saldo em atraso.`,
                    href: '#topDebtorsTable',
                });
            } else {
                insights.push({
                    icon: 'fa-triangle-exclamation',
                    text: 'Risco: sem saldo em atraso relevante para concentração no período.',
                    href: '#topDebtorsTable',
                });
            }

            const today = startOfDay(new Date());
            const next7Horizon = startOfDay(new Date());
            if (next7Horizon) next7Horizon.setDate(next7Horizon.getDate() + 7);
            let dueNext7Total = 0;
            if (today && next7Horizon) {
                safeInstallments.forEach((installment) => {
                    const status = normalizeInstallmentStatus(installment);
                    if (status === 'Pago') return;
                    const dueDate = startOfDay(installment.due_date);
                    if (!dueDate || dueDate < today || dueDate > next7Horizon) return;
                    dueNext7Total += getInstallmentOutstanding(installment, status);
                });
            }
            const periodExpected = Math.max(toNumber(safeMetrics.totalExpected), 0);
            if (periodExpected > 0) {
                const pressurePct = dueNext7Total / periodExpected;
                insights.push({
                    icon: 'fa-calendar-days',
                    text: `Pressão: próximos 7 dias concentram ${formatPercent(pressurePct)} dos vencimentos.`,
                    href: '#nextDueList',
                });
            } else {
                insights.push({
                    icon: 'fa-calendar-days',
                    text: 'Pressão: base insuficiente para calcular vencimentos do período.',
                    href: '#nextDueList',
                });
            }

            const paidInstallments = safeInstallments.filter((installment) => {
                const status = normalizeInstallmentStatus(installment);
                return status === 'Pago' && installment.payment_date && installment.due_date;
            });
            if (paidInstallments.length >= 3) {
                let onTimeCount = 0;
                paidInstallments.forEach((installment) => {
                    const paymentDate = startOfDay(installment.payment_date);
                    const dueDate = startOfDay(installment.due_date);
                    if (paymentDate && dueDate && paymentDate <= dueDate) onTimeCount += 1;
                });
                const onTimeRate = onTimeCount / paidInstallments.length;
                insights.push({
                    icon: 'fa-gauge-high',
                    text: `Eficiência: taxa de recebimento no prazo em ${formatPercent(onTimeRate)}.`,
                    href: '#recentPaidTable',
                });
            } else {
                insights.push({
                    icon: 'fa-gauge-high',
                    text: 'Eficiência: base insuficiente para medir recebimento no prazo.',
                    href: '#recentPaidTable',
                });
            }

            const currentOverdueAging = calculateAverageOverdueDays(safeInstallments);
            const previousOverdueAging = calculateAverageOverdueDays(safePreviousInstallments);
            const hasAgingBase = previousOverdueAging.count >= 2 && currentOverdueAging.count >= 1;
            if (hasAgingBase) {
                const deltaDays = currentOverdueAging.averageDays - previousOverdueAging.averageDays;
                const deltaText = Math.abs(deltaDays).toLocaleString('pt-BR', {
                    minimumFractionDigits: 1,
                    maximumFractionDigits: 1,
                });
                const verb = deltaDays > 0 ? 'subiu' : deltaDays < 0 ? 'caiu' : 'permaneceu estável em';
                const suffix = deltaDays === 0 ? `${deltaText} dia(s)` : `${deltaText} dia(s) vs período anterior`;
                insights.push({
                    icon: 'fa-bell',
                    text: `Alerta: atraso médio ${verb} ${suffix}.`,
                    href: '#statusDistribution',
                });
            } else {
                insights.push({
                    icon: 'fa-bell',
                    text: 'Alerta: base insuficiente para comparar atraso médio com período anterior.',
                    href: '#statusDistribution',
                });
            }

            return insights;
        }

        function renderInsights(installments, metrics, previousMetrics, previousInstallments) {
            const list = document.getElementById('reportInsightsList');
            if (!list) return;

            const insights = buildPeriodInsights(installments, metrics, previousMetrics, previousInstallments);
            list.innerHTML = reportComponents.insightList(insights);
        }

        function renderPeriodDetails(metrics) {
            const safeMetrics = metrics || {};
            const entries = [
                ['periodDetailTotalLoaned', formatCurrency(safeMetrics.totalLoaned)],
                ['periodDetailTotalExpected', formatCurrency(safeMetrics.totalExpected)],
                ['periodDetailTotalOpen', formatCurrency(safeMetrics.totalOpen)],
                ['periodDetailTotalOverdue', formatCurrency(safeMetrics.totalOverdue)],
                ['periodDetailExpectedRiskLoss', formatCurrency(safeMetrics.expectedRiskLoss)],
                ['periodDetailUniqueLoans', toNumber(safeMetrics.uniqueLoanCount).toLocaleString('pt-BR')],
            ];
            entries.forEach(([id, value]) => {
                const element = document.getElementById(id);
                if (element) element.textContent = value;
            });
        }

        function buildMonthlyMetricsSeries(installments, maxMonths = 12) {
            const grouped = new Map();
            installments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const referenceDate = getInstallmentReferenceDate(installment, status) || startOfDay(installment.due_date);
                const monthKey = toMonthKey(referenceDate);
                if (!monthKey) return;
                if (!grouped.has(monthKey)) grouped.set(monthKey, []);
                grouped.get(monthKey).push(installment);
            });

            let rows = Array.from(grouped.entries())
                .map(([month, items]) => ({ month, metrics: calculateReportMetrics(items) }))
                .sort((a, b) => a.month.localeCompare(b.month));
            if (rows.length > maxMonths) rows = rows.slice(rows.length - maxMonths);
            return rows;
        }

        function getVariation(currentValue, previousValue, options = {}) {
            const { invert = false, minBase = 0.00001 } = options;
            if (!Number.isFinite(previousValue)) return null;
            const previous = Number(previousValue);
            if (Math.abs(previous) < minBase) return null;

            const current = Number.isFinite(Number(currentValue)) ? Number(currentValue) : 0;
            const pct = ((current - previous) / Math.abs(previous)) * 100;
            if (!Number.isFinite(pct)) return null;
            if (Math.abs(pct) < 0.005) return { tone: 'neutral', text: '0,00% vs período anterior' };

            const baseTone = pct > 0 ? 'positive' : 'negative';
            const tone = invert ? (baseTone === 'positive' ? 'negative' : 'positive') : baseTone;
            return {
                tone,
                text: `${pct > 0 ? '↑' : '↓'} ${Math.abs(pct).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}% vs período anterior`,
            };
        }

        function renderSparkline(svgElement, seriesValues, tone = 'neutral') {
            if (!svgElement) return;
            const values = Array.isArray(seriesValues) ? seriesValues.map((value) => Number(value)).filter((value) => Number.isFinite(value)) : [];
            if (!values.length) {
                svgElement.innerHTML = '';
                return;
            }

            const color = tone === 'positive' ? '#16a34a' : tone === 'negative' ? '#dc2626' : '#64748b';
            const fillColor = tone === 'positive'
                ? 'rgba(22, 163, 74, 0.12)'
                : tone === 'negative'
                    ? 'rgba(220, 38, 38, 0.12)'
                    : 'rgba(100, 116, 139, 0.10)';

            const width = 100;
            const height = 34;
            const topPad = 3;
            const bottomPad = 3;
            const usableHeight = height - topPad - bottomPad;
            const minValue = Math.min(...values);
            const maxValue = Math.max(...values);
            const range = maxValue - minValue || 1;
            const stepX = values.length > 1 ? width / (values.length - 1) : width;

            const points = values.map((value, index) => {
                const x = values.length > 1 ? index * stepX : width / 2;
                const normalized = (value - minValue) / range;
                const y = topPad + (1 - normalized) * usableHeight;
                return { x, y };
            });

            const linePath = points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(' ');
            const firstPoint = points[0];
            const lastPoint = points[points.length - 1];
            const areaPath = `${linePath} L ${lastPoint.x.toFixed(2)} ${(height - 1).toFixed(2)} L ${firstPoint.x.toFixed(2)} ${(height - 1).toFixed(2)} Z`;
            let pathLength = 0;
            for (let index = 1; index < points.length; index += 1) {
                const dx = points[index].x - points[index - 1].x;
                const dy = points[index].y - points[index - 1].y;
                pathLength += Math.sqrt((dx * dx) + (dy * dy));
            }

            svgElement.innerHTML = `
                <path d="${areaPath}" fill="${fillColor}"></path>
                <path d="${linePath}" fill="none" stroke="${color}" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="stroke-dasharray:${pathLength};stroke-dashoffset:${pathLength};animation:sparkline-draw 0.7s ease forwards;"></path>
            `;
        }

        function renderCards(installments, previousInstallments = []) {
            const currentMetrics = calculateReportMetrics(installments);
            const previousMetrics = calculateReportMetrics(previousInstallments);
            const monthlySeries = buildMonthlyMetricsSeries(
                reportsState.sparkInstallments.length ? reportsState.sparkInstallments : installments,
                8
            );
            const grid = document.getElementById('reportKpiGrid');
            const skeleton = document.getElementById('reportKpiSkeleton');
            if (!grid || !skeleton) return;

            reportsState.currentMetrics = currentMetrics;
            reportsState.previousMetrics = previousMetrics;
            skeleton.classList.add('hidden');
            grid.classList.remove('hidden');

            grid.innerHTML = reportKpiDefinitions.map((definition) => {
                const currentValue = toNumber(currentMetrics[definition.key]);
                const previousValue = toNumber(previousMetrics[definition.key], NaN);
                const variation = getVariation(currentValue, previousValue, {
                    invert: definition.invert,
                    minBase: definition.minBase,
                });
                const sparkId = `kpiSpark_${definition.key}`;
                const valueLabel = definition.type === 'percent' ? formatPercent(currentValue) : formatCurrency(currentValue);
                const deltaLabel = variation?.text || 'Sem base robusta para comparação';
                const deltaType = variation?.tone === 'positive'
                    ? 'up'
                    : variation?.tone === 'negative'
                        ? 'down'
                        : 'neutral';
                const sparklineData = monthlySeries.slice(-8).map((point) => toNumber(point.metrics[definition.key]));
                return KpiCard({
                    title: definition.label,
                    value: valueLabel,
                    subtitle: definition.note,
                    deltaLabel,
                    deltaType,
                    tooltip: definition.help,
                    sparklineData,
                    sparklineId: sparkId,
                });
            }).join('');

            reportKpiDefinitions.forEach((definition) => {
                const svg = document.getElementById(`kpiSpark_${definition.key}`);
                const series = monthlySeries.slice(-8).map((point) => toNumber(point.metrics[definition.key]));
                const variation = getVariation(
                    toNumber(currentMetrics[definition.key]),
                    toNumber(previousMetrics[definition.key], NaN),
                    { invert: definition.invert, minBase: definition.minBase }
                );
                renderSparkline(svg, series, variation?.tone || 'neutral');
            });
        }

        function bindReportEvents() {
            document.getElementById('reportPeriodFilter').addEventListener('change', () => {
                updateReportCustomRangeVisibility();
                applyReportFilters();
            });
            document.getElementById('reportClientFilter').addEventListener('change', applyReportFilters);
            document.getElementById('reportStatusFilter').addEventListener('change', applyReportFilters);
            document.getElementById('reportInterestTypeFilter').addEventListener('change', applyReportFilters);
            document.getElementById('reportFrequencyFilter').addEventListener('change', applyReportFilters);
            document.getElementById('reportCustomStartDate').addEventListener('change', applyReportFilters);
            document.getElementById('reportCustomEndDate').addEventListener('change', applyReportFilters);
            document.getElementById('reportOnlyOverdue').addEventListener('change', applyReportFilters);
            document.getElementById('reportApplyFiltersBtn').addEventListener('click', applyReportFilters);
            document.getElementById('reportClearFiltersBtn').addEventListener('click', clearReportFilters);
            document.getElementById('exportCsvBtn').addEventListener('click', () => notifyExportPlaceholder('CSV'));
            document.getElementById('exportPdfBtn').addEventListener('click', () => notifyExportPlaceholder('PDF'));

            ['reportClientSearch', 'reportMinValue', 'reportMaxValue'].forEach((fieldId) => {
                const field = document.getElementById(fieldId);
                if (!field) return;
                field.addEventListener('input', () => {
                    if (searchDebounceTimer) clearTimeout(searchDebounceTimer);
                    searchDebounceTimer = setTimeout(applyReportFilters, 260);
                });
            });

            const dueTab7 = document.getElementById('dueTab7');
            const dueTab15 = document.getElementById('dueTab15');
            const dueTab30 = document.getElementById('dueTab30');
            if (dueTab7) {
                dueTab7.addEventListener('click', () => {
                    reportsState.activeDueTab = 'next7';
                    renderNextDueDates(
                        reportsState.sparkInstallments.length ? reportsState.sparkInstallments : reportsState.filteredInstallments,
                        reportsState.currentMetrics
                    );
                });
            }
            if (dueTab15) {
                dueTab15.addEventListener('click', () => {
                    reportsState.activeDueTab = 'next15';
                    renderNextDueDates(
                        reportsState.sparkInstallments.length ? reportsState.sparkInstallments : reportsState.filteredInstallments,
                        reportsState.currentMetrics
                    );
                });
            }
            if (dueTab30) {
                dueTab30.addEventListener('click', () => {
                    reportsState.activeDueTab = 'next30';
                    renderNextDueDates(
                        reportsState.sparkInstallments.length ? reportsState.sparkInstallments : reportsState.filteredInstallments,
                        reportsState.currentMetrics
                    );
                });
            }

            const riskDistribution = document.getElementById('statusDistribution');
            if (riskDistribution) {
                riskDistribution.addEventListener('click', (event) => {
                    const target = event.target;
                    if (!(target instanceof Element)) return;
                    const actionButton = target.closest('[data-risk-action]');
                    if (!(actionButton instanceof HTMLElement)) return;
                    const action = actionButton.getAttribute('data-risk-action');
                    if (!action) return;
                    handleRiskQuickAction(action);
                });
            }

            document.getElementById('topDebtorsMoreBtn').addEventListener('click', () => {
                reportsState.topDebtorsLimit += 8;
                renderTopDebtors(reportsState.filteredInstallments);
            });
            document.getElementById('recentPaidMoreBtn').addEventListener('click', () => {
                reportsState.recentPaidLimit += 8;
                renderRecentPaid(reportsState.filteredInstallments);
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            bindReportEvents();
            loadReportsData();
        });
    </script>
