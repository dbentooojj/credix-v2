                            <article class="period-metric">
                                <p class="period-metric-label">Total em aberto</p>
                                <p id="periodDetailTotalOpen" class="period-metric-value">R$ 0,00</p>
                            </article>
                            <article class="period-metric">
                                <p class="period-metric-label">Total em atraso</p>
                                <p id="periodDetailTotalOverdue" class="period-metric-value">R$ 0,00</p>
                            </article>
                            <article class="period-metric">
                                <p class="period-metric-label">Perda esperada por risco</p>
                                <p id="periodDetailExpectedRiskLoss" class="period-metric-value text-red-600">R$ 0,00</p>
                            </article>
                            <article class="period-metric">
                                <p class="period-metric-label">Empréstimos no filtro</p>
                                <p id="periodDetailUniqueLoans" class="period-metric-value">0</p>
                            </article>
                        </div>
                    </details>
                </div>
                <div class="report-risk-card glass-card rounded-2xl p-5">
                    <div class="intel-section-head mb-3">
                        <div>
                            <h3 class="intel-section-title">Pressão de vencimentos</h3>
                            <p class="intel-section-subtitle">Leitura agregada por dia para decisão rápida.</p>
                        </div>
                        <div class="due-tabs inline-flex rounded-xl border border-slate-300 bg-slate-50 p-1 text-xs font-semibold">
                            <button id="dueTab7" type="button" class="rounded-lg px-3 py-1.5 text-slate-700" aria-pressed="true">Próx. 7 dias</button>
                            <button id="dueTab15" type="button" class="rounded-lg px-3 py-1.5 text-slate-700" aria-pressed="false">Próx. 15 dias</button>
                            <button id="dueTab30" type="button" class="rounded-lg px-3 py-1.5 text-slate-700" aria-pressed="false">Próx. 30 dias</button>
                        </div>
                    </div>
                    <div id="nextDueList" class="space-y-3" role="region" aria-label="Lista de vencimentos futuros">
                        <p class="text-gray-500">Carregando vencimentos...</p>
                    </div>
                </div>
            </section>

            <section class="mb-6">
                <div class="glass-card rounded-2xl p-5">
                    <div class="intel-section-head mb-3">
                        <h3 class="intel-section-title">Seção D: Insights Estratégicos</h3>
                    </div>
                    <ul id="reportInsightsList" class="space-y-2 text-sm text-gray-700" aria-live="polite">
                        <li class="insight-item"><i class="fas fa-bolt"></i><span>Carregando insights...</span></li>
                    </ul>
                </div>
            </section>

            <section class="mb-6">
                <div id="reportProjectionSection" class="glass-card rounded-2xl p-5">
                    <div class="intel-section-head mb-3">
                        <div>
                            <h3 class="intel-section-title">Projeções (30 dias)</h3>
                            <p class="intel-section-subtitle">Estimativas orientativas de caixa e risco para os próximos 30 dias.</p>
                        </div>
                    </div>
                    <div id="projection30dPanel" class="space-y-3" role="region" aria-label="Projeções dos próximos 30 dias">
                        <p class="text-gray-500">Carregando projeções...</p>
                    </div>
                </div>
            </section>

            <section class="glass-card rounded-2xl p-5">
                <div class="intel-section-head mb-4">
                    <h3 class="intel-section-title">Seção E: Tabelas Operacionais</h3>
                </div>
                <div class="report-operational-grid mb-4 grid grid-cols-1 gap-6 xl:grid-cols-2">
                    <div class="report-operational-col">
                        <div class="intel-section-head mb-3">
                            <h3 class="intel-section-title">Top clientes (risco/concentração)</h3>
                            <button id="topDebtorsMoreBtn" type="button" class="action-btn action-btn-soft py-1.5 text-xs">Ver mais</button>
                        </div>
                        <div class="report-operational-table-shell table-shell">
                            <table class="operational-table" aria-label="Tabela de clientes em maior risco">
                                <thead>
                                    <tr>
                                        <th>Cliente</th>
                                        <th>Parcelas em atraso</th>
                                        <th>Saldo em atraso</th>
                                        <th>Total em aberto</th>
                                        <th>Último pagamento</th>
                                        <th>Ações</th>
                                    </tr>
                                </thead>
                                <tbody id="topDebtorsTable">
                                    <tr><td colspan="6" class="py-8 text-center text-gray-500">Carregando ranking...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="report-operational-col">
                        <div class="intel-section-head mb-3">
                            <h3 class="intel-section-title">Últimas parcelas pagas</h3>
                            <button id="recentPaidMoreBtn" type="button" class="action-btn action-btn-soft py-1.5 text-xs">Ver mais</button>
                        </div>
                        <div class="report-operational-table-shell table-shell">
                            <table class="operational-table" aria-label="Tabela de pagamentos recentes">
                                <thead>
                                    <tr>
                                        <th>Data</th>
                                        <th>Cliente</th>
                                        <th>Parcela</th>
                                        <th>Valor</th>
                                    </tr>
                                </thead>
                                <tbody id="recentPaidTable">
                                    <tr><td colspan="4" class="py-8 text-center text-gray-500">Carregando pagamentos...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            const displayName = currentUser.name || currentUser.full_name || 'Administrador';
            document.getElementById('userName').textContent = `Olá, ${displayName}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const sidebarLinks = document.querySelectorAll('#sidebar .sidebar-item');
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');
        const filterAccordionToggle = document.getElementById('filterAccordionToggle');
        const filterAccordionBody = document.getElementById('filterAccordionBody');

        const tableCache = {};
        function getDemoTable(tableName) {
            return Array.isArray(tableCache[tableName]) ? tableCache[tableName] : [];
        }

        async function fetchTableData(tableName) {
            try {
                const response = await fetch(`/api/tables/${tableName}`, { credentials: 'include' });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const payload = await response.json();
                if (Array.isArray(payload?.data)) {
                    tableCache[tableName] = payload.data;
                    return payload.data;
                }
            } catch (error) {
                console.warn(`Fallback para dados demo: ${tableName}`, error);
            }
            return getDemoTable(tableName);
        }

        function setActiveSidebarItem(targetHref) {
            sidebarLinks.forEach(link => {
                const isActive = link.getAttribute('href') === targetHref;
                link.classList.toggle('active', isActive);
                if (isActive) link.setAttribute('aria-current', 'page');
                else link.removeAttribute('aria-current');
            });
        }

        function syncActiveSidebarWithRoute() {
            const currentPage = window.location.pathname.split('/').pop() || 'reports.html';
            setActiveSidebarItem(currentPage);
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            sidebar.classList.remove('mobile-open');
            if (document.body.classList.contains('sidebar-collapsed')) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            main.style.marginLeft = '16rem';
            main.style.width = 'calc(100% - 16rem)';
            main.style.flex = '0 1 calc(100% - 16rem)';
        }

        sidebarToggle.addEventListener('click', function() {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();
        syncActiveSidebarWithRoute();

        function closeUserMenu() {
            if (!userMenuDropdown) return;
            userMenuDropdown.classList.add('hidden');
        }

        function showUserMenuNotice(message) {
            if (typeof showMessage === 'function') {
                showMessage(message, 'success');
                return;
            }
            window.alert(message);
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        async function handleUserMenuAction(action) {
            if (action === 'logout') {
                await performLogout();
                return;
            }

            const allowedTabs = new Set(['profile', 'security', 'help']);
            const destination = allowedTabs.has(action) ? action : 'profile';
            window.location.href = `/admin/account.html?tab=${encodeURIComponent(destination)}`;
        }

        if (userMenuBtn && userMenuDropdown) {
            userMenuBtn.addEventListener('click', (event) => {
                event.stopPropagation();
                userMenuDropdown.classList.toggle('hidden');
            });

            userMenuDropdown.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Element)) return;
                const actionBtn = target.closest('[data-user-menu-action]');
                if (!actionBtn) return;
                const action = actionBtn.getAttribute('data-user-menu-action');
                closeUserMenu();
                void handleUserMenuAction(action);
            });

            document.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Node)) return;
                if (userMenuDropdown.classList.contains('hidden')) return;
                if (userMenuDropdown.contains(target) || userMenuBtn.contains(target)) return;
                closeUserMenu();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeUserMenu();
            });
        }

        function syncFilterAccordionLabel(isOpen) {
            if (!filterAccordionToggle) return;
            const label = filterAccordionToggle.querySelector('span');
            if (label) label.textContent = isOpen ? 'Ocultar filtros' : 'Mostrar filtros';
            filterAccordionToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }

        if (filterAccordionToggle && filterAccordionBody) {
            filterAccordionToggle.addEventListener('click', () => {
                const isOpen = filterAccordionBody.classList.toggle('open');
                syncFilterAccordionLabel(isOpen);
            });

            syncFilterAccordionLabel(filterAccordionBody.classList.contains('open'));
        }

        const reportsState = {
            loans: [],
            installments: [],
            debtors: [],
            filteredInstallments: [],
            previousInstallments: [],
            sparkInstallments: [],
            loanFrequencyById: new Map(),
            activeDueTab: 'next7',
            topDebtorsLimit: 8,
            recentPaidLimit: 8,
            topDebtorsRows: [],
            recentPaidRows: [],
            currentMetrics: null,
            previousMetrics: null,
            isLoading: true,
        };

        const reportKpiDefinitions = [
            { key: 'totalReceived', label: 'Receita do período', note: 'Recebimentos consolidados no recorte.', type: 'currency', invert: false, minBase: 50, help: 'Soma dos pagamentos efetivamente recebidos no período.' },
            { key: 'estimatedProfit', label: 'Lucro líquido estimado', note: 'Margem estimada da carteira filtrada.', type: 'currency', invert: false, minBase: 50, help: 'Diferença entre previsto total e principal emprestado.' },
            { key: 'delinquencyRate', label: 'Taxa de inadimplência real', note: 'Atraso sobre o total previsto.', type: 'percent', invert: true, minBase: 0.0001, help: 'Percentual de saldo vencido sobre o valor previsto no período.' },
            { key: 'ticketAverage', label: 'Ticket médio', note: 'Valor médio por empréstimo.', type: 'currency', invert: false, minBase: 1, help: 'Principal total dividido pela quantidade de empréstimos no recorte.' },
        ];

        function KpiCard({
            title,
            value,
            subtitle,
            deltaLabel,
            deltaType = 'neutral',
            tooltip = '',
            sparklineData = [],
            sparklineId = '',
        }) {
            const deltaClass = deltaType === 'up'
                ? 'kpi-delta-up'
                : deltaType === 'down'
                    ? 'kpi-delta-down'
                    : 'kpi-delta-neutral';
            const sparkline = Array.isArray(sparklineData) && sparklineData.length && sparklineId
                ? `<div class="mt-3 h-[34px] w-full" aria-hidden="true"><svg id="${sparklineId}" class="h-full w-full" viewBox="0 0 100 34" preserveAspectRatio="none"></svg></div>`
                : '';

            return `
                <article class="report-kpi-card glass-card rounded-2xl p-5" role="group" aria-label="${escapeHtml(title)}">
                    <div class="flex items-start justify-between gap-3">
                        <p class="kpi-label">${escapeHtml(title)}</p>
                        <i class="fas fa-circle-info cursor-help text-slate-400" title="${escapeHtml(tooltip)}" aria-hidden="true"></i>
                    </div>
                    <p class="kpi-value mt-2">${escapeHtml(value)}</p>
                    <p class="kpi-note">${escapeHtml(subtitle)}</p>
                    <span class="kpi-delta-pill ${deltaClass}">${escapeHtml(deltaLabel || 'Sem base robusta para comparação')}</span>
                    ${sparkline}
                </article>
            `;
        }

        function KpiCardSkeleton() {
            return `
                <article class="report-kpi-card glass-card rounded-2xl p-5" aria-hidden="true">
                    <div class="skeleton h-3 w-24"></div>
                    <div class="skeleton mt-3 h-8 w-36"></div>
                    <div class="skeleton mt-3 h-3 w-44"></div>
                    <div class="skeleton mt-3 h-4 w-40 rounded-full"></div>
                    <div class="skeleton mt-3 h-8 w-full"></div>
                </article>
            `;
        }

        const reportComponents = {
            insightList(items = [], emptyMessage = 'Sem insights para o filtro atual.') {
                if (!items.length) {
                    return `<li class="insight-item"><i class="fas fa-circle-info" aria-hidden="true"></i><span>${escapeHtml(emptyMessage)}</span></li>`;
                }

                return items.map((item, index) => {
                    const insight = typeof item === 'string'
                        ? {
                            icon: index === 0 ? 'fa-bolt' : 'fa-lightbulb',
                            text: item,
                            href: '#reportKpiSection',
                            detailLabel: 'Ver detalhes',
                        }
                        : {
                            icon: item?.icon || (index === 0 ? 'fa-bolt' : 'fa-lightbulb'),
                            text: item?.text || '',
                            href: item?.href || '#reportKpiSection',
                            detailLabel: item?.detailLabel || 'Ver detalhes',
                        };
                    const iconClass = sanitizeFaIcon(insight.icon);
                    const href = sanitizeInsightHref(insight.href);
                    const detailLabel = String(insight.detailLabel || 'Ver detalhes');
                    return `
                        <li class="insight-item">
                            <i class="fas ${iconClass}" aria-hidden="true"></i>
                            <div class="flex min-w-0 flex-1 items-start justify-between gap-3">
                                <span class="leading-relaxed">${escapeHtml(insight.text)}</span>
                                <a href="${href}" class="inline-flex shrink-0 items-center rounded-md border border-slate-300 bg-slate-50 px-2 py-1 text-[11px] font-semibold text-slate-700 hover:bg-slate-100 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 dark:hover:bg-slate-700">${escapeHtml(detailLabel)}</a>
                            </div>
                        </li>
                    `;
                }).join('');
            },
            riskPanel({ overduePercent, overdueCount, openCount, overdueAmount, openAmount }) {
                return `
                    <div class="risk-panel-summary mb-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
                        <article class="risk-chip">
                            <p class="risk-chip-label">Inadimplência</p>
                            <p class="risk-chip-value text-red-600">${formatPercentAbsolute(overduePercent)}</p>
                            <p class="risk-chip-note">${overdueCount} parcela(s) atrasada(s)</p>
                        </article>
                        <article class="risk-chip">
                            <p class="risk-chip-label">Pressão em aberto</p>
                            <p class="risk-chip-value">${formatCurrency(openAmount)}</p>
                            <p class="risk-chip-note">${openCount} parcela(s) em aberto</p>
                        </article>
                        <article class="risk-chip">
                            <p class="risk-chip-label">Exposição atrasada</p>
                            <p class="risk-chip-value text-red-600">${formatCurrency(overdueAmount)}</p>
                            <p class="risk-chip-note">Saldo total em atraso</p>
                        </article>
                        <article class="risk-chip">
                            <p class="risk-chip-label">Cobertura recebida</p>
                            <p class="risk-chip-value">${formatPercentAbsolute(Math.max(0, 100 - toNumber(overduePercent)))}</p>
                            <p class="risk-chip-note">Parcela saudável da carteira</p>
                        </article>
                    </div>
                `;
            },
        };

        let searchDebounceTimer = null;

        function sameId(a, b) {
            return String(a ?? '') === String(b ?? '');
        }

        function toNumber(value, fallback = 0) {
            const parsed = Number(value);
            return Number.isFinite(parsed) ? parsed : fallback;
        }

        function round2(value) {
            return Math.round((toNumber(value) + Number.EPSILON) * 100) / 100;
        }

        function normalizeAscii(value) {
            return String(value ?? '')
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .toLowerCase()
                .trim();
        }

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function parseDateValue(value) {
            if (!value) return null;
            if (value instanceof Date) return new Date(value.getTime());

            const raw = String(value).trim();
            const dateOnlyMatch = raw.match(/^(\d{4})-(\d{2})-(\d{2})$/);
            if (dateOnlyMatch) {
                return new Date(Number(dateOnlyMatch[1]), Number(dateOnlyMatch[2]) - 1, Number(dateOnlyMatch[3]));
            }

            const parsed = new Date(raw);
            if (Number.isNaN(parsed.getTime())) return null;
            return parsed;
        }

        function startOfDay(value) {
            const date = parseDateValue(value);
            if (!date) return null;
            date.setHours(0, 0, 0, 0);
            return date;
        }

        function toIsoDate(value) {
            const date = parseDateValue(value);
            if (!date) return '';
            return date.toISOString().slice(0, 10);
        }

        function toMonthKey(value) {
            const date = startOfDay(value);
            if (!date) return '';
            return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
        }

        function formatMonthLabel(monthKey) {
            if (!monthKey) return '--';
            const [year, month] = monthKey.split('-').map(Number);
            const date = new Date(year, (month || 1) - 1, 1);
            return date.toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' });
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(toNumber(value));
        }

        function formatCompactCurrency(value) {
            const numeric = toNumber(value);
            if (Math.abs(numeric) < 1000000) return formatCurrency(numeric);
            return new Intl.NumberFormat('pt-BR', {
                style: 'currency',
                currency: 'BRL',
                notation: 'compact',
                compactDisplay: 'short',
                maximumFractionDigits: 1,
            }).format(numeric);
        }

        function formatPercent(value) {
            return `${(toNumber(value) * 100).toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            })}%`;
        }

        function formatPercentAbsolute(value) {
            return `${toNumber(value).toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            })}%`;
        }

        function formatSignedPercent(value) {
            const numeric = toNumber(value) * 100;
            const sign = numeric > 0 ? '+' : '';
            return `${sign}${numeric.toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            })}%`;
        }

        function clamp(value, min, max) {
            return Math.min(max, Math.max(min, value));
        }

        function sanitizeInsightHref(href) {
            const raw = String(href || '').trim();
            return /^#[a-zA-Z][\w:-]*$/.test(raw) ? raw : '#reportKpiSection';
        }

        function sanitizeFaIcon(iconClass) {
            const raw = String(iconClass || '').trim().toLowerCase();
            return /^fa-[a-z0-9-]+$/.test(raw) ? raw : 'fa-circle-info';
        }

        function formatDate(value) {
            const date = parseDateValue(value);
            if (!date) return '-';
            return date.toLocaleDateString('pt-BR');
        }

        function normalizeLoanRow(row) {
            return {
                ...row,
                id: row.id,
                debtor_id: row.debtor_id ?? row.client_id ?? row.clientId,
                principal_amount: round2(row.principal_amount ?? row.principalAmount ?? 0),
                total_amount: round2(row.total_amount ?? row.totalAmount ?? 0),
            };
        }

        function normalizeDebtorRow(row) {
            return {
                ...row,
                id: row.id,
                name: row.name || row.full_name || 'Cliente sem nome',
                phone: row.phone || '',
            };
        }

        function normalizeInstallmentRow(row) {
            return {
                ...row,
                id: row.id,
                loan_id: row.loan_id ?? row.loanId,
                debtor_id: row.debtor_id ?? row.client_id ?? row.clientId,
                installment_number: Math.max(1, Math.trunc(toNumber(row.installment_number ?? row.installmentNumber ?? row.number ?? 1))),
                due_date: toIsoDate(row.due_date ?? row.dueDate),
                payment_date: toIsoDate(row.payment_date ?? row.paymentDate),
                amount: round2(row.amount),
                paid_amount: round2(row.paid_amount ?? row.paidAmount ?? row.amount),
                principal_amount: row.principal_amount ?? row.principalAmount ?? null,
                interest_amount: row.interest_amount ?? row.interestAmount ?? null,
                status: row.status || 'Pendente',
            };
        }

        function getLoanById(loanId) {
            return reportsState.loans.find((loan) => sameId(loan.id, loanId));
        }

        function getDebtorById(debtorId) {
            return reportsState.debtors.find((debtor) => sameId(debtor.id, debtorId));
        }

        function normalizeInstallmentStatus(installment) {
            const rawStatus = normalizeAscii(installment.status);
            if (rawStatus === 'pago' || rawStatus === 'paid') return 'Pago';
            if (rawStatus === 'atrasado' || rawStatus === 'overdue') return 'Atrasado';
            if (installment.payment_date) return 'Pago';

            const dueDate = startOfDay(installment.due_date);
            const today = startOfDay(new Date());
            if (dueDate && today && dueDate < today) return 'Atrasado';
            return 'Pendente';
        }

        function getStatusBadgeClass(status) {
            if (status === 'Pago') return 'badge-success';
            if (status === 'Atrasado') return 'badge-danger';
            return 'badge-warn';
        }

        function getInstallmentReferenceDate(installment, status) {
            if (status === 'Pago' && installment.payment_date) {
                return startOfDay(installment.payment_date);
            }
            return startOfDay(installment.due_date);
        }

        function getInstallmentPaidAmount(installment, status) {
            if (status === 'Pago') return Math.max(toNumber(installment.paid_amount ?? installment.amount), 0);
            return Math.max(Math.min(toNumber(installment.paid_amount), toNumber(installment.amount)), 0);
        }

        function getInstallmentOutstanding(installment, status) {
            if (status === 'Pago') return 0;
            const amount = Math.max(toNumber(installment.amount), 0);
            const paidAmount = getInstallmentPaidAmount(installment, status);
            return Math.max(amount - paidAmount, 0);
        }

        function getInstallmentPrincipal(installment) {
            const explicitPrincipal = Number(installment.principal_amount);
            if (Number.isFinite(explicitPrincipal) && explicitPrincipal > 0) return round2(explicitPrincipal);

            const explicitInterest = Number(installment.interest_amount);
            const amount = toNumber(installment.amount);
            if (Number.isFinite(explicitInterest) && explicitInterest >= 0 && explicitInterest <= amount) {
                return round2(Math.max(amount - explicitInterest, 0));
            }

            const loan = getLoanById(installment.loan_id);
            const loanPrincipal = toNumber(loan?.principal_amount);
            const loanTotal = toNumber(loan?.total_amount);
            if (loanPrincipal > 0 && loanTotal > 0) {
                return round2(amount * (loanPrincipal / loanTotal));
            }

            return round2(amount);
        }

        function buildRiskClientRows(installments) {
            const grouped = new Map();
            const today = startOfDay(new Date());
            const dayMs = 24 * 60 * 60 * 1000;

            installments.forEach((installment) => {
                const debtorId = String(installment.debtor_id ?? '');
                if (!debtorId) return;

                if (!grouped.has(debtorId)) {
                    grouped.set(debtorId, {
                        id: debtorId,
                        openAmount: 0,
                        overdueAmount: 0,
                        overdueDaysTotal: 0,
                        overdueCount: 0,
                    });
                }

                const status = normalizeInstallmentStatus(installment);
                const outstanding = getInstallmentOutstanding(installment, status);
                const row = grouped.get(debtorId);

                if (status !== 'Pago') row.openAmount += outstanding;
                if (status === 'Atrasado') {
                    row.overdueAmount += outstanding;
                    const dueDate = startOfDay(installment.due_date);
                    if (today && dueDate) {
                        const days = Math.max(0, Math.floor((today.getTime() - dueDate.getTime()) / dayMs));
                        row.overdueDaysTotal += days;
                        row.overdueCount += 1;
                    }
                }
            });

            return Array.from(grouped.values())
                .map((row) => {
                    const avgOverdueDays = row.overdueCount > 0 ? (row.overdueDaysTotal / row.overdueCount) : 0;
                    const debtor = getDebtorById(row.id);
                    const scoreCliente = (row.overdueAmount * 2) + (row.openAmount * 1) + (avgOverdueDays * 0.5);
                    return {
                        ...row,
                        name: debtor?.name || `Cliente #${row.id}`,
                        avgOverdueDays,
                        scoreCliente,
                    };
                })
                .sort((a, b) => (b.scoreCliente - a.scoreCliente) || (b.overdueAmount - a.overdueAmount));
        }

        function exportRiskListCsv() {
            const rows = buildRiskClientRows(reportsState.filteredInstallments || []);
            if (!rows.length) {
                showReportFeedback('Sem clientes críticos para exportar a lista de risco.', 'error');
                return;
            }

            const header = ['Cliente', 'Saldo em atraso', 'Saldo em aberto', 'Dias atraso médio', 'Score cliente'];
            const lines = rows.slice(0, 300).map((row) => ([
                row.name,
                round2(row.overdueAmount).toFixed(2).replace('.', ','),
                round2(row.openAmount).toFixed(2).replace('.', ','),
                row.avgOverdueDays.toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 }),
                row.scoreCliente.toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 }),
            ].map(escapeCsvField).join(';')));
            const csvContent = [header.map(escapeCsvField).join(';'), ...lines].join('\n');
            downloadBlob(`risco-carteira-${new Date().toISOString().slice(0, 10)}.csv`, new Blob([csvContent], { type: 'text/csv;charset=utf-8;' }));
            showReportFeedback('Lista de risco exportada com sucesso.', 'info');
        }

