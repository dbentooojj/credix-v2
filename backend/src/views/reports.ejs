                        <div class="card"><div class="label">Total previsto</div><div class="value">${formatCurrency(metrics.totalExpected)}</div></div>
                        <div class="card"><div class="label">Total recebido</div><div class="value">${formatCurrency(metrics.totalReceived)}</div></div>
                        <div class="card"><div class="label">Total em atraso</div><div class="value">${formatCurrency(metrics.totalOverdue)}</div></div>
                    </section>
