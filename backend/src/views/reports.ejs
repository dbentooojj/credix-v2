        function applyReportFilters() {
            const periodValue = document.getElementById('reportPeriodFilter')?.value || 'month_current';
            const clientValue = document.getElementById('reportClientFilter')?.value || 'all';
            const clientSearch = document.getElementById('reportClientSearch')?.value || '';
            const statusValue = document.getElementById('reportStatusFilter')?.value || 'all';
            const interestTypeValue = document.getElementById('reportInterestTypeFilter')?.value || 'all';
            const frequencyValue = document.getElementById('reportFrequencyFilter')?.value || 'all';
            const minValue = document.getElementById('reportMinValue')?.value || '';
            const maxValue = document.getElementById('reportMaxValue')?.value || '';
            const onlyOverdue = !!document.getElementById('reportOnlyOverdue')?.checked;
            const { start, end } = getPeriodBounds(periodValue);

            if (periodValue === 'custom' && (!start || !end)) {
                showReportFeedback('Defina data inicial e final para o intervalo custom.', 'error');
                return;
            }

            const previousBounds = getPreviousPeriodBounds(start, end);
            const sharedFilters = {
                clientValue,
                clientSearch,
                statusValue,
                interestTypeValue,
                frequencyValue,
                minValue,
                maxValue,
                onlyOverdue,
            };

            reportsState.sparkInstallments = filterInstallments(reportsState.installments, {
                ...sharedFilters,
                start: null,
                end: null,
            });
            reportsState.filteredInstallments = filterInstallments(reportsState.installments, {
                ...sharedFilters,
                start,
                end,
            });
            reportsState.previousInstallments = previousBounds.start && previousBounds.end
                ? filterInstallments(reportsState.installments, {
                    ...sharedFilters,
                    start: previousBounds.start,
                    end: previousBounds.end,
                })
                : [];

            reportsState.topDebtorsLimit = 8;
            reportsState.recentPaidLimit = 8;
            showReportFeedback('');
            renderReports();
            document.getElementById('reportUpdatedAt').textContent = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
        }

