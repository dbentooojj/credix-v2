            margin-top: 4px;
            font-size: 12px;
            color: #64748b;
        }

        .portfolio-score-card {
            border: 1px solid #dbe4f1;
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        }

        .score-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .score-title {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #64748b;
        }

        .score-main {
            display: flex;
            align-items: baseline;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 4px;
        }

        .score-value {
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
            color: #0f172a;
        }

        .score-badge {
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            border: 1px solid transparent;
            padding: 4px 10px;
            font-size: 12px;
            font-weight: 700;
            white-space: nowrap;
        }

        .score-badge-healthy {
            background: #ecfdf3;
            border-color: #bbf7d0;
            color: #166534;
        }

        .score-badge-moderate {
            background: #fffbeb;
            border-color: #fde68a;
            color: #92400e;
        }

        .score-badge-risk {
            background: #fef2f2;
            border-color: #fecaca;
            color: #991b1b;
        }

        .score-factors {
            margin-top: 12px;
            display: grid;
            grid-template-columns: repeat(1, minmax(0, 1fr));
            gap: 8px;
        }

        .score-factor {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            background: #ffffff;
            padding: 8px 10px;
        }

        .score-factor-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 6px;
        }

        .score-factor-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
        }

        .score-factor-impact {
            font-size: 11px;
            font-weight: 700;
            color: #334155;
            white-space: nowrap;
        }

        .score-factor-meta {
            margin-top: 5px;
            font-size: 11px;
            color: #64748b;
        }

        .score-bar-track {
            height: 7px;
            border-radius: 999px;
            background: #e2e8f0;
            overflow: hidden;
        }

        .score-bar-fill {
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
            transition: width 180ms ease-out;
        }

        .kpi-delta-pill {
            width: fit-content;
            margin-top: 8px;
            border-radius: 999px;
            border: 1px solid #e2e8f0;
            padding: 2px 8px;
            font-size: 11px;
            font-weight: 700;
            line-height: 1.3;
        }

        .kpi-delta-up {
            border-color: #bbf7d0;
            background: #f0fdf4;
            color: #166534;
        }

        .kpi-delta-down {
            border-color: #fecaca;
            background: #fef2f2;
            color: #991b1b;
        }

        .kpi-delta-neutral {
            border-color: #e2e8f0;
            background: #f8fafc;
            color: #475569;
        }

        .report-chart-shell-xl {
            min-height: 360px;
        }

        .operational-table {
            width: 100%;
            min-width: 0;
            table-layout: auto;
        }

        .intel-section-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .intel-section-title {
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: 0.01em;
        }

        .intel-section-subtitle {
            margin-top: 4px;
            font-size: 12px;
            color: #64748b;
            line-height: 1.4;
        }

        .period-details {
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            background: #f8fafc;
            padding: 10px 12px;
        }

        .period-details > summary {
            cursor: pointer;
            font-size: 12px;
            font-weight: 700;
            color: #334155;
            list-style: none;
        }

        .period-details > summary::-webkit-details-marker {
            display: none;
        }

        .period-details-grid {
            margin-top: 10px;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
            align-items: stretch;
        }

        .period-metric {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            background: #ffffff;
            padding: 8px 10px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .period-metric-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            font-weight: 700;
        }

        .period-metric-value {
            margin-top: 4px;
            color: #0f172a;
            font-size: 0.95rem;
            font-weight: 700;
            margin-bottom: 0;
        }

        .report-operational-grid {
            align-items: start;
        }

        .report-risk-grid {
            align-items: stretch;
        }

        .report-risk-card {
            min-width: 0;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .report-risk-card > * {
            min-width: 0;
        }

        .due-tabs {
            display: flex;
            gap: 4px;
            flex-wrap: nowrap;
            max-width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .due-tabs button {
            flex: 0 0 auto;
            white-space: nowrap;
        }

        .report-operational-col {
            display: block;
            min-height: auto;
        }

        .report-operational-table-shell {
            display: block;
        }

        .report-operational-table-shell td {
            vertical-align: top;
        }

        .report-projection-grid,
        .report-projection-week-grid {
            align-items: stretch;
        }

        .report-projection-card,
        .report-projection-week-card {
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .report-projection-card-value {
            margin-top: 8px;
            line-height: 1.15;
        }

        .report-projection-card-note {
            margin-top: auto;
            padding-top: 8px;
        }

        .due-summary-grid {
            align-items: stretch;
        }

        .due-summary-item {
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        @media (max-width: 1280px) {
            .report-command-deck {
                grid-template-columns: 1fr 1fr;
            }

            .deck-main {
                grid-column: 1 / -1;
            }
        }

        @media (max-width: 900px) {
            .report-command-deck {
                grid-template-columns: 1fr;
            }

            .report-chart-highlights {
                grid-template-columns: 1fr;
            }

            .deck-metrics {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .kpi-value {
                font-size: 1.75rem;
            }

            .period-details-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 1024px) {
            .operational-table {
                min-width: 680px;
            }
        }

        @media (min-width: 768px) {
            .score-factors {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .risk-distribution-grid {
                grid-template-columns: 180px 1fr;
            }

            .risk-actions {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (min-width: 1280px) {
            .score-factors {
                grid-template-columns: repeat(4, minmax(0, 1fr));
            }

            .risk-actions {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
        }

        @media (min-width: 1536px) {
            .risk-layout {
                grid-template-columns: 1.1fr 1fr;
            }

            .risk-concentration-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .skeleton,
            .chart-bar,
            .report-kpi-card,
            .action-btn,
            .filter-control {
                animation: none !important;
                transition: none !important;
            }
        }
</style>
</head>
<body class="primary-gradient min-h-screen">
    <header class="premium-header fixed w-full top-0 z-50">
        <div class="flex items-center justify-between px-3 py-3 sm:px-6 sm:py-4">
            <div class="flex items-center">
                <button id="sidebarToggle" class="icon-btn focus:outline-none"><i class="fas fa-bars text-xl"></i></button>
                <h1 class="ml-3 sm:ml-6">
                    <a href="dashboard.html" class="flex items-center" aria-label="Credix">
                        <%- include('partials/brand-wordmark', { size: 'header' }) %>
                    </a>
                </h1>
            </div>
            <div class="flex flex-1 items-center justify-end gap-1 sm:gap-4 lg:gap-6 min-w-0">
                <div class="relative min-w-0">
                    <button id="userMenuBtn" class="flex items-center gap-2 text-slate-200 hover:text-white focus:outline-none min-w-0 max-w-full overflow-hidden">
                        <span id="userName" class="header-user-name font-semibold min-w-0 truncate">Olá, <%= currentUser?.name || currentUser?.full_name || 'Administrador' %></span>
                        <i class="header-user-chevron fas fa-chevron-down text-sm"></i>
                    </button>
                    <div id="userMenuDropdown" class="absolute right-0 top-full z-50 mt-2 hidden w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-xl dark:border-slate-700 dark:bg-slate-900">
                        <button type="button" data-user-menu-action="profile" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                            <i class="fas fa-id-card text-slate-500 dark:text-slate-300"></i>
                            <span>Meu perfil</span>
                        </button>
                        <button type="button" data-user-menu-action="security" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                            <i class="fas fa-shield-halved text-slate-500 dark:text-slate-300"></i>
                            <span>Segurança</span>
                        </button>
                        <button type="button" data-user-menu-action="help" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                            <i class="fas fa-circle-question text-slate-500 dark:text-slate-300"></i>
                            <span>Ajuda</span>
                        </button>
                        <div class="my-1 h-px bg-slate-200 dark:bg-slate-700"></div>
                        <button type="button" data-user-menu-action="logout" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-950/40">
                            <i class="fas fa-right-from-bracket"></i>
                            <span>Sair</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="flex pt-16 sm:pt-20">
        <aside id="sidebar" class="modern-sidebar fixed left-0 top-16 h-[calc(100%-4rem)] w-64 z-40 sm:top-20 sm:h-[calc(100%-5rem)]">
            <nav class="mt-8 px-4">
                <ul class="space-y-2">
                    <li><a href="dashboard.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-tachometer-alt mr-4 text-lg"></i><span>Painel financeiro</span></a></li>
                    <li><a href="debtors.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-users mr-4 text-lg"></i><span>Clientes</span></a></li>
                    <li><a href="loans.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-hand-holding-usd mr-4 text-lg"></i><span>Empréstimos</span></a></li>
                    <li><a href="installments.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-calendar-check mr-4 text-lg"></i><span>Parcelas</span></a></li>
                    <li><a href="reports.html" class="sidebar-item active flex items-center px-4 py-3 text-white rounded-lg"><i class="fas fa-chart-bar mr-4 text-lg"></i><span class="font-medium">Relatórios</span></a></li>
                </ul>
            </nav>
        </aside>

        <main class="flex-1 ml-64 p-4 sm:p-6 lg:p-8">
            <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                <div>
                    <h2 class="page-title text-3xl font-bold">Relatórios</h2>
                    <p class="muted-on-dark mt-1 text-sm">Resumo da carteira, risco e projeções em tempo real.</p>
                </div>
                <div class="report-page-toolbar">
                    <p class="text-xs text-slate-300">Última atualização: <span id="reportUpdatedAt" class="font-semibold text-slate-100" aria-live="polite">--:--</span></p>
                    <div class="report-page-actions">
                        <button id="exportCsvBtn" type="button" class="action-btn action-btn-soft">
                            <i class="fas fa-file-csv mr-1"></i>Exportar CSV
                        </button>
                        <button id="exportPdfBtn" type="button" class="action-btn action-btn-soft">
                            <i class="fas fa-file-pdf mr-1"></i>Exportar PDF
                        </button>
                    </div>
                </div>
            </div>

            <section id="reportFilterBar" class="glass-card mb-4 rounded-2xl p-4 sm:p-6">
                <div class="intel-section-head">
                    <div>
                        <h3 class="intel-section-title">Filtros avançados</h3>
                    </div>
                    <button id="filterAccordionToggle" type="button" class="inline-flex items-center gap-2 rounded-xl border border-slate-300 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700" aria-expanded="false" aria-controls="filterAccordionBody">
                        <i class="fas fa-sliders"></i>
                        <span>Mostrar filtros</span>
                    </button>
                </div>

                <div id="filterAccordionBody" class="mt-3 space-y-3">
                    <div class="report-filter-grid">
                        <div class="report-filter-field">
                            <label for="reportPeriodFilter" class="mb-1 block text-sm text-gray-600">Período</label>
                            <select id="reportPeriodFilter" class="filter-control">
                                <option value="all">Todo período</option>
                                <option value="month_current" selected>Mês atual</option>
                                <option value="month_previous">Mês anterior</option>
                                <option value="last7">Últimos 7 dias</option>
                                <option value="last15">Últimos 15 dias</option>
                                <option value="last30">Últimos 30 dias</option>
                                <option value="custom">Intervalo custom</option>
                            </select>
                        </div>
                        <div id="reportCustomRangeWrap" class="hidden report-filter-field report-filter-field-range">
                            <label class="mb-1 block text-sm text-gray-600">Intervalo custom</label>
                            <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                                <input id="reportCustomStartDate" type="date" class="filter-control" aria-label="Data inicial do relatório">
                                <input id="reportCustomEndDate" type="date" class="filter-control" aria-label="Data final do relatório">
                            </div>
                        </div>
                        <div class="report-filter-field">
                            <label for="reportClientFilter" class="mb-1 block text-sm text-gray-600">Cliente</label>
                            <select id="reportClientFilter" class="filter-control">
                                <option value="all">Todos os clientes</option>
                            </select>
                        </div>
                        <div class="report-filter-field">
                            <label for="reportClientSearch" class="mb-1 block text-sm text-gray-600">Busca de cliente</label>
                            <input id="reportClientSearch" type="text" class="filter-control" placeholder="Nome, telefone ou documento">
                        </div>
                        <div class="report-filter-field">
                            <label for="reportStatusFilter" class="mb-1 block text-sm text-gray-600">Status</label>
                            <select id="reportStatusFilter" class="filter-control">
                                <option value="all">Todos</option>
                                <option value="paid">Pago</option>
                                <option value="pending">Pendente</option>
                                <option value="overdue">Atrasado</option>
                            </select>
                        </div>
                        <div class="report-filter-field">
                            <label for="reportInterestTypeFilter" class="mb-1 block text-sm text-gray-600">Tipo de juros</label>
                            <select id="reportInterestTypeFilter" class="filter-control">
                                <option value="all">Todos</option>
                                <option value="simples">Simples</option>
                                <option value="composto">Composto</option>
                                <option value="fixo">Valor fixo</option>
                            </select>
                        </div>
                        <div class="report-filter-field">
                            <label for="reportFrequencyFilter" class="mb-1 block text-sm text-gray-600">Forma</label>
                            <select id="reportFrequencyFilter" class="filter-control">
                                <option value="all">Todas</option>
                                <option value="mensal">Mensal</option>
                                <option value="quinzenal">Quinzenal</option>
                            </select>
                        </div>
                        <div class="report-filter-field">
                            <label for="reportMinValue" class="mb-1 block text-sm text-gray-600">Valor mín.</label>
                            <input id="reportMinValue" type="number" min="0" step="0.01" class="filter-control" placeholder="0,00">
                        </div>
                        <div class="report-filter-field">
                            <label for="reportMaxValue" class="mb-1 block text-sm text-gray-600">Valor máx.</label>
                            <input id="reportMaxValue" type="number" min="0" step="0.01" class="filter-control" placeholder="0,00">
                        </div>
                    </div>

                    <div class="report-filter-footer">
                        <label class="inline-flex items-center gap-2 rounded-xl border border-slate-300 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700">
                            <input id="reportOnlyOverdue" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500">
                            Somente atrasados
                        </label>
                        <div class="report-filter-actions">
                            <button id="reportApplyFiltersBtn" type="button" class="action-btn action-btn-primary">
                                <i class="fas fa-filter mr-1"></i>Aplicar
                            </button>
                            <button id="reportClearFiltersBtn" type="button" class="action-btn action-btn-soft">Limpar</button>
                        </div>
                    </div>
                </div>
                <p id="reportFeedback" class="report-feedback info mt-4 hidden" role="status" aria-live="polite"></p>
            </section>

            <section id="reportKpiSection" class="mb-5">
                <div class="intel-section-head mb-1">
                    <div>
                        <h3 class="intel-section-title text-slate-200">Seção A: Visão Executiva</h3>
                    </div>
                </div>
                <div id="reportPortfolioScoreCard" class="portfolio-score-card glass-card mb-4 rounded-2xl p-5" role="region" aria-label="Score da Carteira">
                    <div class="skeleton h-5 w-48"></div>
                    <div class="mt-3 grid grid-cols-1 gap-3 lg:grid-cols-4">
                        <div class="skeleton h-12 w-full rounded-xl"></div>
                        <div class="skeleton h-12 w-full rounded-xl"></div>
                        <div class="skeleton h-12 w-full rounded-xl"></div>
                        <div class="skeleton h-12 w-full rounded-xl"></div>
                    </div>
                </div>
                <div id="reportKpiSkeleton" class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4"></div>
                <div id="reportKpiGrid" class="hidden grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
                    <div class="glass-card rounded-2xl p-5">
                        <p class="kpi-label">Receita do período</p>
                        <p class="kpi-value mt-2">R$ 0,00</p>
                        <p class="kpi-note">Recebimentos consolidados no recorte.</p>
                        <p class="kpi-insight">--</p>
                    </div>
                    <div class="glass-card rounded-2xl p-5">
                        <p class="kpi-label">Lucro líquido estimado</p>
                        <p class="kpi-value mt-2">R$ 0,00</p>
                        <p class="kpi-note">Margem estimada da carteira filtrada.</p>
                        <p class="kpi-insight">--</p>
                    </div>
                    <div class="glass-card rounded-2xl p-5">
                        <p class="kpi-label">Taxa de inadimplência real</p>
                        <p class="kpi-value mt-2">0,00%</p>
                        <p class="kpi-note">Atraso sobre o total previsto.</p>
                        <p class="kpi-insight">--</p>
                    </div>
                    <div class="glass-card rounded-2xl p-5">
                        <p class="kpi-label">Ticket médio</p>
                        <p class="kpi-value mt-2">R$ 0,00</p>
                        <p class="kpi-note">Valor médio por empréstimo.</p>
                        <p class="kpi-insight">--</p>
                    </div>
                </div>
            </section>

            <section class="mb-6">
                <div class="glass-card rounded-2xl p-5">
                    <div class="intel-section-head mb-3">
                        <div>
                            <h3 class="intel-section-title">Seção B: Performance</h3>
                            <p class="intel-section-subtitle">Comparativo protagonista de Previsto x Recebido x Em aberto no recorte selecionado.</p>
                        </div>
                        <p id="reportChartSubtitle" class="text-sm text-gray-500">Comparativo do filtro selecionado.</p>
                    </div>
                    <div id="reportChartQuickStats" class="report-chart-highlights mb-4">
                        <article class="report-chart-highlight">
                            <p>Pico previsto</p>
                            <strong id="reportChartPeakReceived">--</strong>
                        </article>
                        <article class="report-chart-highlight">
                            <p>Pico recebido</p>
                            <strong id="reportChartPeakOverdue">--</strong>
                        </article>
                        <article class="report-chart-highlight">
                            <p>Em aberto atual</p>
                            <strong id="reportChartCurrentProfit">--</strong>
                        </article>
                    </div>
                    <div id="reportChart" class="report-chart-shell report-chart-shell-xl" role="img" aria-label="Comparativo de previsto, recebido e em aberto da carteira">
                        <p class="text-gray-500">Carregando gráfico...</p>
                    </div>
                    <div class="mt-4 flex flex-wrap items-center gap-4 text-xs text-gray-600">
                        <span class="inline-flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm bg-blue-500"></span>Previsto</span>
                        <span class="inline-flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm bg-green-500"></span>Recebido</span>
                        <span class="inline-flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm bg-amber-500"></span>Em aberto</span>
                    </div>
                </div>
            </section>

            <section class="report-risk-grid mb-6 grid grid-cols-1 gap-6 xl:grid-cols-2">
                <div class="report-risk-card glass-card rounded-2xl p-5">
                    <div class="intel-section-head mb-3">
                        <div>
                            <h3 class="intel-section-title">Seção C: Mapa de Risco</h3>
                            <p class="intel-section-subtitle">Concentração de atraso, exposição e inadimplência ativa.</p>
                        </div>
