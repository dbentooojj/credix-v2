            let points = Array.from(grouped.values()).sort((a, b) => a.orderKey - b.orderKey);
            const maxBuckets = granularity === 'day' ? 14 : granularity === 'week' ? 12 : 8;
            if (points.length > maxBuckets) points = points.slice(points.length - maxBuckets);

            return {
                points,
                selectedPeriodLabel,
                granularityLabel: granularity === 'day' ? 'diário' : granularity === 'week' ? 'semanal' : 'mensal',
            };
        }

        function buildDuePressureSummary(installments, metrics = null, windowDays = 30) {
            const safeInstallments = Array.isArray(installments) ? installments : [];
            const safeMetrics = metrics || calculateReportMetrics(safeInstallments);
            const periodExpectedTotal = Math.max(toNumber(safeMetrics.totalExpected), 0);
            const today = startOfDay(new Date());
            const horizon = startOfDay(new Date());
            if (!today || !horizon) {
                return { totalDueRange: 0, pctOfPeriod: 0, clientsInvolved: 0, dayRows: [] };
            }
            horizon.setDate(horizon.getDate() + windowDays);

            const grouped = new Map();
            safeInstallments.forEach((installment) => {
                const status = normalizeInstallmentStatus(installment);
                if (status === 'Pago') return;
                const dueDate = startOfDay(installment.due_date);
                if (!dueDate || dueDate < today || dueDate > horizon) return;

                const key = toIsoDate(dueDate);
                if (!key) return;
                if (!grouped.has(key)) {
                    grouped.set(key, {
                        dueDate,
                        installmentsCount: 0,
                        totalAmount: 0,
                        uniqueClients: new Set(),
                    });
                }

                const item = grouped.get(key);
                item.installmentsCount += 1;
                item.totalAmount += getInstallmentOutstanding(installment, status);
                const clientKey = String(installment.debtor_id ?? '').trim();
                if (clientKey) item.uniqueClients.add(clientKey);
            });

            const rows = Array.from(grouped.values())
                .filter((item) => item.totalAmount > 0)
                .sort((a, b) => (a.dueDate?.getTime() ?? 0) - (b.dueDate?.getTime() ?? 0))
                .slice(0, 10);

            const totalDueRange = rows.reduce((sum, item) => sum + item.totalAmount, 0);
            const periodBase = periodExpectedTotal > 0 ? periodExpectedTotal : Math.max(totalDueRange, 0);
            const pctOfPeriod = periodBase > 0 ? (totalDueRange / periodBase) : 0;
            const clientsInvolvedSet = new Set();

            const dayRows = rows.map((item) => {
                item.uniqueClients.forEach((id) => clientsInvolvedSet.add(id));
                return {
                    dateLabel: item.dueDate
                        ? item.dueDate.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: '2-digit' })
                        : '-',
                    totalAmount: item.totalAmount,
                    installmentsCount: item.installmentsCount,
                    clientsCount: item.uniqueClients.size,
                    concentrationPct: periodBase > 0 ? (item.totalAmount / periodBase) : 0,
                };
            });

            return {
                totalDueRange,
                pctOfPeriod,
                clientsInvolved: clientsInvolvedSet.size,
                dayRows,
            };
        }

