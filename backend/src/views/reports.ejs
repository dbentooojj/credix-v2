    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            const displayName = currentUser.name || currentUser.full_name || 'Administrador';
            document.getElementById('userName').textContent = `Olá, ${displayName}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const sidebarLinks = document.querySelectorAll('#sidebar .sidebar-item');
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');
        const filterAccordionToggle = document.getElementById('filterAccordionToggle');
        const filterAccordionBody = document.getElementById('filterAccordionBody');

        const tableCache = {};
        function getDemoTable(tableName) {
            return Array.isArray(tableCache[tableName]) ? tableCache[tableName] : [];
        }

        async function fetchTableData(tableName) {
            try {
                const response = await fetch(`/api/tables/${tableName}`, { credentials: 'include' });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const payload = await response.json();
                if (Array.isArray(payload?.data)) {
                    tableCache[tableName] = payload.data;
                    return payload.data;
                }
            } catch (error) {
                console.warn(`Fallback para dados demo: ${tableName}`, error);
            }
            return getDemoTable(tableName);
        }

        function setActiveSidebarItem(targetHref) {
            sidebarLinks.forEach(link => {
                const isActive = link.getAttribute('href') === targetHref;
                link.classList.toggle('active', isActive);
                if (isActive) link.setAttribute('aria-current', 'page');
                else link.removeAttribute('aria-current');
            });
        }

        function syncActiveSidebarWithRoute() {
            const currentPage = window.location.pathname.split('/').pop() || 'reports.html';
            setActiveSidebarItem(currentPage);
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            sidebar.classList.remove('mobile-open');
            if (document.body.classList.contains('sidebar-collapsed')) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            main.style.marginLeft = '16rem';
            main.style.width = 'calc(100% - 16rem)';
            main.style.flex = '0 1 calc(100% - 16rem)';
        }

        sidebarToggle.addEventListener('click', function() {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();
        syncActiveSidebarWithRoute();

        function closeUserMenu() {
            if (!userMenuDropdown) return;
            userMenuDropdown.classList.add('hidden');
        }

        function showUserMenuNotice(message) {
            if (typeof showMessage === 'function') {
                showMessage(message, 'success');
                return;
            }
            window.alert(message);
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        async function handleUserMenuAction(action) {
            if (action === 'logout') {
                await performLogout();
                return;
            }

            const allowedTabs = new Set(['profile', 'security', 'help']);
            const destination = allowedTabs.has(action) ? action : 'profile';
            window.location.href = `/admin/account.html?tab=${encodeURIComponent(destination)}`;
        }

        if (userMenuBtn && userMenuDropdown) {
            userMenuBtn.addEventListener('click', (event) => {
                event.stopPropagation();
                userMenuDropdown.classList.toggle('hidden');
            });

            userMenuDropdown.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Element)) return;
                const actionBtn = target.closest('[data-user-menu-action]');
                if (!actionBtn) return;
                const action = actionBtn.getAttribute('data-user-menu-action');
                closeUserMenu();
                void handleUserMenuAction(action);
            });

            document.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Node)) return;
                if (userMenuDropdown.classList.contains('hidden')) return;
                if (userMenuDropdown.contains(target) || userMenuBtn.contains(target)) return;
                closeUserMenu();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeUserMenu();
            });
        }

        function syncFilterAccordionViewport() {
            if (!filterAccordionBody) return;
            if (window.matchMedia('(min-width: 768px)').matches) {
                filterAccordionBody.classList.add('open');
                return;
            }
            if (!filterAccordionBody.classList.contains('open')) {
                filterAccordionBody.classList.remove('open');
            }
        }

        if (filterAccordionToggle && filterAccordionBody) {
            filterAccordionToggle.addEventListener('click', () => {
                const isOpen = filterAccordionBody.classList.toggle('open');
                const label = filterAccordionToggle.querySelector('span');
                if (label) label.textContent = isOpen ? 'Ocultar filtros' : 'Mostrar filtros';
            });
            syncFilterAccordionViewport();
            window.addEventListener('resize', syncFilterAccordionViewport);
        }

        const reportsState = {
            loans: [],
            installments: [],
            debtors: [],
            filteredInstallments: [],
            previousInstallments: [],
            sparkInstallments: [],
            loanFrequencyById: new Map(),
            activeDueTab: 'next7',
            topDebtorsLimit: 8,
            recentPaidLimit: 8,
            topDebtorsRows: [],
            recentPaidRows: [],
            currentMetrics: null,
            previousMetrics: null,
            isLoading: true,
        };

        const reportKpiDefinitions = [
            { key: 'totalLoaned', label: 'Total emprestado', note: 'Principal aplicado no período.', type: 'currency', invert: false, minBase: 50, help: 'Soma do principal proporcional por parcela no recorte.' },
            { key: 'totalExpected', label: 'Total previsto a receber', note: 'Principal + juros previstos.', type: 'currency', invert: false, minBase: 50, help: 'Soma das parcelas previstas no recorte.' },
            { key: 'totalReceived', label: 'Total recebido', note: 'Entradas liquidadas no período.', type: 'currency', invert: false, minBase: 50, help: 'Somente parcelas com status pago.' },
            { key: 'totalOpen', label: 'Total em aberto', note: 'Saldo pendente ainda não recebido.', type: 'currency', invert: true, minBase: 50, help: 'Parcelas pendentes e atrasadas não quitadas.' },
            { key: 'totalOverdue', label: 'Total em atraso', note: 'Risco ativo de cobrança.', type: 'currency', invert: true, minBase: 50, help: 'Somente parcelas atrasadas (saldo em atraso).' },
            { key: 'estimatedProfit', label: 'Lucro estimado', note: 'Previsto menos principal.', type: 'currency', invert: false, minBase: 50, help: 'Estimativa de margem na carteira filtrada.' },
            { key: 'delinquencyRate', label: 'Taxa de inadimplência', note: 'Atraso sobre o previsto.', type: 'percent', invert: true, minBase: 0.0001, help: 'Total em atraso dividido pelo total previsto.' },
            { key: 'ticketAverage', label: 'Ticket médio', note: 'Média por empréstimo no filtro.', type: 'currency', invert: false, minBase: 1, help: 'Total emprestado dividido por empréstimos únicos.' },
        ];

        let searchDebounceTimer = null;

        function sameId(a, b) {
            return String(a ?? '') === String(b ?? '');
        }

        function toNumber(value, fallback = 0) {
            const parsed = Number(value);
            return Number.isFinite(parsed) ? parsed : fallback;
        }

        function round2(value) {
            return Math.round((toNumber(value) + Number.EPSILON) * 100) / 100;
        }

        function normalizeAscii(value) {
            return String(value ?? '')
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .toLowerCase()
                .trim();
        }

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function parseDateValue(value) {
            if (!value) return null;
            if (value instanceof Date) return new Date(value.getTime());

            const raw = String(value).trim();
            const dateOnlyMatch = raw.match(/^(\d{4})-(\d{2})-(\d{2})$/);
            if (dateOnlyMatch) {
                return new Date(Number(dateOnlyMatch[1]), Number(dateOnlyMatch[2]) - 1, Number(dateOnlyMatch[3]));
            }

            const parsed = new Date(raw);
            if (Number.isNaN(parsed.getTime())) return null;
            return parsed;
        }

        function startOfDay(value) {
            const date = parseDateValue(value);
            if (!date) return null;
            date.setHours(0, 0, 0, 0);
            return date;
        }

        function toIsoDate(value) {
            const date = parseDateValue(value);
            if (!date) return '';
            return date.toISOString().slice(0, 10);
        }

        function toMonthKey(value) {
            const date = startOfDay(value);
            if (!date) return '';
            return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
        }

        function formatMonthLabel(monthKey) {
            if (!monthKey) return '--';
            const [year, month] = monthKey.split('-').map(Number);
            const date = new Date(year, (month || 1) - 1, 1);
            return date.toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' });
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(toNumber(value));
        }

        function formatPercent(value) {
            return `${(toNumber(value) * 100).toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            })}%`;
        }

        function formatDate(value) {
            const date = parseDateValue(value);
            if (!date) return '-';
            return date.toLocaleDateString('pt-BR');
        }

        function normalizeLoanRow(row) {
            return {
                ...row,
                id: row.id,
                debtor_id: row.debtor_id ?? row.client_id ?? row.clientId,
                principal_amount: round2(row.principal_amount ?? row.principalAmount ?? 0),
                total_amount: round2(row.total_amount ?? row.totalAmount ?? 0),
            };
        }

        function normalizeDebtorRow(row) {
            return {
                ...row,
                id: row.id,
                name: row.name || row.full_name || 'Cliente sem nome',
                phone: row.phone || '',
            };
        }

        function normalizeInstallmentRow(row) {
            return {
                ...row,
                id: row.id,
                loan_id: row.loan_id ?? row.loanId,
                debtor_id: row.debtor_id ?? row.client_id ?? row.clientId,
                installment_number: Math.max(1, Math.trunc(toNumber(row.installment_number ?? row.installmentNumber ?? row.number ?? 1))),
                due_date: toIsoDate(row.due_date ?? row.dueDate),
                payment_date: toIsoDate(row.payment_date ?? row.paymentDate),
                amount: round2(row.amount),
                paid_amount: round2(row.paid_amount ?? row.paidAmount ?? row.amount),
                principal_amount: row.principal_amount ?? row.principalAmount ?? null,
                interest_amount: row.interest_amount ?? row.interestAmount ?? null,
                status: row.status || 'Pendente',
            };
        }

        function getLoanById(loanId) {
            return reportsState.loans.find((loan) => sameId(loan.id, loanId));
        }

        function getDebtorById(debtorId) {
            return reportsState.debtors.find((debtor) => sameId(debtor.id, debtorId));
        }

        function normalizeInstallmentStatus(installment) {
            const rawStatus = normalizeAscii(installment.status);
            if (rawStatus === 'pago' || rawStatus === 'paid') return 'Pago';
            if (rawStatus === 'atrasado' || rawStatus === 'overdue') return 'Atrasado';
            if (installment.payment_date) return 'Pago';

            const dueDate = startOfDay(installment.due_date);
            const today = startOfDay(new Date());
            if (dueDate && today && dueDate < today) return 'Atrasado';
            return 'Pendente';
        }

        function getStatusBadgeClass(status) {
            if (status === 'Pago') return 'badge-success';
            if (status === 'Atrasado') return 'badge-danger';
            return 'badge-warn';
        }

        function getInstallmentReferenceDate(installment, status) {
            if (status === 'Pago' && installment.payment_date) {
                return startOfDay(installment.payment_date);
            }
            return startOfDay(installment.due_date);
        }

        function getInstallmentPaidAmount(installment, status) {
            if (status === 'Pago') return Math.max(toNumber(installment.paid_amount ?? installment.amount), 0);
            return Math.max(Math.min(toNumber(installment.paid_amount), toNumber(installment.amount)), 0);
        }

        function getInstallmentOutstanding(installment, status) {
            if (status === 'Pago') return 0;
            const amount = Math.max(toNumber(installment.amount), 0);
            const paidAmount = getInstallmentPaidAmount(installment, status);
            return Math.max(amount - paidAmount, 0);
        }

        function getInstallmentPrincipal(installment) {
            const explicitPrincipal = Number(installment.principal_amount);
            if (Number.isFinite(explicitPrincipal) && explicitPrincipal > 0) return round2(explicitPrincipal);

            const explicitInterest = Number(installment.interest_amount);
            const amount = toNumber(installment.amount);
            if (Number.isFinite(explicitInterest) && explicitInterest >= 0 && explicitInterest <= amount) {
                return round2(Math.max(amount - explicitInterest, 0));
            }

            const loan = getLoanById(installment.loan_id);
            const loanPrincipal = toNumber(loan?.principal_amount);
            const loanTotal = toNumber(loan?.total_amount);
            if (loanPrincipal > 0 && loanTotal > 0) {
                return round2(amount * (loanPrincipal / loanTotal));
            }

            return round2(amount);
        }

        function renderStatusDistribution(installments) {
            const container = document.getElementById('statusDistribution');
            if (!container) return;

            const statusCounts = installments.reduce((acc, installment) => {
                const status = normalizeInstallmentStatus(installment);
                acc[status] = (acc[status] || 0) + 1;
                return acc;
            }, { Pago: 0, Pendente: 0, Atrasado: 0 });
            const totalInstallments = installments.length;

            if (!totalInstallments) {
                container.innerHTML = '<div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-8 text-center text-sm text-slate-500">Sem parcelas no filtro atual para distribuição.</div>';
                return;
            }

            const rows = [
                { key: 'Pago', color: '#22c55e', badge: 'badge-success' },
                { key: 'Pendente', color: '#f59e0b', badge: 'badge-warn' },
                { key: 'Atrasado', color: '#ef4444', badge: 'badge-danger' }
            ];
            const paidPct = ((statusCounts.Pago || 0) / totalInstallments) * 100;
            const pendingPct = ((statusCounts.Pendente || 0) / totalInstallments) * 100;
            const overduePct = ((statusCounts.Atrasado || 0) / totalInstallments) * 100;
            const gradient = `conic-gradient(#22c55e 0% ${paidPct}%, #f59e0b ${paidPct}% ${paidPct + pendingPct}%, #ef4444 ${paidPct + pendingPct}% 100%)`;

            container.innerHTML = `
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-[180px_1fr] sm:items-center">
                    <div class="relative mx-auto h-40 w-40 rounded-full" style="background:${gradient};">
                        <div class="absolute inset-[14px] flex flex-col items-center justify-center rounded-full bg-white text-center text-slate-700">
                            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Atraso</p>
                            <p class="text-xl font-bold text-red-600">${overduePct.toFixed(1)}%</p>
                        </div>
                    </div>
                    <div class="space-y-3">
                        ${rows.map((row) => {
                            const count = statusCounts[row.key] || 0;
                            const percentage = totalInstallments > 0 ? (count / totalInstallments) * 100 : 0;
                            return `
                                <div>
                                    <div class="mb-1 flex items-center justify-between">
                                        <span class="badge ${row.badge}">${row.key}</span>
                                        <span class="text-sm text-slate-600">${count} (${percentage.toFixed(1)}%)</span>
                                    </div>
                                    <div class="progress-track">
                                        <div class="progress-fill" style="width:${percentage}%; background:${row.color};"></div>
                                    </div>
                                </div>
                            `;
                        }).join('')}
                    </div>
                </div>
            `;
        }

        function buildTopDebtorsRows(installments) {
            const grouped = new Map();
            installments.forEach((installment) => {
                const debtorId = String(installment.debtor_id ?? '');
                if (!debtorId) return;

                if (!grouped.has(debtorId)) {
                    grouped.set(debtorId, {
                        id: debtorId,
                        overdueInstallments: 0,
                        overdueAmount: 0,
                        openAmount: 0,
                        lastPaymentDate: null,
                    });
                }

                const status = normalizeInstallmentStatus(installment);
                const outstanding = getInstallmentOutstanding(installment, status);
                const row = grouped.get(debtorId);

                if (status === 'Atrasado') {
                    row.overdueInstallments += 1;
                    row.overdueAmount += outstanding;
                }
                if (status !== 'Pago') {
                    row.openAmount += outstanding;
                } else if (installment.payment_date) {
                    const paymentDate = startOfDay(installment.payment_date);
                    if (paymentDate && (!row.lastPaymentDate || paymentDate > row.lastPaymentDate)) {
                        row.lastPaymentDate = paymentDate;
                    }
                }
            });

            return Array.from(grouped.values())
                .filter((row) => row.overdueInstallments > 0 || row.openAmount > 0)
                .map((row) => {
                    const debtor = getDebtorById(row.id);
                    return {
                        ...row,
                        name: debtor?.name || `Cliente #${row.id}`,
                    };
                })
                .sort((a, b) => (b.overdueAmount - a.overdueAmount) || (b.openAmount - a.openAmount));
        }

        function renderTopDebtors(installments) {
            const tbody = document.getElementById('topDebtorsTable');
            const moreButton = document.getElementById('topDebtorsMoreBtn');
            if (!tbody) return;

            reportsState.topDebtorsRows = buildTopDebtorsRows(installments);
            const rows = reportsState.topDebtorsRows.slice(0, reportsState.topDebtorsLimit);

            if (!rows.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center py-8 text-gray-500">Sem clientes em atraso para o filtro atual.</td></tr>';
                if (moreButton) moreButton.classList.add('hidden');
                return;
            }

            tbody.innerHTML = rows.map((row) => `
                <tr>
                    <td class="font-semibold">${escapeHtml(row.name)}</td>
                    <td>${row.overdueInstallments}</td>
                    <td class="text-red-600">${formatCurrency(row.overdueAmount)}</td>
                    <td>${formatCurrency(row.openAmount)}</td>
                    <td>${row.lastPaymentDate ? row.lastPaymentDate.toLocaleDateString('pt-BR') : '-'}</td>
                    <td>
                        <a href="debtors.html?client=${encodeURIComponent(row.id)}" class="inline-flex rounded-lg border border-slate-300 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Ver detalhes</a>
                    </td>
                </tr>
            `).join('');

            if (moreButton) {
                const hasMore = reportsState.topDebtorsRows.length > reportsState.topDebtorsLimit;
                moreButton.classList.toggle('hidden', !hasMore);
            }
        }

        function renderNextDueDates(installments) {
            const container = document.getElementById('nextDueList');
            const dueTab7 = document.getElementById('dueTab7');
            const dueTab15 = document.getElementById('dueTab15');
            if (!container) return;

            if (dueTab7) dueTab7.classList.toggle('active', reportsState.activeDueTab === 'next7');
            if (dueTab15) dueTab15.classList.toggle('active', reportsState.activeDueTab === 'next15');

            const today = startOfDay(new Date());
            const horizon = startOfDay(new Date());
            const windowDays = reportsState.activeDueTab === 'next15' ? 15 : 7;
            if (!today || !horizon) {
                container.innerHTML = '<p class="text-gray-500">Não foi possível calcular os vencimentos.</p>';
                return;
            }
            horizon.setDate(horizon.getDate() + windowDays);

            const upcoming = installments
                .filter((installment) => normalizeInstallmentStatus(installment) !== 'Pago')
                .filter((installment) => {
                    const due = startOfDay(installment.due_date);
                    if (!due) return false;
                    return due >= today && due <= horizon;
                })
                .sort((a, b) => {
                    const dueA = startOfDay(a.due_date)?.getTime() ?? 0;
                    const dueB = startOfDay(b.due_date)?.getTime() ?? 0;
                    return dueA - dueB;
                });

            if (!upcoming.length) {
                container.innerHTML = `<p class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-3 py-5 text-center text-sm text-slate-500">Sem pressão de vencimentos nos próximos ${windowDays} dias.</p>`;
                return;
            }

            const groupedByDate = new Map();
            upcoming.forEach((installment) => {
                const dueDate = startOfDay(installment.due_date);
                const dueDateIso = toIsoDate(dueDate);
                if (!dueDateIso) return;

                const status = normalizeInstallmentStatus(installment);
                const outstanding = getInstallmentOutstanding(installment, status);
                if (!groupedByDate.has(dueDateIso)) {
                    groupedByDate.set(dueDateIso, {
                        dueDateIso,
                        dueDate,
                        installmentsCount: 0,
                        uniqueClients: new Set(),
                        totalAmount: 0,
                        overdueCount: 0,
                        pendingCount: 0,
                    });
                }

                const group = groupedByDate.get(dueDateIso);
                group.installmentsCount += 1;
                group.totalAmount += outstanding;
                group.uniqueClients.add(String(installment.debtor_id ?? ''));
                if (status === 'Atrasado') group.overdueCount += 1;
                if (status === 'Pendente') group.pendingCount += 1;
            });

            const dayPressure = Array.from(groupedByDate.values())
                .sort((a, b) => (a.dueDate?.getTime() ?? 0) - (b.dueDate?.getTime() ?? 0))
                .slice(0, 10);

            container.innerHTML = dayPressure.map((dayItem) => {
                const dateLabel = dayItem.dueDate
                    ? dayItem.dueDate.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: '2-digit' })
                    : dayItem.dueDateIso;
                const toneClass = dayItem.overdueCount > 0 ? 'badge-danger' : 'badge-warn';
                const toneLabel = dayItem.overdueCount > 0 ? `${dayItem.overdueCount} em atraso` : `${dayItem.pendingCount} pendente(s)`;
                return `
                    <article class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-3">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="font-semibold text-slate-800">${escapeHtml(dateLabel)}</p>
                                <p class="text-xs text-slate-500">${dayItem.installmentsCount} parcela(s) • ${dayItem.uniqueClients.size} cliente(s)</p>
                            </div>
                            <span class="badge ${toneClass}">${toneLabel}</span>
                        </div>
                        <div class="mt-2 flex items-center justify-between text-sm text-slate-600">
                            <p>Valor concentrado no dia</p>
                            <p class="font-semibold text-slate-800">${formatCurrency(dayItem.totalAmount)}</p>
                        </div>
                    </article>
                `;
            }).join('');
        }

        function buildRecentPaidRows(installments) {
            return installments
                .filter((installment) => normalizeInstallmentStatus(installment) === 'Pago' && installment.payment_date)
