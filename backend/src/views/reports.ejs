        function renderNextDueDates(installments, metrics = null) {
            const container = document.getElementById('nextDueList');
            const dueTab7 = document.getElementById('dueTab7');
            const dueTab15 = document.getElementById('dueTab15');
            const dueTab30 = document.getElementById('dueTab30');
            if (!container) return;
            const safeInstallments = Array.isArray(installments) ? installments : [];

            if (dueTab7) {
                const isActive7 = reportsState.activeDueTab === 'next7';
                dueTab7.classList.toggle('active', isActive7);
                dueTab7.setAttribute('aria-pressed', isActive7 ? 'true' : 'false');
            }
            if (dueTab15) {
                const isActive15 = reportsState.activeDueTab === 'next15';
                dueTab15.classList.toggle('active', isActive15);
                dueTab15.setAttribute('aria-pressed', isActive15 ? 'true' : 'false');
            }
            if (dueTab30) {
                const isActive30 = reportsState.activeDueTab === 'next30';
                dueTab30.classList.toggle('active', isActive30);
                dueTab30.setAttribute('aria-pressed', isActive30 ? 'true' : 'false');
            }

            const today = startOfDay(new Date());
            const horizon = startOfDay(new Date());
            const windowDays = reportsState.activeDueTab === 'next30'
                ? 30
                : reportsState.activeDueTab === 'next15'
                    ? 15
                    : 7;
            const safeMetrics = metrics || reportsState.currentMetrics || calculateReportMetrics(safeInstallments);
            const periodExpectedTotal = Math.max(toNumber(safeMetrics.totalExpected), 0);
            if (!today || !horizon) {
                container.innerHTML = '<p class="text-gray-500">Não foi possível calcular os vencimentos.</p>';
                return;
            }
            horizon.setDate(horizon.getDate() + windowDays);

            const upcoming = safeInstallments
                .filter((installment) => normalizeInstallmentStatus(installment) !== 'Pago')
                .filter((installment) => {
                    const due = startOfDay(installment.due_date);
                    if (!due) return false;
                    return due >= today && due <= horizon;
                })
                .sort((a, b) => {
                    const dueA = startOfDay(a.due_date)?.getTime() ?? 0;
                    const dueB = startOfDay(b.due_date)?.getTime() ?? 0;
                    return dueA - dueB;
                });

            const groupedByDate = new Map();
            upcoming.forEach((installment) => {
                const dueDate = startOfDay(installment.due_date);
                const dueDateIso = toIsoDate(dueDate);
                if (!dueDateIso) return;

                const status = normalizeInstallmentStatus(installment);
                const outstanding = getInstallmentOutstanding(installment, status);
                if (!groupedByDate.has(dueDateIso)) {
                    groupedByDate.set(dueDateIso, {
                        dueDateIso,
                        dueDate,
                        installmentsCount: 0,
                        uniqueClients: new Set(),
                        totalAmount: 0,
                        overdueCount: 0,
                        pendingCount: 0,
                    });
                }

                const group = groupedByDate.get(dueDateIso);
                group.installmentsCount += 1;
                group.totalAmount += outstanding;
                const clientKey = String(installment.debtor_id ?? '').trim();
                if (clientKey) group.uniqueClients.add(clientKey);
                if (status === 'Atrasado') group.overdueCount += 1;
                if (status === 'Pendente') group.pendingCount += 1;
            });

            const dayPressure = Array.from(groupedByDate.values())
                .filter((dayItem) => dayItem.totalAmount > 0)
                .sort((a, b) => (a.dueDate?.getTime() ?? 0) - (b.dueDate?.getTime() ?? 0))
                .slice(0, 10);

            const totalDueRange = dayPressure.reduce((sum, dayItem) => sum + dayItem.totalAmount, 0);
            const involvedClients = new Set();
            dayPressure.forEach((dayItem) => {
                dayItem.uniqueClients.forEach((clientKey) => involvedClients.add(clientKey));
            });
            const periodBase = periodExpectedTotal > 0 ? periodExpectedTotal : Math.max(totalDueRange, 0);
            const pctOfPeriod = periodBase > 0 ? (totalDueRange / periodBase) : 0;
            const summaryMarkup = `
                <div class="due-summary-grid mb-2 grid grid-cols-1 gap-2 sm:grid-cols-3" aria-label="Resumo da pressão de vencimentos">
                    <article class="due-summary-item rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5">
                        <p class="due-summary-label">Total a vencer (${windowDays}d)</p>
                        <p class="due-summary-value">${formatCurrency(totalDueRange)}</p>
                    </article>
                    <article class="due-summary-item rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5">
                        <p class="due-summary-label">% do previsto no período</p>
                        <p class="due-summary-value">${formatPercent(pctOfPeriod)}</p>
                    </article>
                    <article class="due-summary-item rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5">
                        <p class="due-summary-label">Clientes envolvidos</p>
                        <p class="due-summary-value">${involvedClients.size.toLocaleString('pt-BR')}</p>
                    </article>
                </div>
            `;

            if (!dayPressure.length) {
                container.innerHTML = `${summaryMarkup}<p class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-3 py-5 text-center text-sm text-slate-500">Sem pressão de vencimentos nos próximos ${windowDays} dias.</p>`;
                return;
            }

            container.innerHTML = `${summaryMarkup}${dayPressure.map((dayItem) => {
                const dateLabel = dayItem.dueDate
                    ? dayItem.dueDate.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: '2-digit' })
                    : dayItem.dueDateIso;
                const toneClass = dayItem.overdueCount > 0 ? 'badge-danger' : 'badge-warn';
                const toneLabel = dayItem.overdueCount > 0 ? `${dayItem.overdueCount} em atraso` : `${dayItem.pendingCount} pendente(s)`;
                const dayConcentration = periodBase > 0 ? (dayItem.totalAmount / periodBase) : 0;
                return `
                    <article class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-3">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="font-semibold text-slate-800">${escapeHtml(dateLabel)}</p>
                                <p class="text-xs text-slate-500">${dayItem.installmentsCount} parcela(s) • ${dayItem.uniqueClients.size} cliente(s)</p>
                            </div>
                            <span class="badge ${toneClass}">${toneLabel}</span>
                        </div>
                        <div class="mt-2 flex items-center justify-between text-sm text-slate-600">
                            <p>Valor concentrado no dia</p>
                            <p class="font-semibold text-slate-800">${formatCurrency(dayItem.totalAmount)}</p>
                        </div>
                        <div class="mt-1 flex items-center justify-between text-xs text-slate-500">
                            <p>Concentração do dia no período</p>
                            <p class="font-semibold text-slate-700">${formatPercent(dayConcentration)}</p>
                        </div>
                    </article>
                `;
            }).join('')}`;
        }

        function buildRecentPaidRows(installments) {
            return installments
                .filter((installment) => normalizeInstallmentStatus(installment) === 'Pago' && installment.payment_date)
                .map((installment) => {
                    const debtor = getDebtorById(installment.debtor_id);
