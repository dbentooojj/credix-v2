                        installmentLabel: `#${installment.installment_number}/${loan?.installments_count ?? '-'}`,
                        value: toNumber(installment.paid_amount ?? installment.amount),
                    };
                })
                .sort((a, b) => (b.paymentDate?.getTime() ?? 0) - (a.paymentDate?.getTime() ?? 0));
        }

