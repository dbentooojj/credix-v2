                                                    <td>${escapeHtml(row.installmentLabel)}</td>
                                                    <td>${formatCurrency(row.value)}</td>
                                                </tr>
                                            `).join('') : '<tr><td colspan="4">Sem dados no recorte.</td></tr>'}
                                        </tbody>
                                    </table>
                                </div>
                            </article>
                        </div>
                    </section>
                </body>
                </html>
            `);
            popup.document.close();

            const triggerPrint = () => {
                popup.focus();
                popup.print();
                showReportFeedback('PDF da Central preparado para impressão.', 'info');
            };

            const images = Array.from(popup.document.images || []);
            if (!images.length) {
                setTimeout(triggerPrint, 120);
                return;
            }

            let pending = images.length;
            let finished = false;
            const finalize = () => {
                if (finished) return;
                finished = true;
                setTimeout(triggerPrint, 120);
            };
            const onImageSettled = () => {
                pending -= 1;
                if (pending <= 0) finalize();
            };

            images.forEach((imageElement) => {
                if (imageElement.complete) {
                    onImageSettled();
                    return;
                }
                imageElement.addEventListener('load', onImageSettled, { once: true });
                imageElement.addEventListener('error', onImageSettled, { once: true });
            });

            setTimeout(finalize, 1600);
        }

        function notifyExportPlaceholder(format) {
            const rows = reportsState.filteredInstallments || [];
            if (!rows.length) {
                showReportFeedback(`Sem dados no filtro atual para exportar ${format}.`, 'error');
                return;
            }

            const sparkRows = reportsState.sparkInstallments.length ? reportsState.sparkInstallments : rows;
            const metrics = reportsState.currentMetrics || calculateReportMetrics(rows);
            const previousMetrics = reportsState.previousMetrics || calculateReportMetrics(reportsState.previousInstallments || []);
            const scoreData = calculatePortfolioScore(rows, metrics);
            const projectionData = buildProjection30dData(sparkRows, metrics);
            const filterSnapshot = getReportFilterSnapshot();

            if (format === 'CSV') {
                exportReportsCsv(rows, metrics, scoreData, projectionData, filterSnapshot);
                return;
            }

            exportReportsPdf(rows, metrics, previousMetrics, scoreData, filterSnapshot, projectionData, sparkRows);
        }

        async function loadReportsData() {
            setLoadingState(true);
            try {
                const [loans, installments, debtors] = await Promise.all([
                    fetchTableData('loans'),
                    fetchTableData('installments'),
                    fetchTableData('debtors'),
                ]);

