<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Credix - Redefinir senha</title>
<%- include('partials/favicon') %>

<style>
html, body { background-color: #020617; }
</style>
<script>
(() => {
    const root = document.documentElement;
    try {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') root.classList.add('dark');
        if (savedTheme === 'light') root.classList.remove('dark');
    } catch (error) {}
})();

window.tailwind = window.tailwind || {};
window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
</script>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
html { font-size: 16px; }
body { font-family: 'Inter', sans-serif; }

.primary-gradient {
    background: linear-gradient(135deg, #000000 0%, #0f172a 50%, #111827 100%);
}

.glass-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 40px rgba(0,0,0,0.25);
}

.modern-input {
    background: rgba(255,255,255,0.9);
    border: 2px solid transparent;
    transition: 0.2s;
}

.modern-input:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
}

.modern-button {
    background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
    transition:
        transform 160ms cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 170ms ease-out,
        filter 140ms ease-out;
    will-change: transform;
    transform: translateZ(0);
}

.modern-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(59,130,246,0.34);
    filter: brightness(1.03);
}
</style>
</head>

<body class="primary-gradient min-h-screen flex items-center justify-center p-4">
<div class="w-full max-w-md">
    <div class="text-center mb-7">
        <div class="flex flex-col items-center gap-2">
            <%- include('partials/brand-wordmark', { size: 'login' }) %>
        </div>
    </div>

    <div class="glass-card rounded-2xl p-7">
        <div class="text-center mb-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-1">Redefinir senha</h2>
            <p class="text-gray-600">Digite sua nova senha para concluir a recuperacao.</p>
        </div>

        <form id="resetPasswordForm" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    <i class="fas fa-lock mr-1 text-blue-600"></i>Nova senha
                </label>
                <input type="password" id="newPassword" required autocomplete="new-password"
                    class="modern-input w-full px-4 py-3 rounded-lg focus:outline-none"
                    placeholder="********">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    <i class="fas fa-lock mr-1 text-blue-600"></i>Confirmar nova senha
                </label>
                <input type="password" id="confirmPassword" required autocomplete="new-password"
                    class="modern-input w-full px-4 py-3 rounded-lg focus:outline-none"
                    placeholder="********">
            </div>

            <p class="text-xs text-gray-600">
                Regras: minimo de 8 caracteres, com maiuscula, minuscula, numero e simbolo.
            </p>

            <div id="resetPasswordMessage" class="hidden text-sm rounded-lg px-3 py-2"></div>

            <button id="resetPasswordSubmitBtn" type="submit"
                class="modern-button w-full text-white py-3.5 rounded-lg font-medium text-base">
                <i class="fas fa-check mr-2"></i>Salvar nova senha
            </button>
        </form>

        <div class="mt-5 text-center text-sm">
            <a href="/login" class="text-blue-700 hover:underline font-semibold">
                <i class="fas fa-arrow-left mr-1"></i>Voltar para o login
            </a>
        </div>
    </div>
</div>

<script>
const token = new URLSearchParams(window.location.search).get('token') || '';
const form = document.getElementById('resetPasswordForm');
const message = document.getElementById('resetPasswordMessage');
const submitButton = document.getElementById('resetPasswordSubmitBtn');

if (!token) {
    message.className = 'text-sm rounded-lg px-3 py-2 bg-red-100 text-red-700';
    message.textContent = 'Link de recuperacao invalido. Solicite um novo e-mail.';
    message.classList.remove('hidden');
    submitButton.disabled = true;
}

form.addEventListener('submit', async function (event) {
    event.preventDefault();
    if (!token) return;

    const newPassword = document.getElementById('newPassword').value;
    const confirmPassword = document.getElementById('confirmPassword').value;

    if (newPassword !== confirmPassword) {
        message.className = 'text-sm rounded-lg px-3 py-2 bg-red-100 text-red-700';
        message.textContent = 'A confirmacao da nova senha nao confere.';
        message.classList.remove('hidden');
        return;
    }

    const originalText = submitButton.innerHTML;
    submitButton.disabled = true;
    submitButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Salvando...';

    try {
        const response = await fetch('/auth/reset-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
                token,
                newPassword,
                confirmPassword,
            }),
        });

        const payload = await response.json().catch(() => null);
        if (!response.ok) {
            throw new Error(payload?.message || 'Nao foi possivel redefinir a senha.');
        }

        message.className = 'text-sm rounded-lg px-3 py-2 bg-green-100 text-green-700';
        message.textContent = payload?.message || 'Senha redefinida com sucesso.';
        message.classList.remove('hidden');

        setTimeout(() => {
            window.location.href = '/login?reason=reset-success';
        }, 1200);
    } catch (error) {
        message.className = 'text-sm rounded-lg px-3 py-2 bg-red-100 text-red-700';
        message.textContent = error.message || 'Falha ao redefinir senha.';
        message.classList.remove('hidden');
    } finally {
        submitButton.disabled = false;
        submitButton.innerHTML = originalText;
    }
});
</script>
</body>
</html>

