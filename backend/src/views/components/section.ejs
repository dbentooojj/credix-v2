<%
  const sectionId = typeof id === 'string' ? id : '';
  const sectionClassName = typeof className === 'string' ? className : '';
  const sectionTitle = typeof title === 'string' ? title : '';
  const sectionSubtitle = typeof subtitle === 'string' ? subtitle : '';
  const sectionHeaderActions = typeof headerActions === 'string' ? headerActions : '';
  const sectionContent = typeof content === 'string' ? content : '';
%>
<section<% if (sectionId) { %> id="<%= sectionId %>"<% } %><% if (sectionClassName) { %> class="<%= sectionClassName %>"<% } %>>
  <div class="app-section-head">
    <div>
      <% if (sectionTitle) { %><h2 class="app-section-title"><%= sectionTitle %></h2><% } %>
      <% if (sectionSubtitle) { %><p class="app-section-subtitle"><%= sectionSubtitle %></p><% } %>
    </div>
    <% if (sectionHeaderActions) { %><div><%- sectionHeaderActions %></div><% } %>
  </div>
  <%- sectionContent %>
</section>
