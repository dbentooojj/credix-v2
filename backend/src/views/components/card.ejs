<%
  const cardId = typeof id === 'string' ? id : '';
  const rawClassName = typeof className === 'string' ? className : '';
  const cardClassName = `app-card ${rawClassName}`.trim();
  const cardTitle = typeof title === 'string' ? title : '';
  const cardSubtitle = typeof subtitle === 'string' ? subtitle : '';
  const cardHeaderActions = typeof headerActions === 'string' ? headerActions : '';
  const cardContent = typeof content === 'string' ? content : '';
  const hasHeader = Boolean(cardTitle || cardSubtitle || cardHeaderActions);
%>
<section<% if (cardId) { %> id="<%= cardId %>"<% } %> class="<%= cardClassName %>">
  <% if (hasHeader) { %>
    <div class="app-section-head">
      <div>
        <% if (cardTitle) { %><h3 class="text-xl font-semibold text-[color:rgb(var(--text))]"><%= cardTitle %></h3><% } %>
        <% if (cardSubtitle) { %><p class="app-section-subtitle"><%= cardSubtitle %></p><% } %>
      </div>
      <% if (cardHeaderActions) { %><div><%- cardHeaderActions %></div><% } %>
    </div>
  <% } %>
  <%- cardContent %>
</section>
