<%
  const buttonId = typeof id === 'string' ? id : '';
  const buttonType = typeof type === 'string' && type ? type : 'button';
  const buttonVariant = typeof variant === 'string' ? variant : 'secondary';
  const rawClassName = typeof className === 'string' ? className : '';
  const baseClass = buttonVariant === 'primary' ? 'app-btn app-btn-primary' : 'app-btn app-btn-secondary';
  const buttonClassName = `${baseClass} ${rawClassName}`.trim();
  const attributeString = typeof attrs === 'string' && attrs.trim() ? ` ${attrs.trim()}` : '';
  const iconClassName = typeof icon === 'string' ? icon.trim() : '';
  const hasIcon = Boolean(iconClassName);
  const iconOnRight = typeof iconRight !== 'undefined' ? Boolean(iconRight) : false;
  const buttonLabel = typeof label === 'string' ? label : '';
%>
<button<% if (buttonId) { %> id="<%= buttonId %>"<% } %> type="<%= buttonType %>" class="<%= buttonClassName %>"<%- attributeString %>>
  <% if (hasIcon && !iconOnRight) { %><i class="<%= iconClassName %>"></i><% } %>
  <span><%= buttonLabel %></span>
  <% if (hasIcon && iconOnRight) { %><i class="<%= iconClassName %>"></i><% } %>
</button>
