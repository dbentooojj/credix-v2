<%
  const inputId = typeof id === 'string' ? id : '';
  const inputName = typeof name === 'string' ? name : '';
  const inputType = typeof type === 'string' && type ? type : 'text';
  const rawClassName = typeof className === 'string' ? className : '';
  const inputClassName = `app-input ${rawClassName}`.trim();
  const attributeString = typeof attrs === 'string' && attrs.trim() ? ` ${attrs.trim()}` : '';
  const inputPlaceholder = typeof placeholder === 'string' ? placeholder : '';
  const inputValue = typeof value !== 'undefined' && value !== null ? String(value) : null;
%>
<input<% if (inputId) { %> id="<%= inputId %>"<% } %><% if (inputName) { %> name="<%= inputName %>"<% } %> type="<%= inputType %>" class="<%= inputClassName %>"<% if (inputPlaceholder) { %> placeholder="<%= inputPlaceholder %>"<% } %><% if (inputValue !== null) { %> value="<%= inputValue %>"<% } %><%- attributeString %>>
