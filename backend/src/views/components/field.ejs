<%
  const rawClassName = typeof className === 'string' ? className : '';
  const wrapperClassName = `app-field ${rawClassName}`.trim();
  const fieldLabelFor = typeof forId === 'string' ? forId : '';
  const fieldLabel = typeof label === 'string' ? label : '';
  const rawLabelClassName = typeof labelClassName === 'string' ? labelClassName : '';
  const labelClass = `app-field-label ${rawLabelClassName}`.trim();
  const helpTextValue = typeof helpText === 'string' ? helpText : '';
  const rawHelpClassName = typeof helpClassName === 'string' ? helpClassName : '';
  const helpClass = `app-field-help ${rawHelpClassName}`.trim();
  const control = typeof controlHtml === 'string' ? controlHtml : '';
  const fieldErrorId = typeof errorId === 'string' ? errorId : '';
%>
<div class="<%= wrapperClassName %>">
  <% if (fieldLabel) { %>
    <label class="<%= labelClass %>"<% if (fieldLabelFor) { %> for="<%= fieldLabelFor %>"<% } %>><%= fieldLabel %></label>
  <% } %>
  <%- control %>
  <% if (helpTextValue) { %>
    <p class="<%= helpClass %>"><%= helpTextValue %></p>
  <% } %>
  <% if (fieldErrorId) { %>
    <p id="<%= fieldErrorId %>" class="field-error" aria-live="polite"></p>
  <% } %>
</div>
