<%
  const selectId = typeof id === 'string' ? id : '';
  const selectName = typeof name === 'string' ? name : '';
  const rawClassName = typeof className === 'string' ? className : '';
  const selectClassName = `app-select ${rawClassName}`.trim();
  const attributeString = typeof attrs === 'string' && attrs.trim() ? ` ${attrs.trim()}` : '';
  const selectOptions = typeof options !== 'undefined' && Array.isArray(options) ? options : [];
  const extraOptionsHtml = typeof optionsHtml === 'string' ? optionsHtml : '';
%>
<select<% if (selectId) { %> id="<%= selectId %>"<% } %><% if (selectName) { %> name="<%= selectName %>"<% } %> class="<%= selectClassName %>"<%- attributeString %>>
  <% selectOptions.forEach((option) => { %>
    <option value="<%= option.value %>"<% if (option.disabled) { %> disabled<% } %><% if (option.selected) { %> selected<% } %>><%= option.label %></option>
  <% }); %>
  <%- extraOptionsHtml %>
</select>
