<%
  const modalId = typeof id === 'string' && id.trim() ? id.trim() : '';
  const modalSize = (typeof size === 'string' && (size === 'md' || size === 'lg')) ? size : 'md';
  const modalClassName = typeof className === 'string' ? className : '';
  const panelClassValue = typeof panelClassName === 'string' ? panelClassName : '';
  const bodyClassValue = typeof bodyClassName === 'string' ? bodyClassName : '';
  const footerClassValue = typeof footerClassName === 'string' ? footerClassName : '';
  const titleId = typeof headingId === 'string' && headingId.trim() ? headingId.trim() : `${modalId || 'modal'}Title`;
  const closeButtonId = typeof closeBtnId === 'string' ? closeBtnId : '';
  const titleValue = typeof title === 'string' ? title : '';
  const subtitleValue = typeof subtitle === 'string' ? subtitle : '';
  const childrenHtml = typeof children === 'string' ? children : '';
  const onCloseAction = typeof onClose === 'string' ? onClose : '';
  const useForm = typeof asForm !== 'undefined' ? Boolean(asForm) : false;
  const formIdValue = typeof formId === 'string' ? formId : '';
  const formClassValue = typeof formClassName === 'string' && formClassName.trim()
    ? formClassName.trim()
    : 'flex min-h-0 flex-1 flex-col';
  const formAttrs = typeof formAttributes === 'string' ? formAttributes.trim() : '';
  const actionsValue = (typeof actions !== 'undefined' && actions && typeof actions === 'object') ? actions : null;
  const secondaryAction = actionsValue && typeof actionsValue.secondary === 'object' ? actionsValue.secondary : null;
  const primaryAction = actionsValue && typeof actionsValue.primary === 'object' ? actionsValue.primary : null;

  function resolveActionClasses(action, fallbackVariant) {
    const base = `modal-btn ${fallbackVariant}`;
    if (!action || typeof action.className !== 'string' || !action.className.trim()) return base;
    return `${base} ${action.className.trim()}`.trim();
  }
%>
<div
  <% if (modalId) { %>id="<%= modalId %>"<% } %>
  class="modal-base fixed inset-0 z-50 hidden items-center justify-center p-3 sm:p-4 <%= modalClassName %>"
  data-modal-base="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="<%= titleId %>"
  <% if (onCloseAction) { %>data-modal-on-close="<%= onCloseAction %>"<% } %>
>
  <div class="modal-base__panel modal-base__panel--<%= modalSize %> <%= panelClassValue %>">
    <% if (useForm) { %>
      <form <% if (formIdValue) { %>id="<%= formIdValue %>"<% } %> class="<%= formClassValue %>" <% if (formAttrs) { %><%- formAttrs %><% } %>>
    <% } %>
      <div class="modal-base__header">
        <div class="modal-base__title-wrap">
          <h3 id="<%= titleId %>" class="modal-base__title"><%= titleValue %></h3>
          <p class="modal-base__description<%= subtitleValue ? '' : ' hidden' %>"><%= subtitleValue %></p>
        </div>
        <button <% if (closeButtonId) { %>id="<%= closeButtonId %>"<% } %> class="modal-base__close" data-modal-close="primary" type="button" aria-label="Fechar modal">
          <i class="fas fa-times"></i>
        </button>
      </div>

      <div class="modal-base__body <%= bodyClassValue %>">
        <%- childrenHtml %>
      </div>

      <div class="modal-base__footer <%= footerClassValue %>">
        <div class="modal-base__footer-secondary">
          <button
            <% if (secondaryAction?.id) { %>id="<%= secondaryAction.id %>"<% } %>
            data-modal-action="secondary"
            <% if (secondaryAction?.close !== false) { %>data-modal-close="secondary"<% } %>
            type="<%= typeof secondaryAction?.type === 'string' ? secondaryAction.type : 'button' %>"
            class="<%= resolveActionClasses(secondaryAction, 'modal-btn--ghost') %>"
            <% if (typeof secondaryAction?.attrs === 'string' && secondaryAction.attrs.trim()) { %><%- secondaryAction.attrs %><% } %>
          >
            <%= typeof secondaryAction?.label === 'string' && secondaryAction.label ? secondaryAction.label : 'Cancelar' %>
          </button>
        </div>
        <div class="modal-base__footer-actions">
          <button
            <% if (primaryAction?.id) { %>id="<%= primaryAction.id %>"<% } %>
            data-modal-action="primary"
            type="<%= typeof primaryAction?.type === 'string' ? primaryAction.type : (useForm ? 'submit' : 'button') %>"
            class="<%= resolveActionClasses(primaryAction, 'modal-btn--primary') %>"
            <% if (typeof primaryAction?.attrs === 'string' && primaryAction.attrs.trim()) { %><%- primaryAction.attrs %><% } %>
          >
            <%= typeof primaryAction?.label === 'string' && primaryAction.label ? primaryAction.label : 'Salvar' %>
          </button>
        </div>
      </div>
    <% if (useForm) { %>
      </form>
    <% } %>
  </div>
</div>
