<%
  const textareaId = typeof id === 'string' ? id : '';
  const textareaName = typeof name === 'string' ? name : '';
  const textareaRows = typeof rows !== 'undefined' && Number.isFinite(Number(rows)) ? Number(rows) : 3;
  const rawClassName = typeof className === 'string' ? className : '';
  const textareaClassName = `app-textarea ${rawClassName}`.trim();
  const attributeString = typeof attrs === 'string' && attrs.trim() ? ` ${attrs.trim()}` : '';
  const textareaPlaceholder = typeof placeholder === 'string' ? placeholder : '';
  const textareaValue = typeof value !== 'undefined' && value !== null ? String(value) : '';
%>
<textarea<% if (textareaId) { %> id="<%= textareaId %>"<% } %><% if (textareaName) { %> name="<%= textareaName %>"<% } %> rows="<%= textareaRows %>" class="<%= textareaClassName %>"<% if (textareaPlaceholder) { %> placeholder="<%= textareaPlaceholder %>"<% } %><%- attributeString %>><%= textareaValue %></textarea>
