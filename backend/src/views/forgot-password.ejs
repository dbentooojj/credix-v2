<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Credix - Recuperar senha</title>
<%- include('partials/favicon') %>

<style>
html, body { background-color: #020617; }
</style>
<script>
(() => {
    const root = document.documentElement;
    try {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') root.classList.add('dark');
        if (savedTheme === 'light') root.classList.remove('dark');
    } catch (error) {}
})();

window.tailwind = window.tailwind || {};
window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
</script>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
html { font-size: 16px; }
body {
    font-family: 'Inter', sans-serif;
    color: #d9ecff;
    overflow-x: hidden;
}

:root {
    --login-bg: #060b18;
    --login-surface: rgba(255, 255, 255, 0.04);
    --login-surface-hover: rgba(255, 255, 255, 0.06);
    --login-border: rgba(148, 163, 184, 0.26);
    --login-border-focus: rgba(129, 140, 248, 0.54);
    --login-text: #e5e7eb;
    --login-muted: #a7b0c0;
    --login-placeholder: #93a4bc;
    --login-icon: #9bb7d7;
    --login-link: #a7b0c0;
    --login-link-hover: #d7deea;
    --login-btn-border: rgba(99, 102, 241, 0.52);
    --login-btn-bg-1: #2f5fde;
    --login-btn-bg-2: #2563eb;
    --login-btn-text: #eef2ff;
}

html, body {
    background-color: var(--login-bg);
}

.auth-page {
    background:
        radial-gradient(1200px 560px at 8% -18%, rgba(99, 102, 241, 0.22), transparent 56%),
        radial-gradient(900px 420px at 100% -6%, rgba(37, 99, 235, 0.17), transparent 60%),
        linear-gradient(165deg, #060b18 0%, #0b1220 50%, #111827 100%);
}

.auth-wrapper {
    width: min(100%, 460px);
    padding: 0;
    position: relative;
}

.auth-brand {
    display: flex;
    justify-content: center;
    margin-bottom: 34px;
}

.auth-form-block {
    width: 100%;
    margin: 0;
}

.auth-heading {
    margin-bottom: 16px;
}

.auth-title {
    color: var(--login-text);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
}

.auth-subtitle {
    margin-top: 6px;
    color: var(--login-muted);
    font-size: 0.95rem;
}

.field-shell {
    width: 100%;
    height: 58px;
    border: 1px solid var(--login-border);
    border-radius: 12px;
    background: var(--login-surface);
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 14px;
    transition: border-color 140ms ease-out, box-shadow 140ms ease-out;
}

.field-shell:focus-within {
    border-color: var(--login-border-focus);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.16);
    background: var(--login-surface-hover);
}

.field-icon {
    color: var(--login-icon);
    font-size: 1rem;
    width: 18px;
    text-align: center;
}

.modern-input {
    background: transparent;
    border: 0;
    color: var(--login-text);
    width: 100%;
    font-size: 1.08rem;
    line-height: 1.2;
    font-weight: 500;
    padding-right: 0;
}

.modern-input::placeholder {
    color: var(--login-placeholder);
    opacity: 0.95;
}

.modern-input:focus {
    outline: none;
}

.modern-button {
    width: 100%;
    height: 46px;
    border-radius: 11px;
    border: 1px solid var(--login-btn-border);
    background: linear-gradient(135deg, var(--login-btn-bg-1) 0%, var(--login-btn-bg-2) 100%);
    color: var(--login-btn-text);
    font-weight: 700;
    letter-spacing: 0.02em;
    box-shadow: 0 10px 24px -16px rgba(59, 130, 246, 0.86), inset 0 1px 0 rgba(191, 219, 254, 0.22);
    transition: transform 140ms ease-out, filter 140ms ease-out, box-shadow 140ms ease-out;
}

.modern-button:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 13px 26px -16px rgba(59, 130, 246, 0.92), inset 0 1px 0 rgba(219, 234, 254, 0.28);
}

.modern-button:disabled {
    opacity: 0.75;
    cursor: not-allowed;
    box-shadow: none;
}

.auth-message {
    border-radius: 11px;
    padding: 10px 12px;
    border: 1px solid transparent;
    font-size: 0.9rem;
}

.auth-message.is-success {
    background: rgba(64, 217, 174, 0.14);
    color: #95f0d2;
    border-color: rgba(64, 217, 174, 0.34);
}

.auth-message.is-error {
    background: rgba(244, 63, 94, 0.15);
    color: #ffcad5;
    border-color: rgba(244, 63, 94, 0.35);
}

.forgot-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--login-link);
    font-style: italic;
    font-size: 1rem;
    transition: color 140ms ease-out;
}

.forgot-link:hover {
    color: var(--login-link-hover);
}

.auth-footer {
    margin-top: 22px;
    color: rgba(148, 163, 184, 0.74);
    text-align: center;
    font-size: 0.8rem;
}
</style>
</head>

<body class="auth-page min-h-screen flex items-center justify-center p-4 sm:p-6">
<div class="auth-wrapper">
    <div class="auth-brand">
        <%- include('partials/brand-wordmark', { size: 'login' }) %>
    </div>

    <div class="auth-form-block">
        <div class="auth-heading text-center">
            <h2 class="auth-title">Recuperar senha</h2>
            <p class="auth-subtitle">Informe seu e-mail para receber o link de redefinicao.</p>
        </div>

        <form id="forgotPasswordForm" class="space-y-5">
            <label class="field-shell">
                <span class="sr-only">Email</span>
                <i class="fas fa-envelope field-icon" aria-hidden="true"></i>
                <input
                    type="email"
                    id="email"
                    required
                    autocomplete="email"
                    class="modern-input"
                    placeholder="Email">
            </label>

            <div id="forgotPasswordMessage" class="hidden auth-message"></div>

            <button id="forgotPasswordSubmitBtn" type="submit" class="modern-button">
                <i class="fas fa-paper-plane mr-2"></i>Enviar link
            </button>
        </form>

        <div class="mt-5 text-center">
            <a href="/login" class="forgot-link">
                <i class="fas fa-arrow-left"></i>Voltar para o login
            </a>
        </div>

        <p class="auth-footer">&copy; 2026 Credix</p>
    </div>
</div>

<script>
async function checkSession() {
    try {
        const response = await fetch('/auth/me', { credentials: 'include' });
        if (response.ok) {
            window.location.href = '/admin/visao-geral.html';
        }
    } catch (error) {}
}

checkSession();

document.getElementById('forgotPasswordForm').addEventListener('submit', async function (event) {
    event.preventDefault();

    const email = document.getElementById('email').value.trim().toLowerCase();
    const message = document.getElementById('forgotPasswordMessage');
    const submitButton = document.getElementById('forgotPasswordSubmitBtn');
    const originalText = submitButton.innerHTML;

    submitButton.disabled = true;
    submitButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Enviando...';

    try {
        const response = await fetch('/auth/forgot-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ email }),
        });

        const payload = await response.json().catch(() => null);
        const responseMessage = payload?.message || 'Se o e-mail estiver cadastrado, enviaremos instrucoes.';

        message.className = 'auth-message is-success';
        message.textContent = responseMessage;
        message.classList.remove('hidden');
    } catch (error) {
        message.className = 'auth-message is-error';
        message.textContent = 'Nao foi possivel solicitar a recuperacao agora. Tente novamente.';
        message.classList.remove('hidden');
    } finally {
        submitButton.disabled = false;
        submitButton.innerHTML = originalText;
    }
});
</script>
</body>
</html>
