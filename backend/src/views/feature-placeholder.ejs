<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credix - <%= featureTitle %></title>
    <%- include('partials/favicon') %>
    <%- include('partials/toast') %>
    <%- include('partials/session-timeout') %>
    <style>
        html, body { background-color: #020617; }
    </style>
    <script>
        (function () {
            const root = document.documentElement;
            try {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark') root.classList.add('dark');
                if (savedTheme === 'light') root.classList.remove('dark');
            } catch (error) {}
        })();

        window.tailwind = window.tailwind || {};
        window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        html { font-size: 16px; }
        body { font-family: 'Inter', sans-serif; overflow-x: hidden; }

        .primary-gradient {
            background:
                radial-gradient(900px 320px at -10% -10%, rgba(30, 64, 175, 0.18), transparent 60%),
                #121b2a;
        }

        .premium-header {
            background: rgba(18, 27, 42, 0.88);
            border-bottom: 1px solid rgba(148, 163, 184, 0.24);
            backdrop-filter: blur(8px);
        }

        .icon-btn {
            color: #cbd5e1;
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background-color 120ms ease-out, color 120ms ease-out, box-shadow 120ms ease-out;
        }

        .icon-btn:hover {
            color: #ffffff;
            background: rgba(59, 130, 246, 0.2);
            box-shadow: 0 0 0 1px rgba(96, 165, 250, 0.35) inset;
        }

        .modern-sidebar {
            transform: translateX(0);
            transition: transform 120ms ease-out;
        }

        .page-title { color: #e7edf7; }
        .muted-on-dark { color: #b8c3d8; }

        .feature-shell {
            border-radius: 24px;
            border: 1px solid rgba(148, 163, 184, 0.22);
            background:
                linear-gradient(160deg, rgba(15, 23, 42, 0.92) 0%, rgba(15, 23, 42, 0.82) 100%);
            box-shadow: 0 24px 60px rgba(2, 6, 23, 0.28);
        }

        .feature-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            border-radius: 999px;
            border: 1px solid rgba(96, 165, 250, 0.28);
            background: rgba(30, 64, 175, 0.18);
            color: #bfdbfe;
            padding: 0.35rem 0.8rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        body.sidebar-collapsed .modern-sidebar { transform: translateX(-100%); }
        body.sidebar-collapsed main { margin-left: 0 !important; width: 100% !important; flex: 1 1 100% !important; }

        @media (max-width: 1024px) {
            .modern-sidebar { transform: translateX(-100%); }
            .modern-sidebar.mobile-open { transform: translateX(0) !important; }
            main { margin-left: 0 !important; width: 100% !important; flex: 1 1 100% !important; }
        }
    </style>
</head>
<body class="primary-gradient min-h-screen">
    <header class="premium-header fixed w-full top-0 z-50">
        <div class="flex items-center justify-between px-3 py-3 sm:px-6 sm:py-4">
            <div class="flex items-center">
                <button id="sidebarToggle" class="icon-btn focus:outline-none">
                    <i class="fas fa-bars text-xl"></i>
                </button>
                <h1 class="ml-3 sm:ml-6">
                    <a href="dashboard.html" class="flex items-center" aria-label="Credix">
                        <%- include('partials/brand-wordmark', { size: 'header' }) %>
                    </a>
                </h1>
            </div>

            <div class="flex items-center gap-4">
                <button id="userMenuBtn" class="flex items-center gap-2 text-slate-200 hover:text-white focus:outline-none">
                    <span id="userName" class="font-semibold">Olá, <%= currentUser?.name || currentUser?.full_name || 'Administrador' %></span>
                    <i class="fas fa-chevron-down text-sm"></i>
                </button>
                <div id="userMenuDropdown" class="absolute right-6 top-full z-50 mt-2 hidden w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-xl dark:border-slate-700 dark:bg-slate-900">
                    <button type="button" data-user-menu-action="profile" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                        <i class="fas fa-id-card text-slate-500 dark:text-slate-300"></i>
                        <span>Meu perfil</span>
                    </button>
                    <button type="button" data-user-menu-action="security" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                        <i class="fas fa-shield-halved text-slate-500 dark:text-slate-300"></i>
                        <span>Segurança</span>
                    </button>
                    <button type="button" data-user-menu-action="help" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
                        <i class="fas fa-circle-question text-slate-500 dark:text-slate-300"></i>
                        <span>Ajuda</span>
                    </button>
                    <div class="my-2 border-t border-slate-200 dark:border-slate-700"></div>
                    <button type="button" data-user-menu-action="logout" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-rose-600 hover:bg-rose-50 dark:text-rose-400 dark:hover:bg-rose-950/40">
                        <i class="fas fa-right-from-bracket"></i>
                        <span>Sair</span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <%- include('partials/admin-sidebar', { activePage }) %>

    <main class="pt-24 pb-10 px-4 sm:px-8 lg:px-10">
        <section class="mx-auto max-w-5xl feature-shell p-8 sm:p-10 lg:p-12">
            <span class="feature-badge">
                <i class="<%= featureIcon %>"></i>
                <span><%= featureBadge %></span>
            </span>
            <div class="mt-6 max-w-3xl">
                <h2 class="page-title text-3xl font-bold sm:text-4xl"><%= featureTitle %></h2>
                <p class="muted-on-dark mt-4 text-base leading-7 sm:text-lg"><%= featureDescription %></p>
                <div class="mt-8 rounded-2xl border border-slate-700/70 bg-slate-950/30 p-5 text-slate-300">
                    <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-400">Próximo passo</p>
                    <p class="mt-3 text-base leading-7"><%= featureNextStep %></p>
                </div>
            </div>
        </section>
    </main>

    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            const displayName = currentUser.name || currentUser.full_name || 'Administrador';
            document.getElementById('userName').textContent = `Olá, ${displayName}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            sidebar.classList.remove('mobile-open');
            if (document.body.classList.contains('sidebar-collapsed')) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            main.style.marginLeft = '16rem';
            main.style.width = 'calc(100% - 16rem)';
            main.style.flex = '0 1 calc(100% - 16rem)';
        }

        function closeUserMenu() {
            if (!userMenuDropdown) return;
            userMenuDropdown.classList.add('hidden');
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        async function handleUserMenuAction(action) {
            if (action === 'logout') {
                await performLogout();
                return;
            }

            const allowedTabs = new Set(['profile', 'security', 'help']);
            const destination = allowedTabs.has(action) ? action : 'profile';
            window.location.href = `/admin/account.html?tab=${encodeURIComponent(destination)}`;
        }

        sidebarToggle.addEventListener('click', () => {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();

        if (userMenuBtn && userMenuDropdown) {
            userMenuBtn.addEventListener('click', (event) => {
                event.stopPropagation();
                userMenuDropdown.classList.toggle('hidden');
            });

            userMenuDropdown.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Element)) return;
                const actionBtn = target.closest('[data-user-menu-action]');
                if (!actionBtn) return;
                const action = actionBtn.getAttribute('data-user-menu-action');
                closeUserMenu();
                void handleUserMenuAction(action);
            });

            document.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Node)) return;
                if (userMenuDropdown.classList.contains('hidden')) return;
                if (userMenuDropdown.contains(target) || userMenuBtn.contains(target)) return;
                closeUserMenu();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeUserMenu();
            });
        }
    </script>
</body>
</html>

