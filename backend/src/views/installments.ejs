        async function saveInstallmentPayment(options) {
            const {
                installmentId,
                paymentDate,
                selectedMethod,
                paymentNotes = '',
                successMessage = 'Parcela marcada como paga.',
            } = options;

            const installment = installmentsState.installments.find((item) => sameId(item.id, installmentId));
            if (!installment) {
                showMessage('Parcela nao encontrada.', 'error');
                return false;
            }

            const methodToPersist = selectedMethod === 'Outro' ? 'Pix' : selectedMethod;
            const apiMethod = toApiPaymentMethod(methodToPersist);
            const notesWithMethod = selectedMethod === 'Outro'
                ? `Forma informada: Outro${paymentNotes ? ` | ${paymentNotes.trim()}` : ''}`
                : paymentNotes;
            const numericLoanId = toNumber(installment.loan_id);
            const numericInstallmentId = toNumber(installment.id);

            if (numericLoanId <= 0 || numericInstallmentId <= 0) {
                showMessage('Parcela invalida para registro de pagamento.', 'error');
                return false;
            }

            try {
                const response = await fetch('/api/payments', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({
                        loanId: numericLoanId,
                        installmentId: numericInstallmentId,
                        amount: round2(installment.amount),
                        paymentDate,
                        method: apiMethod,
                        notes: notesWithMethod || undefined,
                    }),
                });

                if (!response.ok) {
                    const apiMessage = await extractApiErrorMessage(response, 'Nao foi possivel registrar o pagamento.');
                    showMessage(apiMessage, 'error');
                    return false;
                }

                showMessage(successMessage, 'success');
                await loadInstallmentsData({ silent: true, preservePage: true });
                return true;
            } catch (error) {
                console.error('Erro ao registrar pagamento:', error);
                showMessage('Erro de conexao ao registrar pagamento.', 'error');
                return false;
            }
        }

        async function submitInstallmentPaymentFromModal() {
            readInstallmentModalFormValues();

            const installment = getSelectedInstallment();
            if (!installment) {
                showMessage('Parcela nao encontrada.', 'error');
                closeInstallmentModal();
                return;
            }

            if (!installmentModalState.form.paymentDate || !installmentModalState.form.paymentMethod) {
                showMessage('Preencha os campos obrigatorios do pagamento.', 'error');
                return;
            }

            installmentModalState.isSubmitting = true;
            renderInstallmentModal();

            const success = await saveInstallmentPayment({
                installmentId: installment.id,
                paymentDate: installmentModalState.form.paymentDate,
                selectedMethod: installmentModalState.form.paymentMethod,
                paymentNotes: installmentModalState.form.paymentNotes,
                successMessage: 'Pagamento registrado com sucesso.',
            });

            installmentModalState.isSubmitting = false;
            if (!success) {
                renderInstallmentModal();
                return;
            }

            if (!getSelectedInstallment()) {
                closeInstallmentModal();
                return;
            }

            installmentModalState.mode = 'details';
            renderInstallmentModal();
        }

        async function submitInstallmentRefundFromModal() {
            readInstallmentModalFormValues();

            const installment = getSelectedInstallment();
            if (!installment) {
                showMessage('Parcela nao encontrada.', 'error');
                closeInstallmentModal();
                return;
            }

            if (normalizeInstallmentStatus(installment) !== 'Pago') {
                showMessage('Somente parcelas pagas podem ser estornadas.', 'error');
                setInstallmentModalMode('details');
                return;
            }

            const numericInstallmentId = toNumber(installment.id);
            if (numericInstallmentId <= 0) {
                showMessage('Parcela invalida para estorno.', 'error');
                return;
            }

            installmentModalState.isSubmitting = true;
            renderInstallmentModal();

            try {
                const response = await fetch(`/api/payments/installments/${numericInstallmentId}/revert`, {
                    method: 'POST',
                    credentials: 'include',
                });

                if (!response.ok) {
                    const apiMessage = await extractApiErrorMessage(response, 'Nao foi possivel estornar o pagamento.');
                    showMessage(apiMessage, 'error');
                    installmentModalState.isSubmitting = false;
                    renderInstallmentModal();
                    return;
                }

                showMessage('Pagamento estornado com sucesso!', 'success');
                await loadInstallmentsData({ silent: true, preservePage: true });

                installmentModalState.isSubmitting = false;
                if (!getSelectedInstallment()) {
                    closeInstallmentModal();
                    return;
                }

                installmentModalState.mode = 'details';
                renderInstallmentModal();
            } catch (error) {
                console.error('Erro ao estornar pagamento:', error);
                showMessage('Erro de conexao ao estornar pagamento.', 'error');
                installmentModalState.isSubmitting = false;
                renderInstallmentModal();
            }
        }

        async function submitInstallmentDeleteFromModal() {
            const installment = getSelectedInstallment();
            if (!installment) {
                showMessage('Parcela nao encontrada.', 'error');
                closeInstallmentModal();
                return;
            }

            const status = normalizeInstallmentStatus(installment);
            if (status === 'Pago') {
                showMessage('Parcela paga deve ser estornada antes da exclusao.', 'error');
                setInstallmentModalMode('refund');
                return;
            }

            const impact = getDeleteImpact(installment);
            if (impact.isOnlyInstallment) {
                showMessage('Este emprestimo possui apenas uma parcela. Exclua o emprestimo inteiro.', 'error');
                return;
            }

            const numericInstallmentId = toNumber(installment.id);
            if (numericInstallmentId <= 0) {
                showMessage('Parcela invalida para exclusao.', 'error');
                return;
            }

            installmentModalState.isSubmitting = true;
            renderInstallmentModal();

            try {
                const response = await fetch(`/api/payments/installments/${numericInstallmentId}`, {
                    method: 'DELETE',
                    credentials: 'include',
                });

                if (!response.ok) {
                    const apiMessage = await extractApiErrorMessage(response, 'Nao foi possivel excluir a parcela.');
                    showMessage(apiMessage, 'error');
                    installmentModalState.isSubmitting = false;
                    renderInstallmentModal();
                    return;
                }

                showMessage('Parcela excluida com sucesso!', 'success');
                await loadInstallmentsData({ silent: true, preservePage: true });
                closeInstallmentModal();
            } catch (error) {
                console.error('Erro ao excluir parcela:', error);
                showMessage('Erro de conexao ao excluir parcela.', 'error');
                installmentModalState.isSubmitting = false;
                renderInstallmentModal();
            }
        }

