    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            const displayName = currentUser.name || currentUser.full_name || 'Administrador';
            document.getElementById('userName').textContent = `Olá, ${displayName}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebarLinks = document.querySelectorAll('#sidebar .sidebar-item');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');

        const notificationModal = document.getElementById('notificationModal');
        const installmentModal = document.getElementById('installmentModal');
        const installmentModalTitle = document.getElementById('installmentModalTitle');
        const installmentModalContent = document.getElementById('installmentModalContent');
        const installmentModalFooter = document.getElementById('installmentModalFooter');
        const closeInstallmentModalBtn = document.getElementById('closeInstallmentModalBtn');

        const installmentsState = {
            installments: [],
            debtors: [],
            loans: [],
            filtered: [],
            currentPage: 1,
            pageSize: 10,
            isLoading: true,
            kpiFilter: ''
        };

        const installmentModalState = {
            isOpen: false,
            mode: 'details',
            selectedInstallmentId: null,
            isSubmitting: false,
            lastFocusedElement: null,
            form: {
                paymentDate: '',
                paymentMethod: 'Pix',
                paymentNotes: '',
                refundReason: '',
            },
        };

        const modalFocusState = {
            activeModal: null,
        };

        const tableCache = {};
        function getDemoTable(tableName) {
            return Array.isArray(tableCache[tableName]) ? tableCache[tableName] : [];
        }

        async function saveTableData(tableName, rows) {
            const safeRows = Array.isArray(rows) ? rows : [];
            const response = await fetch(`/api/tables/${tableName}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ rows: safeRows })
            });

            if (!response.ok) {
                throw new Error(`Erro ao salvar tabela ${tableName}: HTTP ${response.status}`);
            }

            const payload = await response.json().catch(() => null);
            const data = Array.isArray(payload?.data) ? payload.data : safeRows;
            tableCache[tableName] = data;
            return data;
        }

        async function fetchTableData(tableName) {
            try {
                const response = await fetch(`/api/tables/${tableName}`, { credentials: 'include' });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const payload = await response.json();
                if (Array.isArray(payload?.data)) {
                    tableCache[tableName] = payload.data;
                    return payload.data;
                }
            } catch (error) {
                console.warn(`Fallback para dados demo: ${tableName}`, error);
            }
            return getDemoTable(tableName);
        }

        function sameId(a, b) {
            return String(a ?? '') === String(b ?? '');
        }

        function toNumber(value, fallback = 0) {
            const parsed = Number(value);
            return Number.isFinite(parsed) ? parsed : fallback;
        }

        function round2(value) {
            return Math.round((toNumber(value) + Number.EPSILON) * 100) / 100;
        }

        function normalizeAscii(value) {
            return String(value ?? '')
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .toLowerCase()
                .trim();
        }

        function parseDateValue(value) {
            if (!value) return null;
            if (value instanceof Date) return new Date(value.getTime());

            const raw = String(value).trim();
            const dateOnlyMatch = raw.match(/^(\d{4})-(\d{2})-(\d{2})$/);
            if (dateOnlyMatch) {
                const year = Number(dateOnlyMatch[1]);
                const month = Number(dateOnlyMatch[2]) - 1;
                const day = Number(dateOnlyMatch[3]);
                return new Date(year, month, day);
            }

            const parsed = new Date(raw);
            if (Number.isNaN(parsed.getTime())) return null;
            return parsed;
        }

        function startOfDay(value) {
            const date = parseDateValue(value);
            if (!date || Number.isNaN(date.getTime())) return null;
            date.setHours(0, 0, 0, 0);
            return date;
        }

        function toIsoDate(value) {
            const date = parseDateValue(value);
            if (!date) return '';
            return date.toISOString().slice(0, 10);
        }

        function normalizeInstallmentStatus(installment) {
            const rawStatus = normalizeAscii(installment.status);
            if (rawStatus === 'pago' || rawStatus === 'paid') return 'Pago';
            if (rawStatus === 'atrasado') return 'Atrasado';

            const dueDate = startOfDay(installment.due_date);
            const today = startOfDay(new Date());
            if (dueDate && today && dueDate < today) return 'Atrasado';
            return 'Pendente';
        }

        function dueInDays(installment) {
            const dueDate = startOfDay(installment.due_date);
            const today = startOfDay(new Date());
            if (!dueDate || !today) return null;
            return Math.round((dueDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
        }

        function applyQueryFiltersToControls() {
            const params = new URLSearchParams(window.location.search);
            const statusParam = normalizeAscii(params.get('status'));
            const dueParam = normalizeAscii(params.get('due') || params.get('vence'));
            const statusFilter = document.getElementById('installmentStatusFilter');
            const periodFilter = document.getElementById('installmentPeriodFilter');

            if (statusParam === 'pending' || statusParam === 'pendente') {
                statusFilter.value = 'Pendente';
            } else if (statusParam === 'paid' || statusParam === 'paga' || statusParam === 'pago') {
                statusFilter.value = 'Pago';
            } else if (statusParam === 'overdue' || statusParam === 'atraso' || statusParam === 'atrasada' || statusParam === 'atrasado') {
                statusFilter.value = 'Atrasado';
            }

            if (dueParam === 'today' || dueParam === 'hoje') {
                periodFilter.value = 'today';
            } else if (dueParam === 'next7' || dueParam === '7dias' || dueParam === '7d') {
                periodFilter.value = 'next7';
            } else if (
                dueParam === 'month'
                || dueParam === 'mes'
                || dueParam === 'month_current'
                || dueParam === 'current_month'
                || dueParam === 'thismonth'
                || dueParam === 'mes_atual'
            ) {
                periodFilter.value = 'month_current';
            }

            updateCustomRangeVisibility();
        }

        function updateCustomRangeVisibility() {
            const periodValue = document.getElementById('installmentPeriodFilter').value;
            const customRangeWrap = document.getElementById('customRangeWrap');
            if (!customRangeWrap) return;
            customRangeWrap.classList.toggle('hidden', periodValue !== 'custom');
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(toNumber(value));
        }

        function getMonthEquivalentBounds(referenceDate = new Date(), offsetMonths = 0) {
            const reference = startOfDay(referenceDate);
            if (!reference) return { start: null, end: null };

            const start = new Date(reference.getFullYear(), reference.getMonth() + offsetMonths, 1);
            start.setHours(0, 0, 0, 0);

            if (offsetMonths === 0) {
                return { start, end: reference };
            }

            const targetMonthLastDay = new Date(start.getFullYear(), start.getMonth() + 1, 0).getDate();
            const boundedDay = Math.min(reference.getDate(), targetMonthLastDay);
            const end = new Date(start.getFullYear(), start.getMonth(), boundedDay);
            end.setHours(0, 0, 0, 0);
            return { start, end };
        }

        function getPeriodBoundsFromFilter(periodValue, customStartValue = '', customEndValue = '') {
            const today = startOfDay(new Date());
            if (!today) return { start: null, end: null, label: 'Período atual', isMonthly: false };

            if (periodValue === 'today') {
                return { start: today, end: today, label: 'Hoje', isMonthly: false };
            }

            if (periodValue === 'next7') {
                const end = new Date(today.getTime());
                end.setDate(end.getDate() + 7);
                end.setHours(0, 0, 0, 0);
                return { start: today, end, label: 'Próx. 7 dias', isMonthly: false };
            }

            if (periodValue === 'last30') {
                const start = new Date(today.getTime());
                start.setDate(start.getDate() - 29);
                start.setHours(0, 0, 0, 0);
                return { start, end: today, label: 'Últimos 30 dias', isMonthly: false };
            }

            if (periodValue === 'custom') {
                let start = startOfDay(customStartValue);
                let end = startOfDay(customEndValue);
                if (start && end && start > end) {
                    const temp = start;
                    start = end;
                    end = temp;
                }
                if (start && end) {
                    return { start, end, label: 'Período personalizado', isMonthly: false };
                }
            }

            const monthBounds = getMonthEquivalentBounds(today, 0);
            return { ...monthBounds, label: 'Mês atual', isMonthly: true };
        }

        function shiftRangeByYears(start, end, years = -1) {
            const safeStart = startOfDay(start);
            const safeEnd = startOfDay(end);
            if (!safeStart || !safeEnd || safeEnd < safeStart) return { start: null, end: null };

            const shiftedStart = new Date(safeStart.getFullYear() + years, safeStart.getMonth(), safeStart.getDate());
            const shiftedEnd = new Date(safeEnd.getFullYear() + years, safeEnd.getMonth(), safeEnd.getDate());
            shiftedStart.setHours(0, 0, 0, 0);
            shiftedEnd.setHours(0, 0, 0, 0);
            return { start: shiftedStart, end: shiftedEnd };
        }

        function getPreviousPeriodBounds(start, end, periodsBack = 1) {
            const safeStart = startOfDay(start);
            const safeEnd = startOfDay(end);
            if (!safeStart || !safeEnd || safeEnd < safeStart) return { start: null, end: null };

            const dayMs = 24 * 60 * 60 * 1000;
            const durationDays = Math.max(1, Math.round((safeEnd.getTime() - safeStart.getTime()) / dayMs) + 1);
            const offset = durationDays * Math.max(1, Math.trunc(toNumber(periodsBack, 1)));
            const shiftedStart = new Date(safeStart.getTime() - (offset * dayMs));
            const shiftedEnd = new Date(safeEnd.getTime() - (offset * dayMs));
            shiftedStart.setHours(0, 0, 0, 0);
            shiftedEnd.setHours(0, 0, 0, 0);
            return { start: shiftedStart, end: shiftedEnd };
        }

        function getInsightComparisonRanges(periodValue, currentBounds) {
            const start = startOfDay(currentBounds?.start);
            const end = startOfDay(currentBounds?.end);
            if (!start || !end || end < start) {
                return {
                    previous: { start: null, end: null },
                    avgRanges: [{ start: null, end: null }, { start: null, end: null }, { start: null, end: null }],
                    yearAgo: { start: null, end: null },
                };
            }

            if (periodValue === 'month_current' || periodValue === 'all') {
                const previous = getMonthEquivalentBounds(end, -1);
                const minus2 = getMonthEquivalentBounds(end, -2);
                const minus3 = getMonthEquivalentBounds(end, -3);
                const yearAgo = shiftRangeByYears(start, end, -1);
                return { previous, avgRanges: [previous, minus2, minus3], yearAgo };
            }

            const previous = getPreviousPeriodBounds(start, end, 1);
            const minus2 = getPreviousPeriodBounds(start, end, 2);
            const minus3 = getPreviousPeriodBounds(start, end, 3);
            const yearAgo = shiftRangeByYears(start, end, -1);
            return { previous, avgRanges: [previous, minus2, minus3], yearAgo };
        }

        function isDateInRange(value, start, end) {
            const date = startOfDay(value);
            if (!date || !start || !end) return false;
            return date >= start && date <= end;
        }

        function getInstallmentMetricInRange(metricKey, list, start, end) {
            if (!start || !end) return 0;

            return list.reduce((sum, installment) => {
                const status = normalizeInstallmentStatus(installment);
                if (metricKey === 'received') {
                    if (status !== 'Pago') return sum;
                    if (!isDateInRange(installment.payment_date, start, end)) return sum;
                    return sum + toNumber(installment.paid_amount || installment.amount || 0);
                }

                if (metricKey === 'pending') {
                    if (status === 'Pago') return sum;
                    if (!isDateInRange(installment.due_date, start, end)) return sum;
                    return sum + toNumber(installment.amount || 0);
                }

                if (metricKey === 'overdue') {
                    if (status !== 'Atrasado') return sum;
                    if (!isDateInRange(installment.due_date, start, end)) return sum;
                    return sum + toNumber(installment.amount || 0);
                }

                return sum;
            }, 0);
        }

        function getComparisonPercent(currentValue, baselineValue, minRobustBase = 0) {
            const current = Number.isFinite(Number(currentValue)) ? Number(currentValue) : 0;
            const baseline = Number.isFinite(Number(baselineValue)) ? Number(baselineValue) : 0;
            if (Math.abs(baseline) < Math.max(0, Number(minRobustBase) || 0)) return null;
            return ((current - baseline) / Math.abs(baseline)) * 100;
        }

        function formatPercentMagnitude(percentValue) {
            return Math.abs(percentValue).toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            });
        }

        function getInsightTone(percentValue, invert = false) {
            if (!Number.isFinite(percentValue) || Math.abs(percentValue) < 0.005) return 'neutral';
            const isPositive = percentValue > 0;
            if (invert) return isPositive ? 'negative' : 'positive';
            return isPositive ? 'positive' : 'negative';
        }

        function formatPrimaryInsightText(percentValue, label) {
            if (!Number.isFinite(percentValue) || Math.abs(percentValue) < 0.005) {
                return `0,00% ${label}`;
            }
            return `${percentValue > 0 ? '+' : '-'} ${formatPercentMagnitude(percentValue)}% ${label}`;
        }

        function formatSecondaryInsightText(percentValue, label) {
            if (!Number.isFinite(percentValue) || Math.abs(percentValue) < 0.005) {
                return `${label}: 0,00%`;
            }
            return `${label}: ${percentValue > 0 ? '+' : '-'}${formatPercentMagnitude(percentValue)}%`;
        }

        function buildSmartKpiInsight(currentValue, comparisons, options = {}) {
            const {
                invert = false,
                minRobustBase = 0,
            } = options;

            const average3Pct = getComparisonPercent(currentValue, comparisons?.average3, minRobustBase);
            const previousPct = getComparisonPercent(currentValue, comparisons?.previous, minRobustBase);
            const yearAgoPct = getComparisonPercent(currentValue, comparisons?.yearAgo, minRobustBase);

            const primary = Number.isFinite(average3Pct)
                ? { key: 'average3', pct: average3Pct, label: 'vs média 3 períodos' }
                : Number.isFinite(previousPct)
                    ? { key: 'previous', pct: previousPct, label: 'vs período anterior' }
                    : Number.isFinite(yearAgoPct)
                        ? { key: 'yearAgo', pct: yearAgoPct, label: 'vs A/A' }
                        : null;

            if (!primary) {
                return { tone: 'neutral', text: 'sem base robusta para comparação' };
            }

            const secondary = [];
            if (primary.key !== 'previous' && Number.isFinite(previousPct)) {
                secondary.push(formatSecondaryInsightText(previousPct, 'M-1'));
            }
            if (primary.key !== 'yearAgo' && Number.isFinite(yearAgoPct)) {
                secondary.push(formatSecondaryInsightText(yearAgoPct, 'A/A'));
            }
            if (primary.key !== 'average3' && Number.isFinite(average3Pct)) {
                secondary.unshift(formatSecondaryInsightText(average3Pct, '3P'));
            }

            let text = formatPrimaryInsightText(primary.pct, primary.label);
            if (secondary.length) {
                text += ` | ${secondary.join(' | ')}`;
            }

            return {
                tone: getInsightTone(primary.pct, invert),
                text,
            };
        }

        function applyKpiInsight(elementId, prefixText, insight) {
            const element = document.getElementById(elementId);
            if (!element) return;
            element.classList.remove('kpi-insight-positive', 'kpi-insight-negative');
            if (insight?.tone === 'positive') element.classList.add('kpi-insight-positive');
            if (insight?.tone === 'negative') element.classList.add('kpi-insight-negative');
            element.textContent = prefixText ? `${prefixText} ${insight?.text || ''}` : (insight?.text || '--');
        }

        function formatDate(value) {
            const date = parseDateValue(value);
            if (!date) return '-';
            return date.toLocaleDateString('pt-BR');
        }

        function normalizePaymentMethod(value, notes = '') {
            const source = normalizeAscii(value);
            const notesSource = normalizeAscii(notes);
            if (notesSource.includes('forma informada: outro')) return 'Outro';
            if (source.includes('pix')) return 'Pix';
            if (source.includes('dinheiro')) return 'Dinheiro';
            if (source.includes('transfer')) return 'Transferência';
            if (source.includes('cartao')) return 'Cartão';
            if (source.includes('outro')) return 'Outro';
            return '';
        }

        function toApiPaymentMethod(value) {
            const source = normalizeAscii(value);
            if (source.includes('dinheiro')) return 'DINHEIRO';
            if (source.includes('transfer')) return 'TRANSFERENCIA';
            if (source.includes('cartao')) return 'CARTAO';
            return 'PIX';
        }

        async function extractApiErrorMessage(response, fallback) {
            try {
                const payload = await response.json();
                if (payload && typeof payload.message === 'string' && payload.message.trim()) {
                    return payload.message.trim();
                }
            } catch (_error) {
                // usa fallback quando nao houver JSON valido
            }
            return fallback;
        }

        function normalizeLoanRow(row) {
            return {
                ...row,
                id: row.id,
                debtor_id: row.debtor_id ?? row.client_id ?? row.clientId,
                principal_amount: round2(row.principal_amount ?? row.principalAmount ?? 0),
                total_amount: round2(row.total_amount ?? row.totalAmount ?? 0),
                installments_count: Math.max(1, Math.trunc(toNumber(row.installments_count ?? row.installmentsCount ?? 1))),
                interest_rate: round2(row.interest_rate ?? row.interestRate ?? 0),
                interest_type: normalizeAscii(row.interest_type ?? row.interestType) === 'simples' ? 'simples' : 'composto',
                payment_method: normalizePaymentMethod(row.payment_method ?? row.paymentMethod),
                status: row.status || 'Ativo'
            };
        }

        function normalizeInstallmentRow(row) {
            return {
                ...row,
                id: row.id,
                loan_id: row.loan_id ?? row.loanId,
                debtor_id: row.debtor_id ?? row.client_id ?? row.clientId,
                installment_number: Math.max(1, Math.trunc(toNumber(row.installment_number ?? row.installmentNumber ?? row.number ?? 1))),
                due_date: toIsoDate(row.due_date ?? row.dueDate),
                payment_date: toIsoDate(row.payment_date ?? row.paymentDate),
                amount: round2(row.amount),
                paid_amount: round2(row.paid_amount ?? row.amount),
                payment_method: normalizePaymentMethod(row.payment_method ?? row.paymentMethod, row.notes),
                notes: String(row.notes || ''),
                principal_amount: row.principal_amount ?? row.principalAmount ?? null,
                interest_amount: row.interest_amount ?? row.interestAmount ?? null,
                status: row.status || 'Pendente'
            };
        }

        function getDebtorById(debtorId) {
            return installmentsState.debtors.find(debtor => sameId(debtor.id, debtorId));
        }

        function getDebtorName(debtorId) {
            const debtor = getDebtorById(debtorId);
            return debtor?.name || debtor?.full_name || 'Cliente não identificado';
        }

        function getDebtorPhone(debtorId) {
            const debtor = getDebtorById(debtorId);
            return debtor?.phone || '';
        }

        function populateInstallmentClientFilter() {
            const select = document.getElementById('installmentClientFilter');
            if (!select) return;

            const previousValue = select.value || 'all';
            const clientsMap = new Map();

            installmentsState.installments.forEach((installment) => {
                const debtorId = installment.debtor_id;
                if (debtorId === null || debtorId === undefined || debtorId === '') return;
                const key = String(debtorId);
                if (clientsMap.has(key)) return;

                clientsMap.set(key, {
                    id: key,
                    name: getDebtorName(debtorId),
                });
            });

            const options = Array.from(clientsMap.values()).sort((a, b) => a.name.localeCompare(b.name, 'pt-BR'));
            const optionsHtml = options
                .map((client) => `<option value="${client.id}">${client.name}</option>`)
                .join('');

            select.innerHTML = `<option value="all">Todos os clientes</option>${optionsHtml}`;
            const hasPreviousOption = previousValue === 'all' || options.some((client) => client.id === previousValue);
            select.value = hasPreviousOption ? previousValue : 'all';
        }

        function getLoanById(loanId) {
            return installmentsState.loans.find(loan => sameId(loan.id, loanId));
        }

        function getInstallmentPaymentMethod(installment) {
            const ownMethod = normalizePaymentMethod(installment.payment_method, installment.notes);
            if (ownMethod) return ownMethod;
            const loan = getLoanById(installment.loan_id);
            return normalizePaymentMethod(loan?.payment_method);
        }

        function getDueHint(installment, status) {
            if (status === 'Pago') {
                if (!installment.payment_date) return '(paga)';
                return `(paga em ${formatDate(installment.payment_date)})`;
            }

            const days = dueInDays(installment);
            if (!Number.isFinite(days)) return '';
            if (days < 0) return `(há ${Math.abs(days)} dia(s))`;
            if (days === 0) return '(hoje)';
            return `(em ${days} dia(s))`;
        }

        function getStatusBadge(status) {
            if (status === 'Pago') return { className: 'badge badge-success', text: 'Pago' };
            if (status === 'Atrasado') return { className: 'badge badge-danger', text: 'Em atraso' };
            return { className: 'badge badge-neutral', text: 'Em dia' };
        }

        function getInstallmentLabel(installment, loan) {
            const number = Math.max(1, Math.trunc(toNumber(installment.installment_number, 1)));
            const totalFromLoan = Math.max(0, Math.trunc(toNumber(loan?.installments_count, 0)));
            const total = Math.max(number, totalFromLoan);
            return total > 0 ? `${number}/${total}` : `${number}`;
        }

        function getLoanSummary(loan) {
            if (!loan) return 'Sem resumo';
            const principal = formatCurrency(loan.principal_amount);
            const interest = loan.interest_type === 'simples' ? `Simples ${loan.interest_rate}%` : `Composto ${loan.interest_rate}%`;
            return `Principal ${principal} | ${interest}`;
        }

        function updateInstallmentsSummary() {
            const list = installmentsState.installments;
            const now = new Date();
            const currentMonth = now.getMonth();
            const currentYear = now.getFullYear();

            const receivedThisMonthInstallments = list
                .filter(installment => {
                    if (normalizeInstallmentStatus(installment) !== 'Pago') return false;
                    const paymentDate = parseDateValue(installment.payment_date);
                    return paymentDate && paymentDate.getMonth() === currentMonth && paymentDate.getFullYear() === currentYear;
                });
            const pendingInstallments = list.filter(installment => normalizeInstallmentStatus(installment) === 'Pendente');
            const overdueInstallments = list.filter(installment => normalizeInstallmentStatus(installment) === 'Atrasado');

            const receivedThisMonth = receivedThisMonthInstallments
                .reduce((sum, installment) => sum + Number(installment.paid_amount || installment.amount || 0), 0);
            const pendingTotal = pendingInstallments
                .reduce((sum, installment) => sum + Number(installment.amount || 0), 0);
            const overdueTotal = overdueInstallments
                .reduce((sum, installment) => sum + Number(installment.amount || 0), 0);

            const periodValue = document.getElementById('installmentPeriodFilter')?.value || 'all';
            const customStartDate = document.getElementById('customStartDate')?.value || '';
            const customEndDate = document.getElementById('customEndDate')?.value || '';
            const currentBounds = getPeriodBoundsFromFilter(periodValue, customStartDate, customEndDate);
            const comparisonRanges = getInsightComparisonRanges(periodValue, currentBounds);

            const buildMetricComparisons = (metricKey) => {
                const current = getInstallmentMetricInRange(metricKey, list, currentBounds.start, currentBounds.end);
                const previous = getInstallmentMetricInRange(
                    metricKey,
                    list,
                    comparisonRanges.previous?.start,
                    comparisonRanges.previous?.end
                );
                const yearAgo = getInstallmentMetricInRange(
                    metricKey,
                    list,
                    comparisonRanges.yearAgo?.start,
                    comparisonRanges.yearAgo?.end
                );
                const avgValues = (comparisonRanges.avgRanges || [])
                    .map((range) => getInstallmentMetricInRange(metricKey, list, range?.start, range?.end));
                const average3 = avgValues.length
                    ? avgValues.reduce((sum, value) => sum + value, 0) / avgValues.length
                    : 0;

                return { current, previous, average3, yearAgo };
            };

            const receivedComparisons = buildMetricComparisons('received');
            const pendingComparisons = buildMetricComparisons('pending');
            const overdueComparisons = buildMetricComparisons('overdue');

            const receivedPrefix = currentBounds.isMonthly ? 'Mês atual:' : 'Período atual:';
            const pendingPrefix = currentBounds.isMonthly ? 'Em aberto no mês:' : 'Em aberto no período:';
            const overduePrefix = currentBounds.isMonthly ? 'Atrasos no mês:' : 'Atrasos no período:';

            document.getElementById('receivedMonthValue').textContent = formatCurrency(receivedThisMonth);
            document.getElementById('pendingTotalValue').textContent = formatCurrency(pendingTotal);
            document.getElementById('overdueTotalValue').textContent = formatCurrency(overdueTotal);

            document.getElementById('receivedMonthCount').innerHTML = `<i class="fas fa-check-circle kpi-icon mr-1"></i>${receivedThisMonthInstallments.length} parcela(s) paga(s)`;
            document.getElementById('pendingTotalCount').innerHTML = `<i class="fas fa-clock kpi-icon mr-1"></i>${pendingInstallments.length} parcela(s) em aberto`;
            document.getElementById('overdueTotalCount').innerHTML = `<i class="fas fa-triangle-exclamation kpi-icon mr-1"></i>${overdueInstallments.length} parcela(s) em atraso`;

            applyKpiInsight(
                'receivedMonthInsight',
                receivedPrefix,
                buildSmartKpiInsight(receivedComparisons.current, {
                    average3: receivedComparisons.average3,
                    previous: receivedComparisons.previous,
                    yearAgo: receivedComparisons.yearAgo,
                }, { minRobustBase: 50 })
            );
            applyKpiInsight(
                'pendingTotalInsight',
                pendingPrefix,
                buildSmartKpiInsight(pendingComparisons.current, {
                    average3: pendingComparisons.average3,
                    previous: pendingComparisons.previous,
                    yearAgo: pendingComparisons.yearAgo,
                }, { invert: true, minRobustBase: 50 })
            );
            applyKpiInsight(
                'overdueTotalInsight',
                overduePrefix,
                buildSmartKpiInsight(overdueComparisons.current, {
                    average3: overdueComparisons.average3,
                    previous: overdueComparisons.previous,
                    yearAgo: overdueComparisons.yearAgo,
                }, { invert: true, minRobustBase: 50 })
            );

            document.querySelectorAll('[data-kpi-filter]').forEach((button) => {
                const isActive = button.getAttribute('data-kpi-filter') === installmentsState.kpiFilter;
                button.classList.toggle('is-active', isActive);
            });
        }

        function renderInstallmentsTable() {
            const tbody = document.getElementById('installmentsTableBody');
            const mobileList = document.getElementById('installmentsMobileList');
            const tableWrapper = document.getElementById('installmentsTableWrapper');
            const emptyState = document.getElementById('installmentsEmptyState');
            const list = installmentsState.filtered;

            document.getElementById('filteredCount').textContent = String(list.length);
            updateInstallmentsSummary();

            if (installmentsState.isLoading && installmentsState.installments.length === 0) {
                tableWrapper.classList.remove('hidden');
                emptyState.classList.add('hidden');
                tbody.innerHTML = Array.from({ length: 8 }, () => `
                    <tr>
                        <td><div class="skeleton h-3 w-40"></div><div class="skeleton h-3 w-24 mt-2"></div></td>
                        <td><div class="skeleton h-3 w-32"></div><div class="skeleton h-3 w-28 mt-2"></div></td>
                        <td><div class="skeleton h-3 w-12"></div></td>
                        <td><div class="skeleton h-3 w-28"></div><div class="skeleton h-3 w-20 mt-2"></div></td>
                        <td><div class="skeleton h-3 w-20"></div></td>
                        <td><div class="skeleton h-6 w-20"></div></td>
                        <td><div class="skeleton h-8 w-28"></div></td>
                    </tr>
                `).join('');
                if (mobileList) {
                    mobileList.innerHTML = Array.from({ length: 5 }, () => `
                        <div class="rounded-2xl border border-gray-200 bg-slate-50 p-4">
                            <div class="skeleton h-4 w-40"></div>
                            <div class="skeleton h-3 w-24 mt-2"></div>
                            <div class="skeleton h-3 w-32 mt-4"></div>
                            <div class="skeleton h-3 w-28 mt-2"></div>
                            <div class="skeleton h-8 w-32 mt-4"></div>
                        </div>
                    `).join('');
                }
                updatePaginationInfo(0, 0, 0, 1);
                return;
            }

            if (!list.length) {
                tableWrapper.classList.add('hidden');
                emptyState.classList.remove('hidden');
                tbody.innerHTML = '';
                if (mobileList) mobileList.innerHTML = '';
                updatePaginationInfo(0, 0, 0, 1);
                return;
            }

            const pagination = getPaginationMeta(list.length);
            const pageRows = list.slice(pagination.startIndex, pagination.endIndex);

            tableWrapper.classList.remove('hidden');
            emptyState.classList.add('hidden');

            tbody.innerHTML = pageRows.map(installment => {
                const status = normalizeInstallmentStatus(installment);
                const badge = getStatusBadge(status);
                const loan = getLoanById(installment.loan_id);
                const installmentNumber = getInstallmentLabel(installment, loan);
                const phone = getDebtorPhone(installment.debtor_id);
                const dueHint = getDueHint(installment, status);

                return `
                    <tr class="table-row" data-installment-id="${installment.id}">
                        <td>
                            <p class="font-semibold text-slate-800">${getDebtorName(installment.debtor_id)}</p>
                            <p class="text-xs text-gray-500">${phone || 'Sem telefone'}</p>
                        </td>
                        <td>
                            <p class="font-semibold text-slate-700">#${installment.loan_id ?? '-'}</p>
                            <p class="mt-0.5 text-xs text-gray-500">${getLoanSummary(loan)}</p>
                        </td>
                        <td>
                            <p class="font-semibold text-slate-700">${installmentNumber}</p>
                            <p class="mt-0.5 text-xs text-gray-500">Parcela #${installment.installment_number ?? '-'}</p>
                        </td>
                        <td>
                            <p class="font-semibold text-slate-700">${formatDate(installment.due_date)}</p>
                            <p class="text-xs ${status === 'Atrasado' ? 'text-red-600' : 'text-gray-500'}">${dueHint}</p>
                        </td>
                        <td class="font-semibold text-slate-800">${formatCurrency(installment.amount)}</td>
                        <td><span class="${badge.className}">${badge.text}</span></td>
                        <td class="whitespace-nowrap w-[1%] text-right">
                            <div class="flex items-center justify-end gap-1">
                                <button type="button" data-action="view-installment" data-id="${installment.id}" class="action-btn action-btn-view rounded-md p-2 transition-colors duration-150 hover:bg-slate-100" title="Detalhes">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');

            if (mobileList) {
                mobileList.innerHTML = pageRows.map((installment) => {
                    const status = normalizeInstallmentStatus(installment);
                    const badge = getStatusBadge(status);
                    const loan = getLoanById(installment.loan_id);
                    const installmentNumber = getInstallmentLabel(installment, loan);
                    const phone = getDebtorPhone(installment.debtor_id);
                    const dueHint = getDueHint(installment, status);

                    return `
                        <article class="rounded-2xl border border-gray-200 bg-slate-50 p-4 shadow-sm" data-installment-id="${installment.id}">
                            <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0">
                                    <p class="truncate text-base font-semibold text-slate-800">${getDebtorName(installment.debtor_id)}</p>
                                    <p class="text-xs text-gray-500">${phone || 'Sem telefone'}</p>
                                </div>
