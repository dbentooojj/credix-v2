<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credix - Controle de Cobrança</title>
    <%- include('partials/favicon') %>
    <%- include('partials/toast') %>
    <%- include('partials/session-timeout') %>
    <style>
        html, body { background-color: #020617; }
</style>
    <script>
        (function () {
            const root = document.documentElement;
            try {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark') root.classList.add('dark');
                if (savedTheme === 'light') root.classList.remove('dark');
            } catch (error) {}
        })();

        window.tailwind = window.tailwind || {};
        window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        html { font-size: 16px; }
        body { font-family: 'Inter', sans-serif; overflow-x: hidden; }

        .primary-gradient { background: linear-gradient(135deg, #000000 0%, #0f172a 50%, #111827 100%); }
        .premium-header { background: rgba(2, 6, 23, 0.75); border-bottom: 1px solid rgba(148, 163, 184, 0.2); }
        .icon-btn {
            color: #cbd5e1;
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background-color 120ms ease-out, color 120ms ease-out, box-shadow 120ms ease-out;
        }
        .icon-btn:hover { color: #ffffff; background: rgba(59, 130, 246, 0.2); box-shadow: 0 0 0 1px rgba(96, 165, 250, 0.35) inset; }
        .modern-sidebar {
            background: linear-gradient(180deg, rgba(2, 6, 23, 0.9) 0%, rgba(15, 23, 42, 0.85) 100%);
            border-right: 1px solid rgba(148, 163, 184, 0.18);
            transform: translateX(0);
            transition: transform 120ms ease-out;
        }
        .sidebar-item { transition: background-color 120ms ease-out, color 120ms ease-out, box-shadow 120ms ease-out; border-radius: 12px; margin: 4px 0; }
        .sidebar-item:hover { background: rgba(148, 163, 184, 0.12); box-shadow: 0 0 0 1px rgba(148, 163, 184, 0.2) inset; }
        .sidebar-item.active { background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%); box-shadow: 0 0 0 1px rgba(147, 197, 253, 0.5) inset, 0 2px 8px rgba(59, 130, 246, 0.25); }
        .sidebar-item:focus-visible, .icon-btn:focus-visible { outline: 2px solid rgba(96, 165, 250, 0.7); outline-offset: 2px; }
        .glass-card { background: #f8fafc; border: 1px solid #e2e8f0; box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06); }
        .page-title { color: #ffffff; }
        .muted-on-dark { color: #cbd5e1; }
        .kpi-card {
            background: #e3e9f2;
            border-radius: 16px;
            border: 1px solid #c6d0df;
            min-height: 126px;
            padding: 18px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            cursor: pointer;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
            transition: background-color 120ms ease-out, border-color 120ms ease-out;
        }
        .kpi-card.is-active {
            background: #d3ddea;
            border-color: #94a3b8;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
        }
        .kpi-label {
            color: #64748b;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .kpi-value {
            color: #0f172a;
            font-size: 1.375rem;
            line-height: 1.05;
            font-weight: 700;
            margin-top: 10px;
        }
        .kpi-note {
            font-size: 0.82rem;
            font-weight: 500;
            color: #64748b;
            margin-top: 8px;
        }
        .kpi-insight {
            margin-top: 6px;
            font-size: 0.76rem;
            font-weight: 600;
            color: #64748b;
            line-height: 1.3;
        }
        .kpi-insight-positive { color: #047857; }
        .kpi-insight-negative { color: #b91c1c; }
        .kpi-info { color: #94a3b8; cursor: help; }
        .kpi-tone-paid .kpi-value, .kpi-tone-paid .kpi-icon { color: #047857; }
        .kpi-tone-pending .kpi-value, .kpi-tone-pending .kpi-icon { color: #b45309; }
        .kpi-tone-overdue .kpi-value, .kpi-tone-overdue .kpi-icon { color: #b91c1c; }
        .kpi-tone-due-soon .kpi-value, .kpi-tone-due-soon .kpi-icon { color: #1d4ed8; }
        .filter-control { background: #f8fafc; border: 1px solid #d1d5db; border-radius: 10px; padding: 10px 12px; color: #111827; width: 100%; }
        .filter-control:focus {
            outline: none;
            border-color: #94a3b8;
            box-shadow: 0 0 0 2px rgba(148, 163, 184, 0.25);
        }
        .table-shell { overflow: auto; border-radius: 14px; border: 1px solid #e2e8f0; background: #f8fafc; }
        .table-shell table { width: 100%; border-collapse: collapse; min-width: 1020px; }
        .table-shell th {
            text-align: left;
            background: #f8fafc;
            color: #64748b;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 12px 14px;
            border-bottom: 1px solid #e2e8f0;
        }
        .table-shell td { padding: 16px 14px; border-top: 1px solid #f1f5f9; color: #1f2937; vertical-align: top; }
        .table-row { transition: background-color 120ms ease-out; cursor: pointer; }
        .table-row:hover { background: #f8fafc; }
        .badge { display: inline-flex; align-items: center; padding: 2px 10px; border-radius: 9999px; font-size: 12px; font-weight: 600; white-space: nowrap; }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-danger { background: #fee2e2; color: #991b1b; }
        .badge-neutral { background: #e2e8f0; color: #334155; }
        .action-btn {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid transparent;
            transition: background-color 120ms ease-out, border-color 120ms ease-out;
        }
        .action-btn-view { color: #2563eb; }
        .action-btn-view:hover {
            background: #f1f5f9;
            border-color: #e2e8f0;
        }
        .table-action {
            height: 30px;
            min-width: 30px;
            border-radius: 8px;
            padding: 0 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid transparent;
            font-size: 12px;
            font-weight: 600;
            transition: background-color 120ms ease-out, border-color 120ms ease-out;
        }
        .table-action:hover { background: #f1f5f9; border-color: #e2e8f0; }
        .table-action[disabled] { opacity: 0.45; cursor: not-allowed; }
        .skeleton {
            border-radius: 8px;
            background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
            background-size: 240px 100%;
            animation: skeleton 1.2s ease-in-out infinite;
        }
        @keyframes skeleton {
            0% { background-position: -240px 0; }
            100% { background-position: 240px 0; }
        }
        .modal-backdrop { backdrop-filter: blur(4px); background: rgba(2, 6, 23, 0.72); }
        .modal-panel { background: #f8fafc; border-radius: 14px; border: 1px solid #e2e8f0; box-shadow: 0 18px 40px rgba(2, 6, 23, 0.4); }
        .empty-state { border: 1px dashed rgba(148, 163, 184, 0.4); background: rgba(248, 250, 252, 0.7); border-radius: 14px; }
        main { transition: none; }
        body.sidebar-collapsed .modern-sidebar { transform: translateX(-100%); }
        body.sidebar-collapsed main { margin-left: 0 !important; }
        @media (max-width: 1024px) {
            .modern-sidebar { transform: translateX(-100%); }
            .modern-sidebar.mobile-open { transform: translateX(0) !important; }
            main { margin-left: 0 !important; }
            main { width: 100% !important; flex: 1 1 100% !important; }
        }
        @media (max-width: 640px) {
            .kpi-value { font-size: 1.3rem; }

            .icon-btn {
                width: 36px;
                height: 36px;
                border-radius: 10px;
            }

            .icon-btn i {
                font-size: 1rem !important;
            }

            .header-user-chevron { display: none; }

            #userMenuBtn {
                max-width: min(46vw, 11rem);
                justify-content: flex-end;
            }

            .header-user-name {
                display: inline-block;
                max-width: 100%;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }
        }
        @media (max-width: 639px) {
            #installmentsTableWrapper { display: none !important; }
        }
        @media (min-width: 640px) {
            #installmentsMobileList { display: none !important; }
        }
        .dark .glass-card,
        .dark .kpi-card,
        .dark .modal-panel {
            background: rgba(15, 23, 42, 0.82);
            border: 1px solid rgba(148, 163, 184, 0.2);
            color: #e2e8f0;
        }
        .dark .kpi-card {
            box-shadow: 0 1px 2px rgba(2, 6, 23, 0.45);
        }
.dark .kpi-card.is-active {
            border-color: rgba(148, 163, 184, 0.45);
            box-shadow: 0 1px 2px rgba(2, 6, 23, 0.45);
        }
        .dark .kpi-label,
        .dark .kpi-note,
        .dark .kpi-info { color: #cbd5e1 !important; }
        .dark .kpi-value { color: #f8fafc !important; }
        .dark .kpi-insight { color: #cbd5e1 !important; }
        .dark .kpi-insight-positive { color: #86efac !important; }
        .dark .kpi-insight-negative { color: #fca5a5 !important; }
        .dark .filter-control, .dark .table-shell, .dark .table-shell th, .dark .table-shell td { background: rgba(15, 23, 42, 0.7); color: #e2e8f0; border-color: rgba(148, 163, 184, 0.22); }
        .dark .table-shell th { background: rgba(30, 41, 59, 0.95); color: #cbd5e1; }
        .dark .action-btn-view { color: #93c5fd; }
        .dark .action-btn-view:hover { background: rgba(51, 65, 85, 0.9); border-color: rgba(148, 163, 184, 0.4); }
        .dark .text-gray-800 { color: #f8fafc !important; }
        .dark .text-gray-700 { color: #e2e8f0 !important; }
        .dark .text-gray-600 { color: #cbd5e1 !important; }
        .dark .text-gray-500 { color: #94a3b8 !important; }
        .dark .border-gray-100, .dark .border-gray-200, .dark .border-gray-300 { border-color: rgba(148, 163, 184, 0.22) !important; }
        .dark .bg-white { background: rgba(15, 23, 42, 0.65) !important; }
        .dark .bg-gray-50 { background: rgba(15, 23, 42, 0.8) !important; }
        .dark .empty-state { background: rgba(15, 23, 42, 0.45); border-color: rgba(148, 163, 184, 0.35); }
        .dark .modal-panel { background: rgba(15, 23, 42, 0.98); border-color: rgba(148, 163, 184, 0.3); color: #e2e8f0; }
        .dark textarea, .dark select, .dark input { color: #e2e8f0; }
        /* Premium DS v1 - light skin */
        :root {
            --premium-bg: #121b2a;
            --premium-sidebar: #13203a;
            --premium-card: #E3E9F2;
            --premium-positive: #16A34A;
            --premium-negative: #DC2626;
            --premium-accent: #1E40AF;
            --premium-radius: 16px;
            --premium-shadow-soft: 0 4px 12px rgba(2, 12, 27, 0.08);
        }

        html, body {
            background-color: var(--premium-bg);
        }

        .primary-gradient {
            background:
                radial-gradient(900px 320px at -10% -10%, rgba(30, 64, 175, 0.18), transparent 60%),
                var(--premium-bg);
        }

        .premium-header {
            background: rgba(18, 27, 42, 0.88);
            border-bottom: 1px solid rgba(148, 163, 184, 0.24);
            backdrop-filter: blur(8px);
        }

        .modern-sidebar {
            background: linear-gradient(180deg, #15253f 0%, var(--premium-sidebar) 100%);
            border-right: 1px solid rgba(148, 163, 184, 0.2);
        }

        .sidebar-item.active {
            background: linear-gradient(135deg, #1B3D8F 0%, #234EA8 100%);
        }

        .glass-card,
        .kpi-card,
        .summary-link,
        .modal-panel,
        .modal-content {
            background: var(--premium-card);
            border-radius: var(--premium-radius);
            border: 1px solid rgba(148, 163, 184, 0.28);
            box-shadow: var(--premium-shadow-soft);
        }

        .rounded-2xl {
            border-radius: var(--premium-radius);
        }

        .badge,
        .status-pill {
            border-radius: 999px;
            font-weight: 700;
            border: 1px solid transparent;
        }

        .badge-success,
        .status-green {
            background: rgba(22, 163, 74, 0.14);
            color: var(--premium-positive);
            border-color: rgba(22, 163, 74, 0.34);
        }

        .badge-danger,
        .status-red {
            background: rgba(220, 38, 38, 0.12);
            color: var(--premium-negative);
            border-color: rgba(220, 38, 38, 0.36);
        }

        .badge-warn,
        .status-yellow {
            background: rgba(245, 158, 11, 0.16);
            color: #b45309;
            border-color: rgba(245, 158, 11, 0.35);
        }

        .notification-badge,
        .btn-primary,
        .action-primary {
            background: var(--premium-accent);
        }
        html:not(.dark) main .bg-white { background-color: #e3e9f2 !important; }
        html:not(.dark) main .bg-slate-50 { background-color: #d9e1ec !important; }
        html:not(.dark) main .border-gray-200,
        html:not(.dark) main .border-gray-300,
        html:not(.dark) main .border-slate-200,
        html:not(.dark) main .border-slate-300 { border-color: #c6d0df !important; }
        html:not(.dark) main .hover\\:bg-gray-50:hover,
        html:not(.dark) main .hover\\:bg-slate-50:hover { background-color: #d3ddea !important; }

        .installment-modal {
            background:
                radial-gradient(120% 130% at 90% -10%, rgba(56, 189, 248, 0.08), transparent 55%),
                linear-gradient(150deg, rgba(7, 17, 34, 0.98) 0%, rgba(10, 23, 45, 0.98) 100%);
            border: 1px solid rgba(71, 85, 105, 0.55);
            box-shadow: 0 24px 60px rgba(2, 6, 23, 0.62);
        }

        .installment-modal-header {
            border-bottom: 1px solid rgba(71, 85, 105, 0.38);
            padding-bottom: 14px;
            margin-bottom: 16px;
        }

        .installment-modal-title {
            color: #f8fafc;
            font-size: 1.42rem;
            line-height: 1.15;
            font-weight: 700;
            letter-spacing: -0.01em;
        }

        .installment-close-btn {
            color: #94a3b8;
            border: 1px solid rgba(71, 85, 105, 0.45);
            background: rgba(15, 23, 42, 0.66);
            transition: background-color 120ms ease-out, color 120ms ease-out, border-color 120ms ease-out;
        }

        .installment-close-btn:hover {
            color: #f8fafc;
            border-color: rgba(56, 189, 248, 0.42);
            background: rgba(15, 23, 42, 0.94);
        }

        .installment-surface {
            border-radius: 14px;
            border: 1px solid rgba(71, 85, 105, 0.44);
            background: rgba(15, 23, 42, 0.68);
            padding: 14px;
        }

        .installment-summary-top {
            border-radius: 14px;
            border: 1px solid rgba(71, 85, 105, 0.52);
            background:
                linear-gradient(135deg, rgba(15, 23, 42, 0.76) 0%, rgba(15, 23, 42, 0.58) 100%);
            padding: 14px 16px;
        }

        .installment-kicker {
            font-size: 0.72rem;
            line-height: 1;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            font-weight: 700;
            color: #93c5fd;
        }

        .installment-summary-title {
            margin-top: 8px;
            font-size: 1.62rem;
            line-height: 1.1;
            letter-spacing: -0.02em;
            font-weight: 700;
            color: #f8fafc;
        }

        .installment-summary-subtitle {
            margin-top: 6px;
            font-size: 0.95rem;
            color: #cbd5e1;
        }

        .installment-value-label {
            font-size: 0.74rem;
            line-height: 1;
            letter-spacing: 0.11em;
            text-transform: uppercase;
            font-weight: 700;
            color: #93c5fd;
        }

        .installment-value-main {
            margin-top: 8px;
            font-size: 1.7rem;
            line-height: 1.1;
            letter-spacing: -0.02em;
            font-weight: 700;
            color: #f8fafc;
        }

        .installment-value-main-compact {
            margin-top: 8px;
            font-size: 1.32rem;
            line-height: 1.2;
            font-weight: 700;
            color: #e2e8f0;
        }

        .installment-value-meta {
            margin-top: 5px;
            font-size: 0.88rem;
            color: #94a3b8;
        }

        .installment-value-meta-warning {
            color: #fca5a5;
            font-weight: 600;
        }

        .installment-history-text {
            margin-top: 8px;
            font-size: 1rem;
            line-height: 1.4;
            color: #e2e8f0;
        }

        .installment-history-note {
            margin-top: 6px;
            font-size: 0.88rem;
            color: #94a3b8;
        }

        .installment-context-line {
            margin-top: 8px;
            font-size: 1rem;
            font-weight: 500;
            color: #e2e8f0;
        }

        .installment-alert {
            border-radius: 12px;
            border: 1px solid rgba(251, 191, 36, 0.44);
            background: rgba(120, 53, 15, 0.24);
            color: #fde68a;
            font-size: 0.9rem;
            line-height: 1.45;
            padding: 12px 14px;
        }

        .installment-alert-danger {
            border-color: rgba(248, 113, 113, 0.5);
            background: rgba(127, 29, 29, 0.24);
            color: #fecaca;
        }

        .installment-btn-row {
            padding-top: 4px;
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 10px;
        }

        .installment-btn {
            min-height: 40px;
            border-radius: 12px;
            border: 1px solid transparent;
            padding: 0.55rem 1rem;
            font-size: 0.9rem;
            font-weight: 700;
            transition: background-color 120ms ease-out, border-color 120ms ease-out, color 120ms ease-out;
        }

        .installment-btn-primary {
            background: linear-gradient(135deg, #0891b2 0%, #06b6d4 100%);
            color: #e0f2fe;
            border-color: rgba(34, 211, 238, 0.6);
        }

        .installment-btn-primary:hover {
            background: linear-gradient(135deg, #0e7490 0%, #0891b2 100%);
            color: #ecfeff;
        }

        .installment-btn-success {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
            color: #ecfdf5;
            border-color: rgba(52, 211, 153, 0.56);
        }

        .installment-btn-success:hover {
            background: linear-gradient(135deg, #047857 0%, #059669 100%);
        }

        .installment-btn-secondary {
            border-color: rgba(148, 163, 184, 0.42);
            background: rgba(30, 41, 59, 0.6);
            color: #dbeafe;
        }

        .installment-btn-secondary:hover {
            border-color: rgba(125, 211, 252, 0.42);
            background: rgba(30, 41, 59, 0.88);
            color: #f8fafc;
        }

        .installment-btn-danger {
            border-color: rgba(248, 113, 113, 0.58);
            background: rgba(127, 29, 29, 0.36);
            color: #fecaca;
        }

        .installment-btn-danger:hover {
            background: rgba(127, 29, 29, 0.58);
            color: #fee2e2;
        }

        .installment-btn:disabled {
            opacity: 0.62;
            cursor: not-allowed;
        }

        .installment-field-label {
            display: block;
            margin-bottom: 6px;
            font-size: 0.84rem;
            line-height: 1;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            font-weight: 700;
            color: #bfdbfe;
        }

        .installment-modal .filter-control {
            background: rgba(15, 23, 42, 0.62);
            border-color: rgba(100, 116, 139, 0.54);
            color: #e2e8f0;
        }

        .installment-modal .filter-control:focus {
            border-color: rgba(56, 189, 248, 0.66);
            box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.18);
        }

        .installment-modal .filter-control::placeholder {
            color: #94a3b8;
        }

        .installment-modal textarea.filter-control {
            min-height: 90px;
            resize: vertical;
        }

        .installment-badge-wrap {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        @media (max-width: 640px) {
            .installment-modal-title {
                font-size: 1.26rem;
            }

            .installment-summary-title {
                font-size: 1.34rem;
            }

            .installment-value-main {
                font-size: 1.4rem;
            }

            .installment-btn-row {
                gap: 8px;
            }

            .installment-btn {
                width: 100%;
            }
        }
        </style>
