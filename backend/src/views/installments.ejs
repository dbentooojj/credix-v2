        function handleInstallmentsListClick(event) {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const actionBtn = target.closest('button[data-action]');
            const row = target.closest('[data-installment-id]');

            if (actionBtn) {
                event.stopPropagation();
                const action = actionBtn.getAttribute('data-action');
                const installmentId = actionBtn.getAttribute('data-id');

                if (action === 'view-installment') {
                    openInstallmentDetails(installmentId);
                    return;
                }
                return;
            }

            if (!row) return;
            openInstallmentDetails(row.getAttribute('data-installment-id'));
        }

        const installmentsTableBody = document.getElementById('installmentsTableBody');
        const installmentsMobileList = document.getElementById('installmentsMobileList');
        if (installmentsTableBody) installmentsTableBody.addEventListener('click', handleInstallmentsListClick);
        if (installmentsMobileList) installmentsMobileList.addEventListener('click', handleInstallmentsListClick);

        function handleInstallmentModalAction(event) {
            const target = event.target;
            if (!(target instanceof Element)) return;
            const actionBtn = target.closest('[data-action]');
            if (!actionBtn) return;

            const action = actionBtn.getAttribute('data-action');
            if (!action) return;
            event.preventDefault();

            if (action === 'modal-go-payment') {
                setInstallmentModalMode('payment');
                return;
            }

            if (action === 'modal-go-refund') {
                setInstallmentModalMode('refund');
                return;
            }

            if (action === 'modal-go-delete') {
                setInstallmentModalMode('confirmDelete');
                return;
            }

            if (action === 'modal-back-details') {
                setInstallmentModalMode('details');
                return;
            }

            if (action === 'modal-close') {
                closeInstallmentModal();
            }
        }

        if (installmentModalContent) {
            installmentModalContent.addEventListener('click', handleInstallmentModalAction);

            installmentModalContent.addEventListener('submit', async function(event) {
                const target = event.target;
                if (!(target instanceof HTMLFormElement)) return;
                event.preventDefault();

                if (target.id === 'installmentPaymentForm') {
                    await submitInstallmentPaymentFromModal();
                    return;
                }

                if (target.id === 'installmentRefundForm') {
                    await submitInstallmentRefundFromModal();
                    return;
                }

                if (target.id === 'installmentDeleteForm') {
                    await submitInstallmentDeleteFromModal();
                }
            });
        }

        if (installmentModalFooter) {
            installmentModalFooter.addEventListener('click', handleInstallmentModalAction);
        }

        document.getElementById('prevPageBtn').addEventListener('click', function () {
            if (installmentsState.currentPage <= 1) return;
            installmentsState.currentPage -= 1;
            renderInstallmentsTable();
        });

        document.getElementById('nextPageBtn').addEventListener('click', function () {
            const totalPages = Math.max(1, Math.ceil(installmentsState.filtered.length / installmentsState.pageSize));
            if (installmentsState.currentPage >= totalPages) return;
            installmentsState.currentPage += 1;
            renderInstallmentsTable();
        });

        if (notificationModal) {
            notificationModal.addEventListener('click', function(event) {
                if (event.target === notificationModal) closeModal(notificationModal);
            });
        }

        if (installmentModal) {
            installmentModal.addEventListener('click', function(event) {
                if (event.target === installmentModal) closeInstallmentModal();
            });
        }

        if (closeInstallmentModalBtn) {
            closeInstallmentModalBtn.addEventListener('click', function() {
                closeInstallmentModal();
            });
        }

        document.addEventListener('keydown', function(event) {
            trapFocusWithinInstallmentModal(event);
            if (event.key !== 'Escape') return;
            if (isModalVisible(notificationModal)) closeModal(notificationModal);
            if (installmentModalState.isOpen) closeInstallmentModal();
        });

        document.addEventListener('DOMContentLoaded', function() {
            handleTemplateChange();
            applyQueryFiltersToControls();
            toggleKpiLoading(true);
            renderInstallmentsTable();
            loadInstallmentsData();
        });
    </script>
</body>
</html>







