                                    <p class="text-[11px] uppercase tracking-wide text-gray-500">Empréstimo</p>
                                    <p class="font-semibold text-slate-700">#${installment.loan_id ?? '-'}</p>
                                </div>
                                <div>
                                    <p class="text-[11px] uppercase tracking-wide text-gray-500">Parcela</p>
                                    <p class="font-semibold text-slate-700">${installmentNumber}</p>
                                </div>
                                <div class="col-span-2">
                                    <p class="text-[11px] uppercase tracking-wide text-gray-500">Vencimento</p>
                                    <p class="font-semibold ${status === 'Atrasado' ? 'text-red-600' : 'text-slate-700'}">${formatDate(installment.due_date)} <span class="${status === 'Atrasado' ? 'text-red-600' : 'text-gray-500'}">${dueHint}</span></p>
                                </div>
                                <div class="col-span-2">
                                    <p class="text-[11px] uppercase tracking-wide text-gray-500">Valor</p>
                                    <p class="text-lg font-bold text-slate-800">${formatCurrency(installment.amount)}</p>
                                </div>
                                <div class="col-span-2">
                                    <p class="text-[11px] uppercase tracking-wide text-gray-500">Resumo</p>
                                    <p class="text-sm text-gray-600">${getLoanSummary(loan)}</p>
                                </div>
                            </div>
                            <div class="mt-3 flex flex-wrap items-center justify-end gap-2">
                                <button type="button" data-action="view-installment" data-id="${installment.id}" class="table-action border border-slate-300 px-2 text-slate-700 hover:bg-slate-100" title="Mais detalhes">
                                    Mais detalhes
                                </button>
                            </div>
                        </article>
                    `;
                }).join('');
            }

            updatePaginationInfo(list.length, pagination.startIndex, pagination.endIndex, pagination.totalPages);
        }

        function getPaginationMeta(totalItems) {
            const totalPages = Math.max(1, Math.ceil(totalItems / installmentsState.pageSize));
            if (installmentsState.currentPage > totalPages) installmentsState.currentPage = totalPages;
            if (installmentsState.currentPage < 1) installmentsState.currentPage = 1;

            const startIndex = totalItems === 0 ? 0 : (installmentsState.currentPage - 1) * installmentsState.pageSize;
            const endIndex = totalItems === 0 ? 0 : Math.min(startIndex + installmentsState.pageSize, totalItems);
            return { totalPages, startIndex, endIndex };
        }

        function updatePaginationInfo(totalItems, startIndex, endIndex, totalPages) {
            const showingStart = totalItems === 0 ? 0 : startIndex + 1;
            const showingEnd = endIndex;
            document.getElementById('showingStart').textContent = String(showingStart);
            document.getElementById('showingEnd').textContent = String(showingEnd);
            document.getElementById('totalResults').textContent = String(totalItems);
            document.getElementById('pageIndicator').textContent = `Página ${installmentsState.currentPage} de ${totalPages}`;

            const prevBtn = document.getElementById('prevPageBtn');
            const nextBtn = document.getElementById('nextPageBtn');
            prevBtn.disabled = installmentsState.currentPage <= 1;
            nextBtn.disabled = installmentsState.currentPage >= totalPages;
            prevBtn.classList.toggle('opacity-50', prevBtn.disabled);
            nextBtn.classList.toggle('opacity-50', nextBtn.disabled);
        }

        function applyInstallmentsFilters(options = {}) {
            const { resetPage = true, source = 'controls' } = options;

            if (source === 'controls') {
                installmentsState.kpiFilter = '';
            }

            const searchValue = document.getElementById('installmentSearch').value.trim().toLowerCase();
            const statusValue = document.getElementById('installmentStatusFilter').value;
            const clientValue = document.getElementById('installmentClientFilter')?.value || 'all';
            const periodValue = document.getElementById('installmentPeriodFilter').value;
            const paymentMethodValue = document.getElementById('installmentPaymentMethodFilter').value;
            const customStartDate = document.getElementById('customStartDate')?.value || '';
            const customEndDate = document.getElementById('customEndDate')?.value || '';

            installmentsState.filtered = installmentsState.installments.filter((installment) => {
                const status = normalizeInstallmentStatus(installment);
                const dueDate = startOfDay(installment.due_date);

                if (statusValue !== 'Todos' && status !== statusValue) return false;
                if (clientValue !== 'all' && !sameId(installment.debtor_id, clientValue)) return false;

                if (installmentsState.kpiFilter === 'paid_month') {
                    if (status !== 'Pago') return false;
                    const paymentDate = parseDateValue(installment.payment_date);
                    const now = new Date();
                    if (!paymentDate || paymentDate.getMonth() !== now.getMonth() || paymentDate.getFullYear() !== now.getFullYear()) return false;
                } else if (installmentsState.kpiFilter === 'pending_total') {
                    if (status !== 'Pendente') return false;
                } else if (installmentsState.kpiFilter === 'overdue_total') {
                    if (status !== 'Atrasado') return false;
                }

                if (periodValue === 'today') {
                    const days = dueInDays(installment);
                    if (!Number.isFinite(days) || days !== 0) return false;
                } else if (periodValue === 'next7') {
                    const days = dueInDays(installment);
                    if (!Number.isFinite(days) || days < 0 || days > 7) return false;
                } else if (periodValue === 'month_current') {
                    const today = startOfDay(new Date());
                    if (!today || !dueDate || dueDate.getMonth() !== today.getMonth() || dueDate.getFullYear() !== today.getFullYear()) return false;
                } else if (periodValue === 'last30') {
                    const today = startOfDay(new Date());
                    if (!today || !dueDate) return false;
                    const start = new Date(today.getTime());
                    start.setDate(start.getDate() - 29);
                    if (dueDate < start || dueDate > today) return false;
                } else if (periodValue === 'custom') {
                    const start = startOfDay(customStartDate);
                    const end = startOfDay(customEndDate);
                    if (start && end && (!dueDate || dueDate < start || dueDate > end)) return false;
                }

                if (paymentMethodValue !== 'Todas') {
                    const paymentMethod = getInstallmentPaymentMethod(installment);
                    if (paymentMethod !== paymentMethodValue) return false;
                }

                if (!searchValue) return true;

                const debtorName = getDebtorName(installment.debtor_id).toLowerCase();
                const phone = getDebtorPhone(installment.debtor_id).toLowerCase();
                const loanId = String(installment.loan_id ?? '').toLowerCase();
                const number = String(installment.installment_number ?? installment.number ?? '').toLowerCase();
                const installmentId = String(installment.id ?? '').toLowerCase();

                return debtorName.includes(searchValue)
                    || phone.includes(searchValue)
                    || loanId.includes(searchValue)
                    || number.includes(searchValue)
                    || installmentId.includes(searchValue);
            });

            installmentsState.filtered.sort((a, b) => {
                const statusA = normalizeInstallmentStatus(a);
                const statusB = normalizeInstallmentStatus(b);
                const rankA = statusA === 'Atrasado' ? 0 : statusA === 'Pendente' ? 1 : 2;
                const rankB = statusB === 'Atrasado' ? 0 : statusB === 'Pendente' ? 1 : 2;
                if (rankA !== rankB) return rankA - rankB;

                const daysA = dueInDays(a);
                const daysB = dueInDays(b);
                const safeA = Number.isFinite(daysA) ? daysA : 999999;
                const safeB = Number.isFinite(daysB) ? daysB : 999999;
                if (safeA !== safeB) return safeA - safeB;

                return toNumber(a.id) - toNumber(b.id);
            });

            if (resetPage) installmentsState.currentPage = 1;
            renderInstallmentsTable();
        }
        function normalizePhoneForWhatsApp(phoneRaw) {
            const digits = String(phoneRaw || '').replace(/\D/g, '');
            if (!digits) return '';
            return digits.length <= 11 ? `55${digits}` : digits;
        }

        function buildBatchWhatsAppMessage(baseMessage, installments) {
            const message = String(baseMessage || '').trim();
            if (!installments.length) return message;

            const refs = installments
                .slice(0, 3)
                .map(item => `#${item.installment_number ?? item.number ?? '-'} (${formatDate(item.due_date)})`);

            const extraCount = installments.length - refs.length;
            const details = extraCount > 0
                ? `${refs.join(', ')} e mais ${extraCount}`
                : refs.join(', ');

            return `${message}\n\nParcelas: ${details}`;
        }

        function getNotificationTargets(template) {
            const list = installmentsState.filtered.filter(installment => normalizeInstallmentStatus(installment) !== 'Pago');
            if (template === 'vencimento_hoje') {
                return list.filter(installment => dueInDays(installment) === 0);
            }
            if (template === 'vencimento_proximo') {
                return list.filter(installment => {
                    const days = dueInDays(installment);
                    return Number.isFinite(days) && days > 0 && days <= 3;
                });
            }
            if (template === 'atraso') {
                return list.filter(installment => normalizeInstallmentStatus(installment) === 'Atrasado');
            }
            return list;
        }

        function getTemplateText(template) {
            if (template === 'vencimento_hoje') {
                return 'Olá! Passando para lembrar que sua parcela vence hoje. Caso já tenha realizado o pagamento, desconsidere esta mensagem.';
            }
            if (template === 'atraso') {
                return 'Olá! Identificamos uma parcela em atraso. Entre em contato para regularização e evitar novos encargos.';
            }
            if (template === 'personalizada') {
                return 'Digite aqui sua mensagem personalizada.';
            }
            return 'Olá! Sua parcela vence nos próximos dias. Se precisar de suporte, estou à disposição.';
        }

        function handleTemplateChange() {
            const template = document.getElementById('messageTemplate').value;
            document.getElementById('customMessage').value = getTemplateText(template);
        }
        async function sendBatchNotifications() {
            const template = document.getElementById('messageTemplate').value;
            const message = document.getElementById('customMessage').value.trim();
            const targets = getNotificationTargets(template);

            if (!message) {
                showMessage('Preencha a mensagem da notificacao.', 'error');
                return;
            }

            if (!targets.length) {
                showMessage('Nenhuma parcela se encaixa no filtro de notificacao.', 'error');
                return;
            }

            const groupedByDebtor = new Map();
            targets.forEach((installment) => {
                const debtorKey = String(installment.debtor_id ?? '');
                if (!debtorKey) return;

                if (!groupedByDebtor.has(debtorKey)) {
                    groupedByDebtor.set(debtorKey, []);
                }

                groupedByDebtor.get(debtorKey).push(installment);
            });

            let withoutPhone = 0;
            const recipients = [];

            groupedByDebtor.forEach((debtorInstallments, debtorKey) => {
                const debtorId = debtorInstallments[0]?.debtor_id ?? debtorKey;
                const phone = normalizePhoneForWhatsApp(getDebtorPhone(debtorId));
                if (!phone) {
                    withoutPhone += 1;
                    return;
                }

                const sortedInstallments = [...debtorInstallments].sort((a, b) => {
                    const dueA = startOfDay(a.due_date);
                    const dueB = startOfDay(b.due_date);
                    if (!dueA && !dueB) return 0;
                    if (!dueA) return 1;
                    if (!dueB) return -1;
                    return dueA - dueB;
                });

                const debtorIdNumber = Number(debtorId);
                const recipient = {
                    phone,
                    message: buildBatchWhatsAppMessage(message, sortedInstallments),
                    installmentIds: sortedInstallments.map((item) => Number(item.id)).filter(Number.isFinite),
                };

                if (Number.isFinite(debtorIdNumber) && debtorIdNumber > 0) {
                    recipient.debtorId = debtorIdNumber;
                }

                recipients.push(recipient);
            });

            if (!recipients.length) {
                showMessage('Nenhum cliente com telefone valido para notificacao.', 'error');
                return;
            }

            let payload = null;
            try {
                const response = await fetch('/api/notifications/whatsapp/batch', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ recipients }),
                });

                payload = await response.json().catch(() => null);

                if (!response.ok) {
                    const apiMessage = payload?.message || 'Falha ao enviar notificacoes via WhatsApp.';
                    showMessage(apiMessage, 'error');
                    return;
                }
            } catch (error) {
                console.error('Erro ao enviar notificacoes:', error);
                showMessage('Erro de conexao ao enviar notificacoes.', 'error');
                return;
            }

            closeModal(notificationModal);

            const sent = Number(payload?.summary?.sent ?? 0);
            const failed = Number(payload?.summary?.failed ?? 0);

            const summary = [`${sent} enviada(s)`];
            if (failed > 0) summary.push(`${failed} falha(s)`);
            if (withoutPhone > 0) summary.push(`${withoutPhone} sem telefone`);

            if (sent === 0) {
                showMessage(`Nenhuma mensagem enviada. Resumo: ${summary.join(' | ')}.`, 'error');
                return;
            }

            showMessage(`Notificacoes enviadas: ${summary.join(' | ')}.`, 'success');
        }

        function setRefreshingState(isRefreshing) {
            document.querySelectorAll('[data-refresh-control]').forEach((button) => {
                const icon = button?.querySelector('i');
                if (!button || !icon) return;
                button.disabled = isRefreshing;
                button.classList.toggle('opacity-70', isRefreshing);
                icon.classList.toggle('fa-spin', isRefreshing);
            });
        }

        function toggleKpiLoading(show) {
            const skeleton = document.getElementById('kpiSkeletonGrid');
            const kpiGrid = document.getElementById('kpiGrid');
            if (!skeleton || !kpiGrid) return;
            skeleton.classList.toggle('hidden', !show);
            kpiGrid.classList.toggle('hidden', show);
        }

        async function loadInstallmentsData(options = {}) {
            const { silent = false, preservePage = false } = options;
            if (!silent && installmentsState.installments.length === 0) {
                installmentsState.isLoading = true;
                toggleKpiLoading(true);
                renderInstallmentsTable();
            }

            setRefreshingState(true);
            try {
                const [installments, debtors, loans] = await Promise.all([
                    fetchTableData('installments'),
                    fetchTableData('debtors'),
                    fetchTableData('loans')
                ]);

                installmentsState.installments = (Array.isArray(installments) ? installments : []).map(normalizeInstallmentRow);
                installmentsState.debtors = Array.isArray(debtors) ? debtors : [];
                installmentsState.loans = (Array.isArray(loans) ? loans : []).map(normalizeLoanRow);
                populateInstallmentClientFilter();
                if (!preservePage) installmentsState.currentPage = 1;

                installmentsState.isLoading = false;
                toggleKpiLoading(false);
                applyInstallmentsFilters({ resetPage: !preservePage, source: 'internal' });

                const now = new Date();
                document.getElementById('lastUpdatedAt').textContent = now.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
            } catch (error) {
                console.error('Erro ao carregar parcelas:', error);
                installmentsState.isLoading = false;
                toggleKpiLoading(false);
                showMessage('Erro ao carregar parcelas. Tente novamente.', 'error');
            } finally {
                setRefreshingState(false);
            }
        }

        function clearInstallmentFilters() {
            document.getElementById('installmentSearch').value = '';
            document.getElementById('installmentStatusFilter').value = 'Todos';
            document.getElementById('installmentClientFilter').value = 'all';
            document.getElementById('installmentPeriodFilter').value = 'all';
            document.getElementById('installmentPaymentMethodFilter').value = 'Todas';
            document.getElementById('customStartDate').value = '';
            document.getElementById('customEndDate').value = '';
            installmentsState.kpiFilter = '';
            installmentsState.currentPage = 1;
            updateCustomRangeVisibility();
            applyInstallmentsFilters({ resetPage: true, source: 'internal' });
        }

        function applyKpiFilter(filterKey) {
            if (installmentsState.kpiFilter === filterKey) {
                clearInstallmentFilters();
                return;
            }

            installmentsState.kpiFilter = filterKey;

            if (filterKey === 'paid_month') {
                document.getElementById('installmentStatusFilter').value = 'Pago';
                document.getElementById('installmentPeriodFilter').value = 'month_current';
            } else if (filterKey === 'pending_total') {
                document.getElementById('installmentStatusFilter').value = 'Pendente';
                document.getElementById('installmentPeriodFilter').value = 'all';
            } else if (filterKey === 'overdue_total') {
                document.getElementById('installmentStatusFilter').value = 'Atrasado';
                document.getElementById('installmentPeriodFilter').value = 'all';
            }

            updateCustomRangeVisibility();
            applyInstallmentsFilters({ resetPage: true, source: 'kpi' });
        }
        function setActiveSidebarItem(targetHref) {
            sidebarLinks.forEach(link => {
                const isActive = link.getAttribute('href') === targetHref;
                link.classList.toggle('active', isActive);
                if (isActive) link.setAttribute('aria-current', 'page');
                else link.removeAttribute('aria-current');
            });
        }

        function syncActiveSidebarWithRoute() {
            const currentPage = window.location.pathname.split('/').pop() || 'installments.html';
            setActiveSidebarItem(currentPage);
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            sidebar.classList.remove('mobile-open');
            if (document.body.classList.contains('sidebar-collapsed')) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            main.style.marginLeft = '16rem';
            main.style.width = 'calc(100% - 16rem)';
            main.style.flex = '0 1 calc(100% - 16rem)';
        }

        function isModalVisible(modal) {
            return Boolean(modal) && !modal.classList.contains('hidden');
        }

        function syncBodyScrollLock() {
            const shouldLock = installmentModalState.isOpen || isModalVisible(notificationModal);
            document.body.style.overflow = shouldLock ? 'hidden' : '';
        }

        function getFocusableElements(container) {
            if (!container) return [];
            return Array.from(container.querySelectorAll('a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])'));
        }

        function focusInstallmentModalInitial() {
            if (!installmentModalState.isOpen || !installmentModal) return;
            const focusable = getFocusableElements(installmentModal);
            if (focusable.length > 0) {
                focusable[0].focus();
                return;
            }
            installmentModal.focus();
        }

        function trapFocusWithinInstallmentModal(event) {
            if (!installmentModalState.isOpen || !installmentModal || event.key !== 'Tab') return;

            const focusable = getFocusableElements(installmentModal);
            if (!focusable.length) return;

            const first = focusable[0];
            const last = focusable[focusable.length - 1];
            const active = document.activeElement;

            if (event.shiftKey && active === first) {
                event.preventDefault();
                last.focus();
                return;
            }

            if (!event.shiftKey && active === last) {
                event.preventDefault();
                first.focus();
            }
        }

        function openModal(modal) {
            if (!modal) return;
            if (installmentModalState.isOpen) closeInstallmentModal({ restoreFocus: false });

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            modalFocusState.activeModal = modal;
            syncBodyScrollLock();
        }

        function closeModal(modal) {
            if (!modal) return;
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            if (modalFocusState.activeModal === modal) {
                modalFocusState.activeModal = null;
            }
            syncBodyScrollLock();
        }

        function getLocalTodayDateInputValue() {
            const now = new Date();
            const local = new Date(now.getTime() - (now.getTimezoneOffset() * 60000));
            return local.toISOString().slice(0, 10);
        }

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function getSelectedInstallment() {
            return installmentsState.installments.find((item) => sameId(item.id, installmentModalState.selectedInstallmentId));
        }

        function getInstallmentsByLoan(loanId) {
            return installmentsState.installments
                .filter((item) => sameId(item.loan_id, loanId))
                .sort((a, b) => {
                    const numberDiff = toNumber(a.installment_number) - toNumber(b.installment_number);
                    if (numberDiff !== 0) return numberDiff;
                    const dueA = startOfDay(a.due_date)?.getTime() ?? 0;
                    const dueB = startOfDay(b.due_date)?.getTime() ?? 0;
                    if (dueA !== dueB) return dueA - dueB;
                    return toNumber(a.id) - toNumber(b.id);
                });
        }

        function getDeleteImpact(installment) {
            const loanInstallments = getInstallmentsByLoan(installment.loan_id);
            const remaining = loanInstallments.filter((item) => !sameId(item.id, installment.id));
            const newTotalAmount = remaining.reduce((sum, item) => sum + toNumber(item.amount), 0);
            const preservedSequenceTotal = remaining.reduce((max, item) => {
                const value = Math.max(0, Math.trunc(toNumber(item.installment_number, 0)));
                return value > max ? value : max;
            }, 0);

            return {
                currentCount: loanInstallments.length,
                remainingCount: remaining.length,
                newTotalAmount,
                preservedSequenceTotal,
                isOnlyInstallment: loanInstallments.length <= 1,
            };
        }

        function buildPaymentMethodOptions(selectedMethod) {
            const normalizedSelected = normalizeAscii(selectedMethod);
            const options = [
                { value: 'Pix', label: 'Pix' },
                { value: 'Dinheiro', label: 'Dinheiro' },
                { value: 'Transferencia', label: 'Transferencia' },
                { value: 'Cartao', label: 'Cartao' },
                { value: 'Outro', label: 'Outro' },
            ];

            return options
                .map((option) => {
                    const selected = normalizeAscii(option.value) === normalizedSelected ? 'selected' : '';
                    return `<option value="${option.value}" ${selected}>${option.label}</option>`;
                })
                .join('');
        }

        function openInstallmentModal(installmentId, mode = 'details') {
            const installment = installmentsState.installments.find((item) => sameId(item.id, installmentId));
            if (!installment || !installmentModal) return;

            if (isModalVisible(notificationModal)) {
                closeModal(notificationModal);
            }

            const loan = getLoanById(installment.loan_id);
            installmentModalState.lastFocusedElement = document.activeElement instanceof HTMLElement
                ? document.activeElement
                : null;
            installmentModalState.isOpen = true;
            installmentModalState.selectedInstallmentId = installment.id;
            installmentModalState.mode = 'details';
            installmentModalState.isSubmitting = false;
            installmentModalState.form.paymentDate = getLocalTodayDateInputValue();
            installmentModalState.form.paymentMethod = getInstallmentPaymentMethod(installment) || normalizePaymentMethod(loan?.payment_method) || 'Pix';
            installmentModalState.form.paymentNotes = '';
            installmentModalState.form.refundReason = '';

            installmentModal.classList.remove('hidden');
            installmentModal.classList.add('flex');
            modalFocusState.activeModal = installmentModal;

            setInstallmentModalMode(mode);
            syncBodyScrollLock();
            window.requestAnimationFrame(focusInstallmentModalInitial);
        }

        function openInstallmentDetails(installmentId) {
            openInstallmentModal(installmentId, 'details');
        }

        function closeInstallmentModal(options = {}) {
            if (!installmentModal) return;

            const { restoreFocus = true } = options;
            installmentModalState.isOpen = false;
            installmentModalState.mode = 'details';
            installmentModalState.selectedInstallmentId = null;
            installmentModalState.isSubmitting = false;

            installmentModal.classList.add('hidden');
            installmentModal.classList.remove('flex');
            if (modalFocusState.activeModal === installmentModal) {
                modalFocusState.activeModal = null;
            }
            setInstallmentModalFooter('');

            syncBodyScrollLock();

            if (restoreFocus && installmentModalState.lastFocusedElement) {
                installmentModalState.lastFocusedElement.focus();
            }
            installmentModalState.lastFocusedElement = null;
        }

        function readInstallmentModalFormValues() {
            const paymentDateInput = document.getElementById('installmentModalPaymentDate');
            const paymentMethodInput = document.getElementById('installmentModalPaymentMethod');
            const paymentNotesInput = document.getElementById('installmentModalPaymentNotes');
            const refundReasonInput = document.getElementById('installmentModalRefundReason');

            if (paymentDateInput) installmentModalState.form.paymentDate = String(paymentDateInput.value || '').trim();
            if (paymentMethodInput) installmentModalState.form.paymentMethod = String(paymentMethodInput.value || '').trim() || 'Pix';
            if (paymentNotesInput) installmentModalState.form.paymentNotes = String(paymentNotesInput.value || '').trim();
            if (refundReasonInput) installmentModalState.form.refundReason = String(refundReasonInput.value || '').trim();
        }

        function setInstallmentModalFooter(configOrActionsHtml, maybeActionsHtml) {
            if (!installmentModalFooter) return;
            const secondaryContainer = installmentModalFooter.querySelector('.modal-base__footer-secondary');
            const actionsContainer = installmentModalFooter.querySelector('.modal-base__footer-actions');
            if (!secondaryContainer || !actionsContainer) return;

            let secondaryHtml = '';
            let actionsHtml = '';

            if (configOrActionsHtml && typeof configOrActionsHtml === 'object' && !Array.isArray(configOrActionsHtml)) {
                secondaryHtml = String(configOrActionsHtml.secondary || '').trim();
                actionsHtml = String(configOrActionsHtml.actions || '').trim();
