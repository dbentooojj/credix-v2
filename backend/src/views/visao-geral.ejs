    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        if (!currentUser) window.location.href = '/login';
        else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            document.getElementById('userName').textContent = `Ola, ${currentUser.name || currentUser.full_name || 'Administrador'}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');
        const overviewRoot = document.getElementById('overviewRoot');
        const overviewError = document.getElementById('overviewError');
        const recentMovementsSection = document.getElementById('recentMovementsSection');
        const recentMovementsPaginationShell = document.getElementById('recentMovementsPaginationShell');
        const recentMovementsPageInfo = document.getElementById('recentMovementsPageInfo');
        const recentMovementsPagination = document.getElementById('recentMovementsPagination');
        const recentMovementsMobileList = document.getElementById('recentMovementsMobileList');
        let overviewMonthlyChart = null;
        const overviewState = {
            recentMovementsPage: 1,
            recentMovementsPageSize: 6,
            recentMovementsTotalPages: 1,
            isPaginatingRecentMovements: false,
        };
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;

        function formatCurrency(value) {
            const safe = Number.isFinite(Number(value)) ? Number(value) : 0;
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(safe);
        }
        function formatPercent(value) {
            const safe = Number.isFinite(Number(value)) ? Number(value) : 0;
            return `${safe.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}%`;
        }
        function formatDateTime(value, timeZone) {
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '--';
            return new Intl.DateTimeFormat('pt-BR', { dateStyle: 'medium', timeStyle: 'short', timeZone: timeZone || 'UTC' }).format(date);
        }
        function formatDateShort(value) {
            const date = new Date(`${String(value || '').slice(0, 10)}T00:00:00Z`);
            if (Number.isNaN(date.getTime())) return '--';
            return new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: '2-digit', timeZone: 'UTC' }).format(date);
        }
        function formatDateLong(value) {
            const date = new Date(`${String(value || '').slice(0, 10)}T00:00:00Z`);
            if (Number.isNaN(date.getTime())) return '--';
            return new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'UTC' }).format(date);
        }
        function formatPeriodLabel(period) { return ({ '3m': 'Ultimos 3 meses', '6m': 'Ultimos 6 meses', '12m': 'Ultimos 12 meses' })[String(period || '')] || 'Periodo padrao'; }
        function formatMetricLabel(metric) { return ({ recebido: 'Recebido', emprestado: 'Emprestado', lucro: 'Lucro' })[String(metric || '')] || 'Recebido'; }
        function buildKpiInsight(currentValue, previousValue) {
            const current = Number(currentValue) || 0;
            const previous = Number(previousValue) || 0;
            if (Math.abs(previous) < 0.00001) return Math.abs(current) < 0.00001 ? { tone: 'neutral', text: '0,00% vs mes ant.' } : { tone: current >= 0 ? 'positive' : 'negative', text: 'Sem base ant.' };
            const pct = ((current - previous) / Math.abs(previous)) * 100;
            if (Math.abs(pct) < 0.005) return { tone: 'neutral', text: '0,00% vs mes ant.' };
            const pctText = Math.abs(pct).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            return { tone: pct > 0 ? 'positive' : 'negative', text: `${pct > 0 ? '+' : '-'}${pctText}% vs mes ant.` };
        }
        function renderSparkline(svgElement, rawSeries, tone) {
            if (!svgElement) return;
            const values = Array.isArray(rawSeries) ? rawSeries.map((point) => typeof point === 'number' ? Number(point) : Number(point?.value)).filter((value) => Number.isFinite(value)) : [];
            if (!values.length) { svgElement.innerHTML = ''; return; }
            const color = tone === 'positive' ? '#10B981' : tone === 'negative' ? '#F87171' : '#9CA3AF';
            const fillColor = tone === 'positive' ? 'rgba(16,185,129,.15)' : tone === 'negative' ? 'rgba(248,113,113,.15)' : 'rgba(123,134,155,.13)';
            const glowColor = tone === 'positive' ? 'rgba(16,185,129,.35)' : tone === 'negative' ? 'rgba(248,113,113,.35)' : 'rgba(99,102,241,.35)';
            const minValue = Math.min(...values);
            const maxValue = Math.max(...values);
            const range = maxValue - minValue || 1;
            const points = values.map((value, index) => ({ x: values.length > 1 ? (index * 100) / (values.length - 1) : 50, y: 3 + ((1 - ((value - minValue) / range)) * 28) }));
            const linePath = points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(' ');
            const areaPath = `${linePath} L ${points[points.length - 1].x.toFixed(2)} 33 L ${points[0].x.toFixed(2)} 33 Z`;
            svgElement.innerHTML = `<path d="${areaPath}" fill="${fillColor}"></path><path d="${linePath}" fill="none" stroke="${color}" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="filter: drop-shadow(0 0 8px ${glowColor});"></path>`;
        }
        function applyChipTone(element, tone, text) {
            if (!element) return;
            element.classList.remove('text-emerald-200', 'border-emerald-400/20', 'bg-emerald-500/10', 'text-rose-200', 'border-rose-400/20', 'bg-rose-500/10');
            if (tone === 'positive') element.classList.add('text-emerald-200', 'border-emerald-400/20', 'bg-emerald-500/10');
            if (tone === 'negative') element.classList.add('text-rose-200', 'border-rose-400/20', 'bg-rose-500/10');
            element.textContent = text;
        }
        function escapeHtml(value) {
            return String(value ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }
        function renderOperationList(containerId, items, emptyTitle, emptyNote, amountTone) {
            const container = document.getElementById(containerId);
            if (!container) return;
            if (!Array.isArray(items) || items.length === 0) {
                container.innerHTML = `
                    <div class="rounded-2xl border border-slate-700/60 bg-slate-950/30 px-4 py-10 text-center">
                        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl border border-slate-700/70 bg-slate-900/70 text-slate-400">
                            <i class="fas fa-calendar-check text-xl"></i>
                        </div>
                        <p class="mt-4 text-base font-semibold text-slate-100">${escapeHtml(emptyTitle)}</p>
                        <p class="mt-2 text-sm leading-6 text-slate-400">${escapeHtml(emptyNote)}</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = items.map((item) => `
                <a href="${escapeHtml(item.href || '#')}" class="rounded-2xl border border-slate-700/60 bg-slate-950/30 px-4 py-4 transition hover:-translate-y-0.5 hover:border-slate-500/50 hover:bg-slate-900/70">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <div class="mb-2 flex flex-wrap gap-2">
                                <span class="inline-flex min-h-[28px] items-center rounded-full border border-slate-600/60 bg-slate-900/80 px-3 text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-200">${escapeHtml(item.typeLabel || '-')}</span>
                                <span class="inline-flex min-h-[28px] items-center rounded-full border border-slate-700/60 bg-slate-950/70 px-3 text-[11px] font-bold uppercase tracking-[0.12em] text-slate-400">${escapeHtml(item.moduleLabel || '-')}</span>
                            </div>
                            <p class="truncate text-base font-bold text-slate-50">${escapeHtml(item.title || '-')}</p>
                            <p class="mt-1 text-sm leading-6 text-slate-400">${escapeHtml(item.subtitle || '-')}</p>
                        </div>
                        <div class="shrink-0 text-right">
                            <p class="text-lg font-extrabold tracking-[-0.03em] ${amountTone}">${escapeHtml(formatCurrency(item.amount))}</p>
                        </div>
                    </div>
                </a>
            `).join('');
        }
        function renderHero(payload) {
            document.getElementById('heroGeneratedAt').textContent = formatDateTime(payload?.meta?.generatedAt, payload?.meta?.timezone);
            document.getElementById('heroPeriodChip').textContent = `Periodo: ${formatPeriodLabel(payload?.meta?.period)}`;
        }
        function renderOverviewSummary(payload) {
            const summary = payload?.overviewSummary || {};
            const cash = summary.cashBalance || {};
            const receivable = summary.accountsReceivable || {};
            const payable = summary.accountsPayable || {};
            const projected = summary.projectedBalance || {};

            const cashHref = cash.href || '/admin/dashboard.html';
            const receivableHref = receivable.href || '/admin/contas-a-receber.html';
            const payableHref = payable.href || '/admin/contas-a-pagar.html';
            const projectedHref = projected.href || '/admin/visao-geral.html';

            document.getElementById('overviewCashCard').href = cashHref;
            document.getElementById('overviewReceivableCard').href = receivableHref;
            document.getElementById('overviewPayableCard').href = payableHref;
            document.getElementById('overviewProjectedCard').href = projectedHref;

            document.getElementById('overviewCashValue').textContent = formatCurrency(cash.value || 0);
            document.getElementById('overviewCashNote').textContent = cash.note || 'Disponivel agora';
            document.getElementById('overviewCashMeta').textContent = `Ajustes: ${formatCurrency(payload?.cashAdjustment?.net || 0)}`;

            document.getElementById('overviewReceivableValue').textContent = formatCurrency(receivable.value || 0);
            document.getElementById('overviewReceivableNote').textContent = receivable.note || 'Emprestimos + Financeiro';
            document.getElementById('overviewReceivableMeta').textContent = `Emprestimos: ${formatCurrency(receivable.loanValue || 0)} | Financeiro: ${formatCurrency(receivable.financeValue || 0)}`;

            document.getElementById('overviewPayableValue').textContent = formatCurrency(payable.value || 0);
            document.getElementById('overviewPayableNote').textContent = payable.note || 'Compromissos pendentes';
            document.getElementById('overviewPayableMeta').textContent = `${Number(payable.itemsCount || 0)} lancamento(s) pendente(s)`;

            document.getElementById('overviewProjectedValue').textContent = formatCurrency(projected.value || 0);
            document.getElementById('overviewProjectedNote').textContent = projected.note || 'Apos entradas e saidas';
            document.getElementById('overviewProjectedMeta').textContent = `Entradas: ${formatCurrency(projected.receivableValue || 0)} | Saidas: ${formatCurrency(projected.payableValue || 0)}`;
        }
        function renderDailySummary(payload) {
            const operations = payload?.dailyOperations || {};
            const overview = payload?.overviewSummary || {};
            const receiptsToday = operations.receiptsToday || { totalValue: 0, items: [] };
            const paymentsToday = operations.paymentsToday || { totalValue: 0, items: [] };
            const cashBalance = Number(overview?.cashBalance?.value || 0);
            const incomingValue = Number(receiptsToday.totalValue || 0);
            const outgoingValue = Number(paymentsToday.totalValue || 0);
            const projectedDayValue = cashBalance + incomingValue - outgoingValue;
            const incomingCount = Array.isArray(receiptsToday.items) ? receiptsToday.items.length : 0;
            const outgoingCount = Array.isArray(paymentsToday.items) ? paymentsToday.items.length : 0;

            document.getElementById('summaryIncomingToday').href = overview?.accountsReceivable?.href || '/admin/contas-a-receber.html';
            document.getElementById('summaryIncomingTodayValue').textContent = formatCurrency(incomingValue);
            document.getElementById('summaryIncomingTodayMeta').textContent = incomingCount
                ? `${incomingCount} ${incomingCount === 1 ? 'entrada prevista para hoje.' : 'entradas previstas para hoje.'}`
                : 'Nenhuma entrada prevista para hoje.';

            document.getElementById('summaryOutgoingToday').href = overview?.accountsPayable?.href || '/admin/contas-a-pagar.html';
            document.getElementById('summaryOutgoingTodayValue').textContent = formatCurrency(outgoingValue);
            document.getElementById('summaryOutgoingTodayMeta').textContent = outgoingCount
                ? `${outgoingCount} ${outgoingCount === 1 ? 'saida prevista para hoje.' : 'saidas previstas para hoje.'}`
                : 'Nenhuma saida prevista para hoje.';

            document.getElementById('summaryProjectedToday').href = overview?.projectedBalance?.href || '/admin/visao-geral.html';
            document.getElementById('summaryProjectedTodayValue').textContent = formatCurrency(projectedDayValue);
            document.getElementById('summaryProjectedTodayMeta').textContent = `Caixa atual ${formatCurrency(cashBalance)} + entradas - saidas do dia.`;
        }
        function renderDailyOperations(payload) {
            const operations = payload?.dailyOperations || {};
            const receiptsToday = operations.receiptsToday || { totalValue: 0, items: [] };
            const paymentsToday = operations.paymentsToday || { totalValue: 0, items: [] };
            const alerts = operations.alerts || {};
            const projected = payload?.overviewSummary?.projectedBalance || {};
            const projectedValue = Number(projected.value || 0);
            const projectedThreshold = 1000;
            const paymentsDueTodayCount = Array.isArray(paymentsToday.items) ? paymentsToday.items.length : 0;
            const overdueOutgoingCount = Number(alerts.overdueOutgoingCount) || 0;
            const overdueIncomingCount = Number(alerts.overdueIncomingCount) || 0;
            const financialAlertsList = document.getElementById('financialAlertsList');

            document.getElementById('receiptsTodayTotal').textContent = `Total: ${formatCurrency(receiptsToday.totalValue || 0)}`;
            document.getElementById('paymentsTodayTotal').textContent = `Total: ${formatCurrency(paymentsToday.totalValue || 0)}`;

            renderOperationList(
                'receiptsTodayList',
                receiptsToday.items,
                'Sem recebimentos previstos para hoje.',
                'Quando houver parcelas ou contas a receber no dia, elas aparecem aqui.',
                'text-emerald-100',
            );
            renderOperationList(
                'paymentsTodayList',
                paymentsToday.items,
                'Sem pagamentos previstos para hoje.',
                'Quando houver contas a pagar no dia, elas aparecem aqui.',
                'text-rose-100',
            );

            if (!financialAlertsList) return;

            const alertItems = [
                {
                    href: alerts.outgoingHref || '/admin/contas-a-pagar.html',
                    icon: 'fa-bell',
                    tone: paymentsDueTodayCount ? 'amber' : 'slate',
                    label: paymentsDueTodayCount
                        ? `${paymentsDueTodayCount} ${paymentsDueTodayCount === 1 ? 'conta vence hoje' : 'contas vencem hoje'}`
                        : 'Nenhuma conta vence hoje',
                },
                {
                    href: alerts.outgoingHref || '/admin/contas-a-pagar.html',
                    icon: 'fa-circle-exclamation',
                    tone: overdueOutgoingCount ? 'rose' : 'slate',
                    label: overdueOutgoingCount
                        ? `${overdueOutgoingCount} ${overdueOutgoingCount === 1 ? 'conta atrasada' : 'contas atrasadas'}`
                        : 'Nenhuma conta atrasada',
                },
                {
                    href: alerts.incomingHref || '/admin/installments.html?status=overdue&due=month',
                    icon: 'fa-clock-rotate-left',
                    tone: overdueIncomingCount ? 'amber' : 'slate',
                    label: overdueIncomingCount
                        ? `${overdueIncomingCount} ${overdueIncomingCount === 1 ? 'recebimento atrasado' : 'recebimentos atrasados'}`
                        : 'Nenhum recebimento atrasado',
                },
                {
                    href: projected.href || '/admin/visao-geral.html',
                    icon: 'fa-wave-square',
                    tone: projectedValue < projectedThreshold ? 'violet' : 'sky',
                    label: projectedValue < projectedThreshold
                        ? `Saldo projetado < ${formatCurrency(projectedThreshold)}`
                        : `Saldo projetado: ${formatCurrency(projectedValue)}`,
                },
            ];

            const toneClasses = {
                amber: {
                    card: 'border-amber-400/15 bg-amber-500/10 hover:border-amber-300/25',
                    icon: 'bg-amber-400/10 text-amber-100',
                    text: 'text-amber-50',
                },
                rose: {
                    card: 'border-rose-400/15 bg-rose-500/10 hover:border-rose-300/25',
                    icon: 'bg-rose-400/10 text-rose-100',
                    text: 'text-rose-50',
                },
                violet: {
                    card: 'border-fuchsia-400/15 bg-fuchsia-500/10 hover:border-fuchsia-300/25',
                    icon: 'bg-fuchsia-400/10 text-fuchsia-100',
                    text: 'text-fuchsia-50',
                },
                sky: {
                    card: 'border-sky-400/15 bg-sky-500/10 hover:border-sky-300/25',
                    icon: 'bg-sky-400/10 text-sky-100',
                    text: 'text-sky-50',
                },
                slate: {
                    card: 'border-slate-700/60 bg-slate-950/30 hover:border-slate-500/50 hover:bg-slate-900/70',
                    icon: 'bg-slate-800/80 text-slate-300',
                    text: 'text-slate-100',
                },
            };

            financialAlertsList.innerHTML = alertItems.map((item) => {
                const tone = toneClasses[item.tone] || toneClasses.slate;
                return `
                    <a href="${escapeHtml(item.href || '#')}" class="group flex items-center gap-3 rounded-2xl border px-3.5 py-3 transition hover:-translate-y-0.5 ${tone.card}">
                        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl ${tone.icon}">
                            <i class="fas ${item.icon}"></i>
                        </span>
                        <span class="min-w-0 flex-1 text-sm font-semibold leading-5 ${tone.text}">${escapeHtml(item.label || '-')}</span>
                        <i class="fas fa-chevron-right shrink-0 text-[11px] text-slate-500 transition group-hover:text-slate-300"></i>
                    </a>
                `;
            }).join('');
        }
        function destroyOverviewMonthlyChart() {
            if (!overviewMonthlyChart) return;
            overviewMonthlyChart.destroy();
            overviewMonthlyChart = null;
        }
        function renderMonthlyFlow(payload) {
            const chartPayload = payload?.chart || {};
            const points = Array.isArray(chartPayload.points) ? chartPayload.points : [];
            const currentPoint = points.length ? points[points.length - 1] : null;
            const previousPoint = points.length >= 2 ? points[points.length - 2] : null;
            const currentValue = Number(currentPoint?.received ?? currentPoint?.value ?? 0);
            const previousValue = Number(previousPoint?.received ?? previousPoint?.value ?? 0);
            const currentOpen = Number(currentPoint?.open ?? 0);
            const currentOverdue = Number(currentPoint?.overdue ?? 0);
            const flowInsight = buildKpiInsight(currentValue, previousValue);
            const emptyState = document.getElementById('overviewChartEmpty');

            document.getElementById('flowCurrentValue').textContent = formatCurrency(currentValue);
            document.getElementById('flowCurrentNote').textContent = currentPoint
                ? `${formatMetricLabel(chartPayload.metric)} em ${currentPoint.label || 'mes atual'}.`
                : 'Sem dados no periodo atual.';
            document.getElementById('flowPreviousValue').textContent = previousPoint ? formatCurrency(previousValue) : '--';
            document.getElementById('flowPreviousNote').textContent = previousPoint
                ? `${flowInsight.text} sobre ${previousPoint.label}.`
                : 'Sem base anterior para comparativo.';
            document.getElementById('flowExposureValue').textContent = formatCurrency(currentOpen + currentOverdue);
            document.getElementById('flowExposureNote').textContent = `Em aberto: ${formatCurrency(currentOpen)} | Atrasado: ${formatCurrency(currentOverdue)}`;

            const hasData = Boolean(chartPayload.hasData) && points.length > 0;
            if (!hasData || typeof Chart === 'undefined') {
                destroyOverviewMonthlyChart();
                if (emptyState) emptyState.classList.remove('hidden');
                return;
            }

            if (emptyState) emptyState.classList.add('hidden');

            const canvas = document.getElementById('overviewMonthlyChart');
            if (!(canvas instanceof HTMLCanvasElement)) return;
            const context = canvas.getContext('2d');
            if (!context) return;

            destroyOverviewMonthlyChart();
            overviewMonthlyChart = new Chart(context, {
                type: 'bar',
                data: {
                    labels: points.map((point) => point.label || '--'),
                    datasets: [
                        {
                            type: 'line',
                            label: 'Recebido',
                            data: points.map((point) => Number(point.received ?? point.value ?? 0)),
                            borderColor: '#34d399',
                            backgroundColor: 'rgba(52, 211, 153, 0.16)',
                            fill: true,
                            tension: 0.34,
                            borderWidth: 2.4,
                            pointRadius: 0,
                            pointHoverRadius: 4,
                            pointHitRadius: 14,
                            order: 0,
                        },
                        {
                            label: 'Em aberto',
                            data: points.map((point) => Number(point.open ?? 0)),
                            backgroundColor: 'rgba(59, 130, 246, 0.32)',
                            borderColor: 'rgba(96, 165, 250, 0.7)',
                            borderWidth: 1,
                            borderRadius: 8,
                            order: 1,
                        },
                        {
                            label: 'Atrasado',
                            data: points.map((point) => Number(point.overdue ?? 0)),
                            backgroundColor: 'rgba(248, 113, 113, 0.28)',
                            borderColor: 'rgba(252, 165, 165, 0.75)',
                            borderWidth: 1,
                            borderRadius: 8,
                            order: 2,
                        },
                    ],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            labels: {
                                color: '#cbd5e1',
                                boxWidth: 10,
                                boxHeight: 10,
                                usePointStyle: true,
                                pointStyle: 'circle',
                                padding: 18,
                                font: {
                                    size: 11,
                                    weight: '700',
                                },
                            },
                        },
                        tooltip: {
                            backgroundColor: 'rgba(15, 23, 42, 0.96)',
                            borderColor: 'rgba(148, 163, 184, 0.28)',
                            borderWidth: 1,
                            titleColor: '#f8fafc',
                            bodyColor: '#e2e8f0',
                            padding: 12,
                            callbacks: {
                                label: (context) => `${context.dataset.label}: ${formatCurrency(context.parsed.y || 0)}`,
                            },
                        },
                    },
                    scales: {
                        x: {
                            grid: {
                                display: false,
                            },
                            ticks: {
                                color: '#94a3b8',
                                font: {
                                    size: 11,
                                    weight: '600',
                                },
                            },
                        },
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(71, 85, 105, 0.22)',
                                drawBorder: false,
                            },
                            ticks: {
                                color: '#94a3b8',
                                font: {
                                    size: 11,
                                },
                                callback: (value) => formatCurrency(Number(value) || 0),
                            },
                        },
                    },
                },
            });
        }
        function buildRecentMovementsPaginationSequence(currentPage, totalPages) {
            if (totalPages <= 5) return Array.from({ length: totalPages }, (_item, index) => index + 1);
            const sequence = [1];
            const start = Math.max(2, currentPage - 1);
            const end = Math.min(totalPages - 1, currentPage + 1);
            if (start > 2) sequence.push('ellipsis-left');
            for (let page = start; page <= end; page += 1) sequence.push(page);
            if (end < totalPages - 1) sequence.push('ellipsis-right');
            sequence.push(totalPages);
            return sequence;
        }
        function renderRecentMovementsPagination(meta = {}) {
            if (!recentMovementsPaginationShell || !recentMovementsPageInfo || !recentMovementsPagination) return;

            const totalItems = Number(meta.totalItems) || 0;
            const pageSize = Math.max(1, Number(meta.pageSize) || overviewState.recentMovementsPageSize || 6);
            const totalPages = Math.max(1, Number(meta.totalPages) || 1);
            const currentPage = Math.min(Math.max(Number(meta.page) || 1, 1), totalPages);
            const startItem = totalItems === 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
            const endItem = totalItems === 0 ? 0 : Math.min(startItem + pageSize - 1, totalItems);

            overviewState.recentMovementsPage = currentPage;
            overviewState.recentMovementsPageSize = pageSize;
            overviewState.recentMovementsTotalPages = totalPages;

            if (totalItems <= pageSize) {
                recentMovementsPaginationShell.classList.add('hidden');
                recentMovementsPageInfo.textContent = '';
                recentMovementsPagination.innerHTML = '';
                return;
            }

            recentMovementsPaginationShell.classList.remove('hidden');
            recentMovementsPageInfo.textContent = `Mostrando ${startItem}-${endItem} de ${totalItems} movimentacoes`;

            const pages = buildRecentMovementsPaginationSequence(currentPage, totalPages);
            recentMovementsPagination.innerHTML = [
                `<button type="button" class="movement-pagination-btn" data-recent-movements-page="${currentPage - 1}" ${currentPage <= 1 ? 'disabled' : ''}>Anterior</button>`,
                ...pages.map((page) => {
                    if (typeof page !== 'number') return '<span class="movement-pagination-ellipsis">...</span>';
                    return `<button type="button" class="movement-pagination-btn ${page === currentPage ? 'movement-pagination-btn-active' : ''}" data-recent-movements-page="${page}" ${page === currentPage ? 'aria-current="page"' : ''}>${page}</button>`;
                }),
                `<button type="button" class="movement-pagination-btn" data-recent-movements-page="${currentPage + 1}" ${currentPage >= totalPages ? 'disabled' : ''}>Proxima</button>`,
            ].join('');
        }
        function setRecentMovementsLoading(loading) {
            if (recentMovementsSection) recentMovementsSection.classList.toggle('recent-movements-loading', loading);
        }
        function renderRecentMovements(payload) {
            const container = document.getElementById('recentMovementsList');
            const mobileContainer = recentMovementsMobileList;
            const items = Array.isArray(payload?.recentMovements) ? payload.recentMovements : [];
            const paginationMeta = payload?.recentMovementsPagination || {};
            if (!container || !mobileContainer) return;

            if (!items.length) {
                container.innerHTML = `
                    <tr>
                        <td colspan="6" class="px-4 py-10">
                            <div class="rounded-2xl border border-slate-700/60 bg-slate-950/30 px-4 py-10 text-center">
                                <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl border border-slate-700/70 bg-slate-900/70 text-slate-400">
                                    <i class="fas fa-arrows-rotate text-xl"></i>
                                </div>
                                <p class="mt-4 text-base font-semibold text-slate-100">Sem movimentacoes recentes.</p>
                                <p class="mt-2 text-sm leading-6 text-slate-400">Quando houver recebimentos, ajustes ou lancamentos, eles aparecem aqui.</p>
                            </div>
                        </td>
                    </tr>
                `;
                mobileContainer.innerHTML = `
                    <div class="rounded-2xl border border-slate-700/60 bg-slate-950/30 px-4 py-10 text-center">
                        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl border border-slate-700/70 bg-slate-900/70 text-slate-400">
                            <i class="fas fa-arrows-rotate text-xl"></i>
                        </div>
                        <p class="mt-4 text-base font-semibold text-slate-100">Sem movimentacoes recentes.</p>
                        <p class="mt-2 text-sm leading-6 text-slate-400">Quando houver recebimentos, ajustes ou lancamentos, eles aparecem aqui.</p>
                    </div>
                `;
                renderRecentMovementsPagination(paginationMeta);
                return;
            }

            container.innerHTML = items.map((item) => {
                const direction = item.direction === 'out' ? 'out' : 'in';
                const pillClass = direction === 'out' ? 'movement-pill movement-pill-out' : 'movement-pill movement-pill-in';
                const incomingAmount = direction === 'in' ? formatCurrency(item.amount) : '-';
                const outgoingAmount = direction === 'out' ? formatCurrency(item.amount) : '-';
                const incomingClass = direction === 'in'
                    ? 'recent-movements-amount recent-movements-amount-in'
                    : 'recent-movements-amount recent-movements-amount-muted';
                const outgoingClass = direction === 'out'
                    ? 'recent-movements-amount recent-movements-amount-out'
                    : 'recent-movements-amount recent-movements-amount-muted';
                return `
                    <tr class="recent-movements-row" data-recent-movement-href="${escapeHtml(item.href || '#')}" tabindex="0" role="link">
                        <td class="recent-movements-date">${escapeHtml(formatDateLong(item.occurredAt))}</td>
                        <td><span class="${pillClass}">${escapeHtml(item.typeLabel || '-')}</span></td>
                        <td><span class="movement-pill movement-pill-neutral">${escapeHtml(item.moduleLabel || '-')}</span></td>
                        <td>
                            <p class="recent-movements-description-title">${escapeHtml(item.title || '-')}</p>
                            <p class="recent-movements-description-subtitle">${escapeHtml(item.subtitle || '-')}</p>
                        </td>
                        <td class="recent-movements-cell-right"><span class="${incomingClass}">${escapeHtml(incomingAmount)}</span></td>
                        <td class="recent-movements-cell-right"><span class="${outgoingClass}">${escapeHtml(outgoingAmount)}</span></td>
                    </tr>
                `;
            }).join('');
            mobileContainer.innerHTML = items.map((item) => {
                const direction = item.direction === 'out' ? 'out' : 'in';
                const pillClass = direction === 'out' ? 'movement-pill movement-pill-out' : 'movement-pill movement-pill-in';
                const signedAmount = `${direction === 'out' ? '-' : '+'}${formatCurrency(item.amount)}`;
                const amountClass = direction === 'out'
                    ? 'recent-movements-mobile-amount recent-movements-amount-out'
                    : 'recent-movements-mobile-amount recent-movements-amount-in';
                return `
                    <a href="${escapeHtml(item.href || '#')}" class="recent-movements-mobile-card" data-recent-movement-href="${escapeHtml(item.href || '#')}">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <div class="mb-2 flex flex-wrap gap-2">
                                    <span class="${pillClass}">${escapeHtml(item.typeLabel || '-')}</span>
                                    <span class="movement-pill movement-pill-neutral">${escapeHtml(item.moduleLabel || '-')}</span>
                                </div>
                                <p class="recent-movements-mobile-title">${escapeHtml(item.title || '-')}</p>
                                <p class="recent-movements-mobile-subtitle">${escapeHtml(item.subtitle || '-')}</p>
                            </div>
                            <div class="shrink-0 text-right">
                                <p class="${amountClass}">${escapeHtml(signedAmount)}</p>
                                <p class="recent-movements-mobile-date">${escapeHtml(formatDateLong(item.occurredAt))}</p>
                            </div>
                        </div>
                    </a>
                `;
            }).join('');
            renderRecentMovementsPagination(paginationMeta);
        }
        async function loadRecentMovementsPage(page) {
            const nextPage = Math.max(1, Number(page) || 1);
            if (overviewState.isPaginatingRecentMovements) return;
            if (nextPage === overviewState.recentMovementsPage) return;

            overviewState.isPaginatingRecentMovements = true;
            setRecentMovementsLoading(true);

            try {
                const payload = await fetchOverview(nextPage);
                hideError();
                renderRecentMovements(payload);
            } catch (error) {
                console.error(error);
                showError(error instanceof Error ? error.message : 'Falha ao carregar as movimentacoes recentes.');
            } finally {
                overviewState.isPaginatingRecentMovements = false;
                setRecentMovementsLoading(false);
            }
        }
        async function fetchOverview(recentMovementsPage = overviewState.recentMovementsPage) {
            const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || 'America/Sao_Paulo';
            const params = new URLSearchParams({
                period: '6m',
                metric: 'recebido',
                tz: timezone,
                recentMovementsPage: String(Math.max(1, Number(recentMovementsPage) || 1)),
                recentMovementsPageSize: String(overviewState.recentMovementsPageSize),
            });
            const response = await fetch(`/api/dashboard?${params.toString()}`, { credentials: 'include' });
            const payload = await response.json().catch(() => null);
            if (!response.ok) throw new Error(payload?.message || 'Falha ao carregar a visao geral.');
            return payload;
        }
        function setLoading(loading) { overviewRoot.classList.toggle('loading', loading); }
        function showError(message) { overviewError.textContent = message; overviewError.classList.remove('hidden'); }
        function hideError() { overviewError.textContent = ''; overviewError.classList.add('hidden'); }
        async function loadOverview() {
            setLoading(true); hideError();
            try {
                const payload = await fetchOverview();
                renderHero(payload);
                renderOverviewSummary(payload);
                renderDailySummary(payload);
                renderDailyOperations(payload);
                renderMonthlyFlow(payload);
                renderRecentMovements(payload);
            } catch (error) {
                console.error(error);
                showError(error instanceof Error ? error.message : 'Falha ao carregar a visao geral.');
            } finally { setLoading(false); }
        }
        function syncSidebarLayout() {
            if (isMobileViewport()) { main.style.marginLeft = '0'; main.style.width = '100%'; main.style.flex = '1 1 100%'; return; }
            sidebar.classList.remove('mobile-open');
            if (document.body.classList.contains('sidebar-collapsed')) { main.style.marginLeft = '0'; main.style.width = '100%'; main.style.flex = '1 1 100%'; return; }
            main.style.marginLeft = '16rem'; main.style.width = 'calc(100% - 16rem)'; main.style.flex = '0 1 calc(100% - 16rem)';
        }
        function closeUserMenu() { if (userMenuDropdown) userMenuDropdown.classList.add('hidden'); }
        async function performLogout() { localStorage.removeItem('isLoggedIn'); localStorage.removeItem('currentUser'); await fetch('/auth/logout', { method: 'POST', credentials: 'include' }); window.location.href = '/login'; }
        async function handleUserMenuAction(action) { if (action === 'logout') return performLogout(); const allowedTabs = new Set(['profile', 'security', 'help']); window.location.href = `/admin/account.html?tab=${encodeURIComponent(allowedTabs.has(action) ? action : 'profile')}`; }
        sidebarToggle.addEventListener('click', () => { if (isMobileViewport()) { sidebar.classList.toggle('mobile-open'); return; } document.body.classList.toggle('sidebar-collapsed'); syncSidebarLayout(); });
        const recentMovementsList = document.getElementById('recentMovementsList');
        function openRecentMovementFromTarget(target) {
            if (!(target instanceof HTMLElement)) return;
            const row = target.closest('[data-recent-movement-href]');
            if (!(row instanceof HTMLElement)) return;
            const href = row.getAttribute('data-recent-movement-href');
            if (!href || href === '#') return;
            window.location.href = href;
        }
        [recentMovementsList, recentMovementsMobileList].forEach((list) => {
            if (!list) return;
            list.addEventListener('click', (event) => openRecentMovementFromTarget(event.target));
            list.addEventListener('keydown', (event) => {
                if (!(event instanceof KeyboardEvent)) return;
                if (event.key !== 'Enter' && event.key !== ' ') return;
                event.preventDefault();
                openRecentMovementFromTarget(event.target);
            });
        });
        if (recentMovementsPagination) {
            recentMovementsPagination.addEventListener('click', async (event) => {
                const target = event.target;
                if (!(target instanceof HTMLElement)) return;
                const button = target.closest('[data-recent-movements-page]');
                if (!(button instanceof HTMLButtonElement) || button.disabled) return;
                const nextPage = Number(button.getAttribute('data-recent-movements-page'));
                if (!Number.isFinite(nextPage)) return;
                await loadRecentMovementsPage(nextPage);
            });
        }
        userMenuBtn.addEventListener('click', (event) => { event.stopPropagation(); userMenuDropdown.classList.toggle('hidden'); });
        document.addEventListener('click', async (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) return;
            const actionBtn = target.closest('[data-user-menu-action]');
            if (actionBtn) { const action = actionBtn.getAttribute('data-user-menu-action'); closeUserMenu(); if (action) await handleUserMenuAction(action); return; }
            if (!target.closest('#userMenuBtn') && !target.closest('#userMenuDropdown')) closeUserMenu();
        });
        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();
        loadOverview();
    </script>
</body>
</html>
