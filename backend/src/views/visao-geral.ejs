<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credix - Visao geral</title>
    <%- include('partials/favicon') %>
    <%- include('partials/toast') %>
    <%- include('partials/session-timeout') %>
    <style>html,body{background:#020617;} html{font-size:16px;}</style>
    <script>
        (function () {
            const root = document.documentElement;
            try {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark') root.classList.add('dark');
                if (savedTheme === 'light') root.classList.remove('dark');
            } catch (error) {}
        })();
        window.tailwind = window.tailwind || {};
        window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Inter', sans-serif; overflow-x: hidden; color: #f8fbff; background:
            radial-gradient(72rem 44rem at -8% -12%, rgba(37,99,235,.26), transparent 48%),
            radial-gradient(48rem 32rem at 100% 0%, rgba(6,182,212,.12), transparent 44%),
            linear-gradient(180deg, #050b17 0%, #08111f 100%); }
        body::before { content:""; position:fixed; inset:0; pointer-events:none; opacity:.55; background:
            linear-gradient(180deg, rgba(255,255,255,.02), transparent 22%),
            radial-gradient(circle at 25% 20%, rgba(59,130,246,.08), transparent 24%); mix-blend-mode:screen; }
        .premium-header { background: rgba(12,18,32,.86); border-bottom: 1px solid rgba(148,163,184,.16); backdrop-filter: blur(10px); }
        .icon-btn { color:#cbd5e1; width:42px; height:42px; border-radius:12px; display:inline-flex; align-items:center; justify-content:center; transition:.12s; }
        .icon-btn:hover { color:#fff; background:rgba(59,130,246,.16); box-shadow: inset 0 0 0 1px rgba(96,165,250,.24); }
        .modern-sidebar { transform: translateX(0); transition: transform .12s ease-out; }
        .glass-card { position:relative; overflow:hidden; border:1px solid rgba(148,163,184,.14); border-radius:16px; background:linear-gradient(180deg, rgba(10,18,34,.96), rgba(9,16,30,.84)); box-shadow: 0 10px 30px rgba(2,6,23,.28); }
        .glass-card::before { content:""; position:absolute; inset:0; pointer-events:none; background:linear-gradient(180deg, rgba(255,255,255,.04), transparent 30%); opacity:.6; }
        .chip { display:inline-flex; align-items:center; gap:.4rem; padding:.38rem .68rem; border-radius:999px; border:1px solid rgba(96,165,250,.16); background:rgba(15,23,42,.62); color:#c7d2fe; font-size:.72rem; font-weight:700; }
        .page-title { font-size: clamp(2rem, 1.2vw + 1.2rem, 2.45rem); line-height: 1.04; font-weight: 700; letter-spacing: -.035em; }
        .page-subtitle { max-width: 54rem; color: #cbd5e1; font-size: .96rem; line-height: 1.6; }
        .overview-header-meta { display:grid; gap:.7rem; justify-items:start; }
        .header-period-chip { padding:.34rem .62rem; font-size:.69rem; font-weight:600; color:#cbd5e1; border-color:rgba(96,165,250,.12); background:rgba(15,23,42,.42); }
        .header-updated { color:#94a3b8; font-size:.82rem; line-height:1.4; }
        .header-updated-value { color:#cbd5e1; font-weight:600; }
        .metric-value { font-size: clamp(1.78rem, .7vw + 1.45rem, 2.1rem); line-height: 1.04; font-weight: 700; letter-spacing: -.04em; }
        .section-title { font-size: 1.06rem; line-height: 1.2; font-weight: 700; letter-spacing: -.02em; }
        .section-note { color: #cbd5e1; font-size: .88rem; line-height: 1.55; }
        .overview-top-card { position:relative; display:block; min-height:132px; border-radius:18px; padding:1.15rem 1.2rem; border:1px solid rgba(96,165,250,.2); overflow:hidden; box-shadow:0 16px 34px rgba(2,6,23,.24); }
        .overview-top-card::before { content:""; position:absolute; inset:0; pointer-events:none; background:linear-gradient(180deg, rgba(255,255,255,.05), transparent 42%); }
        .overview-top-card--cash { background:linear-gradient(135deg, rgba(14,41,105,.94), rgba(13,30,77,.9)); border-color:rgba(59,130,246,.38); }
        .overview-top-card--receivable { background:linear-gradient(135deg, rgba(4,93,74,.94), rgba(3,64,50,.9)); border-color:rgba(16,185,129,.34); }
        .overview-top-card--payable { background:linear-gradient(135deg, rgba(117,7,39,.94), rgba(85,7,32,.9)); border-color:rgba(244,63,94,.34); }
        .overview-top-card--projected { background:linear-gradient(135deg, rgba(78,17,133,.94), rgba(67,20,108,.9)); border-color:rgba(168,85,247,.32); }
        .overview-top-label { color:#e2e8f0; font-size:.8rem; font-weight:500; letter-spacing:.04em; text-transform:uppercase; opacity:.95; }
        .overview-top-value { margin-top:1rem; color:#f8fafc; font-size:2rem; line-height:1.04; font-weight:500; letter-spacing:-.03em; }
        .overview-top-note { margin-top:.5rem; color:#f8fafc; font-size:.98rem; line-height:1.35; opacity:.95; }
        .overview-top-meta { margin-top:.3rem; color:rgba(226,232,240,.8); font-size:.8rem; line-height:1.45; }
        .overview-top-icon { color:rgba(226,232,240,.85); font-size:1.05rem; }
        .flow-stat-card { border:1px solid rgba(71,85,105,.42); border-radius:16px; background:rgba(2,8,23,.24); padding:.95rem 1rem; }
        .flow-stat-label { color:#94a3b8; font-size:.72rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; }
        .flow-stat-value { margin-top:.55rem; color:#f8fafc; font-size:1.42rem; line-height:1.05; font-weight:700; letter-spacing:-.03em; }
        .flow-stat-note { margin-top:.4rem; color:#94a3b8; font-size:.82rem; line-height:1.45; }
        .daily-summary-panel { display:grid; gap:1rem; margin-top:1.15rem; }
        .daily-summary-card { position:relative; display:block; overflow:hidden; border-radius:18px; border:1px solid rgba(71,85,105,.4); padding:1.05rem 1.1rem; transition:border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease; }
        .daily-summary-card:hover { transform:translateY(-1px); }
        .daily-summary-card::before { content:""; position:absolute; inset:0; pointer-events:none; background:linear-gradient(180deg, rgba(255,255,255,.05), transparent 42%); opacity:.7; }
        .daily-summary-card--incoming { background:linear-gradient(135deg, rgba(8,76,77,.9), rgba(12,54,64,.88)); border-color:rgba(16,185,129,.34); box-shadow:0 14px 28px rgba(6,78,59,.18); }
        .daily-summary-card--outgoing { background:linear-gradient(135deg, rgba(80,16,58,.9), rgba(60,18,53,.88)); border-color:rgba(244,63,94,.3); box-shadow:0 14px 28px rgba(76,5,25,.16); }
        .daily-summary-card--projected { background:linear-gradient(135deg, rgba(23,49,104,.9), rgba(26,50,93,.88)); border-color:rgba(96,165,250,.32); box-shadow:0 14px 28px rgba(30,64,175,.18); }
        .daily-summary-icon { display:flex; align-items:center; justify-content:center; width:2rem; height:2rem; border-radius:.8rem; font-size:.95rem; }
        .daily-summary-icon--incoming { background:rgba(16,185,129,.12); color:#6ee7b7; }
        .daily-summary-icon--outgoing { background:rgba(244,63,94,.12); color:#fda4af; }
        .daily-summary-icon--projected { background:rgba(96,165,250,.12); color:#93c5fd; }
        .daily-summary-label { color:#e2e8f0; font-size:.96rem; font-weight:500; line-height:1.35; }
        .daily-summary-value { margin-top:.9rem; color:#f8fafc; font-size:2rem; line-height:1.04; font-weight:500; letter-spacing:-.03em; }
        .daily-summary-value--incoming { color:#5eead4; }
        .daily-summary-value--outgoing { color:#fb7185; }
        .daily-summary-value--projected { color:#60a5fa; }
        .daily-summary-meta { margin-top:.55rem; color:rgba(226,232,240,.8); font-size:.84rem; line-height:1.45; }
        .chart-shell { position:relative; min-height:320px; border:1px solid rgba(71,85,105,.42); border-radius:18px; background:rgba(2,8,23,.26); padding:.9rem; }
        .chart-shell canvas { width:100% !important; height:290px !important; display:block; }
        .chart-empty { position:absolute; inset:.9rem; display:flex; align-items:center; justify-content:center; text-align:center; border-radius:14px; background:rgba(2,8,23,.72); color:#94a3b8; font-size:.9rem; line-height:1.6; }
        .recent-movements-table-shell { margin-top:1rem; overflow:hidden; border:1px solid rgba(71,85,105,.42); border-radius:18px; background:rgba(2,8,23,.22); }
        .recent-movements-table-wrap { overflow-x:auto; }
        .recent-movements-table-wrap::-webkit-scrollbar { height:10px; }
        .recent-movements-table-wrap::-webkit-scrollbar-thumb { background:rgba(71,85,105,.75); border-radius:999px; }
        .recent-movements-table { width:100%; min-width:980px; border-collapse:collapse; }
        .recent-movements-mobile-list { display:grid; gap:.75rem; margin-top:1rem; }
        .recent-movements-mobile-card { display:block; border:1px solid rgba(71,85,105,.42); border-radius:16px; background:rgba(2,8,23,.24); padding:.95rem 1rem; transition:border-color 160ms ease, transform 160ms ease, background-color 160ms ease; }
        .recent-movements-mobile-card:hover { transform:translateY(-1px); border-color:rgba(100,116,139,.55); background:rgba(15,23,42,.56); }
        .recent-movements-mobile-title { color:#f8fafc; font-size:.98rem; line-height:1.35; font-weight:700; }
        .recent-movements-mobile-subtitle { margin-top:.35rem; color:#94a3b8; font-size:.82rem; line-height:1.45; }
        .recent-movements-mobile-date { margin-top:.55rem; color:#94a3b8; font-size:.78rem; line-height:1.4; }
        .recent-movements-mobile-amount { font-size:1rem; line-height:1; font-weight:800; letter-spacing:-.02em; white-space:nowrap; }
        .recent-movements-head th { padding:1rem 1.15rem; text-align:left; color:#94a3b8; font-size:.76rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; border-bottom:1px solid rgba(51,65,85,.65); white-space:nowrap; }
        .recent-movements-head th:last-child, .recent-movements-head th:nth-last-child(2) { text-align:right; }
        .recent-movements-row { cursor:pointer; transition:background-color 160ms ease; }
        .recent-movements-row:hover { background:rgba(15,23,42,.54); }
        .recent-movements-row td { padding:1rem 1.15rem; border-top:1px solid rgba(30,41,59,.72); vertical-align:middle; }
        .recent-movements-date { color:#f8fafc; font-size:.98rem; font-weight:500; white-space:nowrap; }
        .movement-pill { display:inline-flex; align-items:center; min-height:26px; padding:0 .65rem; border-radius:999px; font-size:.68rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; }
        .movement-pill-neutral { border:1px solid rgba(100,116,139,.45); background:rgba(15,23,42,.58); color:#cbd5e1; }
        .movement-pill-in { border:1px solid rgba(16,185,129,.32); background:rgba(16,185,129,.12); color:#a7f3d0; }
        .movement-pill-out { border:1px solid rgba(248,113,113,.32); background:rgba(248,113,113,.12); color:#fecaca; }
        .recent-movements-description-title { color:#f8fafc; font-size:1rem; line-height:1.35; font-weight:500; }
        .recent-movements-description-subtitle { margin-top:.3rem; color:#94a3b8; font-size:.82rem; line-height:1.45; }
        .recent-movements-cell-right { text-align:right; white-space:nowrap; }
        .recent-movements-amount { font-size:1rem; line-height:1; font-weight:700; letter-spacing:-.02em; }
        .recent-movements-amount-in { color:#00f0b5; }
        .recent-movements-amount-out { color:#ff5d7b; }
        .recent-movements-amount-muted { color:#94a3b8; }
        .movement-pagination { display:flex; flex-direction:column; gap:.85rem; margin-top:1rem; }
        .movement-pagination-info { color:#94a3b8; font-size:.82rem; line-height:1.4; }
        .movement-pagination-controls { display:flex; flex-wrap:wrap; gap:.5rem; }
        .movement-pagination-btn { display:inline-flex; align-items:center; justify-content:center; min-width:2.35rem; min-height:2.35rem; padding:0 .78rem; border-radius:999px; border:1px solid rgba(71,85,105,.55); background:rgba(2,8,23,.3); color:#cbd5e1; font-size:.82rem; font-weight:700; transition:background-color 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease; }
        .movement-pagination-btn:hover { border-color:rgba(96,165,250,.4); background:rgba(30,41,59,.72); color:#f8fafc; transform:translateY(-1px); }
        .movement-pagination-btn[disabled] { opacity:.45; cursor:not-allowed; transform:none; }
        .movement-pagination-btn-active { border-color:rgba(124,58,237,.5); background:linear-gradient(135deg, rgba(109,40,217,.46), rgba(91,33,182,.4)); color:#fff; box-shadow:0 8px 20px rgba(76,29,149,.24); }
        .movement-pagination-ellipsis { display:inline-flex; align-items:center; justify-content:center; min-width:2rem; color:#64748b; font-size:.82rem; font-weight:700; }
        .recent-movements-loading .recent-movements-table-shell,
        .recent-movements-loading .recent-movements-mobile-list { opacity:.62; pointer-events:none; }
        .recent-movements-loading #recentMovementsPagination { opacity:.75; pointer-events:none; }
        .loading .js-value, .loading .js-note, .loading .js-chip { opacity: .35; }
        body.sidebar-collapsed .modern-sidebar { transform: translateX(-100%); }
        body.sidebar-collapsed main { margin-left: 0 !important; width: 100% !important; flex: 1 1 100% !important; }
        @media (max-width: 1024px) {
            .modern-sidebar { transform: translateX(-100%); }
            .modern-sidebar.mobile-open { transform: translateX(0) !important; }
            main { margin-left: 0 !important; width: 100% !important; flex: 1 1 100% !important; }
        }
        @media (min-width: 640px) {
            .movement-pagination { flex-direction:row; align-items:center; justify-content:space-between; }
            .movement-pagination-controls { justify-content:flex-end; }
        }
        @media (max-width: 767px) {
            .recent-movements-table-shell { display:none; }
        }
        @media (min-width: 768px) {
            .recent-movements-mobile-list { display:none; }
        }
        @media (min-width: 1024px) {
            .overview-header-meta { justify-items:end; text-align:right; }
        }
    </style>
    <link rel="stylesheet" href="/styles/premium-dashboard-theme.css?v=20260303f">
</head>
<body class="dashboard-premium dashboard-financial primary-gradient min-h-screen">
    <header class="premium-header fixed w-full top-0 z-50">
        <div class="flex items-center justify-between px-3 py-3 sm:px-6 sm:py-4">
            <div class="flex items-center">
                <button id="sidebarToggle" class="icon-btn focus:outline-none"><i class="fas fa-bars text-xl"></i></button>
                <h1 class="ml-3 sm:ml-6">
                    <a href="/admin/visao-geral.html" class="flex items-center" aria-label="Credix">
                        <%- include('partials/brand-wordmark', { size: 'header' }) %>
                    </a>
                </h1>
            </div>
            <div class="flex items-center gap-4">
                <button id="userMenuBtn" class="flex items-center gap-2 text-slate-200 hover:text-white focus:outline-none">
                    <span id="userName" class="font-semibold">Ola, <%= currentUser?.name || currentUser?.full_name || 'Administrador' %></span>
                    <i class="fas fa-chevron-down text-sm"></i>
                </button>
                <div id="userMenuDropdown" class="absolute right-6 top-full z-50 mt-2 hidden w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-xl dark:border-slate-700 dark:bg-slate-900">
                    <button type="button" data-user-menu-action="profile" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"><i class="fas fa-id-card text-slate-500 dark:text-slate-300"></i><span>Meu perfil</span></button>
                    <button type="button" data-user-menu-action="security" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"><i class="fas fa-shield-halved text-slate-500 dark:text-slate-300"></i><span>Seguranca</span></button>
                    <button type="button" data-user-menu-action="help" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"><i class="fas fa-circle-question text-slate-500 dark:text-slate-300"></i><span>Ajuda</span></button>
                    <div class="my-2 border-t border-slate-200 dark:border-slate-700"></div>
                    <button type="button" data-user-menu-action="logout" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-rose-600 hover:bg-rose-50 dark:text-rose-400 dark:hover:bg-rose-950/40"><i class="fas fa-right-from-bracket"></i><span>Sair</span></button>
                </div>
            </div>
        </div>
    </header>

    <div class="flex pt-16 sm:pt-20">
        <%- include('partials/admin-sidebar', { activePage }) %>

        <main class="relative z-10 flex-1 p-4 sm:p-6 lg:p-8">
            <div id="overviewRoot" class="w-full">
                <section class="mb-7 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
                    <div>
                        <h2 class="page-title">Visao geral</h2>
                        <p class="page-subtitle mt-2">Resumo do caixa, recebimentos e compromissos financeiros.</p>
                    </div>
                    <div class="overview-header-meta">
                        <span id="heroPeriodChip" class="chip header-period-chip js-chip">Periodo: --</span>
                        <div class="header-updated">Atualizado: <span id="heroGeneratedAt" class="header-updated-value js-value">--</span></div>
                    </div>
                </section>

                <div id="overviewError" class="mb-4 hidden rounded-2xl border border-rose-400/30 bg-rose-950/30 px-4 py-3 text-sm text-rose-200"></div>

                <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                    <a id="overviewCashCard" href="/admin/dashboard.html" class="overview-top-card overview-top-card--cash">
                        <div class="relative z-10 flex items-start justify-between gap-3">
                            <p class="overview-top-label">Saldo em caixa</p>
                            <span class="overview-top-icon"><i class="fas fa-wallet"></i></span>
                        </div>
                        <p id="overviewCashValue" class="overview-top-value js-value">--</p>
                        <p id="overviewCashNote" class="overview-top-note js-note">Disponivel agora</p>
                        <p id="overviewCashMeta" class="overview-top-meta js-note">--</p>
                    </a>

                    <a id="overviewReceivableCard" href="/admin/contas-a-receber.html" class="overview-top-card overview-top-card--receivable">
                        <div class="relative z-10 flex items-start justify-between gap-3">
                            <p class="overview-top-label">Contas a receber</p>
                            <span class="overview-top-icon"><i class="fas fa-arrow-up-right-from-square"></i></span>
                        </div>
                        <p id="overviewReceivableValue" class="overview-top-value js-value">--</p>
                        <p id="overviewReceivableNote" class="overview-top-note js-note">Emprestimos + Financeiro</p>
                        <p id="overviewReceivableMeta" class="overview-top-meta js-note">--</p>
                    </a>

                    <a id="overviewPayableCard" href="/admin/contas-a-pagar.html" class="overview-top-card overview-top-card--payable">
                        <div class="relative z-10 flex items-start justify-between gap-3">
                            <p class="overview-top-label">Contas a pagar</p>
                            <span class="overview-top-icon"><i class="fas fa-arrow-down-left"></i></span>
                        </div>
                        <p id="overviewPayableValue" class="overview-top-value js-value">--</p>
                        <p id="overviewPayableNote" class="overview-top-note js-note">Compromissos pendentes</p>
                        <p id="overviewPayableMeta" class="overview-top-meta js-note">--</p>
                    </a>

                    <a id="overviewProjectedCard" href="/admin/visao-geral.html" class="overview-top-card overview-top-card--projected">
                        <div class="relative z-10 flex items-start justify-between gap-3">
                            <p class="overview-top-label">Saldo previsto</p>
                            <span class="overview-top-icon"><i class="fas fa-arrow-trend-up"></i></span>
                        </div>
                        <p id="overviewProjectedValue" class="overview-top-value js-value">--</p>
                        <p id="overviewProjectedNote" class="overview-top-note js-note">Apos entradas e saidas</p>
                        <p id="overviewProjectedMeta" class="overview-top-meta js-note">--</p>
                    </a>
                </section>

                <section class="mt-4 grid gap-4 xl:grid-cols-[1.15fr_1.15fr_.8fr]">
                    <article class="glass-card p-4">
                    <div class="relative z-10 flex items-start justify-between gap-3">
                        <div>
                            <h3 class="section-title">Recebimentos de hoje</h3>
                            <p class="mt-2 text-sm leading-6 text-slate-300">Titulos previstos para entrada no dia atual.</p>
                        </div>
                        <span id="receiptsTodayTotal" class="chip js-chip">Total: --</span>
                    </div>
                    <div id="receiptsTodayList" class="relative z-10 mt-4 grid gap-3"></div>
                    </article>

                    <article class="glass-card p-4">
                    <div class="relative z-10 flex items-start justify-between gap-3">
                        <div>
                            <h3 class="section-title">Pagamentos de hoje</h3>
                            <p class="mt-2 text-sm leading-6 text-slate-300">Saidas financeiras previstas para hoje.</p>
                        </div>
                        <span id="paymentsTodayTotal" class="chip js-chip">Total: --</span>
                    </div>
                    <div id="paymentsTodayList" class="relative z-10 mt-4 grid gap-3"></div>
                    </article>

                    <article class="glass-card p-4">
                    <div class="relative z-10 grid gap-4">
                        <div>
                            <h3 class="section-title">Alertas financeiros</h3>
                            <p class="mt-2 text-sm leading-6 text-slate-300">Leitura rapida dos compromissos e riscos do dia.</p>
                        </div>

                        <div id="financialAlertsList" class="grid gap-3"></div>
                    </div>
                    </article>
                </section>

                <section class="mt-4 grid gap-4 xl:grid-cols-[1.45fr_.75fr]">
                    <article class="glass-card p-4">
                        <div class="relative z-10">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <h3 class="section-title">Fluxo mensal</h3>
                                    <p class="mt-2 text-sm leading-6 text-slate-300">Leitura dos ultimos meses com recebido, em aberto e atraso.</p>
