        function debounce(callback, waitMs = 150) {
            let timeoutId = null;
            return (...args) => {
                if (timeoutId !== null) {
                    clearTimeout(timeoutId);
                }
                timeoutId = setTimeout(() => {
                    timeoutId = null;
                    callback(...args);
                }, waitMs);
            };
