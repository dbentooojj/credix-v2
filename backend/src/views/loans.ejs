        /* Premium DS v1 - light skin */
        :root {
            --premium-bg: #121b2a;
            --premium-sidebar: #13203a;
            --premium-card: #E3E9F2;
            --premium-positive: #16A34A;
            --premium-negative: #DC2626;
            --premium-accent: #1E40AF;
            --premium-radius: 16px;
            --premium-shadow-soft: 0 4px 12px rgba(2, 12, 27, 0.08);
        }

        html, body {
            background-color: var(--premium-bg);
        }

        .primary-gradient {
            background:
                radial-gradient(900px 320px at -10% -10%, rgba(30, 64, 175, 0.18), transparent 60%),
                var(--premium-bg);
        }

        .premium-header {
            background: rgba(18, 27, 42, 0.88);
            border-bottom: 1px solid rgba(148, 163, 184, 0.24);
            backdrop-filter: blur(8px);
        }

        .modern-sidebar {
            background: linear-gradient(180deg, #15253f 0%, var(--premium-sidebar) 100%);
            border-right: 1px solid rgba(148, 163, 184, 0.2);
        }

        .sidebar-item.active {
            background: linear-gradient(135deg, #1B3D8F 0%, #234EA8 100%);
        }

        .glass-card,
        .kpi-card,
        .summary-link,
        .modal-panel,
        .modal-content {
            background: var(--premium-card);
            border-radius: var(--premium-radius);
            border: 1px solid rgba(148, 163, 184, 0.28);
            box-shadow: var(--premium-shadow-soft);
        }

        .rounded-2xl {
            border-radius: var(--premium-radius);
        }

        .badge,
        .status-pill {
            border-radius: 999px;
            font-weight: 700;
            border: 1px solid transparent;
        }

        .badge-success,
        .status-green {
            background: rgba(22, 163, 74, 0.14);
            color: var(--premium-positive);
            border-color: rgba(22, 163, 74, 0.34);
        }

        .badge-danger,
        .status-red {
            background: rgba(220, 38, 38, 0.12);
            color: var(--premium-negative);
            border-color: rgba(220, 38, 38, 0.36);
        }

        .badge-warn,
        .status-yellow {
            background: rgba(245, 158, 11, 0.16);
            color: #b45309;
            border-color: rgba(245, 158, 11, 0.35);
        }

        .app-toast {
            position: fixed;
            top: 1rem;
            left: 1rem;
            right: 1rem;
            z-index: 60;
            display: flex;
            align-items: center;
            gap: 12px;
            max-width: 420px;
            border-radius: 16px;
            border: 1px solid rgba(16, 185, 129, 0.42);
            background: linear-gradient(135deg, rgba(5, 85, 70, 0.9) 0%, rgba(3, 55, 48, 0.95) 100%);
            color: #d1fae5;
            padding: 12px 14px;
            font-size: 0.98rem;
            font-weight: 600;
            line-height: 1.25;
            box-shadow: 0 16px 38px -22px rgba(16, 185, 129, 0.75), inset 0 1px 0 rgba(167, 243, 208, 0.16);
            backdrop-filter: blur(10px);
            opacity: 0;
            transform: translateY(-8px);
            transition: opacity 200ms ease, transform 200ms ease;
            pointer-events: none;
        }

        .app-toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .app-toast-error {
            border-color: rgba(239, 68, 68, 0.42);
            background: linear-gradient(135deg, rgba(127, 29, 29, 0.92) 0%, rgba(69, 10, 10, 0.95) 100%);
            color: #fee2e2;
            box-shadow: 0 16px 38px -22px rgba(239, 68, 68, 0.7), inset 0 1px 0 rgba(254, 202, 202, 0.15);
        }

        .app-toast-icon {
            width: 34px;
            height: 34px;
            border-radius: 9999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(16, 185, 129, 0.22);
            color: #a7f3d0;
            box-shadow: inset 0 0 0 1px rgba(16, 185, 129, 0.35);
            flex-shrink: 0;
        }

        .app-toast-error .app-toast-icon {
            background: rgba(239, 68, 68, 0.22);
            color: #fecaca;
            box-shadow: inset 0 0 0 1px rgba(239, 68, 68, 0.35);
        }

        .app-toast-text {
            word-break: break-word;
        }

        @media (min-width: 640px) {
            .app-toast {
                left: auto;
                top: 1.5rem;
                right: 1.5rem;
            }
        }

        .notification-badge,
        .btn-primary,
        .action-primary {
            background: var(--premium-accent);
        }
        html:not(.dark) main .bg-white { background-color: #e3e9f2 !important; }
        html:not(.dark) main .bg-slate-50 { background-color: #d9e1ec !important; }
        html:not(.dark) main .border-gray-200,
        html:not(.dark) main .border-gray-300,
        html:not(.dark) main .border-slate-200,
        html:not(.dark) main .border-slate-300 { border-color: #c6d0df !important; }
        html:not(.dark) main .hover\\:bg-gray-50:hover,
        html:not(.dark) main .hover\\:bg-slate-50:hover { background-color: #d3ddea !important; }

        @media (max-width: 640px) {
            .loan-modal-panel {
                max-width: calc(100vw - 0.8rem);
            }

            .loan-action-row .modal-base__footer-actions {
                width: 100%;
            }

            .loan-modal-save-btn {
                width: 100%;
                min-width: 0;
            }
        }
