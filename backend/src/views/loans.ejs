            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeUserMenu();
            });
        }

        const loansState = {
            loans: [],
            debtors: [],
            installments: [],
            filtered: [],
            currentPage: 1,
            pageSize: 8,
            editingLoanId: null,
            expandedLoanIds: new Set()
        };

        const loanModal = document.getElementById('loanModal');
        const loanModalBody = loanModal?.querySelector('.modal-base__body');
        const loanDetailsModal = document.getElementById('loanDetailsModal');
        const deleteLoanConfirmModal = document.getElementById('deleteLoanConfirmModal');
        const closeDeleteLoanConfirmModalBtn = document.getElementById('closeDeleteLoanConfirmModalBtn');
        const loanForm = document.getElementById('loanForm');
        const loanCalculationCard = document.getElementById('loanCalculationCard');
        const installmentsPreviewCard = document.getElementById('installmentsPreviewCard');
        const installmentsPreviewList = document.getElementById('installmentsPreviewList');
        const loanScheduleBody = document.getElementById('loanScheduleBody');
        const loansMobileList = document.getElementById('loansMobileList');
        const loanOpenedModalIds = new Set();
        let previousBodyOverflow = '';
        let pendingDeleteLoanId = null;

        const LOAN_META_START = '[[LOAN_META]]';
        const LOAN_META_END = '[[/LOAN_META]]';

        const loanFormState = {
            schedule: [],
            simulation: null,
            firstDueTouched: false
        };
        function shouldUseLoanFlatpickr() {
            if (typeof window.flatpickr !== 'function') return false;
            if (typeof window.matchMedia !== 'function') return true;
            const isSmallViewport = window.matchMedia('(max-width: 768px)').matches;
            const isCoarsePointer = window.matchMedia('(pointer: coarse)').matches;
            return !isSmallViewport && !isCoarsePointer;
        }

        const ENABLE_LOAN_FLATPICKR = shouldUseLoanFlatpickr();
        const MAX_AUTO_INSTALLMENTS = 96;
        const MAX_INSTALLMENT_TOLERANCE = 1;

        const loanFieldElements = {
            debtorId: document.getElementById('loanDebtor'),
            principal: document.getElementById('loanPrincipal'),
            interestType: document.getElementById('loanInterestType'),
            interestRate: document.getElementById('loanInterestRate'),
            fixedAddition: document.getElementById('loanFixedAddition'),
            installments: document.getElementById('loanInstallments'),
            maxInstallment: document.getElementById('loanMaxInstallment'),
            startDate: document.getElementById('loanStartDate'),
            firstDueDate: document.getElementById('loanFirstDueDate')
        };

        const loanFieldErrorIds = {
            debtorId: 'loanDebtorError',
            principal: 'loanPrincipalError',
            interestType: 'loanInterestTypeError',
            interestRate: 'loanInterestRateError',
            fixedAddition: 'loanFixedAdditionError',
            installments: 'loanInstallmentsError',
            maxInstallment: 'loanMaxInstallmentError',
            startDate: 'loanStartDateError',
            firstDueDate: 'loanFirstDueDateError'
        };

        function sameId(a, b) {
            return String(a ?? '') === String(b ?? '');
        }

        function toNumber(value) {
            const parsed = Number(value);
            return Number.isFinite(parsed) ? parsed : 0;
        }

        function round2(value) {
            return Math.round((toNumber(value) + Number.EPSILON) * 100) / 100;
        }

        function ceil2(value) {
            return Math.ceil((toNumber(value) - Number.EPSILON) * 100) / 100;
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(toNumber(value));
        }

        function parseCurrencyInput(value) {
            const raw = String(value ?? '').trim();
            if (!raw) return 0;

            const sanitized = raw
                .replace(/\s+/g, '')
                .replace(/R\$/gi, '')
                .replace(/[^\d,.-]/g, '');

            const commaIndex = sanitized.lastIndexOf(',');
            const dotIndex = sanitized.lastIndexOf('.');
            let normalized = sanitized;

            if (commaIndex >= 0 && dotIndex >= 0) {
                if (commaIndex > dotIndex) {
                    normalized = sanitized.replace(/\./g, '').replace(',', '.');
                } else {
                    normalized = sanitized.replace(/,/g, '');
                }
            } else if (commaIndex >= 0) {
                normalized = sanitized.replace(/\./g, '').replace(',', '.');
            } else {
                normalized = sanitized.replace(/,/g, '');
            }

            const parsed = Number(normalized);
            return Number.isFinite(parsed) ? parsed : 0;
        }

        function formatCurrencyInput(value) {
            const parsed = parseCurrencyInput(value);
            if (parsed <= 0) return '';
            return parsed.toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            });
        }

        function readLoanPrincipalMaskState() {
            const input = document.getElementById('loanPrincipal');
            if (!(input instanceof HTMLInputElement)) {
                return { intDigits: '', decDigits: '', hasDecimal: false };
            }

            const intDigits = String(input.dataset.amountInt || '')
                .replace(/\D/g, '')
                .replace(/^0+(?=\d)/, '');
            const decDigits = String(input.dataset.amountDec || '')
                .replace(/\D/g, '')
                .slice(0, 2);
            const hasDecimal = String(input.dataset.amountHasDecimal || '') === '1';

            if (intDigits || decDigits || hasDecimal) {
                return { intDigits, decDigits, hasDecimal };
            }

            const parsed = parseCurrencyInput(input.value || '');
            if (parsed <= 0) return { intDigits: '', decDigits: '', hasDecimal: false };

            const [intPart, decPart] = parsed.toFixed(2).split('.');
            const trimmedDec = decPart === '00' ? '' : decPart.replace(/0+$/, '');
            return {
                intDigits: intPart.replace(/^0+(?=\d)/, ''),
                decDigits: trimmedDec,
                hasDecimal: trimmedDec.length > 0,
            };
        }

        function setLoanPrincipalMaskState(state) {
            const input = document.getElementById('loanPrincipal');
            if (!(input instanceof HTMLInputElement)) return;

            const intDigits = String(state?.intDigits || '')
                .replace(/\D/g, '')
                .replace(/^0+(?=\d)/, '');
            const decDigits = String(state?.decDigits || '')
                .replace(/\D/g, '')
                .slice(0, 2);
            const hasDecimal = Boolean(state?.hasDecimal);
            const hasAnyDigit = intDigits.length > 0 || decDigits.length > 0;

            input.dataset.amountInt = intDigits;
            input.dataset.amountDec = decDigits;
            input.dataset.amountHasDecimal = hasDecimal ? '1' : '0';

            if (!hasAnyDigit && !hasDecimal) {
                input.value = '';
                input.dataset.amountValue = '0';
                return;
            }

            const integerValue = intDigits ? Number(intDigits) : 0;
            const decimalDisplay = (hasDecimal || decDigits.length > 0)
                ? decDigits.padEnd(2, '0').slice(0, 2)
                : '00';
            const numericValue = Number(`${integerValue}.${decimalDisplay}`);

            input.dataset.amountValue = Number.isFinite(numericValue) ? String(numericValue) : '0';
            input.value = `R$ ${integerValue.toLocaleString('pt-BR')},${decimalDisplay}`;
        }

        function setLoanPrincipalMaskedValue(value) {
            const amount = Number(value);
            if (!Number.isFinite(amount) || amount <= 0) {
                setLoanPrincipalMaskState({ intDigits: '', decDigits: '', hasDecimal: false });
                return;
            }

            const safe = Math.max(amount, 0);
            const [intPart, decPart] = safe.toFixed(2).split('.');
            const trimmedDec = decPart === '00' ? '' : decPart.replace(/0+$/, '');
            setLoanPrincipalMaskState({
                intDigits: intPart.replace(/^0+(?=\d)/, ''),
                decDigits: trimmedDec,
                hasDecimal: trimmedDec.length > 0,
            });
        }

        function moveLoanPrincipalCaretToEnd() {
            const input = document.getElementById('loanPrincipal');
            if (!(input instanceof HTMLInputElement)) return;
            requestAnimationFrame(() => {
                const length = input.value.length;
                input.setSelectionRange(length, length);
            });
        }

        function syncLoanPrincipalFieldAfterMask() {
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
        }

        function handleLoanPrincipalBeforeInput(event) {
            const input = document.getElementById('loanPrincipal');
            if (!(input instanceof HTMLInputElement)) return;

            const inputType = String(event?.inputType || '');
            if (!inputType) return;
            if (inputType === 'insertFromPaste' || inputType === 'insertFromDrop') return;

            if (
                inputType !== 'insertText'
                && inputType !== 'deleteContentBackward'
                && inputType !== 'deleteContentForward'
            ) {
                return;
            }

            event.preventDefault();

            const hasFullSelection = input.selectionStart === 0 && input.selectionEnd === input.value.length;
            let state = hasFullSelection && inputType === 'insertText'
                ? { intDigits: '', decDigits: '', hasDecimal: false }
                : readLoanPrincipalMaskState();

            if (inputType === 'insertText') {
                const char = String(event.data || '');
                if (!char) return;

                if (char === ',' || char === '.') {
                    state.hasDecimal = true;
                    setLoanPrincipalMaskState(state);
                    moveLoanPrincipalCaretToEnd();
                    syncLoanPrincipalFieldAfterMask();
                    return;
                }

                if (!/^\d$/.test(char)) return;

                if (state.hasDecimal) {
                    if (state.decDigits.length < 2) {
                        state.decDigits = `${state.decDigits}${char}`.slice(0, 2);
                    }
                } else {
                    state.intDigits = `${state.intDigits}${char}`.replace(/^0+(?=\d)/, '');
                }

                setLoanPrincipalMaskState(state);
                moveLoanPrincipalCaretToEnd();
                syncLoanPrincipalFieldAfterMask();
                return;
            }

            if (hasFullSelection) {
                setLoanPrincipalMaskedValue(0);
                moveLoanPrincipalCaretToEnd();
                syncLoanPrincipalFieldAfterMask();
                return;
            }

            if (state.hasDecimal && state.decDigits.length > 0) {
                state.decDigits = state.decDigits.slice(0, -1);
            } else if (state.hasDecimal) {
                state.hasDecimal = false;
            } else if (state.intDigits.length > 0) {
                state.intDigits = state.intDigits.slice(0, -1);
            }

            if (!state.intDigits && !state.decDigits && !state.hasDecimal) {
                setLoanPrincipalMaskedValue(0);
            } else {
                setLoanPrincipalMaskState(state);
            }
            moveLoanPrincipalCaretToEnd();
            syncLoanPrincipalFieldAfterMask();
        }

        function handleLoanPrincipalPaste(event) {
            const rawText = event.clipboardData?.getData('text') || '';
            if (!rawText) return;
            event.preventDefault();
            const parsed = parseCurrencyInput(rawText);
            setLoanPrincipalMaskedValue(parsed);
            moveLoanPrincipalCaretToEnd();
            syncLoanPrincipalFieldAfterMask();
        }

        function formatDate(value) {
            const iso = normalizeIsoDateOnly(value);
            if (!iso) return '-';
            const [year, month, day] = iso.split('-');
            return `${day}/${month}/${year}`;
        }

        function toIsoDate(value) {
            return normalizeIsoDateOnly(value);
        }

        const MS_PER_DAY = 24 * 60 * 60 * 1000;

        function pad2(value) {
            return String(value).padStart(2, '0');
        }

        function toLocalIsoDate(value = new Date()) {
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '';
            return `${date.getFullYear()}-${pad2(date.getMonth() + 1)}-${pad2(date.getDate())}`;
        }

        function normalizeIsoDateOnly(value) {
            if (value === null || value === undefined) return '';

            if (value instanceof Date) {
                if (Number.isNaN(value.getTime())) return '';
                return `${value.getUTCFullYear()}-${pad2(value.getUTCMonth() + 1)}-${pad2(value.getUTCDate())}`;
            }

            const raw = String(value).trim();
            if (!raw) return '';

            const directMatch = raw.match(/^(\d{4})-(\d{2})-(\d{2})$/);
            if (directMatch) {
                const year = Number(directMatch[1]);
                const month = Number(directMatch[2]);
                const day = Number(directMatch[3]);
                const utcMs = Date.UTC(year, month - 1, day);
                const parsed = new Date(utcMs);
                const isValid = parsed.getUTCFullYear() === year
                    && parsed.getUTCMonth() === month - 1
                    && parsed.getUTCDate() === day;
                return isValid ? `${year}-${pad2(month)}-${pad2(day)}` : '';
            }

            const parsed = new Date(raw);
            if (Number.isNaN(parsed.getTime())) return '';
            return `${parsed.getUTCFullYear()}-${pad2(parsed.getUTCMonth() + 1)}-${pad2(parsed.getUTCDate())}`;
        }

        function isoDateToUtcMillis(value) {
            const iso = normalizeIsoDateOnly(value);
            if (!iso) return Number.NaN;
            const [year, month, day] = iso.split('-').map((part) => Number(part));
            return Date.UTC(year, month - 1, day);
        }

        function diffDaysDateOnly(fromDate, toDate) {
            const startMs = isoDateToUtcMillis(fromDate);
            const endMs = isoDateToUtcMillis(toDate);
            if (!Number.isFinite(startMs) || !Number.isFinite(endMs)) return Number.NaN;
            return Math.round((endMs - startMs) / MS_PER_DAY);
        }

        function addMonthsIsoDate(baseIsoDate, count) {
            const safeIso = normalizeIsoDateOnly(baseIsoDate);
            if (!safeIso) return '';

            const [year, month, day] = safeIso.split('-').map((part) => Number(part));
            const totalMonths = (year * 12) + (month - 1) + Math.trunc(toNumber(count));
            const targetYear = Math.floor(totalMonths / 12);
            const targetMonth = (totalMonths % 12) + 1;
            const lastDay = new Date(Date.UTC(targetYear, targetMonth, 0)).getUTCDate();
            const targetDay = Math.min(day, lastDay);

            return `${targetYear}-${pad2(targetMonth)}-${pad2(targetDay)}`;
        }

        function sanitizeMoney(value) {
            const amount = round2(value);
            return Math.abs(amount) < 0.005 ? 0 : amount;
        }

        function isDateBeforeDateOnly(dateIso, referenceIso) {
            const diff = diffDaysDateOnly(dateIso, referenceIso);
            return Number.isFinite(diff) ? diff > 0 : false;
