                },
                onClose: (_selectedDates, dateStr) => {
                    const nextValue = normalizeIsoDateOnly(dateStr || input.value);
                    if (!nextValue) return;
                    input.value = nextValue;
                    const previousValue = input.dataset.fpLastValue || '';
                    input.dataset.fpLastValue = nextValue;
                    if (nextValue === previousValue) return;
                    input.dispatchEvent(new Event('change', { bubbles: true }));
                },
            };
            if (appendTarget) {
                config.appendTo = appendTarget;
            }
            if (options.positionElement instanceof HTMLElement) {
                config.positionElement = options.positionElement;
            }

            const instance = window.flatpickr(input, config);
            if (normalized) {
                instance.setDate(normalized, false, 'Y-m-d');
