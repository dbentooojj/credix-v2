        function createDatePicker(input, options = {}) {
            if (!(input instanceof HTMLInputElement)) return null;
            if (!ENABLE_LOAN_FLATPICKR) return null;
            if (typeof window.flatpickr !== 'function') return null;

            if (input._flatpickr) {
                input._flatpickr.destroy();
            }

            const normalized = normalizeIsoDateOnly(input.value);
            if (normalized) input.value = normalized;
            input.dataset.fpLastValue = normalized;
            const appendTarget = options.appendTo instanceof HTMLElement
                ? options.appendTo
                : document.body;

            const config = {
                dateFormat: 'Y-m-d',
                altInput: options.altInput !== false,
                altFormat: 'd/m/Y',
                altInputClass: options.altInputClass || 'filter-control loan-date-alt-input',
                allowInput: false,
                clickOpens: options.clickOpens !== false,
                disableMobile: true,
                locale: 'pt',
                position: options.position || 'auto left',
                onOpen: (_selectedDates, _dateStr, fpInstance) => {
                    if (!fpInstance) return;

                    const anchorElement = options.positionElement instanceof HTMLElement
                        ? options.positionElement
                        : (fpInstance.altInput instanceof HTMLElement ? fpInstance.altInput : input);

                    fpInstance.set('positionElement', anchorElement);

                    if (fpInstance.calendarContainer instanceof HTMLElement) {
                        fpInstance.calendarContainer.style.zIndex = '9999';
