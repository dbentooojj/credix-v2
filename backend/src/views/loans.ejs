                        <button type="button" data-user-menu-action="logout" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-950/40">
                            <i class="fas fa-right-from-bracket"></i>
                            <span>Sair</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="flex pt-16 sm:pt-20">
        <aside id="sidebar" class="modern-sidebar fixed left-0 top-16 h-[calc(100%-4rem)] w-64 z-40 sm:top-20 sm:h-[calc(100%-5rem)]">
            <nav class="mt-8 px-4">
                <ul class="space-y-2">
                    <li><a href="dashboard.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-tachometer-alt mr-4 text-lg"></i><span>Painel financeiro</span></a></li>
                    <li><a href="debtors.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-users mr-4 text-lg"></i><span>Clientes</span></a></li>
                    <li><a href="loans.html" class="sidebar-item active flex items-center px-4 py-3 text-white rounded-lg"><i class="fas fa-hand-holding-usd mr-4 text-lg"></i><span class="font-medium">Empréstimos</span></a></li>
                    <li><a href="installments.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-calendar-check mr-4 text-lg"></i><span>Parcelas</span></a></li>
                    <li><a href="reports.html" class="sidebar-item flex items-center px-4 py-3 text-gray-300 hover:text-white rounded-lg"><i class="fas fa-chart-bar mr-4 text-lg"></i><span>Relatórios</span></a></li>
                </ul>
            </nav>
        </aside>

        <main class="flex-1 ml-64 p-4 sm:p-6 lg:p-8">
            <%
                const loanHeaderActions = `
                    <div data-loan-header-actions class="flex w-full flex-wrap items-center justify-start gap-2 md:w-auto md:justify-end">
                        ${include('components/button', {
                            id: 'newLoanSimulationBtn',
                            label: 'Nova simulacao',
                            icon: 'fas fa-flask',
                            variant: 'secondary',
                            className: 'min-h-[44px] px-5'
                        })}
                        ${include('components/button', {
                            id: 'newLoanBtn',
                            label: 'Novo emprestimo',
                            icon: 'fas fa-file-invoice-dollar',
                            variant: 'primary',
                            className: 'min-h-[44px] px-5'
                        })}
                    </div>
                `;
            %>
            <%- include('components/section', {
                className: 'mb-6',
                title: 'Emprestimos',
                subtitle: 'Acompanhe contratos, valores e status da carteira ativa.',
                headerActions: loanHeaderActions,
                content: ''
            }) %>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5 mb-6"> 
                <div class="relative rounded-2xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
                    <span class="pointer-events-none absolute right-4 top-4 text-slate-400/80"><i class="fas fa-hashtag"></i></span>
                    <p class="kpi-label">Qtd. empréstimos</p>
                    <p id="totalLoans" class="kpi-value mt-3">0</p>
                    <p id="totalLoansInsight" class="kpi-insight">--</p>
                </div>
                <div class="relative rounded-2xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
                    <span class="pointer-events-none absolute right-4 top-4 text-slate-400/80"><i class="fas fa-hand-holding-usd"></i></span>
                    <p class="kpi-label">Principal total</p>
                    <p id="totalPrincipal" class="kpi-value mt-3">R$ 0,00</p>
                    <p id="totalPrincipalInsight" class="kpi-insight">--</p>
                </div>
                <div class="relative rounded-2xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
                    <span class="pointer-events-none absolute right-4 top-4 text-slate-400/80"><i class="fas fa-chart-line"></i></span>
                    <p class="kpi-label">Total contratado</p>
                    <p id="totalContracted" class="kpi-value mt-3">R$ 0,00</p>
                    <p id="totalContractedInsight" class="kpi-insight">--</p>
                </div>
                <div class="relative rounded-2xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
                    <span class="pointer-events-none absolute right-4 top-4 text-slate-400/80"><i class="fas fa-circle-check"></i></span>
                    <p class="kpi-label">Empréstimos ativos</p>
                    <p id="activeLoans" class="kpi-value mt-3">0</p>
                    <p id="activeLoansInsight" class="kpi-insight">--</p>
                </div>
            </div>
            <%
                const loanSearchField = include('components/field', {
                    label: 'Buscar',
                    forId: 'loanSearch',
                    controlHtml: include('components/input', {
                        id: 'loanSearch',
                        placeholder: 'Cliente ou ID do emprestimo'
                    })
                });
                const loanStatusField = include('components/field', {
                    label: 'Status',
                    forId: 'loanStatusFilter',
                    controlHtml: include('components/select', {
                        id: 'loanStatusFilter',
                        options: [
                            { value: 'Todos', label: 'Todos', selected: true },
                            { value: 'Ativo', label: 'Ativo' },
                            { value: 'Inativo', label: 'Inativo' }
                        ]
                    })
                });
            %>
            <%- include('components/card', {
                className: 'rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm',
                content: `
                    <div class="app-form-grid mb-5">
                        ${loanSearchField}
                        ${loanStatusField}
                    </div>

                    <div id="loansMobileList" class="sm:hidden space-y-3">
                        <div class="rounded-2xl border border-gray-200 bg-slate-50 p-4 text-center text-sm text-gray-500">
                            Carregando emprestimos...
                        </div>
                    </div>

                    <div class="hidden sm:block">
                        <div class="table-shell">
                            <table>
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Cliente</th>
                                        <th>Principal</th>
                                        <th>Total</th>
                                        <th>Parcelas</th>
                                        <th>Juros</th>
                                        <th>Data de inicio</th>
                                        <th>Status</th>
                                        <th>Acoes</th>
                                    </tr>
                                </thead>
                                <tbody id="loansTableBody">
                                    <tr><td colspan="9" class="text-center py-8 text-gray-500">Carregando emprestimos...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center justify-between">
                        <p class="text-sm text-gray-600">
                            Mostrando <span id="showingStart">0</span> ate <span id="showingEnd">0</span> de <span id="totalResults">0</span> resultados
                        </p>
                        <div class="flex items-center gap-2">
                            <button id="prevPageBtn" type="button" class="rounded-lg border border-slate-200 px-3 py-1 text-sm text-slate-700 transition-colors duration-150 hover:bg-slate-50">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                            <span id="pageIndicator" class="text-sm text-gray-600">Pagina 1</span>
                            <button id="nextPageBtn" type="button" class="rounded-lg border border-slate-200 px-3 py-1 text-sm text-slate-700 transition-colors duration-150 hover:bg-slate-50">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                `
            }) %>

            <%
                const simulationSearchField = include('components/field', {
                    label: 'Buscar',
                    forId: 'simulationSearchFilter',
                    controlHtml: include('components/input', {
                        id: 'simulationSearchFilter',
                        placeholder: 'Cliente ou ID da simulacao'
                    })
                });
                const simulationStatusField = include('components/field', {
                    label: 'Status',
                    forId: 'simulationStatusFilter',
                    controlHtml: include('components/select', {
                        id: 'simulationStatusFilter',
                        options: [
                            { value: 'DRAFT,SENT,EXPIRED', label: 'Pendentes', selected: true },
                            { value: 'DRAFT', label: 'Rascunho' },
                            { value: 'SENT', label: 'Enviada' },
                            { value: 'EXPIRED', label: 'Expirada' },
                            { value: 'CANCELED', label: 'Cancelada' },
                            { value: 'ACCEPTED', label: 'Aceita' },
                            { value: '', label: 'Todos' }
                        ]
                    })
                });
            %>
            <%- include('components/card', {
                id: 'loanSimulationsPendingSection',
                className: 'mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm',
                title: 'Simulacoes pendentes',
                content: `
                    <div class="app-form-grid mb-4">
                        ${simulationSearchField}
                        ${simulationStatusField}
                    </div>

                    <div id="loanSimulationsMobileList" class="sm:hidden space-y-3">
                        <div class="rounded-2xl border border-gray-200 bg-slate-50 p-4 text-center text-sm text-gray-500">
                            Carregando simulacoes...
                        </div>
                    </div>

                    <div class="hidden sm:block">
                        <div class="table-shell">
                            <table>
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Cliente</th>
                                        <th>Principal</th>
                                        <th>Total</th>
                                        <th>Parcelas</th>
                                        <th>Juros</th>
                                        <th>Situacao</th>
                                        <th>Validade</th>
                                        <th>Acoes</th>
                                    </tr>
                                </thead>
                                <tbody id="loanSimulationsPendingBody">
                                    <tr>
                                        <td colspan="9" class="px-3 py-4 text-center text-xs text-slate-500">Carregando simulacoes...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <p id="loanSimulationsEmptyState" class="mt-3 hidden rounded-lg border border-dashed border-slate-300 p-3 text-sm text-slate-600">Nenhuma simulacao encontrada para os filtros aplicados.</p>
                `
            }) %>

            <div id="loanModal" class="modal-base modal-form-clean fixed inset-0 z-50 hidden items-center justify-center p-4" data-modal-base="true" role="dialog" aria-modal="true" aria-labelledby="loanModalTitle">
                <div class="modal-base__panel modal-base__panel--lg loan-modal-panel">
                    <div class="modal-base__header">
                        <div class="modal-base__title-wrap">
                            <h3 id="loanModalTitle" class="modal-base__title text-2xl">Novo empréstimo</h3>
                            <p class="modal-base__description">Defina as informações, condições e agenda do contrato.</p>
                        </div>
                        <button id="closeLoanModalBtn" class="modal-base__close" data-modal-close="primary" type="button" aria-label="Fechar modal de empréstimo"><i class="fas fa-times"></i></button>
                    </div>

                    <form id="loanForm" class="flex min-h-0 flex-1 flex-col">
                        <input type="hidden" id="loanEditingId">
                        <div class="modal-base__body loan-modal-body">
                            <div class="loan-modal-content-grid">
                                <div class="loan-modal-main">
                                    <section class="loan-form-section">
                                        <h4 class="loan-form-kicker">Informacoes basicas</h4>
                                        <div class="loan-form-grid-basic">
                                            <div>
                                                <label class="mb-1 block text-sm text-slate-300">Cliente</label>
                                                <select id="loanDebtor" class="filter-control" required data-modal-autofocus>
                                                    <option value="" selected disabled>Selecione o cliente</option>
                                                </select>
                                                <p id="loanDebtorError" class="field-error" aria-live="polite"></p>
                                            </div>
                                            <div>
                                                <label class="mb-1 block text-sm text-slate-300">Valor principal (R$)</label>
                                                <input id="loanPrincipal" class="filter-control" type="text" inputmode="decimal" autocomplete="off" required placeholder="R$ 0,00">
                                                <p id="loanPrincipalError" class="field-error" aria-live="polite"></p>
                                            </div>
                                        </div>
                                    </section>

                                    <section class="loan-form-section">
                                        <h4 class="loan-form-kicker">Condicoes</h4>
                                        <div class="loan-form-grid-conditions">
                                            <div>
                                                <label class="mb-1 block text-sm text-slate-300">Tipo de juros</label>
                                                <select id="loanInterestType" class="filter-control">
                                                    <option value="simples">Simples %</option>
                                                    <option value="composto" selected>Composto %</option>
                                                    <option value="fixo">Fixo (valor total)</option>
                                                </select>
                                                <p id="loanInterestTypeError" class="field-error" aria-live="polite"></p>
                                            </div>
                                            <div id="loanInterestRateWrap">
                                                <label class="mb-1 block text-sm text-slate-300">Taxa mensal (%)*</label>
                                                <input id="loanInterestRate" class="filter-control" type="number" min="0.01" step="0.01" value="" required placeholder="Ex: 8">
                                                <p id="loanInterestRateError" class="field-error" aria-live="polite"></p>
                                            </div>
                                            <div id="loanFixedAdditionWrap" class="hidden">
                                                <label class="mb-1 block text-sm text-slate-300">Acrescimo fixo (R$)</label>
                                                <input id="loanFixedAddition" class="filter-control" type="number" min="0" step="0.01" value="">
                                                <p id="loanFixedAdditionError" class="field-error" aria-live="polite"></p>
                                            </div>
                                            <div id="loanInstallmentsWrap">
                                                <label class="mb-1 block text-sm text-slate-300">Parcelas*</label>
                                                <input id="loanInstallments" class="filter-control" type="number" min="1" max="96" step="1" value="" required>
                                                <p id="loanInstallmentsError" class="field-error" aria-live="polite"></p>
                                            </div>
                                            <div id="loanMaxInstallmentWrap" class="hidden">
                                                <label class="mb-1 block text-sm text-slate-300">Valor da parcela (R$)</label>
                                                <input id="loanMaxInstallment" class="filter-control" type="text" inputmode="decimal" autocomplete="off" placeholder="Ex: 750,00" disabled>
                                                <p id="loanMaxInstallmentError" class="field-error" aria-live="polite"></p>
                                            </div>
                                        </div>
                                        <div class="loan-mode-toggle-row">
                                            <label class="inline-flex cursor-pointer items-center gap-2">
                                                <input id="loanUseMaxInstallment" type="checkbox" class="peer sr-only">
                                                <span class="relative h-6 w-11 rounded-full border border-white/20 bg-white/10 transition-colors duration-200 peer-checked:border-teal-300/60 peer-checked:bg-teal-400/35 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-teal-300 after:absolute after:left-[2px] after:top-[2px] after:h-[18px] after:w-[18px] after:rounded-full after:bg-white after:shadow after:transition-transform after:duration-200 peer-checked:after:translate-x-[20px]"></span>
                                                <span class="text-sm font-medium text-slate-200">Calcular por valor da parcela</span>
                                            </label>
                                        </div>
                                        <p class="loan-mode-helper">Se ativado, o sistema define automaticamente a quantidade de parcelas.</p>
                                        <div id="loanAutoModeHint" class="hidden">
                                            <p>Parcelas calculadas automaticamente.</p>
                                            <p>Quantidade atual: <span id="loanAutoInstallmentsValue">-</span></p>
                                        </div>
                                    </section>

                                    <section class="loan-form-section">
                                        <h4 class="loan-form-kicker">Datas</h4>
                                        <div class="loan-form-grid-dates">
                                            <div>
                                                <label class="mb-1 block text-sm text-slate-300">Data de inicio</label>
                                                <input id="loanStartDate" class="filter-control" type="date" required>
                                                <p id="loanStartDateError" class="field-error" aria-live="polite"></p>
                                            </div>
                                            <div>
                                                <label class="mb-1 block text-sm text-slate-300">1o vencimento</label>
                                                <input id="loanFirstDueDate" class="filter-control" type="date" required>
                                                <p id="loanFirstDueDateError" class="field-error" aria-live="polite"></p>
                                            </div>
                                        </div>
                                    </section>

                                    <section class="loan-form-section">
                                        <h4 class="loan-form-kicker">Observacoes</h4>
                                        <div>
                                            <label class="mb-1 block text-sm text-slate-300">Detalhes adicionais</label>
                                            <textarea id="loanObservations" class="filter-control loan-modal-textarea" rows="3" placeholder="Observacoes sobre o emprestimo"></textarea>
                                        </div>
                                    </section>
                                </div>

                                <aside id="loanCalculationCard">
                                    <h4 class="loan-summary-title">Resumo do emprestimo</h4>
                                    <dl class="loan-summary-list">
                                        <div class="loan-summary-item">
                                            <dt>Valor</dt>
                                            <dd id="loanCalculatedTotal">R$ 0,00</dd>
                                        </div>
                                        <div class="loan-summary-item">
                                            <dt>Valor da parcela</dt>
                                            <dd id="loanCalculatedInstallment" class="loan-summary-installment">R$ 0,00</dd>
                                        </div>
                                        <div class="loan-summary-item">
                                            <dt>Parcelas</dt>
                                            <dd id="loanCalculatedConditionInfo">(a definir)</dd>
                                        </div>
                                        <div class="loan-summary-item">
                                            <dt>Taxa</dt>
                                            <dd class="loan-summary-rate">
                                                <span id="loanCalculatedInterestType" class="loan-summary-rate-main">Composto</span>
                                                <span id="loanCalculatedInterestRates" class="loan-summary-rate-sub">0% a.m.</span>
                                            </dd>
                                        </div>
                                        <div class="loan-summary-item">
                                            <dt>1o vencimento</dt>
                                            <dd id="loanCalculatedConditionDetail">--/--/----</dd>
                                        </div>
                                    </dl>
                                    <p id="loanCalculatedMode" class="loan-summary-mode">Parcelas manuais</p>
                                </aside>
                            </div>

                            <section id="loanScheduleCard" class="loan-form-section loan-form-section--wide hidden">
                                <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
                                    <h4 class="loan-form-kicker mb-0">Agenda das parcelas</h4>
                                    <div class="loan-inline-actions">
                                        <button id="generateScheduleBtn" type="button" class="loan-inline-btn">Gerar agenda</button>
                                        <button id="regenerateScheduleBtn" type="button" class="loan-inline-btn">Regerar agenda</button>
                                    </div>
                                </div>
                                <p id="loanScheduleHint" class="mb-2 text-xs text-slate-300">Preencha parcelas e datas para visualizar a agenda.</p>
                                <p id="loanScheduleError" class="field-error mb-2" aria-live="polite"></p>
                                <div class="loan-schedule-shell">
                                    <table class="min-w-full text-sm">
                                        <thead class="bg-slate-900/45">
                                            <tr>
                                                <th class="px-3 py-2 text-left text-xs font-semibold text-slate-300 uppercase tracking-wide">Parcela</th>
                                                <th class="px-3 py-2 text-left text-xs font-semibold text-slate-300 uppercase tracking-wide">Data</th>
                                                <th class="px-3 py-2 text-right text-xs font-semibold text-slate-300 uppercase tracking-wide">Valor</th>
                                            </tr>
                                        </thead>
                                        <tbody id="loanScheduleBody">
                                            <tr>
                                                <td colspan="3" class="px-3 py-4 text-center text-xs text-slate-400">Agenda ainda nao gerada.</td>
                                            </tr>
                                        </tbody>
                                    </table>
