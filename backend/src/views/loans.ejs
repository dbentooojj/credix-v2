<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credix - Empréstimos</title>
    <%- include('partials/favicon') %>
    <%- include('partials/toast') %>
    <%- include('partials/session-timeout') %>
    <style>
        html, body { background-color: #020617; }
</style>
    <script>
        (function () {
            const root = document.documentElement;
            try {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark') root.classList.add('dark');
                if (savedTheme === 'light') root.classList.remove('dark');
            } catch (error) {}
        })();

        window.tailwind = window.tailwind || {};
        window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>
    <style>
        html { font-size: 16px; }
        body { font-family: 'Inter', sans-serif; overflow-x: hidden; }

        .primary-gradient { background: linear-gradient(135deg, #000000 0%, #0f172a 50%, #111827 100%); }
        .premium-header { background: rgba(2, 6, 23, 0.75); border-bottom: 1px solid rgba(148, 163, 184, 0.2); }

        .icon-btn {
            color: #cbd5e1;
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background-color 120ms ease-out, color 120ms ease-out, box-shadow 120ms ease-out;
        }
        .icon-btn:hover {
            color: #ffffff;
            background: rgba(59, 130, 246, 0.2);
            box-shadow: 0 0 0 1px rgba(96, 165, 250, 0.35) inset;
        }

        .modern-sidebar {
            background: linear-gradient(180deg, rgba(2, 6, 23, 0.9) 0%, rgba(15, 23, 42, 0.85) 100%);
            border-right: 1px solid rgba(148, 163, 184, 0.18);
            transform: translateX(0);
            transition: transform 120ms ease-out;
        }
        .sidebar-item {
            transition: background-color 120ms ease-out, color 120ms ease-out, box-shadow 120ms ease-out;
            border-radius: 12px;
            margin: 4px 0;
        }
        .sidebar-item:hover {
            background: rgba(148, 163, 184, 0.12);
            box-shadow: 0 0 0 1px rgba(148, 163, 184, 0.2) inset;
        }
        .sidebar-item.active {
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
            box-shadow: 0 0 0 1px rgba(147, 197, 253, 0.5) inset, 0 2px 8px rgba(59, 130, 246, 0.25);
        }

        .glass-card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
        }
        .page-title { color: #ffffff; }
        .muted-on-dark { color: #cbd5e1; }

        .kpi-label {
            color: #64748b;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .kpi-value {
            color: #0f172a;
            font-size: 1.375rem;
            line-height: 1.05;
            font-weight: 700;
        }
        .kpi-insight {
            margin-top: 6px;
            font-size: 0.78rem;
            font-weight: 600;
            color: #64748b;
            line-height: 1.3;
        }
        .kpi-insight-positive { color: #047857; }
        .kpi-insight-negative { color: #b91c1c; }
        .filter-control {
            background: #f8fafc;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 10px 12px;
            color: #111827;
            width: 100%;
        }
        #loanModal select.filter-control option,
        #loanModal select.filter-control optgroup {
            background: #f8fafc;
            color: #111827;
        }
        #loanModal select.filter-control option:disabled {
            color: #64748b;
        }
        #loanModal .filter-control:focus,
        #loanModal button:focus,
        #loanSearch:focus,
        #loanStatusFilter:focus {
            outline: none !important;
            box-shadow: none !important;
        }
        .filter-control.field-invalid {
            border-color: #ef4444;
            box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.2);
        }
        #loanSimulationsPendingSection select.filter-control option,
        #loanSimulationsPendingSection select.filter-control optgroup {
            background: #f8fafc;
            color: #111827;
        }
        #loanSimulationsPendingSection select.filter-control option:disabled {
            color: #64748b;
        }
        .field-error {
            margin-top: 6px;
            font-size: 12px;
            color: #dc2626;
            display: none;
        }
        .field-error:not(:empty) { display: block; }

        .table-shell {
            overflow: auto;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
        }
        .table-shell table { width: 100%; border-collapse: collapse; }
        .table-shell th {
            text-align: left;
            background: #f8fafc;
            color: #64748b;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 12px 14px;
            border-bottom: 1px solid #e2e8f0;
        }
        .table-shell td { padding: 16px 14px; border-top: 1px solid #f1f5f9; color: #1f2937; }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 10px;
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
        }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-danger { background: #fee2e2; color: #991b1b; }
        .badge-warn { background: #fef3c7; color: #92400e; }
        .badge-neutral { background: #e2e8f0; color: #334155; }
        .badge-sim-draft {
            background: rgba(148, 163, 184, 0.2);
            color: #cbd5e1;
            border: 1px solid rgba(148, 163, 184, 0.45);
        }
        .badge-sim-sent {
            background: rgba(59, 130, 246, 0.2);
            color: #bfdbfe;
            border: 1px solid rgba(96, 165, 250, 0.5);
        }
        .badge-sim-accepted {
            background: rgba(16, 185, 129, 0.2);
            color: #a7f3d0;
            border: 1px solid rgba(52, 211, 153, 0.5);
        }
        .badge-sim-expired {
            background: rgba(245, 158, 11, 0.2);
            color: #fde68a;
            border: 1px solid rgba(251, 191, 36, 0.45);
        }
        .badge-sim-canceled {
            background: rgba(244, 63, 94, 0.2);
            color: #fecdd3;
            border: 1px solid rgba(251, 113, 133, 0.5);
        }

        .action-btn {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid transparent;
            transition: background-color 120ms ease-out, border-color 120ms ease-out;
        }
        .action-btn-view { color: #2563eb; }
        .action-btn-edit { color: #059669; }
        .action-btn-delete { color: #dc2626; }
        .action-btn-view:hover,
        .action-btn-edit:hover,
        .action-btn-delete:hover {
            background: #f1f5f9;
            border-color: #e2e8f0;
        }

        /* Keep action icon colors in loans table, without bright solid fills. */
        .dashboard-premium.dashboard-loans .action-btn.action-btn-view {
            color: #93c5fd !important;
            border-color: rgba(96, 165, 250, 0.42) !important;
            background: rgba(15, 23, 42, 0.48) !important;
        }
        .dashboard-premium.dashboard-loans .action-btn.action-btn-view:hover {
            color: #dbeafe !important;
            border-color: rgba(147, 197, 253, 0.6) !important;
            background: rgba(30, 41, 59, 0.82) !important;
            transform: none !important;
            box-shadow: none !important;
        }
        .dashboard-premium.dashboard-loans .action-btn.action-btn-edit {
            color: #6ee7b7 !important;
            border-color: rgba(52, 211, 153, 0.42) !important;
            background: rgba(6, 95, 70, 0.2) !important;
        }
        .dashboard-premium.dashboard-loans .action-btn.action-btn-edit:hover {
            color: #a7f3d0 !important;
            border-color: rgba(110, 231, 183, 0.58) !important;
            background: rgba(6, 95, 70, 0.34) !important;
            transform: none !important;
            box-shadow: none !important;
        }
        .dashboard-premium.dashboard-loans .action-btn.action-btn-delete {
            color: #fda4af !important;
            border-color: rgba(244, 63, 94, 0.44) !important;
            background: rgba(127, 29, 29, 0.22) !important;
        }
        .dashboard-premium.dashboard-loans .action-btn.action-btn-delete:hover {
            color: #fecdd3 !important;
            border-color: rgba(253, 164, 175, 0.6) !important;
            background: rgba(127, 29, 29, 0.38) !important;
            transform: none !important;
            box-shadow: none !important;
        }
        .dashboard-premium.dashboard-loans .action-btn.action-btn-edit[disabled],
        .dashboard-premium.dashboard-loans .action-btn.action-btn-edit[aria-disabled="true"] {
            color: #94a3b8 !important;
            border-color: rgba(100, 116, 139, 0.45) !important;
            background: rgba(30, 41, 59, 0.58) !important;
        }
        .dashboard-premium.dashboard-loans .action-btn.action-btn-edit[disabled]:hover,
        .dashboard-premium.dashboard-loans .action-btn.action-btn-edit[aria-disabled="true"]:hover {
            color: #94a3b8 !important;
            border-color: rgba(100, 116, 139, 0.45) !important;
            background: rgba(30, 41, 59, 0.58) !important;
            transform: none !important;
            box-shadow: none !important;
        }

        .loan-modal-panel {
            position: relative;
            overflow: hidden;
            border-radius: 18px;
            border: 1px solid rgba(148, 163, 184, 0.26);
            background:
                radial-gradient(95% 95% at 58% -12%, rgba(45, 212, 191, 0.18) 0%, rgba(45, 212, 191, 0) 58%),
                radial-gradient(70% 90% at 96% 100%, rgba(56, 189, 248, 0.12) 0%, rgba(56, 189, 248, 0) 62%),
                linear-gradient(165deg, rgba(5, 11, 26, 0.98) 0%, rgba(8, 19, 39, 0.97) 52%, rgba(6, 16, 34, 0.97) 100%);
            box-shadow: 0 34px 80px -32px rgba(2, 6, 23, 0.95), inset 0 1px 0 rgba(148, 163, 184, 0.1);
            max-width: min(1120px, 96vw);
        }

        .loan-modal-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: linear-gradient(180deg, rgba(148, 163, 184, 0.08) 0%, rgba(148, 163, 184, 0) 22%);
        }

        .dashboard-premium.dashboard-loans .loan-modal-panel .modal-base__header {
            position: relative;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18) !important;
            box-shadow: none !important;
            padding: 1.45rem 1.6rem 1rem;
        }

        .loan-modal-panel .modal-base__title {
            color: #f8fafc;
            letter-spacing: -0.02em;
        }

        .loan-modal-panel .modal-base__description {
            color: #9fb0c8;
        }

        .loan-modal-body {
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding-top: 0.2rem;
        }

        .dashboard-premium.dashboard-loans .loan-modal-panel .modal-base__body {
            border-top: none !important;
        }

        .dashboard-premium.dashboard-loans .loan-modal-panel .modal-base__footer {
            border-top: none !important;
            background: transparent !important;
            box-shadow: none !important;
            padding: 0.55rem 1.6rem 1.35rem;
        }

        .loan-modal-content-grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: 1rem;
            align-items: start;
        }

        .loan-modal-main {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 0.85rem;
        }

        .loan-form-section {
            border-top: none;
            padding-top: 0;
        }

        .loan-modal-main .loan-form-section {
            border-radius: 16px;
            border: 1px solid rgba(148, 163, 184, 0.2);
            background: rgba(15, 23, 42, 0.42);
            box-shadow: inset 0 1px 0 rgba(148, 163, 184, 0.08);
            padding: 0.95rem 1rem;
        }

        .loan-modal-main .loan-form-section + .loan-form-section {
            margin-top: 0;
        }

        .loan-form-section--wide {
            border-radius: 14px;
            border: 1px solid rgba(148, 163, 184, 0.2);
            background: rgba(15, 23, 42, 0.36);
            padding: 0.9rem 1rem;
        }

        .loan-form-kicker {
            margin-bottom: 0.72rem;
            color: #b6c4d8;
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .loan-form-grid-basic,
        .loan-form-grid-dates,
        .loan-form-grid-conditions {
            display: grid;
            grid-template-columns: repeat(1, minmax(0, 1fr));
            gap: 0.85rem;
        }

        @media (min-width: 768px) {
            .loan-form-grid-basic {
                grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
            }

            .loan-form-grid-dates {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .loan-form-grid-conditions {
                grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr) minmax(0, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .loan-modal-content-grid {
                grid-template-columns: minmax(0, 1.65fr) minmax(280px, 1fr);
                gap: 1.1rem;
            }
        }

        .loan-modal-panel .filter-control,
        .loan-modal-panel .app-input,
        .loan-modal-panel .app-select,
        .loan-modal-panel .app-textarea {
            width: 100%;
            border-radius: 12px;
            border: 1px solid rgba(148, 163, 184, 0.28);
            background: rgba(15, 23, 42, 0.72);
            color: #e2e8f0;
            transition: border-color 160ms ease-out, box-shadow 160ms ease-out, background-color 160ms ease-out;
        }

        .loan-modal-panel .filter-control,
        .loan-modal-panel .app-input,
        .loan-modal-panel .app-select {
            min-height: 44px;
        }

        .loan-modal-panel .app-textarea,
        .loan-modal-textarea {
            min-height: 96px;
            resize: vertical;
        }

        .loan-modal-panel .filter-control::placeholder,
        .loan-modal-panel .app-input::placeholder,
        .loan-modal-panel .app-textarea::placeholder {
            color: rgba(148, 163, 184, 0.9);
        }

        .loan-modal-panel .filter-control:hover,
        .loan-modal-panel .app-input:hover,
        .loan-modal-panel .app-select:hover,
        .loan-modal-panel .app-textarea:hover {
            border-color: rgba(203, 213, 225, 0.34);
        }

        .loan-modal-panel .filter-control:focus,
        .loan-modal-panel .app-input:focus,
        .loan-modal-panel .app-select:focus,
        .loan-modal-panel .app-textarea:focus {
            border-color: rgba(45, 212, 191, 0.82) !important;
            box-shadow: 0 0 0 4px rgba(45, 212, 191, 0.2) !important;
            outline: none !important;
        }

        .loan-modal-panel #loanInstallments.bg-slate-100 {
            background: rgba(15, 23, 42, 0.82) !important;
            border-color: rgba(148, 163, 184, 0.28) !important;
        }

        .loan-modal-panel #loanInstallments.cursor-not-allowed {
            opacity: 0.84;
        }

        .loan-modal-panel input[type="date"]::-webkit-calendar-picker-indicator {
            opacity: 0.75;
            filter: invert(0.86) brightness(1.05);
            cursor: pointer;
        }

        .loan-mode-toggle-row {
            display: flex;
            justify-content: flex-end;
            margin-top: 0.7rem;
        }

        @media (max-width: 767px) {
            .loan-mode-toggle-row {
                justify-content: flex-start;
            }
        }

        .loan-mode-helper {
            margin-top: 0.45rem;
            font-size: 0.79rem;
            color: #9fb0c8;
            line-height: 1.35;
        }

        #loanAutoModeHint {
            margin-top: 0.6rem;
            border-radius: 0.8rem;
            border: 1px solid rgba(45, 212, 191, 0.4);
            background: rgba(13, 39, 45, 0.4);
            padding: 0.55rem 0.72rem;
        }

        #loanAutoModeHint p:first-child {
            color: #8de8dd;
            font-size: 0.78rem;
        }

        #loanAutoModeHint p:last-child {
            color: #d7f8f4;
            font-size: 0.9rem;
            font-weight: 600;
            margin-top: 0.2rem;
        }

        #loanCalculationCard {
            border-radius: 16px;
            border: 1px solid rgba(148, 163, 184, 0.26);
            background: rgba(7, 18, 36, 0.66);
            box-shadow: inset 0 1px 0 rgba(148, 163, 184, 0.08);
            padding: 1rem 1.05rem;
            min-height: 100%;
        }

        .loan-summary-title {
            margin: 0;
            color: #f8fafc;
            font-size: 1.15rem;
            line-height: 1.2;
            font-weight: 700;
        }

        .loan-summary-list {
            margin-top: 0.95rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .loan-summary-item dt {
            font-size: 0.8rem;
            font-weight: 600;
            color: #9fb0c8;
        }

        .loan-summary-item dd {
            margin-top: 0.2rem;
            color: #f8fafc;
            font-size: 0.98rem;
            font-weight: 700;
            line-height: 1.3;
        }

        .loan-summary-item .loan-summary-installment {
            color: #bfe9ff;
        }

        .loan-summary-rate {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
        }

        .loan-summary-rate-main {
            color: #e2e8f0;
            font-size: 0.98rem;
            font-weight: 700;
        }

        .loan-summary-rate-sub {
            color: #9fb0c8;
            font-size: 0.82rem;
            font-weight: 500;
        }

        .loan-summary-mode {
            margin-top: 0.9rem;
            padding-top: 0.72rem;
            border-top: 1px solid rgba(148, 163, 184, 0.18);
            color: #9fb0c8;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .loan-inline-actions {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .loan-inline-btn {
            height: 2.2rem;
            border-radius: 0.65rem;
            border: 1px solid rgba(148, 163, 184, 0.35);
            background: rgba(15, 23, 42, 0.6);
            color: #dbeafe;
            font-size: 0.76rem;
            font-weight: 700;
            padding: 0 0.75rem;
            transition: background-color 140ms ease-out, border-color 140ms ease-out;
        }

        .loan-inline-btn:hover {
            background: rgba(30, 41, 59, 0.74);
            border-color: rgba(147, 197, 253, 0.42);
        }

        .loan-schedule-shell {
            overflow-x: auto;
            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 0.75rem;
            background: rgba(15, 23, 42, 0.3);
        }

        .loan-action-row {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 0.75rem;
            border-top: none;
            padding-top: 0.25rem;
        }

        .loan-modal-save-btn {
            min-width: 230px;
            height: 2.9rem;
        }

        .dashboard-premium.dashboard-loans #loanModal .flatpickr-calendar {
            z-index: 120 !important;
        }
        .loan-date-alt-input {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            background: #f8fafc;
            padding: 10px 12px;
            color: #111827;
            line-height: 1.3;
        }
        .loan-date-alt-input:focus {
            outline: none;
            border-color: #93c5fd;
            box-shadow: 0 0 0 1px rgba(147, 197, 253, 0.2);
        }
        .loan-date-alt-input--compact {
            border-radius: 8px;
            padding: 6px 8px;
            font-size: 12px;
        }
        .loan-preview-date-input {
            width: 0;
            height: 0;
            opacity: 0;
            pointer-events: none;
            border: 0;
            padding: 0;
            margin: 0;
        }
        .dashboard-premium.dashboard-loans .flatpickr-calendar {
            border-radius: 12px !important;
            border: 1px solid rgba(100, 116, 139, 0.38) !important;
            background: #0b1730 !important;
            box-shadow: 0 18px 38px rgba(2, 6, 23, 0.62) !important;
            color: #e2e8f0 !important;
            z-index: 9999 !important;
            width: 276px !important;
            font-size: 13px !important;
        }
        .dashboard-premium.dashboard-loans .flatpickr-months {
            background: #0b1730 !important;
            border-bottom: 1px solid rgba(100, 116, 139, 0.32) !important;
            height: 40px !important;
        }
        .dashboard-premium.dashboard-loans .flatpickr-current-month {
            color: #e2e8f0 !important;
            padding-top: 6px !important;
            font-size: 15px !important;
        }
        .dashboard-premium.dashboard-loans .flatpickr-current-month .cur-month,
        .dashboard-premium.dashboard-loans .flatpickr-current-month input.cur-year {
            color: #e2e8f0 !important;
            font-weight: 600 !important;
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
        }
        .dashboard-premium.dashboard-loans .flatpickr-current-month .flatpickr-monthDropdown-months,
        .dashboard-premium.dashboard-loans .flatpickr-current-month .flatpickr-monthDropdown-month {
            background: transparent !important;
            color: #e2e8f0 !important;
            border: none !important;
            box-shadow: none !important;
            -webkit-appearance: none;
            appearance: none;
        }
        .dashboard-premium.dashboard-loans .flatpickr-prev-month svg,
        .dashboard-premium.dashboard-loans .flatpickr-next-month svg {
            fill: #cbd5e1 !important;
            width: 13px !important;
            height: 13px !important;
        }
        .dashboard-premium.dashboard-loans .flatpickr-weekdays {
            background: #0b1730 !important;
            border-bottom: 1px solid rgba(100, 116, 139, 0.2) !important;
            height: 30px !important;
        }
