    <script>window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;</script>
    <script>
        const currentUser = window.__AUTH_USER__;
        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            const displayName = currentUser.name || currentUser.full_name || 'Administrador';
            document.getElementById('userName').textContent = `Olá, ${displayName}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const sidebarLinks = document.querySelectorAll('#sidebar .sidebar-item');
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');

        const tableCache = {};
        function getDemoTable(tableName) {
            return Array.isArray(tableCache[tableName]) ? tableCache[tableName] : [];
        }

        async function fetchTableData(tableName) {
            try {
                const response = await fetch(`/api/tables/${tableName}`, { credentials: 'include' });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const payload = await response.json();
                if (Array.isArray(payload?.data)) {
                    tableCache[tableName] = payload.data;
                    return payload.data;
                }
            } catch (error) {
                console.warn(`Fallback para dados demo: ${tableName}`, error);
            }
            return getDemoTable(tableName);
        }

        async function saveTableData(tableName, rows) {
            const safeRows = Array.isArray(rows) ? rows : [];
            const serializedRows = tableName === 'loans'
                ? safeRows.map((row) => {
                    const parsed = parseLoanMeta(row?.observations ?? row?.notes ?? '');
                    const rowMeta = row?.loan_meta && typeof row.loan_meta === 'object' ? row.loan_meta : null;
                    const baseMeta = rowMeta || parsed.meta || null;
                    const interestMode = normalizeInterestType(baseMeta?.interestMode || row?.interest_type);
                    const fixedAddition = interestMode === 'fixo'
                        ? round2(baseMeta?.fixedAddition ?? row?.interest_rate)
                        : 0;
                    const mergedMeta = {
                        ...(baseMeta && typeof baseMeta === 'object' ? baseMeta : {}),
                        interestMode,
                        fixedAddition,
                    };

                    return {
                        ...row,
                        // O backend persiste apenas simples/composto; modo fixo segue no meta de observacoes.
                        interest_type: interestMode === 'fixo' ? 'composto' : interestMode,
                        observations: encodeLoanObservations(parsed.userText, mergedMeta),
                    };
                })
                : safeRows;

            tableCache[tableName] = serializedRows;

            const response = await fetch(`/api/tables/${tableName}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ rows: serializedRows })
            });

            if (!response.ok) {
                let details = `HTTP ${response.status}`;
                try {
                    const errorPayload = await response.json();
                    if (errorPayload && typeof errorPayload.message === 'string' && errorPayload.message.trim()) {
                        details = errorPayload.message.trim();
                    }
                } catch (error) {
                    // Mantem o fallback com status HTTP quando nao houver JSON de erro.
                }
                throw new Error(`Falha ao salvar ${tableName}: ${details}`);
            }

            const payload = await response.json().catch(() => null);
            if (Array.isArray(payload?.data)) {
                tableCache[tableName] = payload.data;
            }

            return tableCache[tableName];
        }

        function setActiveSidebarItem(targetHref) {
            sidebarLinks.forEach(link => {
                const isActive = link.getAttribute('href') === targetHref;
                link.classList.toggle('active', isActive);
                if (isActive) link.setAttribute('aria-current', 'page');
                else link.removeAttribute('aria-current');
            });
        }

        function syncActiveSidebarWithRoute() {
            const currentPage = window.location.pathname.split('/').pop() || 'loans.html';
            setActiveSidebarItem(currentPage);
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            sidebar.classList.remove('mobile-open');
            if (document.body.classList.contains('sidebar-collapsed')) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }

            main.style.marginLeft = '16rem';
            main.style.width = 'calc(100% - 16rem)';
            main.style.flex = '0 1 calc(100% - 16rem)';
        }

        sidebarToggle.addEventListener('click', function() {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();
        syncActiveSidebarWithRoute();

        function closeUserMenu() {
            if (!userMenuDropdown) return;
            userMenuDropdown.classList.add('hidden');
        }

        function showUserMenuNotice(message) {
            if (typeof showMessage === 'function') {
                showMessage(message, 'success');
                return;
            }
            window.alert(message);
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        async function handleUserMenuAction(action) {
            if (action === 'logout') {
                await performLogout();
                return;
            }

            const allowedTabs = new Set(['profile', 'security', 'help']);
            const destination = allowedTabs.has(action) ? action : 'profile';
            window.location.href = `/admin/account.html?tab=${encodeURIComponent(destination)}`;
        }

        if (userMenuBtn && userMenuDropdown) {
            userMenuBtn.addEventListener('click', (event) => {
                event.stopPropagation();
                userMenuDropdown.classList.toggle('hidden');
            });

            userMenuDropdown.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Element)) return;
                const actionBtn = target.closest('[data-user-menu-action]');
                if (!actionBtn) return;
                const action = actionBtn.getAttribute('data-user-menu-action');
                closeUserMenu();
                void handleUserMenuAction(action);
            });

            document.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Node)) return;
                if (userMenuDropdown.classList.contains('hidden')) return;
                if (userMenuDropdown.contains(target) || userMenuBtn.contains(target)) return;
                closeUserMenu();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeUserMenu();
            });
        }

        const loansState = {
            loans: [],
            debtors: [],
            installments: [],
            filtered: [],
            currentPage: 1,
            pageSize: 8,
            editingLoanId: null,
            expandedLoanIds: new Set()
        };

        const loanModal = document.getElementById('loanModal');
        const loanDetailsModal = document.getElementById('loanDetailsModal');
        const deleteLoanConfirmModal = document.getElementById('deleteLoanConfirmModal');
        const loanForm = document.getElementById('loanForm');
        const loanCalculationCard = document.getElementById('loanCalculationCard');
        const installmentsPreviewCard = document.getElementById('installmentsPreviewCard');
        const installmentsPreviewList = document.getElementById('installmentsPreviewList');
        const loanScheduleBody = document.getElementById('loanScheduleBody');
        const loansMobileList = document.getElementById('loansMobileList');
        const loanOpenedModalIds = new Set();
        let previousBodyOverflow = '';
        let pendingDeleteLoanId = null;

        const LOAN_META_START = '[[LOAN_META]]';
        const LOAN_META_END = '[[/LOAN_META]]';

        const loanFormState = {
            schedule: [],
            simulation: null,
            firstDueTouched: false
        };

        const loanFieldElements = {
            debtorId: document.getElementById('loanDebtor'),
            principal: document.getElementById('loanPrincipal'),
            interestType: document.getElementById('loanInterestType'),
            interestRate: document.getElementById('loanInterestRate'),
            fixedAddition: document.getElementById('loanFixedAddition'),
            installments: document.getElementById('loanInstallments'),
            startDate: document.getElementById('loanStartDate'),
            firstDueDate: document.getElementById('loanFirstDueDate')
        };

        const loanFieldErrorIds = {
            debtorId: 'loanDebtorError',
            principal: 'loanPrincipalError',
            interestType: 'loanInterestTypeError',
            interestRate: 'loanInterestRateError',
            fixedAddition: 'loanFixedAdditionError',
            installments: 'loanInstallmentsError',
            startDate: 'loanStartDateError',
            firstDueDate: 'loanFirstDueDateError'
        };

        function sameId(a, b) {
            return String(a ?? '') === String(b ?? '');
        }

        function toNumber(value) {
            const parsed = Number(value);
            return Number.isFinite(parsed) ? parsed : 0;
        }

        function round2(value) {
            return Math.round((toNumber(value) + Number.EPSILON) * 100) / 100;
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(toNumber(value));
        }

        function parseCurrencyInput(value) {
            const raw = String(value ?? '').trim();
            if (!raw) return 0;

            const sanitized = raw
                .replace(/\s+/g, '')
                .replace(/R\$/gi, '')
                .replace(/[^\d,.-]/g, '');

            const commaIndex = sanitized.lastIndexOf(',');
            const dotIndex = sanitized.lastIndexOf('.');
            let normalized = sanitized;

            if (commaIndex >= 0 && dotIndex >= 0) {
                if (commaIndex > dotIndex) {
                    normalized = sanitized.replace(/\./g, '').replace(',', '.');
                } else {
                    normalized = sanitized.replace(/,/g, '');
                }
            } else if (commaIndex >= 0) {
                normalized = sanitized.replace(/\./g, '').replace(',', '.');
            } else {
                normalized = sanitized.replace(/,/g, '');
            }

            const parsed = Number(normalized);
            return Number.isFinite(parsed) ? parsed : 0;
        }

        function formatCurrencyInput(value) {
            const parsed = parseCurrencyInput(value);
            if (parsed <= 0) return '';
            return parsed.toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            });
        }

        function formatDate(value) {
            if (!value) return '-';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '-';
            return date.toLocaleDateString('pt-BR');
        }

        function toIsoDate(value) {
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '';
            return date.toISOString().slice(0, 10);
        }

        function startOfDay(value) {
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return null;
            date.setHours(0, 0, 0, 0);
            return date;
        }

        function getMonthEquivalentBounds(referenceDate = new Date(), offsetMonths = 0) {
            const reference = startOfDay(referenceDate);
            if (!reference) return { start: null, end: null };

            const start = new Date(reference.getFullYear(), reference.getMonth() + offsetMonths, 1);
            start.setHours(0, 0, 0, 0);

            if (offsetMonths === 0) {
                return { start, end: reference };
            }

            const targetMonthLastDay = new Date(start.getFullYear(), start.getMonth() + 1, 0).getDate();
            const boundedDay = Math.min(reference.getDate(), targetMonthLastDay);
            const end = new Date(start.getFullYear(), start.getMonth(), boundedDay);
            end.setHours(0, 0, 0, 0);
            return { start, end };
        }

        function shiftRangeByYears(start, end, years = -1) {
            const safeStart = startOfDay(start);
            const safeEnd = startOfDay(end);
            if (!safeStart || !safeEnd || safeEnd < safeStart) return { start: null, end: null };

            const shiftedStart = new Date(safeStart.getFullYear() + years, safeStart.getMonth(), safeStart.getDate());
            const shiftedEnd = new Date(safeEnd.getFullYear() + years, safeEnd.getMonth(), safeEnd.getDate());
            shiftedStart.setHours(0, 0, 0, 0);
            shiftedEnd.setHours(0, 0, 0, 0);
            return { start: shiftedStart, end: shiftedEnd };
        }

        function isDateInRange(value, start, end) {
            const date = startOfDay(value);
            if (!date || !start || !end) return false;
            return date >= start && date <= end;
        }

        function getComparisonPercent(currentValue, baselineValue, minRobustBase = 0) {
            const current = Number.isFinite(Number(currentValue)) ? Number(currentValue) : 0;
            const baseline = Number.isFinite(Number(baselineValue)) ? Number(baselineValue) : 0;
            if (Math.abs(baseline) < Math.max(0, Number(minRobustBase) || 0)) return null;
            return ((current - baseline) / Math.abs(baseline)) * 100;
        }

        function formatPercentMagnitude(percentValue) {
            return Math.abs(percentValue).toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            });
        }

        function getInsightTone(percentValue, invert = false) {
            if (!Number.isFinite(percentValue) || Math.abs(percentValue) < 0.005) return 'neutral';
            const isPositive = percentValue > 0;
            if (invert) return isPositive ? 'negative' : 'positive';
            return isPositive ? 'positive' : 'negative';
        }

        function formatPrimaryInsightText(percentValue, label) {
            if (!Number.isFinite(percentValue) || Math.abs(percentValue) < 0.005) {
                return `0,00% ${label}`;
            }
            return `${percentValue > 0 ? '↑' : '↓'} ${formatPercentMagnitude(percentValue)}% ${label}`;
        }

        function formatSecondaryInsightText(percentValue, label) {
            if (!Number.isFinite(percentValue) || Math.abs(percentValue) < 0.005) {
                return `${label}: 0,00%`;
            }
            return `${label}: ${percentValue > 0 ? '+' : '-'}${formatPercentMagnitude(percentValue)}%`;
        }

        function buildSmartKpiInsight(currentValue, comparisons, options = {}) {
            const {
                invert = false,
                minRobustBase = 0,
            } = options;

            const average3Pct = getComparisonPercent(currentValue, comparisons?.average3, minRobustBase);
            const previousPct = getComparisonPercent(currentValue, comparisons?.previous, minRobustBase);
            const yearAgoPct = getComparisonPercent(currentValue, comparisons?.yearAgo, minRobustBase);

            const primary = Number.isFinite(average3Pct)
                ? { key: 'average3', pct: average3Pct, label: 'vs média 3M' }
                : Number.isFinite(previousPct)
                    ? { key: 'previous', pct: previousPct, label: 'vs M-1' }
                    : Number.isFinite(yearAgoPct)
                        ? { key: 'yearAgo', pct: yearAgoPct, label: 'vs A/A' }
                        : null;

            if (!primary) {
                return { tone: 'neutral', text: 'sem base robusta para comparação' };
            }

            const secondary = [];
            if (primary.key !== 'previous' && Number.isFinite(previousPct)) {
                secondary.push(formatSecondaryInsightText(previousPct, 'M-1'));
            }
            if (primary.key !== 'yearAgo' && Number.isFinite(yearAgoPct)) {
                secondary.push(formatSecondaryInsightText(yearAgoPct, 'A/A'));
            }
            if (primary.key !== 'average3' && Number.isFinite(average3Pct)) {
                secondary.unshift(formatSecondaryInsightText(average3Pct, '3M'));
            }

            let text = formatPrimaryInsightText(primary.pct, primary.label);
            if (secondary.length) {
                text += ` | ${secondary.join(' | ')}`;
            }

            return {
                tone: getInsightTone(primary.pct, invert),
                text,
            };
        }

        function renderKpiInsight(elementId, prefixText, insight) {
            const element = document.getElementById(elementId);
            if (!element) return;
            element.classList.remove('kpi-insight-positive', 'kpi-insight-negative');
            if (insight?.tone === 'positive') element.classList.add('kpi-insight-positive');
            if (insight?.tone === 'negative') element.classList.add('kpi-insight-negative');
            element.textContent = prefixText ? `${prefixText} ${insight?.text || ''}` : (insight?.text || '--');
        }

        function normalizeLoanStatus(status) {
            if (!status) return 'Ativo';
            const s = String(status).trim().toLowerCase();
            if (s.includes('inativ') || s.includes('final') || s.includes('quit')) return 'Inativo';
            if (s.includes('ativo') || s.includes('aberto') || s.includes('pendente') || s.includes('atras')) return 'Ativo';
            return 'Ativo';
        }

        function normalizeInterestType(value) {
            const s = String(value || '').trim().toLowerCase();
            if (s === 'simples') return 'simples';
            if (s === 'fixo') return 'fixo';
            return 'composto';
        }

        function formatInterestTypeLabel(type) {
            if (type === 'simples') return 'Simples';
            if (type === 'fixo') return 'Fixo';
            return 'Composto';
        }

        function stripLoanMeta(rawText) {
            const text = String(rawText || '');
            const start = text.indexOf(LOAN_META_START);
            const end = text.indexOf(LOAN_META_END);
            if (start === -1 || end === -1 || end <= start) return text.trim();
            return `${text.slice(0, start)}${text.slice(end + LOAN_META_END.length)}`.trim();
        }

        function parseLoanMeta(rawText) {
            const text = String(rawText || '');
            const start = text.indexOf(LOAN_META_START);
            const end = text.indexOf(LOAN_META_END);
            if (start === -1 || end === -1 || end <= start) {
                return { userText: text.trim(), meta: null };
            }

            const metaRaw = text.slice(start + LOAN_META_START.length, end).trim();
            let meta = null;
            try {
                meta = JSON.parse(metaRaw);
            } catch (_error) {
                meta = null;
            }

            const userText = `${text.slice(0, start)}${text.slice(end + LOAN_META_END.length)}`.trim();
            return { userText, meta };
        }

        function encodeLoanObservations(userText, meta) {
            const cleanText = stripLoanMeta(userText || '');
            if (!meta || typeof meta !== 'object') return cleanText;
            const encodedMeta = `${LOAN_META_START}${JSON.stringify(meta)}${LOAN_META_END}`;
            if (!cleanText) return encodedMeta;
            return `${cleanText}\n${encodedMeta}`;
        }

        function normalizeLoanRow(row) {
            const installmentsCount = toNumber(row.installments_count ?? row.installments ?? row.total_installments ?? 0);
            const principalAmount = round2(row.principal_amount ?? row.principal ?? row.amount ?? 0);
            const totalAmount = round2(row.total_amount ?? row.total ?? row.contract_amount ?? 0);
            const interestRate = round2(row.interest_rate ?? row.interest ?? row.monthly_interest ?? 0);
            const installmentAmount = installmentsCount > 0 ? round2(row.installment_amount ?? (totalAmount / installmentsCount)) : 0;
            const parsed = parseLoanMeta(row.observations || row.notes || '');
            const storedMode = normalizeInterestType(parsed.meta?.interestMode || row.interest_type);
            const inferredFixedByTotals = storedMode === 'composto'
                && !parsed.meta?.interestMode
                && interestRate > 0
                && totalAmount >= principalAmount
                && Math.abs(round2(totalAmount - principalAmount) - interestRate) <= 0.01;
            const interestMode = inferredFixedByTotals ? 'fixo' : storedMode;
            const loanMeta = {
                ...(parsed.meta && typeof parsed.meta === 'object' ? parsed.meta : {}),
                interestMode,
                fixedAddition: interestMode === 'fixo'
                    ? round2(parsed.meta?.fixedAddition ?? interestRate)
                    : 0,
            };

            return {
                ...row,
                id: row.id,
                debtor_id: row.debtor_id,
                principal_amount: principalAmount,
                total_amount: totalAmount,
                installments_count: installmentsCount,
                interest_rate: interestRate,
                installment_amount: installmentAmount,
                interest_type: interestMode,
                payment_method: row.payment_method || 'Pix',
                observations: parsed.userText,
                loan_meta: loanMeta,
                status: normalizeLoanStatus(row.status),
                start_date: row.start_date || row.created_at || '',
                first_due_date: row.first_due_date || row.due_date || ''
            };
        }

        function badgeForStatus(status) {
            if (status === 'Ativo') return 'badge bg-emerald-100 text-emerald-700';
            if (status === 'Inativo') return 'badge bg-slate-200 text-slate-700';
            return 'badge bg-emerald-100 text-emerald-700';
        }

        function getDebtorName(debtorId) {
            const debtor = loansState.debtors.find(item => sameId(item.id, debtorId));
            return debtor?.name || debtor?.full_name || 'Cliente não identificado';
        }

        function addMonths(date, count) {
            const copy = new Date(date.getTime());
            copy.setMonth(copy.getMonth() + count);
            return copy;
        }

        function getTodayIsoDate() {
            return new Date().toISOString().slice(0, 10);
        }

        function splitAmount(total, parts) {
            const safeParts = Math.max(1, toNumber(parts));
            const cents = Math.round(round2(total) * 100);
            const base = Math.floor(cents / safeParts);
            const remainder = cents - base * safeParts;

            return Array.from({ length: safeParts }, (_, index) => {
                const current = base + (index === safeParts - 1 ? remainder : 0);
                return round2(current / 100);
            });
        }

        function calculateLoanValues(principal, ratePercent, installmentsCount, interestType) {
            const p = round2(principal);
            const r = toNumber(ratePercent) / 100;
            const n = Math.max(1, Math.trunc(toNumber(installmentsCount)));

            if (p <= 0 || n <= 0 || r < 0) return null;

            if (interestType === 'simples') {
                const totalInterest = round2(p * r * n);
                const totalAmount = round2(p + totalInterest);
                const installmentAmount = round2(totalAmount / n);
                return { totalAmount, installmentAmount, totalInterest };
            }

            if (r === 0) {
                const totalAmount = p;
                const installmentAmount = round2(p / n);
                return { totalAmount, installmentAmount, totalInterest: 0 };
            }

            const factor = Math.pow(1 + r, n);
            const installmentAmount = round2((p * r * factor) / (factor - 1));
            const totalAmount = round2(installmentAmount * n);
            const totalInterest = round2(totalAmount - p);
            return { totalAmount, installmentAmount, totalInterest };
        }

        function buildInstallmentPlan(values, calcResult, scheduleRows) {
            const n = values.installments;
            const monthlyRate = values.interestRate / 100;
            const today = new Date(getTodayIsoDate());
            const plan = [];
            const dueDates = (Array.isArray(scheduleRows) ? scheduleRows : []).map((item, index) => {
                const parsed = new Date(item?.due_date);
                if (!Number.isNaN(parsed.getTime())) return parsed;
                const fallback = getDueDateByFrequency(values.firstDueDate, index);
                return fallback || new Date(values.firstDueDate);
            });

            while (dueDates.length < n) {
                const index = dueDates.length;
                const fallback = getDueDateByFrequency(values.firstDueDate, index);
                dueDates.push(fallback || new Date(values.firstDueDate));
            }

            if (values.interestType === 'simples') {
                const principalParts = splitAmount(values.principal, n);
                const interestParts = splitAmount(calcResult.totalInterest, n);

                for (let index = 0; index < n; index += 1) {
                    const due = dueDates[index];
                    const amount = round2(principalParts[index] + interestParts[index]);
                    plan.push({
                        installment_number: index + 1,
                        amount,
                        principal_amount: principalParts[index],
                        interest_amount: interestParts[index],
                        due_date: toIsoDate(due),
                        status: due < today ? 'Atrasado' : 'Pendente',
                        payment_date: null
                    });
                }
                return plan;
            }

            const amounts = splitAmount(calcResult.totalAmount, n);
            let remainingPrincipal = round2(values.principal);

            for (let index = 0; index < n; index += 1) {
                const due = dueDates[index];
                const amount = amounts[index];

                let interestAmount = values.interestRate === 0 ? 0 : round2(remainingPrincipal * monthlyRate);
                let principalAmount = round2(amount - interestAmount);

                if (index === n - 1) {
                    principalAmount = round2(remainingPrincipal);
                    interestAmount = round2(amount - principalAmount);
                }

                remainingPrincipal = round2(remainingPrincipal - principalAmount);
                if (remainingPrincipal < 0) remainingPrincipal = 0;

                plan.push({
                    installment_number: index + 1,
                    amount,
                    principal_amount: principalAmount,
                    interest_amount: interestAmount,
                    due_date: toIsoDate(due),
                    status: due < today ? 'Atrasado' : 'Pendente',
                    payment_date: null
                });
            }

            return plan;
        }

        function deriveLoanStatus(plan) {
            if (!plan.length) return 'Ativo';
            const allPaid = plan.every(item => isPaidInstallmentStatus(item.status));
            return allPaid ? 'Inativo' : 'Ativo';
        }

        function getLoanInstallments(loanId) {
            return loansState.installments
                .filter(item => sameId(item.loan_id, loanId))
                .sort((a, b) => toNumber(a.installment_number) - toNumber(b.installment_number));
        }

        function getLoanInstallmentsSummary(loan) {
            const installments = getLoanInstallments(loan.id);
            const total = loan.installments_count || installments.length;
            if (!total) return '-';

            const paid = installments.filter(item => String(item.status || '').toLowerCase() === 'pago').length;
            return `${paid}/${total}`;
        }

        function isPaidInstallmentStatus(status) {
            const normalized = String(status || '').trim().toLowerCase();
            return normalized === 'pago' || normalized === 'paid' || normalized === 'quitado' || normalized === 'finalizado';
        }

        function getLoanFinancialSituation(installments) {
            const rows = Array.isArray(installments) ? installments : [];
            if (!rows.length) {
                return { label: 'Em dia', badgeClass: 'badge bg-emerald-100 text-emerald-700' };
            }

            const allPaid = rows.every(item => isPaidInstallmentStatus(item.status));
            if (allPaid) {
                return { label: 'Em dia', badgeClass: 'badge bg-emerald-100 text-emerald-700' };
            }

            const today = new Date(getTodayIsoDate());
            const hasOverdueOpen = rows.some(item => {
                if (isPaidInstallmentStatus(item.status)) return false;
                const dueDate = new Date(item.due_date);
                if (Number.isNaN(dueDate.getTime())) return false;
                return dueDate < today;
            });

            if (hasOverdueOpen) {
                return { label: 'Atrasado', badgeClass: 'badge bg-red-100 text-red-700' };
            }

            return { label: 'Em dia', badgeClass: 'badge bg-emerald-100 text-emerald-700' };
        }

        function updateLoanMetrics() {
            const total = loansState.loans.length;
            const principal = loansState.loans.reduce((acc, loan) => acc + toNumber(loan.principal_amount), 0);
            const contracted = loansState.loans.reduce((acc, loan) => acc + toNumber(loan.total_amount), 0);
            const active = loansState.loans.filter(loan => normalizeLoanStatus(loan.status) === 'Ativo').length;

            document.getElementById('totalLoans').textContent = String(total);
            document.getElementById('totalPrincipal').textContent = formatCurrency(principal);
            document.getElementById('totalContracted').textContent = formatCurrency(contracted);
            document.getElementById('activeLoans').textContent = String(active);

            const referenceDate = startOfDay(new Date());
            const currentRange = getMonthEquivalentBounds(referenceDate, 0);
            const previousRange = getMonthEquivalentBounds(referenceDate, -1);
            const monthMinus2Range = getMonthEquivalentBounds(referenceDate, -2);
            const monthMinus3Range = getMonthEquivalentBounds(referenceDate, -3);
            const yearAgoRange = shiftRangeByYears(currentRange.start, currentRange.end, -1);

            const getLoansByRange = (range) => loansState.loans.filter((loan) => isDateInRange(loan.start_date, range?.start, range?.end));
            const summarizeRange = (rows) => ({
                loansCount: rows.length,
                principalAmount: rows.reduce((sum, loan) => sum + toNumber(loan.principal_amount), 0),
                contractedAmount: rows.reduce((sum, loan) => sum + toNumber(loan.total_amount), 0),
                activeCreatedCount: rows.filter((loan) => normalizeLoanStatus(loan.status) === 'Ativo').length,
            });

            const currentSummary = summarizeRange(getLoansByRange(currentRange));
            const previousSummary = summarizeRange(getLoansByRange(previousRange));
            const monthMinus2Summary = summarizeRange(getLoansByRange(monthMinus2Range));
            const monthMinus3Summary = summarizeRange(getLoansByRange(monthMinus3Range));
            const yearAgoSummary = summarizeRange(getLoansByRange(yearAgoRange));

            const average3Summary = {
                loansCount: (previousSummary.loansCount + monthMinus2Summary.loansCount + monthMinus3Summary.loansCount) / 3,
                principalAmount: (previousSummary.principalAmount + monthMinus2Summary.principalAmount + monthMinus3Summary.principalAmount) / 3,
                contractedAmount: (previousSummary.contractedAmount + monthMinus2Summary.contractedAmount + monthMinus3Summary.contractedAmount) / 3,
                activeCreatedCount: (previousSummary.activeCreatedCount + monthMinus2Summary.activeCreatedCount + monthMinus3Summary.activeCreatedCount) / 3,
            };

            renderKpiInsight(
                'totalLoansInsight',
                `Novos no mês: ${currentSummary.loansCount.toLocaleString('pt-BR')} |`,
                buildSmartKpiInsight(currentSummary.loansCount, {
                    average3: average3Summary.loansCount,
                    previous: previousSummary.loansCount,
                    yearAgo: yearAgoSummary.loansCount,
                }, { minRobustBase: 1 })
            );
            renderKpiInsight(
                'totalPrincipalInsight',
                `Liberado no mês: ${formatCurrency(currentSummary.principalAmount)} |`,
                buildSmartKpiInsight(currentSummary.principalAmount, {
                    average3: average3Summary.principalAmount,
                    previous: previousSummary.principalAmount,
                    yearAgo: yearAgoSummary.principalAmount,
                }, { minRobustBase: 50 })
            );
            renderKpiInsight(
                'totalContractedInsight',
                `Contratado no mês: ${formatCurrency(currentSummary.contractedAmount)} |`,
                buildSmartKpiInsight(currentSummary.contractedAmount, {
                    average3: average3Summary.contractedAmount,
                    previous: previousSummary.contractedAmount,
                    yearAgo: yearAgoSummary.contractedAmount,
                }, { minRobustBase: 50 })
            );
            renderKpiInsight(
                'activeLoansInsight',
                `Ativos novos no mês: ${currentSummary.activeCreatedCount.toLocaleString('pt-BR')} |`,
                buildSmartKpiInsight(currentSummary.activeCreatedCount, {
                    average3: average3Summary.activeCreatedCount,
                    previous: previousSummary.activeCreatedCount,
                    yearAgo: yearAgoSummary.activeCreatedCount,
                }, { minRobustBase: 1 })
            );
        }

        function updatePaginationInfo(total) {
            const totalPages = Math.max(1, Math.ceil(total / loansState.pageSize));
            if (loansState.currentPage > totalPages) {
                loansState.currentPage = totalPages;
            }

            const start = total === 0 ? 0 : (loansState.currentPage - 1) * loansState.pageSize + 1;
            const end = total === 0 ? 0 : Math.min(start + loansState.pageSize - 1, total);

            document.getElementById('showingStart').textContent = String(start);
            document.getElementById('showingEnd').textContent = String(end);
            document.getElementById('totalResults').textContent = String(total);
            document.getElementById('pageIndicator').textContent = `Página ${loansState.currentPage} de ${totalPages}`;

            const prevPageBtn = document.getElementById('prevPageBtn');
            const nextPageBtn = document.getElementById('nextPageBtn');
            prevPageBtn.disabled = loansState.currentPage <= 1;
            nextPageBtn.disabled = loansState.currentPage >= totalPages;
            prevPageBtn.classList.toggle('opacity-50', prevPageBtn.disabled);
            nextPageBtn.classList.toggle('opacity-50', nextPageBtn.disabled);
        }

        function isLoanDetailExpanded(loanId) {
            return loansState.expandedLoanIds.has(String(loanId));
        }

        function setLoanDetailExpanded(loanId, expanded) {
            const key = String(loanId || '');
            if (!key) return;

            if (expanded) {
                loansState.expandedLoanIds.add(key);
            } else {
                loansState.expandedLoanIds.delete(key);
            }

            const detailNodes = document.querySelectorAll(`[data-loan-detail-for="${key}"]`);
            const toggleButtons = document.querySelectorAll(`#loansMobileList button[data-action="view-loan"][data-id="${key}"]`);

            detailNodes.forEach((node) => {
                node.classList.toggle('hidden', !expanded);
            });

            toggleButtons.forEach((button) => {
                button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
                button.setAttribute('title', expanded ? 'Fechar detalhes' : 'Ver detalhes');
                const icon = button.querySelector('i');
                if (icon) {
                    icon.classList.toggle('fa-eye', !expanded);
                    icon.classList.toggle('fa-eye-slash', expanded);
                }
            });
        }

        function toggleLoanDetail(loanId) {
            const expanded = isLoanDetailExpanded(loanId);
            setLoanDetailExpanded(loanId, !expanded);
        }

        function renderLoansMobileList(pageRows) {
            if (!loansMobileList) return;

            loansMobileList.innerHTML = pageRows.map((loan) => {
                const status = normalizeLoanStatus(loan.status);
                const installments = getLoanInstallments(loan.id);
                const installmentsInfo = getLoanInstallmentsSummary(loan);
                const financialSituation = getLoanFinancialSituation(installments);
                const interestType = normalizeInterestType(loan.interest_type);
                const interestPrimary = interestType === 'fixo'
                    ? formatCurrency(loan.interest_rate)
                    : `${loan.interest_rate}%`;
                const interestTypeLabel = formatInterestTypeLabel(interestType);
                const totalInstallments = toNumber(loan.installments_count || installments.length);
                const paidInstallments = installments.filter(item => isPaidInstallmentStatus(item.status)).length;
                const pendingInstallments = Math.max(0, totalInstallments - paidInstallments);
                const nextOpenInstallment = installments.find(item => !isPaidInstallmentStatus(item.status));
                const nextDueLabel = nextOpenInstallment
                    ? `${formatDate(nextOpenInstallment.due_date)} | ${formatCurrency(nextOpenInstallment.amount)}`
                    : '&mdash;';
                const isExpanded = isLoanDetailExpanded(loan.id);

                return `
                    <div class="rounded-2xl border border-gray-200 bg-slate-50 p-4 shadow-sm" data-loan-id="${loan.id}" aria-expanded="${isExpanded ? 'true' : 'false'}">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <div class="text-[11px] uppercase tracking-wide text-gray-500">Empréstimo #${loan.id ?? '-'}</div>
                                <div class="mt-1 truncate text-base font-semibold text-gray-900">${getDebtorName(loan.debtor_id)}</div>
                            </div>
                            <div class="text-right">
                                <div class="text-[11px] uppercase tracking-wide text-gray-500">Total</div>
                                <div class="mt-1 text-base font-extrabold text-gray-900">${formatCurrency(loan.total_amount)}</div>
                            </div>
                        </div>

                        <div class="mt-3 grid grid-cols-2 gap-2 text-xs text-gray-700">
                            <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Principal:</span> <span class="font-semibold text-gray-800">${formatCurrency(loan.principal_amount)}</span></div>
                            <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Parcelas:</span> <span class="font-semibold text-gray-800">${installmentsInfo}</span></div>
                            <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Juros:</span> <span class="font-semibold text-gray-800">${interestPrimary}</span></div>
                            <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Início:</span> <span class="font-semibold text-gray-800">${formatDate(loan.start_date)}</span></div>
                        </div>

                        <div class="mt-3 flex flex-wrap items-center gap-2">
                            <span class="${badgeForStatus(status)}">${status}</span>
                            <span class="${financialSituation.badgeClass}">${financialSituation.label}</span>
                        </div>

                        <div class="mt-3 flex items-center justify-end gap-1">
                            <button type="button" class="action-btn action-btn-view rounded-md p-2 transition-colors duration-150 hover:bg-slate-100" data-action="view-loan" data-id="${loan.id}" aria-expanded="${isExpanded ? 'true' : 'false'}" title="${isExpanded ? 'Fechar detalhes' : 'Ver detalhes'}"><i class="fas ${isExpanded ? 'fa-eye-slash' : 'fa-eye'}"></i></button>
                            <button type="button" class="action-btn action-btn-edit rounded-md p-2 transition-colors duration-150 hover:bg-slate-100" data-action="edit-loan" data-id="${loan.id}" title="Editar"><i class="fas fa-pen-to-square"></i></button>
                            <button type="button" class="action-btn action-btn-delete rounded-md p-2 transition-colors duration-150 hover:bg-slate-100" data-action="delete-loan" data-id="${loan.id}" title="Excluir"><i class="fas fa-trash"></i></button>
                        </div>

                        <div class="mt-3 ${isExpanded ? '' : 'hidden'} rounded-xl border border-gray-200 bg-slate-50 p-3" data-loan-detail-for="${loan.id}">
                            <div class="grid grid-cols-1 gap-2 text-xs text-gray-700">
                                <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Juros:</span> <span class="font-semibold text-gray-800">${interestPrimary} (${interestTypeLabel})</span></div>
                                <div><span class="text-[11px] uppercase tracking-wide text-gray-500">1º vencimento:</span> <span class="font-semibold text-gray-800">${formatDate(loan.first_due_date)}</span></div>
                                <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Parcelas pagas/em aberto:</span> <span class="font-semibold text-gray-800">${paidInstallments}/${pendingInstallments}</span></div>
                                <div><span class="text-[11px] uppercase tracking-wide text-gray-500">Próx. venc. | Parcela:</span> <span class="font-semibold text-gray-800">${nextDueLabel}</span></div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function renderLoansTable() {
            const tbody = document.getElementById('loansTableBody');
            const total = loansState.filtered.length;
            updatePaginationInfo(total);

            if (!total) {
                if (tbody) {
                    tbody.innerHTML = '<tr><td colspan="9" class="text-center py-8 text-gray-500">Nenhum empréstimo encontrado.</td></tr>';
                }
                if (loansMobileList) {
                    loansMobileList.innerHTML = `
                        <div class="rounded-2xl border border-gray-200 bg-slate-50 p-4 text-center text-sm text-gray-500">
                            Nenhum empréstimo encontrado.
                        </div>
                    `;
                }
                return;
            }

            const startIndex = (loansState.currentPage - 1) * loansState.pageSize;
            const pageRows = loansState.filtered.slice(startIndex, startIndex + loansState.pageSize);

            renderLoansMobileList(pageRows);

            if (!tbody) return;

            tbody.innerHTML = pageRows.map((loan) => {
                const status = normalizeLoanStatus(loan.status);
                const interestType = normalizeInterestType(loan.interest_type);
                const installmentsInfo = getLoanInstallmentsSummary(loan);
                const interestPrimary = interestType === 'fixo'
                    ? formatCurrency(loan.interest_rate)
                    : `${loan.interest_rate}%`;

                return `
                    <tr data-loan-id="${loan.id}" class="cursor-pointer transition-colors duration-150 hover:bg-slate-50" title="Ver detalhes do empréstimo">
                        <td>#${loan.id ?? '-'}</td>
                        <td>${getDebtorName(loan.debtor_id)}</td>
                        <td>${formatCurrency(loan.principal_amount)}</td>
                        <td>${formatCurrency(loan.total_amount)}</td>
                        <td>${installmentsInfo}</td>
                        <td>
                            <div class="leading-tight">
                                <div class="font-semibold text-slate-800">${interestPrimary}</div>
                                <div class="mt-0.5 text-xs text-slate-500">${formatInterestTypeLabel(interestType)}</div>
                            </div>
                        </td>
                        <td>${formatDate(loan.start_date)}</td>
                        <td><span class="${badgeForStatus(status)}">${status}</span></td>
                        <td>
                            <div class="flex items-center gap-1">
                                <button type="button" class="action-btn action-btn-view rounded-md p-2 transition-colors duration-150 hover:bg-slate-100" data-action="view-loan" data-id="${loan.id}" title="Detalhes"><i class="fas fa-eye"></i></button>
                                <button type="button" class="action-btn action-btn-edit rounded-md p-2 transition-colors duration-150 hover:bg-slate-100" data-action="edit-loan" data-id="${loan.id}" title="Editar"><i class="fas fa-pen-to-square"></i></button>
                                <button type="button" class="action-btn action-btn-delete rounded-md p-2 transition-colors duration-150 hover:bg-slate-100" data-action="delete-loan" data-id="${loan.id}" title="Excluir"><i class="fas fa-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function applyLoansFilters(resetPage) {
            if (resetPage) loansState.currentPage = 1;

            const searchValue = document.getElementById('loanSearch').value.trim().toLowerCase();
            const statusValue = document.getElementById('loanStatusFilter').value;

            loansState.filtered = loansState.loans
                .filter(loan => {
                    const normalizedStatus = normalizeLoanStatus(loan.status);
                    if (statusValue !== 'Todos' && normalizedStatus !== statusValue) return false;

                    if (!searchValue) return true;
                    const debtorName = getDebtorName(loan.debtor_id).toLowerCase();
                    const idValue = String(loan.id ?? '').toLowerCase();
                    return debtorName.includes(searchValue) || idValue.includes(searchValue);
                })
                .sort((a, b) => {
                    const first = new Date(a.start_date || 0).getTime();
                    const second = new Date(b.start_date || 0).getTime();
                    if (second !== first) return second - first;
                    return toNumber(b.id) - toNumber(a.id);
                });

            renderLoansTable();
        }

        function populateDebtorOptions(selectedDebtorId) {
            const select = document.getElementById('loanDebtor');
            const activeDebtors = loansState.debtors.filter(item => String(item.status || '').toLowerCase() === 'ativo');
            const source = activeDebtors.length ? [...activeDebtors] : [...loansState.debtors];

            if (selectedDebtorId && !source.some(item => sameId(item.id, selectedDebtorId))) {
                const selectedDebtor = loansState.debtors.find(item => sameId(item.id, selectedDebtorId));
                if (selectedDebtor) {
                    source.unshift(selectedDebtor);
                }
            }

            if (!source.length) {
                select.innerHTML = '<option value="">Nenhum cliente disponível</option>';
                return;
            }

            const placeholderOption = `<option value="" disabled ${selectedDebtorId ? '' : 'selected'}>Selecione o cliente</option>`;
            const debtorOptions = source
                .map(item => `<option value="${item.id}">${item.name || item.full_name || `Cliente #${item.id}`}</option>`)
                .join('');
            select.innerHTML = `${placeholderOption}${debtorOptions}`;

            if (selectedDebtorId) {
                const hasSelected = source.some(item => sameId(item.id, selectedDebtorId));
                if (hasSelected) select.value = String(selectedDebtorId);
            }
        }

        function addDays(date, days) {
            const copy = new Date(date.getTime());
            copy.setDate(copy.getDate() + days);
            return copy;
        }

        function suggestFirstDueDate(startDateIso) {
            const start = new Date(startDateIso);
            if (Number.isNaN(start.getTime())) return '';
            return toIsoDate(addDays(start, 30));
        }

        function getDueDateByFrequency(firstDueDateIso, index) {
            const firstDue = new Date(firstDueDateIso);
            if (Number.isNaN(firstDue.getTime())) return null;
            return addMonths(firstDue, index);
        }

        function clearFieldErrors() {
            Object.entries(loanFieldElements).forEach(([field, input]) => {
                if (!input) return;
                input.classList.remove('field-invalid');
                const errorEl = document.getElementById(loanFieldErrorIds[field]);
                if (errorEl) errorEl.textContent = '';
            });
            const scheduleErrorEl = document.getElementById('loanScheduleError');
            if (scheduleErrorEl) scheduleErrorEl.textContent = '';
        }

        function applyFieldErrors(errors) {
            clearFieldErrors();
            Object.entries(errors).forEach(([field, message]) => {
                if (!message) return;
                if (field === 'schedule') {
                    const scheduleErrorEl = document.getElementById('loanScheduleError');
                    if (scheduleErrorEl) scheduleErrorEl.textContent = message;
                    return;
                }

                const input = loanFieldElements[field];
                const errorEl = document.getElementById(loanFieldErrorIds[field]);
                if (input) input.classList.add('field-invalid');
                if (errorEl) errorEl.textContent = message;
            });
        }

        function updateInterestTypeVisibility() {
            const interestType = normalizeInterestType(document.getElementById('loanInterestType').value);
            const rateWrap = document.getElementById('loanInterestRateWrap');
            const fixedWrap = document.getElementById('loanFixedAdditionWrap');
            const rateInput = document.getElementById('loanInterestRate');
            const fixedInput = document.getElementById('loanFixedAddition');

            if (interestType === 'fixo') {
                rateWrap.classList.add('hidden');
                fixedWrap.classList.remove('hidden');
                rateInput.required = false;
                rateInput.disabled = true;
                rateInput.removeAttribute('min');
                fixedInput.required = true;
                fixedInput.disabled = false;
            } else {
                rateWrap.classList.remove('hidden');
                fixedWrap.classList.add('hidden');
                rateInput.disabled = false;
                rateInput.required = true;
                rateInput.min = '0.01';
                fixedInput.required = false;
                fixedInput.disabled = true;
            }
        }

        function resetSimulationState() {
            loanFormState.simulation = null;
            loanCalculationCard.classList.add('hidden');
            installmentsPreviewCard.classList.add('hidden');
            document.getElementById('installmentsPreviewList').innerHTML = '';
            document.getElementById('loanCalculatedTotal').textContent = 'R$ 0,00';
            document.getElementById('loanCalculatedInstallment').textContent = 'R$ 0,00';
            document.getElementById('loanCalculatedInterestType').textContent = 'Composto';
            document.getElementById('loanCalculatedRateInfo').textContent = 'Taxa: 0%';
        }

        function buildScheduleRows(values, existingSchedule, forceGenerate) {
            const total = Math.max(1, Math.trunc(toNumber(values.installments)));
            const current = Array.isArray(existingSchedule) ? existingSchedule : [];
            const rows = [];

            for (let index = 0; index < total; index += 1) {
                let dueDate = current[index]?.due_date || '';
                if (forceGenerate || !dueDate) {
                    const calculated = getDueDateByFrequency(values.firstDueDate, index);
                    dueDate = calculated ? toIsoDate(calculated) : '';
                }

                rows.push({
                    installment_number: index + 1,
                    due_date: dueDate
                });
            }

            return rows;
        }

        function renderScheduleTable(plan) {
            const values = getLoanFormValues();
            const schedule = loanFormState.schedule;

            if (!values.installments || values.installments <= 0 || !values.startDate || !values.firstDueDate) {
                loanScheduleBody.innerHTML = '<tr><td colspan="3" class="px-3 py-4 text-center text-xs text-gray-500">Preencha parcelas e datas para visualizar a agenda.</td></tr>';
                return;
            }

            loanScheduleBody.innerHTML = schedule.map((row, index) => {
                const installmentPlan = Array.isArray(plan) ? plan[index] : null;
                const amountLabel = installmentPlan ? formatCurrency(installmentPlan.amount) : '-';

                return `
                    <tr class="border-t border-slate-200">
                        <td class="px-3 py-2 font-semibold text-slate-700">#${row.installment_number}</td>
                        <td class="px-3 py-2">
                            <input
                                type="date"
                                class="filter-control !px-2 !py-1.5 text-xs focus:ring-2 focus:ring-blue-500/40"
                                data-schedule-index="${index}"
                                value="${row.due_date || ''}">
                        </td>
                        <td class="px-3 py-2 text-right font-semibold text-slate-700">${amountLabel}</td>
                    </tr>
                `;
            }).join('');

            const hint = document.getElementById('loanScheduleHint');
            if (hint) {
                hint.textContent = 'Datas mensais sugeridas: você pode editar as datas e regerar quando precisar.';
            }
        }

        function refreshSchedule(forceGenerate) {
            const values = getLoanFormValues();
            if (!values.installments || values.installments <= 0 || !values.startDate || !values.firstDueDate) {
                loanFormState.schedule = [];
                renderScheduleTable([]);
                return false;
            }

            loanFormState.schedule = buildScheduleRows(values, loanFormState.schedule, forceGenerate);
            renderScheduleTable(loanFormState.simulation?.plan || []);
            return true;
        }

        function captureScheduleFromTable() {
            const inputs = loanScheduleBody.querySelectorAll('input[data-schedule-index]');
            if (!inputs.length) return;

            inputs.forEach(input => {
                const index = Math.trunc(toNumber(input.getAttribute('data-schedule-index')));
                if (!Number.isFinite(index)) return;
                if (!loanFormState.schedule[index]) return;
                loanFormState.schedule[index].due_date = input.value;
            });
        }

        function updateSimulationSummary(values, calcResult) {
            document.getElementById('loanCalculatedTotal').textContent = formatCurrency(calcResult.totalAmount);
            document.getElementById('loanCalculatedInstallment').textContent = formatCurrency(calcResult.installmentAmount);
            document.getElementById('loanCalculatedInterestType').textContent = formatInterestTypeLabel(values.interestType);
            document.getElementById('loanCalculatedRateInfo').textContent = values.interestType === 'fixo'
                ? `Acréscimo fixo: ${formatCurrency(values.fixedAddition)}`
                : `Taxa mensal: ${values.interestRate}%`;
            loanCalculationCard.classList.remove('hidden');
        }

        function setDefaultLoanDates() {
            const todayIso = getTodayIsoDate();
            document.getElementById('loanStartDate').value = todayIso;
            document.getElementById('loanFirstDueDate').value = suggestFirstDueDate(todayIso);
            loanFormState.firstDueTouched = false;
        }

        function lockBodyScrollForLoanModal(modalElement = loanModal) {
            if (!modalElement) return;
            const modalId = modalElement.id || '';
            if (!modalId || loanOpenedModalIds.has(modalId)) return;

            if (loanOpenedModalIds.size === 0) {
                previousBodyOverflow = document.body.style.overflow || '';
                document.body.style.overflow = 'hidden';
            }

            loanOpenedModalIds.add(modalId);
        }

        function unlockBodyScrollForLoanModal(modalElement = loanModal) {
            if (!modalElement) return;
            const modalId = modalElement.id || '';
            if (!modalId || !loanOpenedModalIds.has(modalId)) return;

            loanOpenedModalIds.delete(modalId);

            if (loanOpenedModalIds.size === 0) {
                document.body.style.overflow = previousBodyOverflow;
                previousBodyOverflow = '';
            }
        }

        function openLoanModal(mode, loan) {
            loansState.editingLoanId = mode === 'edit' ? loan.id : null;

            loanForm.reset();
            clearFieldErrors();
            resetSimulationState();
            setDefaultLoanDates();
            document.getElementById('loanFixedAddition').value = '';
            document.getElementById('loanInterestRate').value = '';
            document.getElementById('loanInterestType').value = 'composto';
            document.getElementById('loanInstallments').value = '';
            document.getElementById('loanEditingId').value = '';
            loanFormState.schedule = [];

            if (mode === 'edit' && loan) {
                const installments = getLoanInstallments(loan.id);
                const interestType = normalizeInterestType(loan.loan_meta?.interestMode || loan.interest_type);
                const startDateValue = toIsoDate(loan.start_date) || getTodayIsoDate();
                const firstDueValue = toIsoDate(loan.first_due_date) || installments[0]?.due_date || suggestFirstDueDate(startDateValue);

                document.getElementById('loanModalTitle').textContent = `Editar empréstimo #${loan.id}`;
                document.getElementById('saveLoanBtn').textContent = 'Salvar alterações';
                document.getElementById('loanEditingId').value = String(loan.id);

                populateDebtorOptions(loan.debtor_id);
                document.getElementById('loanDebtor').value = String(loan.debtor_id);
                document.getElementById('loanPrincipal').value = formatCurrencyInput(loan.principal_amount);
                document.getElementById('loanInstallments').value = loan.installments_count;
                document.getElementById('loanStartDate').value = startDateValue;
                document.getElementById('loanFirstDueDate').value = firstDueValue;
                document.getElementById('loanObservations').value = loan.observations || '';

                document.getElementById('loanInterestType').value = interestType;
                if (interestType === 'fixo') {
                    document.getElementById('loanFixedAddition').value = round2(loan.loan_meta?.fixedAddition ?? loan.interest_rate);
                    document.getElementById('loanInterestRate').value = 0;
                } else {
                    document.getElementById('loanInterestRate').value = loan.interest_rate;
                    document.getElementById('loanFixedAddition').value = 0;
                }

                loanFormState.firstDueTouched = true;
                loanFormState.schedule = buildScheduleRows({
                    ...getLoanFormValues(),
                    installments: Math.max(1, Math.trunc(toNumber(loan.installments_count)))
                }, installments.map((item, idx) => ({
                    installment_number: idx + 1,
                    due_date: toIsoDate(item.due_date)
                })), false);
            } else {
                document.getElementById('loanModalTitle').textContent = 'Novo empréstimo';
                document.getElementById('saveLoanBtn').textContent = 'Salvar empréstimo';
                loanFormState.firstDueTouched = false;
                populateDebtorOptions();
            }

            updateInterestTypeVisibility();
            const scheduleReady = refreshSchedule(mode !== 'edit');
            if (mode === 'edit' && scheduleReady) {
                calculateLoanFromForm(false);
            }

            loanModal.classList.remove('hidden');
            loanModal.classList.add('flex');
            lockBodyScrollForLoanModal();
            document.getElementById('loanDebtor').focus();
        }
        function closeLoanModal() {
            loansState.editingLoanId = null;
            loanModal.classList.add('hidden');
            loanModal.classList.remove('flex');
            unlockBodyScrollForLoanModal();
            loanForm.reset();
            clearFieldErrors();
            loanFormState.schedule = [];
            loanFormState.simulation = null;
            loanFormState.firstDueTouched = false;
        }

        function closeLoanDetailsModal() {
            loanDetailsModal.classList.add('hidden');
            loanDetailsModal.classList.remove('flex');
            unlockBodyScrollForLoanModal(loanDetailsModal);
            document.getElementById('loanDetailsContent').innerHTML = '';
        }

        function getLoanFormValues() {
            const interestType = normalizeInterestType(document.getElementById('loanInterestType').value);
            const installmentsRaw = Math.trunc(toNumber(document.getElementById('loanInstallments').value));

            return {
                debtorId: document.getElementById('loanDebtor').value,
                principal: round2(parseCurrencyInput(document.getElementById('loanPrincipal').value)),
                interestRate: round2(document.getElementById('loanInterestRate').value),
                fixedAddition: round2(document.getElementById('loanFixedAddition').value),
                interestType,
                installments: installmentsRaw > 0 ? installmentsRaw : 0,
                startDate: document.getElementById('loanStartDate').value,
                firstDueDate: document.getElementById('loanFirstDueDate').value,
                observations: document.getElementById('loanObservations').value.trim()
            };
        }

        function validateLoanFormValues(values) {
            const errors = {};

            if (!values.debtorId) errors.debtorId = 'Selecione um cliente.';
            if (values.principal <= 0) errors.principal = 'Informe um valor principal maior que zero.';
            if (values.installments <= 0) errors.installments = 'Informe ao menos uma parcela.';

            if (values.interestType === 'fixo') {
                if (values.fixedAddition < 0) errors.fixedAddition = 'O acréscimo fixo não pode ser negativo.';
            } else if (values.interestRate <= 0) {
                errors.interestRate = 'Informe uma taxa mensal maior que zero.';
            }

            if (!values.startDate) errors.startDate = 'Informe a data de início.';
            if (!values.firstDueDate) errors.firstDueDate = 'Informe o primeiro vencimento.';

            const startDate = new Date(values.startDate);
            const firstDueDate = new Date(values.firstDueDate);
            if (!errors.startDate && Number.isNaN(startDate.getTime())) errors.startDate = 'Data de início inválida.';
            if (!errors.firstDueDate && Number.isNaN(firstDueDate.getTime())) errors.firstDueDate = 'Primeiro vencimento inválido.';
            if (!errors.startDate && !errors.firstDueDate && firstDueDate < startDate) {
                errors.firstDueDate = 'O 1º vencimento deve ser igual ou posterior à data de início.';
            }

            const hasSchedule = loanFormState.schedule.length === values.installments;
            if (!hasSchedule) {
                errors.schedule = 'Gere a agenda das parcelas antes de simular/salvar.';
            } else {
                for (let index = 0; index < loanFormState.schedule.length; index += 1) {
                    const dueDate = loanFormState.schedule[index]?.due_date;
                    if (!dueDate) {
                        errors.schedule = 'Revise as datas da agenda antes de continuar.';
                        break;
                    }

                    const due = new Date(dueDate);
                    if (Number.isNaN(due.getTime()) || due < startDate) {
                        errors.schedule = 'Todas as datas de parcela devem ser válidas e iguais ou após a data de início.';
                        break;
                    }
                }
            }

            return errors;
        }

        function renderInstallmentPreview(plan) {
            installmentsPreviewList.innerHTML = '';

            plan.forEach(item => {
                const statusClass = item.status === 'Atrasado' ? 'overdue' : 'pending';
                const index = Math.max(0, toNumber(item.installment_number) - 1);
                const dueIso = toIsoDate(item.due_date);
                const div = document.createElement('div');
                div.className = `installment-preview ${statusClass} p-3 transition-colors duration-150 hover:bg-slate-50`;
                div.innerHTML = `
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <p class="font-semibold text-sm">Parcela #${item.installment_number}</p>
                            <div class="mt-0.5 flex flex-wrap items-center gap-2">
                                <p class="text-xs text-gray-600">Vencimento: <span class="font-medium text-gray-700">${formatDate(item.due_date)}</span></p>
                                <button
                                    type="button"
                                    class="inline-flex h-7 w-7 items-center justify-center rounded-md p-1 text-slate-600 transition-colors duration-150 hover:bg-slate-100"
                                    data-action="edit-preview-due"
                                    data-index="${index}"
                                    aria-label="Editar data de vencimento da parcela #${item.installment_number}">
                                    <i class="fas fa-pen text-[11px]"></i>
                                </button>
                                <input
                                    type="date"
                                    class="sr-only"
                                    data-action="preview-due-input"
                                    data-index="${index}"
                                    value="${dueIso}">
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="font-bold text-sm">${formatCurrency(item.amount)}</p>
                            <p class="text-xs text-gray-600">Juros: ${formatCurrency(item.interest_amount)}</p>
                        </div>
                    </div>
                `;
                installmentsPreviewList.appendChild(div);
            });

            installmentsPreviewCard.classList.remove('hidden');
        }

        function updateInstallmentDueDate(index, dueDateIso, showFeedback) {
            const parsedIndex = Math.trunc(toNumber(index));
            const due = new Date(dueDateIso);
            const startDate = new Date(document.getElementById('loanStartDate').value);

            if (!dueDateIso || Number.isNaN(due.getTime())) {
                if (showFeedback) showMessage('Data de vencimento inválida.', 'error');
                return false;
            }

            if (!Number.isNaN(startDate.getTime()) && due < startDate) {
                if (showFeedback) showMessage('Vencimento deve ser igual ou após a data de início.', 'error');
                return false;
            }

            if (!loanFormState.schedule[parsedIndex]) {
                loanFormState.schedule[parsedIndex] = {
                    installment_number: parsedIndex + 1,
                    due_date: dueDateIso
                };
            } else {
                loanFormState.schedule[parsedIndex].due_date = dueDateIso;
            }

            if (loanFormState.simulation?.plan?.[parsedIndex]) {
                loanFormState.simulation.plan[parsedIndex].due_date = dueDateIso;
                loanFormState.simulation.plan[parsedIndex].status = due < new Date(getTodayIsoDate()) ? 'Atrasado' : 'Pendente';
                renderScheduleTable(loanFormState.simulation.plan);
                renderInstallmentPreview(loanFormState.simulation.plan);
            } else {
                renderScheduleTable([]);
            }

            clearFieldErrors();
            if (showFeedback) showMessage(`Vencimento da parcela #${parsedIndex + 1} atualizado.`, 'success');
            return true;
        }

        function calculateLoanFromForm(showErrors) {
            captureScheduleFromTable();
            refreshSchedule(false);
            const values = getLoanFormValues();
            const errors = validateLoanFormValues(values);
            applyFieldErrors(errors);
            if (Object.keys(errors).length > 0) {
                if (showErrors) showMessage('Revise os campos destacados antes de continuar.', 'error');
                return null;
            }

            let calcResult;
            let plan;

            if (values.interestType === 'fixo') {
                const totalAmount = round2(values.principal + values.fixedAddition);
                const parcelas = Math.max(1, Math.trunc(toNumber(values.installments)));
                const totalCents = Math.round(totalAmount * 100);
                const baseCents = Math.floor(totalCents / parcelas);
                const diferencaCents = totalCents - (baseCents * parcelas);
                const principalParts = splitAmount(values.principal, parcelas);
                const fixedParts = splitAmount(values.fixedAddition, parcelas);
                const today = new Date(getTodayIsoDate());

                const parcelasCents = Array.from({ length: parcelas }, (_, index) => baseCents + (index === parcelas - 1 ? diferencaCents : 0));
                plan = parcelasCents.map((amountCents, index) => {
                    const dueDate = loanFormState.schedule[index]?.due_date;
                    const due = new Date(dueDate);
                    const safeDue = Number.isNaN(due.getTime())
                        ? (getDueDateByFrequency(values.firstDueDate, index) || new Date(values.firstDueDate))
                        : due;

                    return {
                        installment_number: index + 1,
                        amount: round2(amountCents / 100),
                        principal_amount: principalParts[index],
                        interest_amount: fixedParts[index],
                        due_date: toIsoDate(safeDue),
                        status: safeDue < today ? 'Atrasado' : 'Pendente',
                        payment_date: null
                    };
                });
                calcResult = {
                    totalAmount,
                    installmentAmount: round2(totalAmount / parcelas),
                    totalInterest: round2(values.fixedAddition)
                };
            } else {
                calcResult = calculateLoanValues(values.principal, values.interestRate, values.installments, values.interestType);
                if (!calcResult) {
                    if (showErrors) showMessage('Não foi possível calcular o empréstimo.', 'error');
                    return null;
                }
                plan = buildInstallmentPlan(values, calcResult, loanFormState.schedule);
            }

            loanFormState.simulation = { values, calcResult, plan };
            updateSimulationSummary(values, calcResult);
            renderScheduleTable(plan);
            renderInstallmentPreview(plan);

            return { values, calcResult, plan };
        }

        function resolvePersistedCreatedLoanId(savedLoans, draftLoan, previousLoans) {
            const normalizedSaved = Array.isArray(savedLoans) ? savedLoans.map(normalizeLoanRow) : [];
            const previousIdSet = new Set((Array.isArray(previousLoans) ? previousLoans : []).map((loan) => String(loan?.id ?? '')));

            const sameMoney = (a, b) => Math.abs(round2(a) - round2(b)) <= 0.01;
            const sameDate = (a, b) => String(a || '') === String(b || '');

            const exactIdMatch = normalizedSaved.find((loan) => sameId(loan.id, draftLoan.id));
            if (exactIdMatch) return exactIdMatch.id;

            const candidates = normalizedSaved.filter((loan) => {
                if (!sameId(loan.debtor_id, draftLoan.debtor_id)) return false;
                if (!sameMoney(loan.principal_amount, draftLoan.principal_amount)) return false;
                if (!sameMoney(loan.total_amount, draftLoan.total_amount)) return false;
                if (!sameMoney(loan.interest_rate, draftLoan.interest_rate)) return false;
                if (!sameMoney(loan.installment_amount, draftLoan.installment_amount)) return false;
                if (!sameDate(loan.start_date, draftLoan.start_date)) return false;
                if (!sameDate(loan.first_due_date, draftLoan.first_due_date)) return false;
                if (!sameDate(loan.due_date, draftLoan.due_date)) return false;
                return toNumber(loan.installments_count) === toNumber(draftLoan.installments_count);
            });

            if (!candidates.length) return null;

            const freshCandidates = candidates.filter((loan) => !previousIdSet.has(String(loan.id ?? '')));
            const pool = freshCandidates.length > 0 ? freshCandidates : candidates;
            pool.sort((a, b) => toNumber(b.id) - toNumber(a.id));
            return pool[0]?.id ?? null;
        }

        async function saveLoanAndInstallments(loanPayload, plan, isEditing) {
            const previousLoansSnapshot = [...loansState.loans];

            if (isEditing) {
                loansState.loans = loansState.loans.map(loan => sameId(loan.id, loanPayload.id) ? loanPayload : loan);
            } else {
                loansState.loans = [loanPayload, ...loansState.loans];
            }

            const persistedLoansRaw = await saveTableData('loans', loansState.loans);
            loansState.loans = (Array.isArray(persistedLoansRaw) ? persistedLoansRaw : loansState.loans).map(normalizeLoanRow);

            const effectiveLoanId = (() => {
                if (isEditing) {
                    const exists = loansState.loans.some((loan) => sameId(loan.id, loanPayload.id));
                    return exists ? loanPayload.id : null;
                }
                return resolvePersistedCreatedLoanId(loansState.loans, loanPayload, previousLoansSnapshot);
            })();

            if (!effectiveLoanId) {
                throw new Error('Nao foi possivel confirmar o emprestimo salvo. Atualize a pagina e tente novamente.');
            }

            loansState.installments = loansState.installments.filter((item) => {
                const loanId = item?.loan_id;
                if (sameId(loanId, effectiveLoanId)) return false;
                if (!isEditing && sameId(loanId, loanPayload.id)) return false;
                return true;
            });

            const generatedInstallments = plan.map((item) => ({
                loan_id: effectiveLoanId,
                debtor_id: loanPayload.debtor_id,
                installment_number: item.installment_number,
                due_date: item.due_date,
                payment_date: null,
                amount: item.amount,
                principal_amount: item.principal_amount,
                interest_amount: item.interest_amount,
                status: item.status
            }));

            loansState.installments = [...generatedInstallments, ...loansState.installments];

            const persistedInstallmentsRaw = await saveTableData('installments', loansState.installments);
            if (Array.isArray(persistedInstallmentsRaw)) {
                loansState.installments = persistedInstallmentsRaw;
            }
        }

        async function deleteLoan(loanId) {
            loansState.loans = loansState.loans.filter(loan => !sameId(loan.id, loanId));
            loansState.installments = loansState.installments.filter(item => !sameId(item.loan_id, loanId));

            try {
                await saveTableData('loans', loansState.loans);
                await saveTableData('installments', loansState.installments);

                updateLoanMetrics();
                applyLoansFilters(false);
                showMessage('Empréstimo excluído com sucesso.', 'success');
            } catch (error) {
                console.error('Erro ao excluir empréstimo:', error);
                showMessage('Erro ao excluir empréstimo. Tente novamente.', 'error');
                loadLoansData();
            }
        }

        function openDeleteLoanConfirmModal(loanId) {
            pendingDeleteLoanId = loanId;
            deleteLoanConfirmModal.classList.remove('hidden');
            deleteLoanConfirmModal.classList.add('flex');
            lockBodyScrollForLoanModal(deleteLoanConfirmModal);
        }

        function closeDeleteLoanConfirmModal() {
            pendingDeleteLoanId = null;
            deleteLoanConfirmModal.classList.add('hidden');
            deleteLoanConfirmModal.classList.remove('flex');
            unlockBodyScrollForLoanModal(deleteLoanConfirmModal);
        }

        function openLoanDetails(loanId) {
            const loan = loansState.loans.find(item => sameId(item.id, loanId));
            if (!loan) return;

            const installments = getLoanInstallments(loan.id);
            const financialSituation = getLoanFinancialSituation(installments);
            const paid = installments.filter(item => String(item.status || '').toLowerCase() === 'pago').length;
            const pending = installments.length - paid;
            const interestType = normalizeInterestType(loan.interest_type);
            const interestTypeLabel = formatInterestTypeLabel(interestType);
            const interestValue = interestType === 'fixo'
                ? `${formatCurrency(loan.interest_rate)} (${interestTypeLabel})`
                : `${loan.interest_rate}% (${interestTypeLabel})`;

            document.getElementById('loanDetailsTitle').textContent = `Detalhes do empréstimo #${loan.id}`;

            const detailRows = `
                <div class="details-grid">
                    <div class="details-item"><p class="text-xs text-gray-500">Cliente</p><p class="font-semibold">${getDebtorName(loan.debtor_id)}</p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">Status</p><p class="font-semibold">${normalizeLoanStatus(loan.status)}</p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">Situação</p><p class="font-semibold"><span class="${financialSituation.badgeClass}">${financialSituation.label}</span></p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">Principal</p><p class="font-semibold">${formatCurrency(loan.principal_amount)}</p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">Total contratado</p><p class="font-semibold">${formatCurrency(loan.total_amount)}</p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">Juros</p><p class="font-semibold">${interestValue}</p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">Data de início</p><p class="font-semibold">${formatDate(loan.start_date)}</p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">1º vencimento</p><p class="font-semibold">${formatDate(loan.first_due_date)}</p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">Parcelas pagas</p><p class="font-semibold">${paid}</p></div>
                    <div class="details-item"><p class="text-xs text-gray-500">Parcelas em aberto</p><p class="font-semibold">${pending}</p></div>
                </div>
            `;

            const installmentsHtml = installments.length
                ? installments.map(item => {
                    const status = String(item.status || '').trim() || 'Pendente';
                    const normalizedStatus = status.toLowerCase();
                    const badgeClass = normalizedStatus === 'pago' ? 'badge badge-success' : normalizedStatus === 'atrasado' ? 'badge badge-danger' : 'badge badge-warn';
                    const installmentClass = normalizedStatus === 'atrasado'
                        ? 'installment-preview overdue p-3'
                        : normalizedStatus === 'pago'
                            ? 'installment-preview p-3'
                            : 'installment-preview pending p-3';

                    return `
                        <div class="${installmentClass}">
                            <div class="flex items-center justify-between gap-4">
                                <div>
                                    <p class="font-semibold text-sm">Parcela #${item.installment_number}</p>
                                    <p class="text-xs text-gray-600">Vencimento: ${formatDate(item.due_date)}</p>
                                </div>
                                <div class="flex items-center gap-3">
                                    <p class="font-semibold text-sm">${formatCurrency(item.amount)}</p>
                                    <span class="${badgeClass}">${status}</span>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('')
                : '<p class="text-sm text-gray-500">Nenhuma parcela vinculada.</p>';

            const notesHtml = loan.observations
                ? `<div class="details-item"><p class="text-xs text-gray-500">Observações</p><p class="font-semibold">${loan.observations}</p></div>`
                : '';

            document.getElementById('loanDetailsContent').innerHTML = `
                ${detailRows}
                ${notesHtml}
                <div>
                    <h4 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-700">Parcelas</h4>
                    <div class="space-y-2 max-h-64 overflow-y-auto">${installmentsHtml}</div>
                </div>
            `;

            loanDetailsModal.classList.remove('hidden');
            loanDetailsModal.classList.add('flex');
            lockBodyScrollForLoanModal(loanDetailsModal);
        }
        async function loadLoansData() {
            try {
                const [loans, debtors, installments] = await Promise.all([
                    fetchTableData('loans'),
                    fetchTableData('debtors'),
                    fetchTableData('installments')
                ]);

                loansState.loans = loans.map(normalizeLoanRow);
                loansState.debtors = debtors;
                loansState.installments = installments;

                updateLoanMetrics();
                applyLoansFilters(true);
            } catch (error) {
                console.error('Erro ao carregar empréstimos:', error);
                const tbody = document.getElementById('loansTableBody');
                if (tbody) {
                    tbody.innerHTML = '<tr><td colspan="9" class="text-center py-8 text-red-600">Erro ao carregar dados.</td></tr>';
                }
                if (loansMobileList) {
                    loansMobileList.innerHTML = `
                        <div class="rounded-2xl border border-red-200 bg-red-50 p-4 text-center text-sm font-semibold text-red-700">
                            Erro ao carregar dados.
                        </div>
                    `;
                }
            }
        }

        document.getElementById('loanSearch').addEventListener('input', function () {
            applyLoansFilters(true);
        });

        document.getElementById('loanStatusFilter').addEventListener('change', function () {
            applyLoansFilters(true);
        });

        document.getElementById('prevPageBtn').addEventListener('click', function () {
            if (loansState.currentPage <= 1) return;
            loansState.currentPage -= 1;
            renderLoansTable();
        });

        document.getElementById('nextPageBtn').addEventListener('click', function () {
            const totalPages = Math.max(1, Math.ceil(loansState.filtered.length / loansState.pageSize));
            if (loansState.currentPage >= totalPages) return;
            loansState.currentPage += 1;
            renderLoansTable();
        });

        document.getElementById('newLoanBtn').addEventListener('click', function () {
            if (!loansState.debtors.length) {
                showMessage('Cadastre um cliente antes de criar empréstimos.', 'error');
                return;
            }
            openLoanModal('create');
        });

        document.getElementById('closeLoanModalBtn').addEventListener('click', closeLoanModal);
        document.getElementById('cancelLoanModalBtn').addEventListener('click', closeLoanModal);
        loanModal.addEventListener('click', function (event) {
            if (event.target === loanModal) closeLoanModal();
        });

        document.getElementById('loanInterestType').addEventListener('change', function () {
            updateInterestTypeVisibility();
            clearFieldErrors();
            resetSimulationState();
        });

        document.getElementById('loanStartDate').addEventListener('change', function () {
            if (!loanFormState.firstDueTouched || !document.getElementById('loanFirstDueDate').value) {
                document.getElementById('loanFirstDueDate').value = suggestFirstDueDate(this.value);
            }
            refreshSchedule(true);
            clearFieldErrors();
            resetSimulationState();
        });

        document.getElementById('loanFirstDueDate').addEventListener('change', function () {
            loanFormState.firstDueTouched = true;
            refreshSchedule(true);
            clearFieldErrors();
            resetSimulationState();
        });

        ['loanPrincipal', 'loanInterestRate', 'loanFixedAddition', 'loanInstallments'].forEach((fieldId) => {
            const numericField = document.getElementById(fieldId);
            if (!(numericField instanceof HTMLInputElement)) return;

            numericField.addEventListener('beforeinput', function (event) {
                const incoming = typeof event.data === 'string' ? event.data : '';
                if (/[eE+\-]/.test(incoming)) {
                    event.preventDefault();
                }
            });

            numericField.addEventListener('keydown', function (event) {
                if (event.key === 'e' || event.key === 'E' || event.key === '+' || event.key === '-') {
                    event.preventDefault();
                }
            });

            numericField.addEventListener('focus', function () {
                if (String(numericField.value || '').trim() === '0') {
                    numericField.value = '';
                }
            });

            numericField.addEventListener('input', function () {
                const rawValue = String(numericField.value || '');
                let sanitized = rawValue.replace(/[eE+\-]/g, '');

                if (fieldId === 'loanInstallments') {
                    sanitized = sanitized.replace(/[^\d]/g, '');
                    sanitized = sanitized.replace(/^0+(?=\d)/, '');
                } else {
                    sanitized = sanitized.replace(',', '.');
                    sanitized = sanitized.replace(/^0+(?=\d)/, '');
                }

                if (sanitized !== rawValue) {
                    numericField.value = sanitized;
                }
            });
        });

        const loanPrincipalInput = document.getElementById('loanPrincipal');
        if (loanPrincipalInput instanceof HTMLInputElement) {
            loanPrincipalInput.addEventListener('input', function () {
                const sanitized = String(loanPrincipalInput.value || '').replace(/[^\d,.\sR$]/gi, '');
                if (sanitized !== loanPrincipalInput.value) {
                    loanPrincipalInput.value = sanitized;
                }
            });

            loanPrincipalInput.addEventListener('blur', function () {
                loanPrincipalInput.value = formatCurrencyInput(loanPrincipalInput.value);
            });
        }

        document.getElementById('loanInstallments').addEventListener('input', function () {
            refreshSchedule(true);
            clearFieldErrors();
            resetSimulationState();
        });

        ['loanPrincipal', 'loanInterestRate', 'loanFixedAddition'].forEach((fieldId) => {
            const element = document.getElementById(fieldId);
            if (!element) return;
            element.addEventListener('input', function () {
                clearFieldErrors();
                resetSimulationState();
                renderScheduleTable([]);
            });
        });

        document.getElementById('generateScheduleBtn').addEventListener('click', function () {
            const generated = refreshSchedule(true);
            if (!generated) {
                showMessage('Preencha parcelas e datas antes de gerar a agenda.', 'error');
                return;
            }
            clearFieldErrors();
            showMessage('Agenda gerada com sucesso.', 'success');
        });

        document.getElementById('regenerateScheduleBtn').addEventListener('click', function () {
            const generated = refreshSchedule(true);
            if (!generated) {
                showMessage('Preencha parcelas e datas antes de regerar a agenda.', 'error');
                return;
            }
            clearFieldErrors();
            resetSimulationState();
            showMessage('Agenda regerada com sucesso.', 'success');
        });

        loanScheduleBody.addEventListener('input', function (event) {
            const target = event.target;
            if (!(target instanceof HTMLInputElement)) return;
            if (!target.matches('input[data-schedule-index]')) return;
            captureScheduleFromTable();
            clearFieldErrors();
        });

        installmentsPreviewList.addEventListener('click', function (event) {
            const target = event.target;
            if (!(target instanceof Element)) return;
            const editBtn = target.closest('button[data-action="edit-preview-due"]');
            if (!editBtn) return;

            const index = Math.trunc(toNumber(editBtn.getAttribute('data-index')));
            const dateInput = installmentsPreviewList.querySelector(`input[data-action="preview-due-input"][data-index="${index}"]`);
            if (!(dateInput instanceof HTMLInputElement)) return;

            dateInput.focus();
            if (typeof dateInput.showPicker === 'function') {
                dateInput.showPicker();
            } else {
                dateInput.click();
            }
        });

        installmentsPreviewList.addEventListener('change', function (event) {
            const target = event.target;
            if (!(target instanceof HTMLInputElement)) return;
            if (target.getAttribute('data-action') !== 'preview-due-input') return;
            const index = Math.trunc(toNumber(target.getAttribute('data-index')));
            updateInstallmentDueDate(index, target.value, true);
        });

        document.getElementById('calculateLoanBtn').addEventListener('click', function () {
            calculateLoanFromForm(true);
        });

        loanForm.addEventListener('submit', async function (event) {
            event.preventDefault();

            const result = calculateLoanFromForm(true);
            if (!result) return;

            const { values, calcResult, plan } = result;
            const isEditing = Boolean(loansState.editingLoanId);

            if (isEditing) {
                const hasPaidInstallments = getLoanInstallments(loansState.editingLoanId)
                    .some(item => String(item.status || '').toLowerCase() === 'pago');

                if (hasPaidInstallments) {
                    const confirmed = confirm('Este empréstimo possui parcelas pagas. Ao salvar, as parcelas serão recriadas. Deseja continuar?');
                    if (!confirmed) return;
                }
            }

            const loanId = isEditing ? loansState.editingLoanId : null;
            const status = deriveLoanStatus(plan);
            const firstScheduleDueDate = plan[0]?.due_date || values.firstDueDate;
            const lastScheduleDueDate = plan[plan.length - 1]?.due_date || values.firstDueDate;
            const loanMeta = {
                interestMode: values.interestType,
                fixedAddition: values.interestType === 'fixo' ? round2(values.fixedAddition) : 0
            };
            // TODO: persistir frequency/interestMode em colunas próprias quando o backend expor esses campos.

            const payload = normalizeLoanRow({
                ...(isEditing ? { id: loanId } : {}),
                debtor_id: values.debtorId,
                principal_amount: values.principal,
                total_amount: calcResult.totalAmount,
                installments_count: values.installments,
                interest_rate: values.interestType === 'fixo' ? round2(values.fixedAddition) : values.interestRate,
                interest_type: values.interestType === 'fixo' ? 'composto' : values.interestType,
                installment_amount: calcResult.installmentAmount,
                observations: encodeLoanObservations(values.observations, loanMeta),
                start_date: values.startDate,
                first_due_date: firstScheduleDueDate,
                due_date: lastScheduleDueDate,
                status
            });

            try {
                await saveLoanAndInstallments(payload, plan, isEditing);
                updateLoanMetrics();
                applyLoansFilters(!isEditing);
                closeLoanModal();
                showMessage(isEditing ? 'Empréstimo atualizado com sucesso.' : 'Empréstimo criado com sucesso.', 'success');
            } catch (error) {
                console.error('Erro ao salvar empréstimo:', error);
                const errorMessage = error instanceof Error && error.message
                    ? error.message
                    : 'Erro ao salvar empréstimo. Tente novamente.';
                showMessage(errorMessage, 'error');
                await loadLoansData();
            }
        });

        function handleLoansListClick(event) {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const actionBtn = target.closest('button[data-action]');
            const row = target.closest('[data-loan-id]');
            if (!row) return;
            const inMobileList = Boolean(target.closest('#loansMobileList'));

            const rowLoanId = row.getAttribute('data-loan-id');
            const rowLoan = loansState.loans.find(item => sameId(item.id, rowLoanId));
            if (!rowLoan) return;

            if (!actionBtn) {
                if (!inMobileList) {
                    openLoanDetails(rowLoan.id);
                }
                return;
            }

            const action = actionBtn.getAttribute('data-action');
            const loanId = actionBtn.getAttribute('data-id');
            const loan = loansState.loans.find(item => sameId(item.id, loanId));

            if (!loan) return;

            if (action === 'view-loan') {
                if (inMobileList) {
                    toggleLoanDetail(loan.id);
                } else {
                    openLoanDetails(loan.id);
                }
                return;
            }

            if (action === 'edit-loan') {
                openLoanModal('edit', loan);
                return;
            }

            if (action === 'delete-loan') {
                openDeleteLoanConfirmModal(loan.id);
            }
        }

        const loansTableBody = document.getElementById('loansTableBody');
        if (loansTableBody) loansTableBody.addEventListener('click', handleLoansListClick);
        if (loansMobileList) loansMobileList.addEventListener('click', handleLoansListClick);

        document.getElementById('closeLoanDetailsBtn').addEventListener('click', closeLoanDetailsModal);
        document.getElementById('closeLoanDetailsFooterBtn').addEventListener('click', closeLoanDetailsModal);
        loanDetailsModal.addEventListener('click', function (event) {
            if (event.target === loanDetailsModal) closeLoanDetailsModal();
        });

        document.getElementById('cancelDeleteLoanBtn').addEventListener('click', closeDeleteLoanConfirmModal);
        document.getElementById('confirmDeleteLoanBtn').addEventListener('click', async function () {
            const targetLoanId = pendingDeleteLoanId;
            if (targetLoanId === null || targetLoanId === undefined) {
                closeDeleteLoanConfirmModal();
                return;
            }

            closeDeleteLoanConfirmModal();
            await deleteLoan(targetLoanId);
        });
        deleteLoanConfirmModal.addEventListener('click', function (event) {
            if (event.target === deleteLoanConfirmModal) closeDeleteLoanConfirmModal();
        });

        document.addEventListener('DOMContentLoaded', function() {
            loadLoansData();
        });
    </script>
</body>
</html>






