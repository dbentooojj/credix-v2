        function getLoanDetailsBadgeClassByLabel(label, kind = 'generic') {
            const normalized = String(label || '').trim().toLowerCase();

            if (kind === 'loan-status') {
                if (normalized.includes('inativ') || normalized.includes('final') || normalized.includes('quit')) {
                    return 'loan-detail-badge loan-detail-badge--neutral';
                }
                if (normalized.includes('atras')) {
                    return 'loan-detail-badge loan-detail-badge--danger';
                }
                if (normalized.includes('pend')) {
                    return 'loan-detail-badge loan-detail-badge--warning';
                }
                return 'loan-detail-badge loan-detail-badge--success';
            }

            if (kind === 'installment') {
                if (isPaidInstallmentStatus(normalized)) {
                    return 'loan-detail-badge loan-detail-badge--success';
                }
                if (normalized.includes('atras')) {
                    return 'loan-detail-badge loan-detail-badge--danger';
                }
                if (normalized.includes('pend') || normalized.includes('aberto')) {
                    return 'loan-detail-badge loan-detail-badge--warning';
                }
                return 'loan-detail-badge loan-detail-badge--neutral';
            }

            if (normalized.includes('atras')) {
                return 'loan-detail-badge loan-detail-badge--danger';
            }
            if (normalized.includes('pend')) {
                return 'loan-detail-badge loan-detail-badge--warning';
            }
            if (normalized.includes('dia') || normalized.includes('ativo') || normalized.includes('pago')) {
                return 'loan-detail-badge loan-detail-badge--success';
            }
            return 'loan-detail-badge loan-detail-badge--neutral';
        }

        function normalizeInstallmentStatusLabel(status) {
            const normalized = String(status || '').trim().toLowerCase();
            if (!normalized) return 'Pendente';
            if (isPaidInstallmentStatus(normalized)) return 'Pago';
            if (normalized.includes('atras')) return 'Atrasado';
            if (normalized.includes('pend') || normalized.includes('aberto')) return 'Pendente';
            return normalized.charAt(0).toUpperCase() + normalized.slice(1);
        }

        function getInstallmentRelativeDueLabel(installment) {
            const dueIso = normalizeIsoDateOnly(installment?.due_date);
            if (!dueIso) return '-';
            if (isPaidInstallmentStatus(installment?.status)) return 'Quitada';

            const diff = diffDaysDateOnly(getTodayIsoDate(), dueIso);
            if (!Number.isFinite(diff)) return '-';
            if (diff === 0) return 'Vence hoje';
            if (diff > 0) return `Vence em ${diff} dia(s)`;
            return `Atrasada ha ${Math.abs(diff)} dia(s)`;
        }

        function openLoanDetails(loanId) {
            const loan = loansState.loans.find((item) => sameId(item.id, loanId));
            if (!loan) return;

            const installments = getLoanInstallments(loan.id);
            const financialSituation = getLoanFinancialSituation(installments);
            const loanStatusLabel = normalizeLoanStatus(loan.status);
            const loanStatusBadgeClass = getLoanDetailsBadgeClassByLabel(loanStatusLabel, 'loan-status');
            const situationBadgeClass = getLoanDetailsBadgeClassByLabel(financialSituation.label, 'situation');
            const paidInstallments = installments.filter((item) => isPaidInstallmentStatus(item.status)).length;
            const openInstallments = Math.max(installments.length - paidInstallments, 0);
            const overdueInstallments = installments.filter((item) => {
                if (isPaidInstallmentStatus(item.status)) return false;
                const dueIso = normalizeIsoDateOnly(item.due_date);
                if (!dueIso) return false;
                return diffDaysDateOnly(dueIso, getTodayIsoDate()) > 0;
            }).length;
            const pendingInstallments = Math.max(openInstallments - overdueInstallments, 0);

            const nextOpenInstallment = installments
                .filter((item) => !isPaidInstallmentStatus(item.status))
                .map((item) => ({
                    item,
                    dueIso: normalizeIsoDateOnly(item.due_date),
                }))
                .sort((a, b) => {
                    const aMsRaw = isoDateToUtcMillis(a.dueIso);
                    const bMsRaw = isoDateToUtcMillis(b.dueIso);
                    const aMs = Number.isFinite(aMsRaw) ? aMsRaw : Number.POSITIVE_INFINITY;
                    const bMs = Number.isFinite(bMsRaw) ? bMsRaw : Number.POSITIVE_INFINITY;
                    return aMs - bMs;
