                        </div>
                        ${observationsHtml}
                    </div>
                </section>

                <section class="loan-detail-section">
                    <div class="loan-detail-section-head">
                        <h4 class="loan-detail-section-title">3. Parcelas</h4>
                        <span class="loan-detail-counter">${installments.length} registro(s)</span>
                    </div>
                    <div class="loan-detail-installments-list">${installmentsHtml}</div>
                </section>
            `;

            loanDetailsModal.classList.remove('hidden');
            loanDetailsModal.classList.add('flex');
            lockBodyScrollForLoanModal(loanDetailsModal);
        }

        async function loadLoansData() {
            try {
                const [loans, debtors, installments] = await Promise.all([
                    fetchTableData('loans'),
                    fetchTableData('debtors'),
                    fetchTableData('installments')
                ]);

                loansState.loans = loans.map(normalizeLoanRow);
                loansState.debtors = debtors;
                loansState.installments = installments;

                updateLoanMetrics();
                applyLoansFilters(true);
            } catch (error) {
                console.error('Erro ao carregar empréstimos:', error);
                const tbody = document.getElementById('loansTableBody');
                if (tbody) {
                    tbody.innerHTML = '<tr><td colspan="9" class="text-center py-8 text-red-600">Erro ao carregar dados.</td></tr>';
                }
                if (loansMobileList) {
                    loansMobileList.innerHTML = `
                        <div class="rounded-2xl border border-red-200 bg-red-50 p-4 text-center text-sm font-semibold text-red-700">
                            Erro ao carregar dados.
                        </div>
                    `;
                }
            }
        }

        initializeStaticDatePickers();

        document.getElementById('loanSearch').addEventListener('input', function () {
            applyLoansFilters(true);
        });

        document.getElementById('loanStatusFilter').addEventListener('change', function () {
            applyLoansFilters(true);
        });

        document.getElementById('prevPageBtn').addEventListener('click', function () {
            if (loansState.currentPage <= 1) return;
            loansState.currentPage -= 1;
            renderLoansTable();
        });

        document.getElementById('nextPageBtn').addEventListener('click', function () {
            const totalPages = Math.max(1, Math.ceil(loansState.filtered.length / loansState.pageSize));
            if (loansState.currentPage >= totalPages) return;
            loansState.currentPage += 1;
            renderLoansTable();
        });

        document.getElementById('newLoanBtn').addEventListener('click', function () {
            if (!loansState.debtors.length) {
                showMessage('Cadastre um cliente antes de criar empréstimos.', 'error');
                return;
            }
            openLoanModal('create');
        });

        document.getElementById('closeLoanModalBtn').addEventListener('click', closeLoanModal);
        const cancelLoanModalBtn = document.getElementById('cancelLoanModalBtn');
        if (cancelLoanModalBtn) cancelLoanModalBtn.addEventListener('click', closeLoanModal);
        loanModal.addEventListener('click', function (event) {
            if (event.target === loanModal) closeLoanModal();
        });
        if (loanModalBody instanceof HTMLElement) {
            loanModalBody.addEventListener('scroll', repositionOpenPrimaryDatePickers, { passive: true });
        }

        document.getElementById('loanInterestType').addEventListener('change', function () {
            updateInterestTypeVisibility();
            syncInstallmentsInputMode();
            refreshSchedule(false);
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
        });

        const loanUseMaxInstallmentInput = document.getElementById('loanUseMaxInstallment');
        if (loanUseMaxInstallmentInput instanceof HTMLInputElement) {
            loanUseMaxInstallmentInput.addEventListener('change', function () {
                syncInstallmentsInputMode();
                refreshSchedule(false);
                clearFieldErrors();
                triggerReactiveLoanRecalculation();

                if (loanUseMaxInstallmentInput.checked) {
                    document.getElementById('loanMaxInstallment')?.focus();
                }
            });
        }

        document.getElementById('loanDebtor').addEventListener('change', function () {
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
        });

        document.getElementById('loanStartDate').addEventListener('change', function () {
            const firstDueInput = document.getElementById('loanFirstDueDate');
            const currentFirstDueIso = normalizeIsoDateOnly(firstDueInput?.value);
            const shouldAutoSyncFirstDue = !loanFormState.firstDueTouched
                || !currentFirstDueIso
                || diffDaysDateOnly(normalizeIsoDateOnly(this.value), currentFirstDueIso) <= 0;

            if (shouldAutoSyncFirstDue) {
                const correctedFirstDue = ensureFirstDueDateAfterStart(this.value, currentFirstDueIso);
                setDateInputValue(firstDueInput, correctedFirstDue);
            }
            refreshSchedule(true);
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
        });

        document.getElementById('loanFirstDueDate').addEventListener('change', function () {
            loanFormState.firstDueTouched = true;
            const startDateIso = normalizeIsoDateOnly(document.getElementById('loanStartDate')?.value);
            const firstDueIso = normalizeIsoDateOnly(this.value);
            if (startDateIso && firstDueIso) {
                const diff = diffDaysDateOnly(startDateIso, firstDueIso);
                if (!Number.isFinite(diff) || diff <= 0) {
                    const corrected = ensureFirstDueDateAfterStart(startDateIso, firstDueIso);
                    setDateInputValue(document.getElementById('loanFirstDueDate'), corrected);
                }
            }
            refreshSchedule(true);
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
        });

        ['loanPrincipal', 'loanInterestRate', 'loanFixedAddition', 'loanInstallments'].forEach((fieldId) => {
            const numericField = document.getElementById(fieldId);
            if (!(numericField instanceof HTMLInputElement)) return;

            numericField.addEventListener('beforeinput', function (event) {
                const incoming = typeof event.data === 'string' ? event.data : '';
                if (/[eE+\-]/.test(incoming)) {
                    event.preventDefault();
                }
            });

            numericField.addEventListener('keydown', function (event) {
                if (event.key === 'e' || event.key === 'E' || event.key === '+' || event.key === '-') {
                    event.preventDefault();
                }
            });

            numericField.addEventListener('focus', function () {
                if (String(numericField.value || '').trim() === '0') {
                    numericField.value = '';
                }
            });

            numericField.addEventListener('input', function () {
                const rawValue = String(numericField.value || '');
                let sanitized = rawValue.replace(/[eE+\-]/g, '');

                if (fieldId === 'loanInstallments') {
                    sanitized = sanitized.replace(/[^\d]/g, '');
                    sanitized = sanitized.replace(/^0+(?=\d)/, '');
                } else {
                    sanitized = sanitized.replace(',', '.');
                    sanitized = sanitized.replace(/^0+(?=\d)/, '');
                }

                if (sanitized !== rawValue) {
                    numericField.value = sanitized;
                }
            });
        });

        const loanPrincipalInput = document.getElementById('loanPrincipal');
        if (loanPrincipalInput instanceof HTMLInputElement) {
            loanPrincipalInput.addEventListener('beforeinput', handleLoanPrincipalBeforeInput);
            loanPrincipalInput.addEventListener('paste', handleLoanPrincipalPaste);
            loanPrincipalInput.addEventListener('focus', moveLoanPrincipalCaretToEnd);

            loanPrincipalInput.addEventListener('blur', function () {
                setLoanPrincipalMaskedValue(parseCurrencyInput(loanPrincipalInput.value));
                triggerReactiveLoanRecalculation();
            });
        }

        const loanMaxInstallmentInput = document.getElementById('loanMaxInstallment');
        if (loanMaxInstallmentInput instanceof HTMLInputElement) {
            loanMaxInstallmentInput.addEventListener('input', function () {
                const sanitized = String(loanMaxInstallmentInput.value || '').replace(/[^\d,.\sR$]/gi, '');
                if (sanitized !== loanMaxInstallmentInput.value) {
                    loanMaxInstallmentInput.value = sanitized;
                }
                syncInstallmentsInputMode();
                clearFieldErrors();
            });

            loanMaxInstallmentInput.addEventListener('blur', function () {
                loanMaxInstallmentInput.value = formatCurrencyInput(loanMaxInstallmentInput.value);
                syncInstallmentsInputMode();
                refreshSchedule(true);
                triggerReactiveLoanRecalculation();
            });
        }

        document.getElementById('loanInstallments').addEventListener('input', function () {
            updateAutoInstallmentsIndicator();
            refreshSchedule(true);
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
        });

        ['loanPrincipal', 'loanInterestRate', 'loanFixedAddition'].forEach((fieldId) => {
            const element = document.getElementById(fieldId);
            if (!element) return;
            element.addEventListener('input', function () {
                clearFieldErrors();
                triggerReactiveLoanRecalculation();
            });
        });

        document.getElementById('generateScheduleBtn').addEventListener('click', function () {
            const generated = refreshSchedule(true);
            if (!generated) {
                showMessage('Preencha parcelas e datas antes de gerar a agenda.', 'error');
                return;
            }
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
            showMessage('Agenda gerada com sucesso.', 'success');
        });

        document.getElementById('regenerateScheduleBtn').addEventListener('click', function () {
            const generated = refreshSchedule(true);
            if (!generated) {
                showMessage('Preencha parcelas e datas antes de regerar a agenda.', 'error');
                return;
            }
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
            showMessage('Agenda regerada com sucesso.', 'success');
        });

        loanScheduleBody.addEventListener('input', function (event) {
            const target = event.target;
            if (!(target instanceof HTMLInputElement)) return;
            if (!target.matches('input[data-schedule-index]')) return;
            captureScheduleFromTable();
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
        });

        loanScheduleBody.addEventListener('change', function (event) {
            const target = event.target;
            if (!(target instanceof HTMLInputElement)) return;
            if (!target.matches('input[data-schedule-index]')) return;
            captureScheduleFromTable();
            clearFieldErrors();
            triggerReactiveLoanRecalculation();
        });

        installmentsPreviewList.addEventListener('click', function (event) {
            const target = event.target;
            if (!(target instanceof Element)) return;
            const editBtn = target.closest('button[data-action="edit-preview-due"]');
            if (!editBtn) return;

            const index = Math.trunc(toNumber(editBtn.getAttribute('data-index')));
            const dateInput = installmentsPreviewList.querySelector(`input[data-action="preview-due-input"][data-index="${index}"]`);
            if (!(dateInput instanceof HTMLInputElement)) return;

            if (dateInput._flatpickr) {
                dateInput._flatpickr.set('positionElement', editBtn);
                dateInput._flatpickr.set('position', getPreviewDatePickerPosition(editBtn));
                dateInput._flatpickr.open();
                return;
            }
            openNativePreviewDatePicker(dateInput, index, editBtn);
        });

        installmentsPreviewList.addEventListener('change', function (event) {
            const target = event.target;
            if (!(target instanceof HTMLInputElement)) return;
            if (target.getAttribute('data-action') !== 'preview-due-input') return;
            const index = Math.trunc(toNumber(target.getAttribute('data-index')));
            updateInstallmentDueDate(index, target.value, true);
        });

        loanForm.addEventListener('submit', async function (event) {
            event.preventDefault();

            const result = calculateLoanFromForm(true);
            if (!result) return;

            const { values, calcResult, plan } = result;
            const isEditing = Boolean(loansState.editingLoanId);

            if (isEditing && loanHasPaidInstallments(loansState.editingLoanId)) {
                showMessage('Nao e permitido editar emprestimo com parcela paga. Estorne os pagamentos antes de editar.', 'error');
                return;
            }

            const loanId = isEditing ? loansState.editingLoanId : null;
            const status = deriveLoanStatus(plan);
            const firstScheduleDueDate = plan[0]?.due_date || values.firstDueDate;
            const lastScheduleDueDate = plan[plan.length - 1]?.due_date || values.firstDueDate;
            const loanMeta = {
                interestMode: values.interestType,
                fixedAddition: values.interestType === 'fixo' ? round2(values.fixedAddition) : 0,
                maxInstallment: values.maxInstallment > 0 ? round2(values.maxInstallment) : 0
            };
            // TODO: persistir frequency/interestMode em colunas próprias quando o backend expor esses campos.

            const payload = normalizeLoanRow({
                ...(isEditing ? { id: loanId } : {}),
                debtor_id: values.debtorId,
                principal_amount: values.principal,
                total_amount: calcResult.totalAmount,
                installments_count: values.installments,
                interest_rate: values.interestType === 'fixo' ? 0 : values.interestRate,
                interest_type: values.interestType === 'fixo' ? 'composto' : values.interestType,
                installment_amount: calcResult.installmentAmount,
                observations: encodeLoanObservations(values.observations, loanMeta),
                start_date: values.startDate,
                first_due_date: firstScheduleDueDate,
                due_date: lastScheduleDueDate,
                status
            });

            try {
                await saveLoanAndInstallments(payload, plan, isEditing);
                updateLoanMetrics();
                applyLoansFilters(!isEditing);
                closeLoanModal();
                showMessage(isEditing ? 'Empréstimo atualizado com sucesso.' : 'Empréstimo criado com sucesso.', 'success');
            } catch (error) {
                console.error('Erro ao salvar empréstimo:', error);
                const errorMessage = error instanceof Error && error.message
                    ? error.message
                    : 'Nao foi possivel salvar o emprestimo. Revise os dados e tente novamente.';
                showMessage(errorMessage, 'error');
                await loadLoansData();
            }
        });

        function handleLoansListClick(event) {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const actionBtn = target.closest('button[data-action]');
            const row = target.closest('[data-loan-id]');
            if (!row) return;
            const inMobileList = Boolean(target.closest('#loansMobileList'));

            const rowLoanId = row.getAttribute('data-loan-id');
            const rowLoan = loansState.loans.find(item => sameId(item.id, rowLoanId));
            if (!rowLoan) return;

            if (!actionBtn) {
                if (!inMobileList) {
                    openLoanDetails(rowLoan.id);
                }
                return;
            }

            const action = actionBtn.getAttribute('data-action');
            const loanId = actionBtn.getAttribute('data-id');
            const loan = loansState.loans.find(item => sameId(item.id, loanId));

            if (!loan) return;

            if (action === 'view-loan') {
                if (inMobileList) {
                    toggleLoanDetail(loan.id);
                } else {
                    openLoanDetails(loan.id);
                }
                return;
            }

            if (action === 'edit-loan') {
                openLoanModal('edit', loan);
                return;
            }

            if (action === 'delete-loan') {
                openDeleteLoanConfirmModal(loan.id);
            }
        }

        const loansTableBody = document.getElementById('loansTableBody');
        if (loansTableBody) loansTableBody.addEventListener('click', handleLoansListClick);
        if (loansMobileList) loansMobileList.addEventListener('click', handleLoansListClick);

        document.getElementById('closeLoanDetailsBtn').addEventListener('click', closeLoanDetailsModal);
        document.getElementById('closeLoanDetailsFooterBtn').addEventListener('click', closeLoanDetailsModal);
        loanDetailsModal.addEventListener('click', function (event) {
            if (event.target === loanDetailsModal) closeLoanDetailsModal();
        });

        if (closeDeleteLoanConfirmModalBtn) closeDeleteLoanConfirmModalBtn.addEventListener('click', closeDeleteLoanConfirmModal);
        document.getElementById('cancelDeleteLoanBtn').addEventListener('click', closeDeleteLoanConfirmModal);
        document.getElementById('confirmDeleteLoanBtn').addEventListener('click', async function () {
            const targetLoanId = pendingDeleteLoanId;
            if (targetLoanId === null || targetLoanId === undefined) {
                closeDeleteLoanConfirmModal();
                return;
            }

            closeDeleteLoanConfirmModal();
            await deleteLoan(targetLoanId);
        });
        deleteLoanConfirmModal.addEventListener('click', function (event) {
            if (event.target === deleteLoanConfirmModal) closeDeleteLoanConfirmModal();
        });

        document.addEventListener('DOMContentLoaded', function() {
            loadLoansData();
        });
    </script>
    <script src="/scripts/loan-simulations.js?v=20260303-pt-status-v1"></script>
</body>
</html>



