<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credix - <%= financePage.browserTitle %></title>
    <%- include('partials/favicon') %>
    <%- include('partials/toast') %>
    <%- include('partials/session-timeout') %>
    <style>html,body{background:#020617;} html{font-size:16px;}</style>
    <script>
        (function () {
            const root = document.documentElement;
            try {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark') root.classList.add('dark');
                if (savedTheme === 'light') root.classList.remove('dark');
            } catch (error) {}
        })();
        window.tailwind = window.tailwind || {};
        window.tailwind.config = Object.assign({}, window.tailwind.config || {}, { darkMode: 'class' });
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family:'Inter',sans-serif; overflow-x:hidden; color:#f8fbff; background:
            radial-gradient(72rem 44rem at -8% -12%, rgba(37,99,235,.26), transparent 48%),
            radial-gradient(48rem 32rem at 100% 0%, rgba(15,23,42,.22), transparent 44%),
            linear-gradient(180deg, #050b17 0%, #08111f 100%); }
        body::before { content:""; position:fixed; inset:0; pointer-events:none; opacity:.55; background:
            linear-gradient(180deg, rgba(255,255,255,.02), transparent 22%),
            radial-gradient(circle at 25% 20%, rgba(59,130,246,.08), transparent 24%); mix-blend-mode:screen; }
        .premium-header { background: rgba(12,18,32,.86); border-bottom: 1px solid rgba(148,163,184,.16); backdrop-filter: blur(10px); }
        .icon-btn { color:#cbd5e1; width:42px; height:42px; border-radius:12px; display:inline-flex; align-items:center; justify-content:center; transition:.12s; }
        .icon-btn:hover { color:#fff; background:rgba(59,130,246,.16); box-shadow: inset 0 0 0 1px rgba(96,165,250,.24); }
        .modern-sidebar { transform: translateX(0); transition: transform .12s ease-out; }

        .page-title { font-size:clamp(2rem, 1.3vw + 1.2rem, 2.85rem); line-height:1.04; font-weight:800; letter-spacing:-.04em; color:#f8fafc; }
        .page-subtitle { color:#94a3b8; font-size:1rem; line-height:1.6; }
        .toolbar-search {
            position:relative; display:flex; align-items:center; min-height:56px; padding:0 1.1rem 0 3.15rem;
            border:1px solid rgba(59,130,246,.18); border-radius:16px;
            background:linear-gradient(180deg, rgba(8,16,31,.92), rgba(8,16,30,.82)); box-shadow:0 12px 32px rgba(2,6,23,.2);
        }
        .toolbar-search i { position:absolute; left:1.15rem; color:#64748b; font-size:1.15rem; }
        .toolbar-search input { width:100%; background:transparent; border:none; color:#f8fafc; font-size:1rem; line-height:1.3; outline:none; }
        .toolbar-search input::placeholder { color:#64748b; }
        .month-switcher {
            display:inline-flex; align-items:center; gap:.45rem; padding:.35rem; border:1px solid rgba(59,130,246,.16);
            border-radius:16px; background:linear-gradient(180deg, rgba(8,16,31,.92), rgba(8,16,30,.82)); box-shadow:0 12px 28px rgba(2,6,23,.18);
        }
        .month-switcher-btn {
            min-width:112px; min-height:44px; padding:0 .95rem; border-radius:12px; border:1px solid transparent;
            color:#cbd5e1; font-size:.98rem; font-weight:700;
            transition:background-color 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease;
        }
        .month-switcher-btn:hover { color:#fff; background:rgba(30,41,59,.82); }
        .month-switcher-btn.is-active {
            background:linear-gradient(135deg, rgba(37,99,235,.94), rgba(59,130,246,.9)); border-color:rgba(96,165,250,.44);
            color:#fff; box-shadow:0 10px 24px rgba(37,99,235,.25);
        }
        .payables-primary-btn {
            display:inline-flex; align-items:center; justify-content:center; gap:.7rem; min-height:56px; padding:0 1.35rem;
            border-radius:16px; border:1px solid rgba(96,165,250,.48); background:linear-gradient(135deg, rgba(37,99,235,.96), rgba(59,130,246,.92));
            color:#eff6ff; font-size:1.02rem; font-weight:800; box-shadow:0 18px 34px rgba(37,99,235,.28); transition:transform 160ms ease, box-shadow 160ms ease;
        }
        .payables-primary-btn:hover { transform:translateY(-1px); box-shadow:0 22px 40px rgba(37,99,235,.34); }
        .filter-chip-row { display:flex; flex-wrap:wrap; gap:.7rem; }
        .filter-chip {
            display:inline-flex; align-items:center; justify-content:center; min-height:38px; padding:0 1rem; border-radius:999px;
            border:1px solid rgba(71,85,105,.52); background:rgba(15,23,42,.68); color:#cbd5e1; font-size:.9rem; font-weight:700;
            transition:background-color 160ms ease, border-color 160ms ease, color 160ms ease;
        }
        .filter-chip:hover { color:#fff; background:rgba(30,41,59,.82); }
        .filter-chip.is-active { border-color:rgba(96,165,250,.44); background:linear-gradient(135deg, rgba(37,99,235,.92), rgba(59,130,246,.9)); color:#fff; box-shadow:0 12px 24px rgba(37,99,235,.2); }
        .page-panel {
            overflow:hidden; border:1px solid rgba(59,130,246,.14); border-radius:24px;
            background:linear-gradient(180deg, rgba(8,16,31,.96), rgba(8,15,28,.88)); box-shadow:0 22px 52px rgba(2,6,23,.28);
        }
        .panel-summary {
            display:flex; flex-wrap:wrap; gap:.85rem; align-items:center; padding:1rem 1.25rem; border-bottom:1px solid rgba(51,65,85,.72);
            font-size:.84rem; line-height:1.4; font-weight:800; letter-spacing:.08em; text-transform:uppercase;
        }
        .panel-summary-dot { color:#475569; }
        .panel-summary--overdue { color:#f87171; }
        .panel-summary--today { color:#f59e0b; }
        .panel-summary--pending { color:#93c5fd; }
        .payables-table-wrap { overflow-x:auto; overflow-y:visible; }
        .payables-table-wrap::-webkit-scrollbar { height:10px; }
        .payables-table-wrap::-webkit-scrollbar-thumb { background:rgba(71,85,105,.8); border-radius:999px; }
        .payables-table { width:100%; min-width:1120px; border-collapse:collapse; }
        .payables-table th {
            padding:1rem 1.1rem; text-align:left; color:#8ea4c5; font-size:.82rem; line-height:1.2; font-weight:800;
            letter-spacing:.08em; text-transform:uppercase; border-bottom:1px solid rgba(51,65,85,.72);
        }
        .payables-table th:last-child { text-align:right; }
        .payables-table td { padding:1rem 1.1rem; border-top:1px solid rgba(30,41,59,.72); vertical-align:middle; }
        .payables-row { position:relative; transition:background-color 160ms ease; }
        .payables-row:hover { background:rgba(15,23,42,.48); }
        .payables-row--overdue { box-shadow:inset 4px 0 0 #ef4444; }
        .payables-row--today { box-shadow:inset 4px 0 0 #f59e0b; }
        .payables-row--pending { box-shadow:inset 4px 0 0 #3b82f6; }
        .payables-row--scheduled { box-shadow:inset 4px 0 0 #38bdf8; }
        .payables-row--paid { box-shadow:inset 4px 0 0 #10b981; }
        .payable-main { display:flex; align-items:flex-start; gap:.95rem; }
        .payable-status-icon { flex-shrink:0; width:1.55rem; height:1.55rem; display:inline-flex; align-items:center; justify-content:center; border-radius:999px; font-size:.82rem; }
        .payable-status-icon--overdue { background:rgba(239,68,68,.16); color:#fda4af; }
        .payable-status-icon--today { background:rgba(245,158,11,.16); color:#fcd34d; }
        .payable-status-icon--pending { background:rgba(148,163,184,.16); color:#cbd5e1; }
        .payable-status-icon--scheduled { background:rgba(59,130,246,.16); color:#93c5fd; }
        .payable-status-icon--paid { background:rgba(16,185,129,.16); color:#6ee7b7; }
        .payable-title { color:#f8fafc; font-size:1.02rem; line-height:1.25; font-weight:800; }
        .payable-subtitle { margin-top:.2rem; color:#64748b; font-size:.86rem; line-height:1.4; }
        .payable-amount { color:#f8fafc; font-size:1rem; line-height:1.2; font-weight:800; letter-spacing:-.02em; }
        .payable-due { color:#cbd5e1; font-size:1rem; line-height:1.2; font-weight:700; }
        .payable-due--overdue { color:#f87171; }
        .payable-due--today { color:#f59e0b; }
        .payable-note { color:#94a3b8; font-size:.92rem; line-height:1.5; }
        .status-pill { display:inline-flex; align-items:center; min-height:28px; padding:0 .75rem; border-radius:999px; border:1px solid transparent; font-size:.72rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase; white-space:nowrap; }
        .status-pill--paid { border-color:rgba(16,185,129,.34); background:rgba(16,185,129,.14); color:#6ee7b7; }
        .status-pill--overdue { border-color:rgba(248,113,113,.34); background:rgba(248,113,113,.14); color:#fda4af; }
        .status-pill--today { border-color:rgba(245,158,11,.34); background:rgba(245,158,11,.14); color:#fcd34d; }
        .status-pill--pending { border-color:rgba(100,116,139,.36); background:rgba(51,65,85,.44); color:#cbd5e1; }
        .status-pill--scheduled { border-color:rgba(59,130,246,.32); background:rgba(37,99,235,.14); color:#93c5fd; }
        .row-actions { display:flex; align-items:center; justify-content:flex-end; gap:.65rem; position:relative; }
        .row-complete-btn {
            display:inline-flex; align-items:center; justify-content:center; min-height:36px; padding:0 .95rem; border-radius:10px;
            border:1px solid rgba(96,165,250,.44); background:linear-gradient(135deg, rgba(37,99,235,.94), rgba(59,130,246,.9));
            color:#eff6ff; font-size:.86rem; font-weight:800; transition:transform 160ms ease, box-shadow 160ms ease;
        }
        .row-complete-btn:hover { transform:translateY(-1px); box-shadow:0 14px 26px rgba(37,99,235,.22); }
        .row-menu-toggle { width:2.15rem; height:2.15rem; display:inline-flex; align-items:center; justify-content:center; border-radius:999px; color:#94a3b8; transition:background-color 160ms ease, color 160ms ease; }
        .row-menu-toggle:hover { background:rgba(30,41,59,.72); color:#f8fafc; }
        .row-menu { position:absolute; top:calc(100% + .45rem); right:0; z-index:20; min-width:11rem; padding:.45rem; border:1px solid rgba(71,85,105,.72); border-radius:14px; background:linear-gradient(180deg, rgba(10,18,34,.98), rgba(9,16,30,.96)); box-shadow:0 20px 40px rgba(2,6,23,.36); }
        .row-menu.hidden { display:none; }
        .row-menu-btn { width:100%; display:flex; align-items:center; gap:.65rem; min-height:40px; padding:0 .8rem; border-radius:10px; color:#cbd5e1; font-size:.88rem; font-weight:700; text-align:left; transition:background-color 160ms ease, color 160ms ease; }
        .row-menu-btn:hover { background:rgba(30,41,59,.74); color:#fff; }
        .row-menu-btn--danger { color:#fda4af; }
        .row-menu-btn--danger:hover { background:rgba(127,29,29,.36); color:#fecaca; }
        .table-empty { padding:3.4rem 1.2rem; text-align:center; color:#94a3b8; }
        .table-empty-icon { width:3.25rem; height:3.25rem; margin:0 auto; display:flex; align-items:center; justify-content:center; border-radius:1rem; border:1px solid rgba(51,65,85,.76); background:rgba(2,8,23,.48); color:#64748b; font-size:1.1rem; }
        .table-empty-title { margin-top:1rem; color:#f8fafc; font-size:1.04rem; font-weight:800; }
        .table-empty-note { margin-top:.45rem; font-size:.92rem; line-height:1.6; }
        .panel-footer { display:flex; flex-direction:column; gap:.95rem; padding:1rem 1.25rem 1.2rem; border-top:1px solid rgba(51,65,85,.72); }
        .panel-footer-info { color:#94a3b8; font-size:.9rem; line-height:1.5; }
        .panel-footer-pagination { display:flex; flex-wrap:wrap; gap:.55rem; }
        .panel-page-btn {
            display:inline-flex; align-items:center; justify-content:center; min-width:2.4rem; min-height:2.4rem; padding:0 .8rem; border-radius:12px;
            border:1px solid rgba(71,85,105,.64); background:rgba(15,23,42,.72); color:#cbd5e1; font-size:.86rem; font-weight:700;
            transition:background-color 160ms ease, border-color 160ms ease, color 160ms ease;
        }
        .panel-page-btn:hover { border-color:rgba(96,165,250,.42); color:#fff; background:rgba(30,41,59,.9); }
        .panel-page-btn[disabled] { opacity:.45; cursor:not-allowed; }
        .panel-page-btn.is-active { border-color:rgba(96,165,250,.48); background:linear-gradient(135deg, rgba(37,99,235,.94), rgba(59,130,246,.9)); color:#fff; }
        .panel-page-ellipsis { display:inline-flex; align-items:center; justify-content:center; min-width:2rem; color:#64748b; font-size:.86rem; font-weight:700; }
        .mobile-list { display:grid; gap:.9rem; padding:1rem; }
        .mobile-card { border:1px solid rgba(51,65,85,.7); border-radius:18px; background:rgba(2,8,23,.34); padding:1rem; box-shadow:inset 0 1px 0 rgba(255,255,255,.02); }
        .mobile-card--overdue { border-color:rgba(248,113,113,.28); }
        .mobile-card--today { border-color:rgba(245,158,11,.28); }
        .mobile-card--pending { border-color:rgba(59,130,246,.22); }
        .mobile-card--scheduled { border-color:rgba(56,189,248,.22); }
        .mobile-card--paid { border-color:rgba(16,185,129,.22); }
        .mobile-card-grid { display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:.85rem; margin-top:1rem; }
        .mobile-card-label { color:#64748b; font-size:.72rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase; }
        .mobile-card-value { margin-top:.3rem; color:#e2e8f0; font-size:.92rem; line-height:1.45; font-weight:700; }
        .mobile-card-actions { display:flex; align-items:center; justify-content:flex-end; gap:.65rem; margin-top:1rem; position:relative; }
        .error-banner { border:1px solid rgba(248,113,113,.3); border-radius:16px; background:rgba(127,29,29,.18); color:#fecaca; padding:.95rem 1rem; font-size:.92rem; line-height:1.55; }
        .screen-loading .page-panel, .screen-loading .toolbar-search, .screen-loading .month-switcher, .screen-loading .filter-chip-row { opacity:.72; pointer-events:none; }
        body.sidebar-collapsed .modern-sidebar { transform: translateX(-100%); }
        body.sidebar-collapsed main { margin-left: 0 !important; width: 100% !important; flex: 1 1 100% !important; }
        @media (max-width: 1279px) { .month-switcher-btn { min-width:96px; } }
        @media (max-width: 1024px) {
            .modern-sidebar { transform: translateX(-100%); }
            .modern-sidebar.mobile-open { transform: translateX(0) !important; }
            main { margin-left: 0 !important; width: 100% !important; flex: 1 1 100% !important; }
        }
        @media (max-width: 767px) { .payables-table-wrap { display:none; } }
        @media (min-width: 768px) { .mobile-list { display:none; } }
        @media (min-width: 768px) {
            .panel-footer { flex-direction:row; align-items:center; justify-content:space-between; }
            .panel-footer-pagination { justify-content:flex-end; }
        }
    </style>
    <link rel="stylesheet" href="/styles/premium-dashboard-theme.css?v=20260303f">
</head>
<body class="dashboard-premium dashboard-financial min-h-screen">
    <header class="premium-header fixed w-full top-0 z-50">
        <div class="flex items-center justify-between px-3 py-3 sm:px-6 sm:py-4">
            <div class="flex items-center">
                <button id="sidebarToggle" class="icon-btn focus:outline-none"><i class="fas fa-bars text-xl"></i></button>
                <h1 class="ml-3 sm:ml-6">
                    <a href="/admin/visao-geral.html" class="flex items-center" aria-label="Credix">
                        <%- include('partials/brand-wordmark', { size: 'header' }) %>
                    </a>
                </h1>
            </div>
            <div class="flex items-center gap-4">
                <button id="userMenuBtn" class="flex items-center gap-2 text-slate-200 hover:text-white focus:outline-none">
                    <span id="userName" class="font-semibold">Ola, <%= currentUser?.name || currentUser?.full_name || 'Administrador' %></span>
                    <i class="fas fa-chevron-down text-sm"></i>
                </button>
                <div id="userMenuDropdown" class="absolute right-6 top-full z-50 mt-2 hidden w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-xl dark:border-slate-700 dark:bg-slate-900">
                    <button type="button" data-user-menu-action="profile" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"><i class="fas fa-id-card text-slate-500 dark:text-slate-300"></i><span>Meu perfil</span></button>
                    <button type="button" data-user-menu-action="security" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"><i class="fas fa-shield-halved text-slate-500 dark:text-slate-300"></i><span>Seguranca</span></button>
                    <button type="button" data-user-menu-action="help" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"><i class="fas fa-circle-question text-slate-500 dark:text-slate-300"></i><span>Ajuda</span></button>
                    <div class="my-2 border-t border-slate-200 dark:border-slate-700"></div>
                    <button type="button" data-user-menu-action="logout" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-semibold text-rose-600 hover:bg-rose-50 dark:text-rose-400 dark:hover:bg-rose-950/40"><i class="fas fa-right-from-bracket"></i><span>Sair</span></button>
                </div>
            </div>
        </div>
    </header>

    <div class="flex pt-16 sm:pt-20">
        <%- include('partials/admin-sidebar', { activePage }) %>

        <main class="relative z-10 flex-1 p-4 sm:p-6 lg:p-8">
            <div id="payablesRoot" class="mx-auto w-full max-w-[118rem]">
                <section class="mb-6 flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
                    <div>
                        <h2 class="page-title"><%= financePage.pageTitle %></h2>
                        <p class="page-subtitle mt-2"><%= financePage.pageSubtitle %></p>
                    </div>
                    <button id="openPayableModalBtn" type="button" class="payables-primary-btn">
                        <i class="fas fa-plus text-sm"></i>
                        <span><%= financePage.primaryButtonLabel %></span>
                    </button>
                </section>

                <div id="payablesError" class="error-banner mb-5 hidden"></div>

                <section class="mb-5 grid gap-4 xl:grid-cols-[minmax(0,1.15fr)_auto] xl:items-center">
                    <label class="toolbar-search" aria-label="<%= financePage.searchAriaLabel %>">
                        <i class="fas fa-magnifying-glass"></i>
                        <input id="payablesSearchInput" type="search" autocomplete="off" placeholder="<%= financePage.searchPlaceholder %>">
                    </label>
                    <div id="monthSwitcher" class="month-switcher"></div>
                </section>

                <section class="mb-5">
                    <div id="statusFilters" class="filter-chip-row"></div>
                </section>

                <section class="page-panel">
                    <div class="panel-summary">
                        <span id="summaryOverdue" class="panel-summary--overdue">0 vencidas</span>
                        <span class="panel-summary-dot">•</span>
                        <span id="summaryDueToday" class="panel-summary--today">0 vence hoje</span>
                        <span class="panel-summary-dot">•</span>
                        <span id="summaryPending" class="panel-summary--pending">0 pendentes</span>
                    </div>

                    <div class="payables-table-wrap">
                        <table class="payables-table">
                            <thead>
                                <tr>
                                    <th><%= financePage.tablePrimaryHeader %></th>
                                    <th>Valor (R$)</th>
                                    <th><%= financePage.tableDateHeader %></th>
                                    <th>Status</th>
                                    <th><%= financePage.tableNotesHeader %></th>
                                    <th><%= financePage.tableActionsHeader %></th>
                                </tr>
                            </thead>
                            <tbody id="payablesTableBody"></tbody>
                        </table>
                    </div>

                    <div id="payablesMobileList" class="mobile-list"></div>

                    <div class="panel-footer">
                        <p id="paginationInfo" class="panel-footer-info">Mostrando 0-0 de 0 <%= financePage.paginationPlural %></p>
                        <div id="paginationControls" class="panel-footer-pagination"></div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <div id="payableModal" class="modal-base fixed inset-0 z-50 hidden items-center justify-center p-3 sm:p-4" data-modal-base="true" role="dialog" aria-modal="true" aria-labelledby="payableModalTitle">
        <div class="modal-base__panel modal-base__panel--md">
            <form id="payableForm" class="flex min-h-0 flex-1 flex-col">
                <div class="modal-base__header">
                    <div class="modal-base__title-wrap">
                        <h3 id="payableModalTitle" class="modal-base__title"><%= financePage.modalNewTitle %></h3>
                        <p id="payableModalSubtitle" class="modal-base__description"><%= financePage.modalNewSubtitle %></p>
                    </div>
                    <button id="closePayableModalBtn" class="modal-base__close" type="button" aria-label="Fechar modal">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="modal-base__body">
                    <section class="modal-base__section">
                        <h4 class="modal-base__section-title">Dados principais</h4>
                        <div class="modal-base__grid-2">
                            <div class="modal-base__field modal-base__field--full">
                                <label for="payableDescriptionInput" class="modal-base__field-label"><%= financePage.modalDescriptionLabel %></label>
                                <input id="payableDescriptionInput" class="filter-control" type="text" maxlength="300" placeholder="<%= financePage.modalDescriptionPlaceholder %>" required data-modal-autofocus>
                            </div>
                            <div class="modal-base__field">
                                <label for="payableCategoryInput" class="modal-base__field-label">Categoria</label>
                                <input id="payableCategoryInput" class="filter-control" type="text" maxlength="120" placeholder="<%= financePage.modalCategoryPlaceholder %>" required>
                            </div>
                            <div class="modal-base__field">
                                <label for="payableAmountInput" class="modal-base__field-label">Valor (R$)</label>
                                <input id="payableAmountInput" class="filter-control" type="number" min="0.01" step="0.01" inputmode="decimal" placeholder="0,00" required>
                            </div>
                        </div>
                    </section>

                    <section class="modal-base__section">
                        <h4 class="modal-base__section-title">Agenda</h4>
                        <div class="modal-base__grid-2">
                            <div class="modal-base__field">
                                <label for="payableDateInput" class="modal-base__field-label"><%= financePage.modalDateLabel %></label>
                                <input id="payableDateInput" class="filter-control" type="date" required>
                            </div>
                            <div class="modal-base__field">
                                <label for="payableStatusInput" class="modal-base__field-label">Situacao</label>
                                <select id="payableStatusInput" class="filter-control">
                                    <option value="pending">Pendente</option>
                                    <option value="scheduled">Agendada</option>
                                    <option value="completed"><%= financePage.completedOptionLabel %></option>
                                </select>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="modal-base__footer">
                    <div class="modal-base__footer-secondary">
                        <button type="button" id="cancelPayableModalBtn" class="modal-btn modal-btn--ghost">Cancelar</button>
                    </div>
                    <div class="modal-base__footer-actions">
                        <button type="submit" id="savePayableBtn" class="modal-btn modal-btn--primary"><%= financePage.modalSaveNewLabel %></button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script>
        window.__AUTH_USER__ = <%- JSON.stringify(currentUser || null) %>;
        window.__FINANCE_PAGE__ = <%- JSON.stringify(financePage) %>;
    </script>
    <script>
        const currentUser = window.__AUTH_USER__;
        const pageText = window.__FINANCE_PAGE__ || {};
        if (!currentUser) {
            window.location.href = '/login';
        } else {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('currentUser', JSON.stringify(currentUser));
            const displayName = currentUser.name || currentUser.full_name || 'Administrador';
            document.getElementById('userName').textContent = `Ola, ${displayName}`;
        }

        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('main');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;
        const userMenuBtn = document.getElementById('userMenuBtn');
        const userMenuDropdown = document.getElementById('userMenuDropdown');

        const payablesRoot = document.getElementById('payablesRoot');
        const payablesError = document.getElementById('payablesError');
        const searchInput = document.getElementById('payablesSearchInput');
        const monthSwitcher = document.getElementById('monthSwitcher');
        const statusFilters = document.getElementById('statusFilters');
        const summaryOverdue = document.getElementById('summaryOverdue');
        const summaryDueToday = document.getElementById('summaryDueToday');
        const summaryPending = document.getElementById('summaryPending');
        const payablesTableBody = document.getElementById('payablesTableBody');
        const payablesMobileList = document.getElementById('payablesMobileList');
        const paginationInfo = document.getElementById('paginationInfo');
        const paginationControls = document.getElementById('paginationControls');

        const payableModal = document.getElementById('payableModal');
        const payableForm = document.getElementById('payableForm');
        const payableModalTitle = document.getElementById('payableModalTitle');
        const payableModalSubtitle = document.getElementById('payableModalSubtitle');
        const payableDescriptionInput = document.getElementById('payableDescriptionInput');
        const payableCategoryInput = document.getElementById('payableCategoryInput');
        const payableAmountInput = document.getElementById('payableAmountInput');
        const payableDateInput = document.getElementById('payableDateInput');
        const payableStatusInput = document.getElementById('payableStatusInput');
        const savePayableBtn = document.getElementById('savePayableBtn');
        const openPayableModalBtn = document.getElementById('openPayableModalBtn');
        const closePayableModalBtn = document.getElementById('closePayableModalBtn');
        const cancelPayableModalBtn = document.getElementById('cancelPayableModalBtn');

        const SYSTEM_TRANSACTION_CATEGORIES = new Set(Array.isArray(pageText.systemCategories) ? pageText.systemCategories : []);
        const STATUS_FILTERS = [
            { key: 'all', label: 'Todas' },
            { key: 'pending', label: 'Pendentes' },
            { key: 'paid', label: pageText.statusFilterPaidLabel || 'Pagas' },
            { key: 'overdue', label: 'Vencidas' },
            { key: 'due-today', label: 'Vencendo hoje' },
        ];

        const state = {
            items: [],
            search: '',
            statusFilter: 'all',
            monthCursor: startOfMonth(new Date()),
            page: 1,
            pageSize: 15,
            loading: false,
            saving: false,
            editingId: null,
            openMenuId: null,
        };

        function startOfDay(date) {
            const next = new Date(date);
            next.setHours(0, 0, 0, 0);
            return next;
        }

        function startOfMonth(date) {
            return new Date(date.getFullYear(), date.getMonth(), 1);
        }

        function parseDateOnly(value) {
            if (typeof value !== 'string') return new Date(NaN);
            const [year, month, day] = value.split('-').map(Number);
            return new Date(year, (month || 1) - 1, day || 1);
        }

        function toDateInputValue(date) {
            if (!(date instanceof Date) || Number.isNaN(date.getTime())) return '';
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function addMonths(date, diff) {
            return new Date(date.getFullYear(), date.getMonth() + diff, 1);
        }

        function sameMonth(date, monthCursor) {
            return date.getFullYear() === monthCursor.getFullYear() && date.getMonth() === monthCursor.getMonth();
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('pt-BR', {
                style: 'currency',
                currency: 'BRL',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            }).format(Number(value) || 0);
        }

        function formatAmountPlain(value) {
            return new Intl.NumberFormat('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
            }).format(Number(value) || 0);
        }

        function formatDate(value) {
            const date = value instanceof Date ? value : parseDateOnly(value);
            if (Number.isNaN(date.getTime())) return '--';
            return new Intl.DateTimeFormat('pt-BR', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
            }).format(date);
        }

        function formatMonthLabel(date) {
            return new Intl.DateTimeFormat('pt-BR', { month: 'long' }).format(date).replace(/^\p{L}/u, (char) => char.toUpperCase());
        }

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function notify(message, type = 'success') {
            if (typeof showMessage === 'function') {
                showMessage(message, type);
                return;
            }
            window.alert(message);
        }

        function showError(message) {
            payablesError.textContent = message;
            payablesError.classList.remove('hidden');
        }

        function hideError() {
            payablesError.textContent = '';
            payablesError.classList.add('hidden');
        }

        function setScreenLoading(loading) {
            state.loading = loading;
            payablesRoot.classList.toggle('screen-loading', loading);
        }

        function setSaving(loading) {
            state.saving = loading;
            savePayableBtn.disabled = loading;
            savePayableBtn.textContent = loading
                ? 'Salvando...'
                : (state.editingId ? (pageText.modalSaveEditLabel || 'Salvar alteracoes') : (pageText.modalSaveNewLabel || 'Salvar conta'));
        }

        function normalizeTransaction(row) {
            return {
                id: String(row?.id || ''),
                type: row?.type === 'expense' ? 'expense' : 'income',
                amount: Number(row?.amount || 0),
                category: String(row?.category || '').trim(),
                date: String(row?.date || ''),
                description: String(row?.description || '').trim(),
                status: row?.status === 'completed' || row?.status === 'scheduled' ? row.status : 'pending',
            };
        }

        function matchesPageTransaction(item) {
            return item.type === (pageText.itemType || 'expense') && !SYSTEM_TRANSACTION_CATEGORIES.has(item.category);
        }

        function getDisplayStatus(item) {
            const dueDate = startOfDay(parseDateOnly(item.date));
            const today = startOfDay(new Date());

            if (item.status === 'completed') {
                return { key: 'paid', group: 'paid', label: pageText.statusPaidLabel || 'Paga', pillClass: 'status-pill status-pill--paid', rowClass: 'payables-row--paid', iconClass: 'payable-status-icon payable-status-icon--paid', iconName: 'fa-check' };
            }
            if (dueDate.getTime() < today.getTime()) {
                return { key: 'overdue', group: 'overdue', label: pageText.statusOverdueLabel || 'Vencida', pillClass: 'status-pill status-pill--overdue', rowClass: 'payables-row--overdue', iconClass: 'payable-status-icon payable-status-icon--overdue', iconName: 'fa-triangle-exclamation' };
            }
            if (dueDate.getTime() === today.getTime()) {
                return { key: 'due-today', group: 'due-today', label: pageText.statusTodayLabel || 'Vence hoje', pillClass: 'status-pill status-pill--today', rowClass: 'payables-row--today', iconClass: 'payable-status-icon payable-status-icon--today', iconName: 'fa-clock' };
            }
            if (item.status === 'scheduled') {
                return { key: 'scheduled', group: 'pending', label: pageText.statusScheduledLabel || 'Agendada', pillClass: 'status-pill status-pill--scheduled', rowClass: 'payables-row--scheduled', iconClass: 'payable-status-icon payable-status-icon--scheduled', iconName: 'fa-calendar-day' };
            }
            return { key: 'pending', group: 'pending', label: pageText.statusPendingLabel || 'Pendente', pillClass: 'status-pill status-pill--pending', rowClass: 'payables-row--pending', iconClass: 'payable-status-icon payable-status-icon--pending', iconName: 'fa-circle' };
        }

        function buildObservation(item, displayStatus) {
            const dueDate = parseDateOnly(item.date);
            const today = startOfDay(new Date());
            const diffDays = Math.floor((startOfDay(dueDate).getTime() - today.getTime()) / 86400000);

            if (displayStatus.key === 'paid') return pageText.observationPaid || 'Pagamento registrado no sistema.';
            if (displayStatus.key === 'overdue') return `Em atraso ha ${Math.abs(diffDays)} dia(s).`;
            if (displayStatus.key === 'due-today') return pageText.observationToday || 'Compromisso previsto para hoje.';
            if (displayStatus.key === 'scheduled') return pageText.observationScheduled || 'Pagamento agendado para esta data.';
            return pageText.observationPending || 'Aguardando baixa financeira.';
        }

        function getMonthBaseItems() {
            return state.items.filter((item) => sameMonth(parseDateOnly(item.date), state.monthCursor));
        }

        function matchesSearch(item) {
            if (!state.search) return true;
            return item.description.toLowerCase().includes(state.search) || item.category.toLowerCase().includes(state.search);
        }

        function matchesStatusFilter(item) {
            if (state.statusFilter === 'all') return true;
            const displayStatus = getDisplayStatus(item);
            if (state.statusFilter === 'pending') return displayStatus.group === 'pending';
            return displayStatus.group === state.statusFilter;
        }

        function sortItems(items) {
            const order = { overdue: 0, 'due-today': 1, scheduled: 2, pending: 3, paid: 4 };
            return [...items].sort((left, right) => {
                const leftStatus = getDisplayStatus(left);
                const rightStatus = getDisplayStatus(right);
                const rankDiff = (order[leftStatus.key] ?? 9) - (order[rightStatus.key] ?? 9);
                if (rankDiff !== 0) return rankDiff;

                const leftDate = parseDateOnly(left.date).getTime();
                const rightDate = parseDateOnly(right.date).getTime();
                if (leftStatus.group === 'paid' && rightStatus.group === 'paid') {
                    if (leftDate !== rightDate) return rightDate - leftDate;
                } else if (leftDate !== rightDate) {
                    return leftDate - rightDate;
                }
                return right.amount - left.amount;
            });
        }

        function getFilteredItems() {
            return sortItems(getMonthBaseItems().filter(matchesSearch).filter(matchesStatusFilter));
        }

        function getPaginationMeta(totalItems) {
            const totalPages = Math.max(1, Math.ceil(totalItems / state.pageSize));
            const currentPage = Math.min(state.page, totalPages);
            const start = totalItems === 0 ? 0 : ((currentPage - 1) * state.pageSize) + 1;
            const end = totalItems === 0 ? 0 : Math.min(currentPage * state.pageSize, totalItems);
            state.page = currentPage;
            return { totalPages, currentPage, start, end };
        }

        function buildPaginationSequence(currentPage, totalPages) {
            if (totalPages <= 7) return Array.from({ length: totalPages }, (_, index) => index + 1);

            const pages = new Set([1, totalPages, currentPage, currentPage - 1, currentPage + 1]);
            if (currentPage <= 3) {
                pages.add(2); pages.add(3); pages.add(4);
            }
            if (currentPage >= totalPages - 2) {
                pages.add(totalPages - 1); pages.add(totalPages - 2); pages.add(totalPages - 3);
            }

            const sorted = [...pages].filter((page) => page >= 1 && page <= totalPages).sort((a, b) => a - b);
            const sequence = [];
            sorted.forEach((page, index) => {
                if (index > 0 && page - sorted[index - 1] > 1) sequence.push('...');
                sequence.push(page);
            });
            return sequence;
        }

        function renderMonthSwitcher() {
            const months = [-1, 0, 1].map((offset) => addMonths(state.monthCursor, offset));
            monthSwitcher.innerHTML = months.map((date) => {
                const iso = toDateInputValue(date);
                const active = sameMonth(date, state.monthCursor);
                return `<button type="button" class="month-switcher-btn ${active ? 'is-active' : ''}" data-month-value="${iso}" ${active ? 'aria-current="true"' : ''}>${escapeHtml(formatMonthLabel(date))}</button>`;
            }).join('');
        }

        function renderStatusFilters() {
            statusFilters.innerHTML = STATUS_FILTERS.map((filter) => `
                <button type="button" class="filter-chip ${filter.key === state.statusFilter ? 'is-active' : ''}" data-status-filter="${filter.key}" ${filter.key === state.statusFilter ? 'aria-current="true"' : ''}>${escapeHtml(filter.label)}</button>
            `).join('');
        }

        function renderSummary(baseItems) {
            const counts = baseItems.reduce((accumulator, item) => {
                const group = getDisplayStatus(item).group;
                if (group === 'overdue') accumulator.overdue += 1;
                if (group === 'due-today') accumulator.dueToday += 1;
                if (group === 'pending') accumulator.pending += 1;
                return accumulator;
            }, { overdue: 0, dueToday: 0, pending: 0 });

            summaryOverdue.textContent = `${counts.overdue} ${pageText.summaryOverdueSuffix || 'vencidas'}`;
            summaryDueToday.textContent = `${counts.dueToday} ${pageText.summaryTodaySuffix || 'vence hoje'}`;
            summaryPending.textContent = `${counts.pending} ${pageText.summaryPendingSuffix || 'pendentes'}`;
        }

        function buildDesktopRow(item) {
            const displayStatus = getDisplayStatus(item);
            const note = buildObservation(item, displayStatus);
            const dueClass = displayStatus.group === 'overdue' ? 'payable-due payable-due--overdue'
                : displayStatus.group === 'due-today' ? 'payable-due payable-due--today'
                    : 'payable-due';
            const menuOpen = state.openMenuId === item.id;

            return `
                <tr class="payables-row ${displayStatus.rowClass}">
                    <td>
                        <div class="payable-main">
                            <span class="${displayStatus.iconClass}"><i class="fas ${displayStatus.iconName}"></i></span>
                            <div class="min-w-0">
                                <p class="payable-title">${escapeHtml(item.description || 'Conta sem descricao')}</p>
                                <p class="payable-subtitle">${escapeHtml(item.category || 'Sem categoria')}</p>
                            </div>
                        </div>
                    </td>
                    <td><span class="payable-amount">${escapeHtml(formatAmountPlain(item.amount))}</span></td>
                    <td><span class="${dueClass}">${escapeHtml(formatDate(item.date))}</span></td>
                    <td><span class="${displayStatus.pillClass}">${escapeHtml(displayStatus.label)}</span></td>
                    <td><p class="payable-note">${escapeHtml(note)}</p></td>
                    <td>
                        <div class="row-actions">
                            ${displayStatus.group !== 'paid' ? `<button type="button" class="row-complete-btn" data-payable-action="complete" data-payable-id="${escapeHtml(item.id)}">${escapeHtml(pageText.actionCompleteLabel || 'Baixar')}</button>` : ''}
                            <button type="button" class="row-menu-toggle" data-payable-action="toggle-menu" data-payable-id="${escapeHtml(item.id)}" aria-label="Abrir menu da conta">
                                <i class="fas fa-ellipsis-vertical"></i>
                            </button>
                            <div class="row-menu ${menuOpen ? '' : 'hidden'}" data-payable-menu="${escapeHtml(item.id)}">
                                <button type="button" class="row-menu-btn" data-payable-action="edit" data-payable-id="${escapeHtml(item.id)}"><i class="fas fa-pen"></i><span>Editar</span></button>
                                <button type="button" class="row-menu-btn row-menu-btn--danger" data-payable-action="delete" data-payable-id="${escapeHtml(item.id)}"><i class="fas fa-trash"></i><span>Excluir</span></button>
                            </div>
                        </div>
                    </td>
                </tr>
            `;
        }

        function buildMobileCard(item) {
            const displayStatus = getDisplayStatus(item);
            const note = buildObservation(item, displayStatus);
            const menuOpen = state.openMenuId === item.id;

            return `
                <article class="mobile-card mobile-card--${displayStatus.key}">
                    <div class="flex items-start justify-between gap-3">
                        <div class="payable-main min-w-0">
                            <span class="${displayStatus.iconClass}"><i class="fas ${displayStatus.iconName}"></i></span>
                            <div class="min-w-0">
                                <p class="payable-title">${escapeHtml(item.description || 'Conta sem descricao')}</p>
                                <p class="payable-subtitle">${escapeHtml(item.category || 'Sem categoria')}</p>
                            </div>
                        </div>
                        <span class="${displayStatus.pillClass}">${escapeHtml(displayStatus.label)}</span>
                    </div>
                    <div class="mobile-card-grid">
                        <div><p class="mobile-card-label">Valor</p><p class="mobile-card-value">${escapeHtml(formatCurrency(item.amount))}</p></div>
                        <div><p class="mobile-card-label">${escapeHtml(pageText.tableDateHeader || 'Vencimento')}</p><p class="mobile-card-value">${escapeHtml(formatDate(item.date))}</p></div>
                        <div class="col-span-2"><p class="mobile-card-label">Observacoes</p><p class="mobile-card-value">${escapeHtml(note)}</p></div>
                    </div>
                    <div class="mobile-card-actions">
                        ${displayStatus.group !== 'paid' ? `<button type="button" class="row-complete-btn" data-payable-action="complete" data-payable-id="${escapeHtml(item.id)}">${escapeHtml(pageText.actionCompleteLabel || 'Baixar')}</button>` : ''}
                        <button type="button" class="row-menu-toggle" data-payable-action="toggle-menu" data-payable-id="${escapeHtml(item.id)}" aria-label="Abrir menu da conta">
                            <i class="fas fa-ellipsis-vertical"></i>
                        </button>
                        <div class="row-menu ${menuOpen ? '' : 'hidden'}" data-payable-menu="${escapeHtml(item.id)}">
                            <button type="button" class="row-menu-btn" data-payable-action="edit" data-payable-id="${escapeHtml(item.id)}"><i class="fas fa-pen"></i><span>Editar</span></button>
                            <button type="button" class="row-menu-btn row-menu-btn--danger" data-payable-action="delete" data-payable-id="${escapeHtml(item.id)}"><i class="fas fa-trash"></i><span>Excluir</span></button>
                        </div>
                    </div>
                </article>
            `;
        }

        function renderEmptyState(target, isTable) {
            const content = `
                <div class="table-empty">
                    <div class="table-empty-icon"><i class="fas fa-file-invoice-dollar"></i></div>
                    <p class="table-empty-title">${escapeHtml(pageText.emptyTitle || 'Nenhuma conta encontrada.')}</p>
                    <p class="table-empty-note">${escapeHtml(pageText.emptyNote || 'Ajuste os filtros ou cadastre uma nova conta para preencher esta lista.')}</p>
                </div>
            `;
            if (isTable) {
                target.innerHTML = `<tr><td colspan="6">${content}</td></tr>`;
                return;
            }
            target.innerHTML = content;
        }

        function renderPagination(totalItems) {
            const { totalPages, currentPage, start, end } = getPaginationMeta(totalItems);
            const noun = totalItems === 1 ? (pageText.paginationSingular || 'conta') : (pageText.paginationPlural || 'contas');
            paginationInfo.textContent = `Mostrando ${start}-${end} de ${totalItems} ${noun}`;
            if (totalItems <= state.pageSize) {
                paginationControls.innerHTML = '';
                return;
            }
            const pages = buildPaginationSequence(currentPage, totalPages);
            paginationControls.innerHTML = [
                `<button type="button" class="panel-page-btn" data-payable-page="${currentPage - 1}" ${currentPage <= 1 ? 'disabled' : ''}>Anterior</button>`,
                ...pages.map((page) => typeof page === 'number'
                    ? `<button type="button" class="panel-page-btn ${page === currentPage ? 'is-active' : ''}" data-payable-page="${page}" ${page === currentPage ? 'aria-current="page"' : ''}>${page}</button>`
                    : '<span class="panel-page-ellipsis">...</span>'),
                `<button type="button" class="panel-page-btn" data-payable-page="${currentPage + 1}" ${currentPage >= totalPages ? 'disabled' : ''}>Proxima</button>`,
            ].join('');
        }

        function renderPayables() {
            const monthBaseItems = getMonthBaseItems();
            renderSummary(monthBaseItems);

            const filteredItems = getFilteredItems();
            const { currentPage } = getPaginationMeta(filteredItems.length);
            const startIndex = (currentPage - 1) * state.pageSize;
            const visibleItems = filteredItems.slice(startIndex, startIndex + state.pageSize);

            if (!visibleItems.length) {
                renderEmptyState(payablesTableBody, true);
                renderEmptyState(payablesMobileList, false);
                renderPagination(filteredItems.length);
                return;
            }

            payablesTableBody.innerHTML = visibleItems.map(buildDesktopRow).join('');
            payablesMobileList.innerHTML = visibleItems.map(buildMobileCard).join('');
            renderPagination(filteredItems.length);
        }

        async function fetchTransactions(preserveMonthCursor = false) {
            const response = await fetch('/api/finance/transactions', { credentials: 'include' });
            const payload = await response.json().catch(() => null);
            if (!response.ok) throw new Error(payload?.message || pageText.loadError || 'Falha ao carregar as contas a pagar.');

            const items = Array.isArray(payload?.data) ? payload.data.map(normalizeTransaction).filter(matchesPageTransaction) : [];
            state.items = items;
            if (!preserveMonthCursor) {
                state.monthCursor = items.length
                    ? startOfMonth(parseDateOnly([...items].sort((left, right) => parseDateOnly(right.date) - parseDateOnly(left.date))[0].date))
                    : startOfMonth(new Date());
            } else if (!items.length) {
                state.monthCursor = startOfMonth(new Date());
            }
            state.page = 1;
            state.openMenuId = null;
        }

        async function loadPayables(preserveMonthCursor = false) {
            setScreenLoading(true);
            hideError();
            try {
                await fetchTransactions(preserveMonthCursor);
                renderMonthSwitcher();
                renderStatusFilters();
                renderPayables();
            } catch (error) {
                console.error(error);
                showError(error instanceof Error ? error.message : pageText.loadError || 'Falha ao carregar as contas a pagar.');
                payablesTableBody.innerHTML = '';
                payablesMobileList.innerHTML = '';
                paginationControls.innerHTML = '';
                paginationInfo.textContent = `Mostrando 0-0 de 0 ${pageText.paginationPlural || 'contas'}`;
            } finally {
                setScreenLoading(false);
            }
        }

        function openPayableModal(item = null) {
            state.editingId = item?.id || null;
            payableModalTitle.textContent = item ? (pageText.modalEditTitle || 'Editar conta') : (pageText.modalNewTitle || 'Nova conta');
            payableModalSubtitle.textContent = item
                ? (pageText.modalEditSubtitle || 'Ajuste os dados financeiros antes de salvar a alteracao.')
                : (pageText.modalNewSubtitle || 'Cadastre uma obrigacao financeira do modulo.');
            savePayableBtn.textContent = item ? (pageText.modalSaveEditLabel || 'Salvar alteracoes') : (pageText.modalSaveNewLabel || 'Salvar conta');
            payableDescriptionInput.value = item?.description || '';
            payableCategoryInput.value = item?.category || '';
            payableAmountInput.value = item ? String(Number(item.amount || 0)) : '';
            payableDateInput.value = item?.date || toDateInputValue(new Date());
            payableStatusInput.value = item?.status || 'pending';
            payableModal.classList.remove('hidden');
            payableModal.classList.add('flex');
            document.body.style.overflow = 'hidden';
            window.setTimeout(() => payableDescriptionInput.focus(), 0);
        }

        function closePayableModal() {
            state.editingId = null;
            payableModal.classList.add('hidden');
            payableModal.classList.remove('flex');
            document.body.style.overflow = '';
            payableForm.reset();
        }

        async function savePayable(event) {
            event.preventDefault();
            if (state.saving) return;

            const description = payableDescriptionInput.value.trim();
            const category = payableCategoryInput.value.trim();
            const amount = Number(payableAmountInput.value);
            const date = payableDateInput.value;
            const status = payableStatusInput.value;

            if (!description || !category) return notify('Preencha descricao e categoria.', 'error');
            if (!Number.isFinite(amount) || amount <= 0) return notify('Informe um valor maior que zero.', 'error');
            if (!date) return notify('Informe uma data de vencimento valida.', 'error');
            if (!['pending', 'scheduled', 'completed'].includes(status)) return notify('Situacao invalida.', 'error');

            setSaving(true);
            const isEditing = Boolean(state.editingId);

            try {
                const payload = { type: pageText.itemType || 'expense', amount, category, date, description, status };
                const response = await fetch(
                    isEditing ? `/api/finance/transactions/${encodeURIComponent(state.editingId)}` : '/api/finance/transactions',
                    {
                        method: isEditing ? 'PATCH' : 'POST',
                        credentials: 'include',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    },
                );
                const body = await response.json().catch(() => null);
                if (!response.ok) throw new Error(body?.message || pageText.saveError || 'Falha ao salvar a conta.');

                state.monthCursor = startOfMonth(parseDateOnly(date));
                state.page = 1;
                state.statusFilter = 'all';
                state.search = '';
                searchInput.value = '';
                closePayableModal();
                await loadPayables(true);
                notify(isEditing ? (pageText.saveSuccessEdit || 'Conta atualizada com sucesso.') : (pageText.saveSuccessCreate || 'Conta cadastrada com sucesso.'), 'success');
            } catch (error) {
                console.error(error);
                notify(error instanceof Error ? error.message : pageText.saveError || 'Falha ao salvar a conta.', 'error');
            } finally {
                setSaving(false);
            }
        }

        async function completePayable(id) {
            try {
                const response = await fetch(`/api/finance/transactions/${encodeURIComponent(id)}`, {
                    method: 'PATCH',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'completed' }),
                });
                const body = await response.json().catch(() => null);
                if (!response.ok) throw new Error(body?.message || pageText.completeError || 'Falha ao baixar a conta.');
                await loadPayables(true);
                notify(pageText.completeSuccess || 'Conta baixada com sucesso.', 'success');
            } catch (error) {
                console.error(error);
                notify(error instanceof Error ? error.message : pageText.completeError || 'Falha ao baixar a conta.', 'error');
            }
        }

        async function deletePayable(id) {
            if (!window.confirm(pageText.deleteConfirm || 'Deseja excluir esta conta?')) return;
            try {
                const response = await fetch(`/api/finance/transactions/${encodeURIComponent(id)}`, {
                    method: 'DELETE',
                    credentials: 'include',
                });
                if (!response.ok && response.status !== 204) {
                    const body = await response.json().catch(() => null);
                    throw new Error(body?.message || pageText.deleteError || 'Falha ao excluir a conta.');
                }
                await loadPayables(true);
                notify(pageText.deleteSuccess || 'Conta excluida com sucesso.', 'success');
            } catch (error) {
                console.error(error);
                notify(error instanceof Error ? error.message : pageText.deleteError || 'Falha ao excluir a conta.', 'error');
            }
        }

        function closeMenus() {
            state.openMenuId = null;
            document.querySelectorAll('[data-payable-menu]').forEach((menu) => menu.classList.add('hidden'));
        }

        function openMenu(id) {
            if (state.openMenuId === id) return closeMenus();
            state.openMenuId = id;
            document.querySelectorAll('[data-payable-menu]').forEach((menu) => {
                menu.classList.toggle('hidden', menu.getAttribute('data-payable-menu') !== id);
            });
        }

        function syncSidebarLayout() {
            if (isMobileViewport()) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }
            sidebar.classList.remove('mobile-open');
            if (document.body.classList.contains('sidebar-collapsed')) {
                main.style.marginLeft = '0';
                main.style.width = '100%';
                main.style.flex = '1 1 100%';
                return;
            }
            main.style.marginLeft = '16rem';
            main.style.width = 'calc(100% - 16rem)';
            main.style.flex = '0 1 calc(100% - 16rem)';
        }

        function closeUserMenu() {
            if (userMenuDropdown) userMenuDropdown.classList.add('hidden');
        }

        async function performLogout() {
            localStorage.removeItem('isLoggedIn');
            localStorage.removeItem('currentUser');
            await fetch('/auth/logout', { method: 'POST', credentials: 'include' });
            window.location.href = '/login';
        }

        async function handleUserMenuAction(action) {
            if (action === 'logout') return performLogout();
            const allowedTabs = new Set(['profile', 'security', 'help']);
            window.location.href = `/admin/account.html?tab=${encodeURIComponent(allowedTabs.has(action) ? action : 'profile')}`;
        }

        sidebarToggle.addEventListener('click', () => {
            if (isMobileViewport()) {
                sidebar.classList.toggle('mobile-open');
                return;
            }
            document.body.classList.toggle('sidebar-collapsed');
            syncSidebarLayout();
        });

        openPayableModalBtn.addEventListener('click', () => openPayableModal());
        closePayableModalBtn.addEventListener('click', closePayableModal);
        cancelPayableModalBtn.addEventListener('click', closePayableModal);
        payableForm.addEventListener('submit', savePayable);

        searchInput.addEventListener('input', (event) => {
            state.search = String(event.target.value || '').trim().toLowerCase();
            state.page = 1;
            closeMenus();
            renderPayables();
        });

        monthSwitcher.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) return;
            const button = target.closest('[data-month-value]');
            if (!(button instanceof HTMLButtonElement)) return;
            const nextMonth = parseDateOnly(button.getAttribute('data-month-value'));
            if (Number.isNaN(nextMonth.getTime())) return;
            state.monthCursor = startOfMonth(nextMonth);
            state.page = 1;
            closeMenus();
            renderMonthSwitcher();
            renderPayables();
        });

        statusFilters.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) return;
            const button = target.closest('[data-status-filter]');
            if (!(button instanceof HTMLButtonElement)) return;
            state.statusFilter = button.getAttribute('data-status-filter') || 'all';
            state.page = 1;
            closeMenus();
            renderStatusFilters();
            renderPayables();
        });

        paginationControls.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) return;
            const button = target.closest('[data-payable-page]');
            if (!(button instanceof HTMLButtonElement) || button.disabled) return;
            const page = Number(button.getAttribute('data-payable-page'));
            if (!Number.isFinite(page) || page < 1) return;
            state.page = page;
            renderPayables();
        });

        [payablesTableBody, payablesMobileList].forEach((container) => {
            container.addEventListener('click', async (event) => {
                const target = event.target;
                if (!(target instanceof HTMLElement)) return;
                const actionButton = target.closest('[data-payable-action]');
                if (!(actionButton instanceof HTMLButtonElement)) return;

                const action = actionButton.getAttribute('data-payable-action');
                const payableId = actionButton.getAttribute('data-payable-id');
                if (!action || !payableId) return;

                if (action === 'toggle-menu') {
                    event.preventDefault();
                    event.stopPropagation();
                    openMenu(payableId);
                    return;
                }

                closeMenus();
                const item = state.items.find((entry) => entry.id === payableId);
                if (!item) return;

                if (action === 'edit') return openPayableModal(item);
                if (action === 'delete') return deletePayable(payableId);
                if (action === 'complete') await completePayable(payableId);
            });
        });

        userMenuBtn.addEventListener('click', (event) => {
            event.stopPropagation();
            userMenuDropdown.classList.toggle('hidden');
        });

        document.addEventListener('click', async (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) return;

            const actionBtn = target.closest('[data-user-menu-action]');
            if (actionBtn) {
                const action = actionBtn.getAttribute('data-user-menu-action');
                closeUserMenu();
                if (action) await handleUserMenuAction(action);
                return;
            }

            if (!target.closest('[data-payable-menu]') && !target.closest('[data-payable-action="toggle-menu"]')) closeMenus();
            if (!target.closest('#userMenuBtn') && !target.closest('#userMenuDropdown')) closeUserMenu();
            if (target === payableModal) closePayableModal();
        });

        document.addEventListener('keydown', (event) => {
            if (!(event instanceof KeyboardEvent)) return;
            if (event.key === 'Escape') {
                closeMenus();
                if (!payableModal.classList.contains('hidden')) closePayableModal();
            }
        });

        window.addEventListener('resize', syncSidebarLayout);
        syncSidebarLayout();
        loadPayables();
    </script>
</body>
</html>
